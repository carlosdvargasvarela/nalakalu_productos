<%# app/views/procurement_requirements/index.html.erb %>
<div class="container-fluid mt-4 pb-5">
  <div class="mb-4">
    <h2 class="fw-bold text-dark">
      <i class="bi bi-boxes text-primary me-2"></i>Gestión de Abastecimiento
    </h2>
    <p class="text-muted">
      Revisa los pedidos pendientes y genera órdenes de compra por proveedor.
    </p>
  </div>
  <!-- Filtros -->
  <div class="card border-0 shadow-sm mb-4 bg-light">
    <div class="card-body">
      <%= form_with url: procurement_requirements_path, method: :get, class: "row g-3 align-items-end" do |f| %>
        <div class="col-md-3">
          <label class="small fw-bold text-muted">Rango de Pedidos</label>
          <div class="input-group">
            <%= f.date_field :from, value: @from, class: "form-control border-0 shadow-sm" %>
            <span class="input-group-text bg-white border-0 shadow-sm">-</span>
            <%= f.date_field :to, value: @to, class: "form-control border-0 shadow-sm" %>
          </div>
        </div>
        <div class="col-md-4">
          <label class="small fw-bold text-muted">Proveedor</label>
          <%= f.collection_select :provider_id, Provider.all, :id, :name,
                { include_blank: "Todos los proveedores", selected: params[:provider_id] },
                { class: "form-select border-0 shadow-sm" } %>
        </div>
        <div class="col-md-2">
          <%= f.submit "Refrescar",
                class: "btn btn-primary w-100 fw-bold shadow-sm" %>
        </div>
      <% end %>
    </div>
  </div>
  <% if @grouped_requirements.any? %>
    <% @grouped_requirements.each do |provider, reqs| %>
      <div data-controller="procurement" class="mb-5">
        <%= form_with url: create_purchase_order_procurement_requirements_path, method: :post do |f| %>
          <%= f.hidden_field :provider_id, value: provider.id %>
          <!-- Header proveedor -->
          <div class="d-flex justify-content-between align-items-center mb-3 bg-white p-3 rounded-3 shadow-sm border-start border-4 border-primary">
            <div>
              <h4 class="mb-0 fw-bold"><%= provider.name %></h4>
              <span class="text-muted small">
                <%= reqs.size %> piezas pendientes
              </span>
            </div>
            <%= f.submit "Generar OC",
                  class: "btn btn-success fw-bold px-4 py-2 shadow",
                  data: {
                    procurement_target: "submitBtn",
                    turbo_confirm: "¿Crear Orden de Compra con los items seleccionados?"
                  } %>
          </div>
          <!-- Pedidos -->
          <% reqs.group_by(&:origin_order_number).each do |order_number, order_reqs| %>
            <div class="card border-0 shadow-sm mb-3 overflow-hidden">
              <!-- Header pedido -->
              <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-2">
                <div class="form-check mb-0">
                  <input type="checkbox"
                         class="form-check-input"
                         checked
                         data-order="<%= order_number %>"
                  data-action="change->procurement#toggleOrder">
                  <label class="form-check-label fw-bold ms-2">
                    Pedido: <%= order_number %>
                  </label>
                </div>
                <span class="badge bg-secondary">
                  <%= order_reqs.first.origin_product_name %>
                </span>
              </div>
              <!-- Tabla -->
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light small text-uppercase text-muted">
                      <tr>
                        <th width="50"></th>
                        <th class="ps-3">Pieza</th>
                        <th>Especificaciones</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-end pe-4">Costo</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% order_reqs.each do |req| %>
                        <tr>
                          <td class="text-center">
                            <%= check_box_tag "requirement_ids[]", req.id, true,
                                  class: "form-check-input",
                                  data: {
                                    procurement_target: "checkbox",
                                    order: order_number,
                                    action: "change->procurement#updateButton"
                                  } %>
                          </td>
                          <td class="ps-3">
                            <div class="fw-bold"><%= req.supplier_item.name %></div>
                            <div class="text-muted small">
                              SKU: <%= req.supplier_item.sku.presence || "N/A" %>
                            </div>
                          </td>
                          <td>
                            <% if req.specifications.any? %>
                              <div class="d-flex flex-wrap gap-1">
                                <% req.specifications.each do |k, v| %>
                                  <span class="badge bg-info-subtle text-info-emphasis border border-info small">
                                    <%= k %>: <%= v %>
                                  </span>
                                <% end %>
                              </div>
                            <% else %>
                              <span class="text-muted fst-italic small">Estándar</span>
                            <% end %>
                          </td>
                          <td class="text-center fw-bold text-primary">
                            <%= number_with_precision(req.quantity, precision: 2) %>
                            <small class="text-muted"><%= req.supplier_item.unit %></small>
                          </td>
                          <td class="text-end pe-4 text-muted small">
                            <%= number_to_currency(req.quantity * (req.supplier_item.default_cost || 0)) %>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5 bg-white rounded shadow-sm">
      <i class="bi bi-clipboard-check display-1 text-light"></i>
      <h3 class="text-muted mt-3">Todo al día</h3>
      <p class="text-muted">
        No hay requerimientos pendientes para el rango seleccionado.
      </p>
    </div>
  <% end %>
</div>