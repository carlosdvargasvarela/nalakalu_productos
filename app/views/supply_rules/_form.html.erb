<%= form_with(model: supply_rule) do |f| %>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">

      <div class="row g-3">

        <div class="col-md-6">
          <%= f.label :product_id, "Producto", class: "form-label small fw-bold text-muted" %>
          <%= f.collection_select :product_id, Product.order(:name), :id, :name,
                { prompt: "Seleccionar producto" },
                { class: "form-select" } %>
        </div>

        <div class="col-md-6">
          <%= f.label :variant_id, "Variante", class: "form-label small fw-bold text-muted" %>
          <%= f.collection_select :variant_id, Variant.order(:name), :id, :name,
                { prompt: "Seleccionar variante" },
                { class: "form-select" } %>
        </div>

        <div class="col-md-8">
          <%= f.label :supplier_item_id, "Pieza de Proveedor", class: "form-label small fw-bold text-muted" %>
          <%= f.collection_select :supplier_item_id, SupplierItem.includes(:provider).map { |i| ["#{i.name} (#{i.provider.name})", i.id] },
                :last, :first,
                { prompt: "Seleccionar pieza" },
                { class: "form-select" } %>
        </div>

        <div class="col-md-4">
          <%= f.label :quantity, "Cantidad necesaria", class: "form-label small fw-bold text-muted" %>
          <%= f.number_field :quantity, step: 0.01, class: "form-control" %>
        </div>

      </div>

      <div class="text-end mt-4">
        <%= f.submit "Guardar Regla", class: "btn btn-primary px-5 rounded-pill fw-bold" %>
      </div>

    </div>
  </div>
<% end %>