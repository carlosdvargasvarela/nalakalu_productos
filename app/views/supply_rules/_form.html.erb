<%# app/views/supply_rules/_form.html.erb %>
<%= form_with(model: supply_rule) do |f| %>
  <% if supply_rule.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar:</h6>
      <ul class="mb-0 ps-3 small">
        <% supply_rule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
      <div class="row g-3">
        <%# Producto %>
        <div class="col-md-6">
          <%= f.label :product_id, "Producto", class: "form-label small fw-bold text-muted" %>
          <%= f.collection_select :product_id,
                Product.where(active: true).order(:name), :id, :name,
                { prompt: "Seleccionar producto..." },
                { class: "form-select border-2 shadow-none" } %>
          <div class="form-text small">Deja en blanco si aplica a todos los productos.</div>
        </div>
        <%# Tipo de variante %>
        <div class="col-md-6">
          <%= f.label :variant_type_id, "Tipo de Variante", class: "form-label small fw-bold text-muted" %>
          <%= f.collection_select :variant_type_id,
                VariantType.where(active: true).order(:name), :id, :name,
                { prompt: "Seleccionar tipo..." },
                { class: "form-select border-2 shadow-none" } %>
        </div>
        <%# Variante específica (opcional) %>
        <div class="col-md-6">
          <%= f.label :variant_id, "Variante Específica (opcional)",
                class: "form-label small fw-bold text-muted" %>
          <%= f.collection_select :variant_id,
                Variant.where(active: true).order(:name), :id, :name,
                { include_blank: "— Aplica a todo el tipo —" },
                { class: "form-select border-2 shadow-none" } %>
          <div class="form-text small">
            Si se deja en blanco, la regla aplica a <strong>todas</strong> las variantes del tipo.
          </div>
        </div>
        <%# Pieza de proveedor %>
        <div class="col-md-6">
          <%= f.label :supplier_item_id, "Pieza de Proveedor",
                class: "form-label small fw-bold text-muted" %>
          <%= f.collection_select :supplier_item_id,
                SupplierItem.active.includes(:provider).order("providers.name, supplier_items.name"),
                :id,
                ->(i) { "#{i.name} (#{i.provider.name})" },
                { prompt: "Seleccionar pieza..." },
                { class: "form-select border-2 shadow-none" } %>
        </div>
        <%# Cantidad necesaria %>
        <div class="col-md-4">
          <%= f.label :quantity_needed, "Cantidad Necesaria",
                class: "form-label small fw-bold text-muted" %>
          <div class="input-group">
            <%= f.number_field :quantity_needed,
                  step: 0.01, min: 0.01, value: supply_rule.quantity_needed || 1.0,
                  class: "form-control border-2 shadow-none" %>
            <span class="input-group-text bg-light text-muted small border-2">unidades</span>
          </div>
        </div>
        <%# Tipo de regla %>
        <div class="col-md-4">
          <%= f.label :rule_type, "Tipo de Regla", class: "form-label small fw-bold text-muted" %>
          <%= f.select :rule_type,
                [["Individual (una pieza por variante)", "individual"],
                 ["Consolidada (agrupa variantes del tipo)", "consolidated"]],
                { selected: supply_rule.rule_type || "individual" },
                { class: "form-select border-2 shadow-none" } %>
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <div class="alert alert-info border-0 rounded-3 py-2 px-3 small mb-0 w-100">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Individual:</strong> cada variante genera su propia línea.<br>
            <strong>Consolidada:</strong> todas las variantes del tipo se agrupan en una pieza.
          </div>
        </div>
      </div>
      <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-4">
        <%= link_to supply_rules_path,
              class: "btn btn-link text-muted text-decoration-none fw-bold" do %>
          <i class="bi bi-x-lg me-1"></i>Descartar
        <% end %>
        <%= f.submit supply_rule.new_record? ? "Crear Regla" : "Guardar Cambios",
              class: "btn btn-primary px-5 rounded-pill fw-bold shadow-sm" %>
      </div>
    </div>
  </div>
<% end %>