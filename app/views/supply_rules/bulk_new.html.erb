<%# app/views/supply_rules/bulk_new.html.erb %>
<div class="container-fluid py-4" style="max-width: 1100px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">
        <i class="bi bi-grid-3x3-gap text-primary me-2"></i>Asignación Masiva de Reglas
      </h2>
      <p class="text-muted small mb-0">
        Configura qué pieza de proveedor corresponde a cada variante de un producto.
      </p>
    </div>
    <%= link_to supply_rules_path, class: "btn btn-outline-secondary btn-sm rounded-pill" do %>
      <i class="bi bi-arrow-left me-1"></i>Volver
    <% end %>
  </div>
  <%# SELECTOR DE PRODUCTO %>
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <%= form_tag bulk_new_supply_rules_path, method: :get, class: "row g-2 align-items-end" do %>
        <div class="col-md-9">
          <label class="form-label small fw-bold text-muted">
            Selecciona un Producto para configurar sus variantes:
          </label>
          <%= select_tag :product_id,
                options_from_collection_for_select(@products, :id, :name, params[:product_id]),
                include_blank: "Buscar producto...",
                class: "form-select form-select-lg border-2 shadow-none",
                onchange: "this.form.submit()" %>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold">
            <i class="bi bi-search me-1"></i>Cargar Variantes
          </button>
        </div>
      <% end %>
    </div>
  </div>
  <% if @product %>
    <%= form_tag bulk_create_supply_rules_path(product_id: @product.id), method: :post do %>
      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-box-seam me-2"></i>Configurando: <%= @product.name %>
          </h5>
          <span class="badge bg-white text-primary rounded-pill px-3">
            <%= @variant_types.sum { |vt| vt.variants.size } %> variantes
          </span>
        </div>
        <% @variant_types.each do |variant_type| %>
          <%# Encabezado de tipo de variante %>
          <div class="px-4 py-2 bg-light border-bottom d-flex align-items-center gap-2">
            <span class="fw-bold text-dark small text-uppercase">
              <i class="bi bi-tag me-1 text-primary"></i><%= variant_type.name %>
            </span>
            <span class="badge bg-secondary-subtle text-secondary rounded-pill small">
              <%= variant_type.procurement_strategy %>
            </span>
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="bg-white border-bottom small text-muted text-uppercase" style="font-size: 0.7rem;">
                <tr>
                  <th class="ps-4" style="width: 25%;">Variante</th>
                  <th style="width: 40%;">Pieza de Proveedor</th>
                  <th class="text-center" style="width: 12%;">Cantidad</th>
                  <th class="text-center" style="width: 13%;">Tipo Regla</th>
                  <th class="pe-4 text-center" style="width: 10%;">Estado</th>
                </tr>
              </thead>
              <tbody>
                <% variant_type.variants.where(active: true).order(:name).each do |variant| %>
                  <%# La key del form es "variant_type_id_variant_id" para evitar colisiones %>
                  <% form_key = "#{variant_type.id}_#{variant.id}" %>
                  <% rule = @existing_rules[form_key] %>
                  <tr>
                    <td class="ps-4 py-2">
                      <div class="fw-bold small"><%= variant.display_name.presence || variant.name %></div>
                      <% if variant.code.present? %>
                        <code class="text-muted" style="font-size: 0.7rem;"><%= variant.code %></code>
                      <% end %>
                    </td>
                    <td class="py-2">
                      <%= select_tag "rules[#{form_key}][supplier_item_id]",
                            options_for_select(
                              @supplier_items.map { |i| ["#{i.name} (#{i.provider.name})", i.id] },
                              rule&.supplier_item_id
                            ),
                            include_blank: "— No comprar nada —",
                            class: "form-select form-select-sm border-0 bg-light shadow-none fw-bold" %>
                    </td>
                    <td class="py-2">
                      <%= number_field_tag "rules[#{form_key}][quantity_needed]",
                            rule&.quantity_needed || 1.0,
                            step: 0.01, min: 0.01,
                            class: "form-control form-control-sm text-center border-0 bg-light shadow-none" %>
                    </td>
                    <td class="py-2 text-center">
                      <%= select_tag "rules[#{form_key}][rule_type]",
                            options_for_select(
                              [["Individual", "individual"], ["Consolidada", "consolidated"]],
                              rule&.rule_type || (variant_type.procurement_strategy == "consolidated" ? "consolidated" : "individual")
                            ),
                            class: "form-select form-select-sm border-0 bg-light shadow-none text-center" %>
                    </td>
                    <td class="pe-4 py-2 text-center">
                      <% if rule %>
                        <i class="bi bi-check-circle-fill text-success fs-5" title="Regla configurada"></i>
                      <% else %>
                        <i class="bi bi-dash-circle text-muted opacity-50 fs-5" title="Sin regla"></i>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
        <div class="card-footer bg-white p-4 d-flex justify-content-between align-items-center border-top">
          <span class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Deja "No comprar nada" para variantes que no requieren compra.
          </span>
          <%= submit_tag "Guardar Todas las Reglas",
                class: "btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>