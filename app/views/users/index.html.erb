<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold mb-0">Gestión de Usuarios</h2>
    <p class="text-muted mb-0 small">Administra el acceso del equipo al sistema</p>
  </div>
  <%= link_to new_user_path, class: "btn btn-primary d-flex align-items-center gap-2 shadow-sm" do %>
    <i class="bi bi-person-plus-fill"></i> Nuevo Usuario
  <% end %>
</div>
<div class="card border-0 shadow-sm rounded-3">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="bg-light text-muted small text-uppercase fw-bold">
        <tr>
          <th class="px-4 py-3">Email</th>
          <th class="py-3">Rol</th>
          <th class="py-3">Creado</th>
          <th class="px-4 py-3 text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td class="px-4 py-3">
              <div class="d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                  <i class="bi bi-person-fill"></i>
                </div>
                <div>
                  <div class="fw-bold text-dark"><%= user.email %></div>
                  <% if user == current_user %>
                    <span class="badge bg-info text-dark x-small" style="font-size: 0.65rem;">TÚ</span>
                  <% end %>
                </div>
              </div>
            </td>
            <td class="py-3">
              <span class="badge rounded-pill <%= user.role == 'admin' ? 'bg-dark' : 'bg-secondary' %>">
                <%= user.role.capitalize %>
              </span>
            </td>
            <td class="py-3 text-muted small">
              <%= l user.created_at, format: :short %>
            </td>
            <td class="px-4 py-3 text-end">
              <div class="btn-group shadow-sm">
                <%= link_to edit_user_path(user), class: "btn btn-white btn-sm border", title: "Editar" do %>
                  <i class="bi bi-pencil text-primary"></i>
                <% end %>
                <%= link_to edit_password_user_path(user), class: "btn btn-white btn-sm border", title: "Cambiar Contraseña" do %>
                  <i class="bi bi-key text-warning"></i>
                <% end %>
                <% unless user == current_user %>
                  <%= button_to user_path(user), method: :delete, 
                      data: { turbo_confirm: "¿Estás seguro de eliminar a #{user.email}?" },
                      class: "btn btn-white btn-sm border text-danger", title: "Eliminar" do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>