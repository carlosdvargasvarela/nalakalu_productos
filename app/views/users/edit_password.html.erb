<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card border-0 shadow-sm p-4">
      <h4 class="fw-bold mb-3 text-center">Cambiar Contraseña</h4>
      <p class="text-muted text-center small mb-4">Usuario: <strong><%= @user.email %></strong></p>
      <%= form_with(model: @user, url: update_password_user_path(@user), method: :patch) do |f| %>
        <div class="mb-3">
          <%= f.label :password, "Nueva Contraseña", class: "form-label fw-bold small" %>
          <%= f.password_field :password, class: "form-control form-control-lg", autofocus: true %>
        </div>
        <div class="mb-4">
          <%= f.label :password_confirmation, "Confirmar Nueva Contraseña", class: "form-label fw-bold small" %>
          <%= f.password_field :password_confirmation, class: "form-control form-control-lg" %>
        </div>
        <div class="d-grid gap-2">
          <%= f.submit "Actualizar Contraseña", class: "btn btn-warning fw-bold py-2" %>
          <%= link_to "Cancelar", users_path, class: "btn btn-link text-muted text-decoration-none" %>
        </div>
      <% end %>
    </div>
  </div>
</div>