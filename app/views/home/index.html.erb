<% unless user_signed_in? %>
  <div class="alert alert-info text-center mb-4">
    <i class="bi bi-info-circle me-2"></i>
    Puedes usar el generador de códigos sin iniciar sesión.
    <%= link_to "Iniciar sesión", new_user_session_path, class: "alert-link ms-1" %>
    para acceder a las funciones de administración.
  </div>
<% end %>
<div class="row mb-4">
  <div class="col-12 text-center">
    <h1 class="display-5 fw-bold">
      Bienvenido<% if user_signed_in? %>, <%= current_user.email.split('@').first.capitalize %><% end %>
    </h1>
    <p class="lead text-muted">Sistema Interno de Gestión de Productos - Nalakalú</p>
  </div>
</div>
<div class="row g-4 justify-content-center">
  <%# ACCIÓN PRINCIPAL: GENERADOR (Para todos) %>
  <div class="col-md-6">
    <div class="card h-100 border-primary shadow">
      <div class="card-body text-center p-5">
        <div class="display-1 text-primary mb-3">
          <i class="bi bi-upc-scan"></i>
        </div>
        <h2 class="card-title">Generador de Códigos</h2>
        <p class="card-text text-muted">Crea códigos únicos para el CRM seleccionando variantes y productos.</p>
        <%= link_to new_sale_path, class: "btn btn-primary btn-lg w-100 py-3 fw-bold" do %>
          IR AL GENERADOR <i class="bi bi-arrow-right-short"></i>
        <% end %>
      </div>
    </div>
  </div>
  <% if user_signed_in? && current_user.role == 'admin' %>
    <%# ACCIONES DE ADMIN %>
    <div class="col-md-6">
      <div class="row g-3">
        <div class="col-6">
          <div class="card h-100 shadow-sm border-0 bg-light">
            <div class="card-body text-center">
              <i class="bi bi-box-seam fs-2 text-secondary"></i>
              <h5 class="mt-2">Productos</h5>
              <%= link_to "Gestionar", products_path, class: "btn btn-sm btn-outline-secondary w-100" %>
            </div>
          </div>
        </div>
        <div class="col-6">
          <div class="card h-100 shadow-sm border-0 bg-light">
            <div class="card-body text-center">
              <i class="bi bi-tags fs-2 text-secondary"></i>
              <h5 class="mt-2">Variantes</h5>
              <%= link_to "Gestionar", variants_path, class: "btn btn-sm btn-outline-secondary w-100" %>
            </div>
          </div>
        </div>
        <div class="col-6">
          <div class="card h-100 shadow-sm border-0 bg-light">
            <div class="card-body text-center">
              <i class="bi bi-truck fs-2 text-secondary"></i>
              <h5 class="mt-2">Proveedores</h5>
              <%= link_to "Gestionar", providers_path, class: "btn btn-sm btn-outline-secondary w-100" %>
            </div>
          </div>
        </div>
        <div class="col-6">
          <div class="card h-100 shadow-sm border-0 bg-light">
            <div class="card-body text-center">
              <i class="bi bi-diagram-3 fs-2 text-secondary"></i>
              <h5 class="mt-2">Tipos de Variante</h5>
              <%= link_to "Gestionar", variant_types_path, class: "btn btn-sm btn-outline-secondary w-100" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
<% if user_signed_in? && current_user.role == 'admin' %>
  <div class="row mt-5">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
          <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Resumen del Sistema</h5>
        </div>
        <div class="card-body">
          <div class="row text-center">
            <div class="col-md-3">
              <div class="p-3">
                <h2 class="text-primary"><%= Product.count %></h2>
                <p class="text-muted mb-0">Productos</p>
              </div>
            </div>
            <div class="col-md-3">
              <div class="p-3">
                <h2 class="text-success"><%= Variant.where(active: true).count %></h2>
                <p class="text-muted mb-0">Variantes Activas</p>
              </div>
            </div>
            <div class="col-md-3">
              <div class="p-3">
                <h2 class="text-info"><%= Provider.where(active: true).count %></h2>
                <p class="text-muted mb-0">Proveedores Activos</p>
              </div>
            </div>
            <div class="col-md-3">
              <div class="p-3">
                <h2 class="text-warning"><%= VariantType.count %></h2>
                <p class="text-muted mb-0">Tipos de Variante</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>