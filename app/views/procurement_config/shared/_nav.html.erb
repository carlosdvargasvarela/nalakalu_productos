<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-body p-3">
    <div class="d-flex gap-2 flex-wrap">
      <%= link_to procurement_config_by_variant_type_path,
            class: "btn #{controller_name == 'by_variant_type' ? 'btn-primary' : 'btn-outline-secondary'} rounded-pill px-4 fw-bold" do %>
        <i class="bi bi-palette me-2"></i>Por Tipo de Variante
      <% end %>
      <%= link_to procurement_config_by_product_path,
            class: "btn #{controller_name == 'by_product' ? 'btn-primary' : 'btn-outline-secondary'} rounded-pill px-4 fw-bold" do %>
        <i class="bi bi-box-seam me-2"></i>Por Producto
      <% end %>
      <%= link_to procurement_config_consolidated_path,
            class: "btn #{controller_name == 'consolidated' ? 'btn-primary' : 'btn-outline-secondary'} rounded-pill px-4 fw-bold" do %>
        <i class="bi bi-layers me-2"></i>Consolidadas
      <% end %>
    </div>
  </div>
</div>