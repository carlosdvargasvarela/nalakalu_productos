<div class="container-fluid py-4" style="max-width: 1100px;">
  <%= render "procurement_config/shared/nav" %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">
        <i class="bi bi-box-seam text-primary me-2"></i>Reglas por Producto
      </h2>
      <p class="text-muted small mb-0">
        Configura qué pieza comprar para cada variante de un producto específico
        (sobres, bases, estructuras…).
      </p>
    </div>
  </div>
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <%= form_tag procurement_config_by_product_path, method: :get,
            class: "row g-2 align-items-end" do %>
        <div class="col-md-9">
          <label class="form-label small fw-bold text-muted">Producto:</label>
          <%= select_tag :product_id,
                options_from_collection_for_select(@products, :id, :name, params[:product_id]),
                include_blank: "Buscar producto...",
                class: "form-select form-select-lg border-2 shadow-none",
                onchange: "this.form.submit()" %>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold">
            <i class="bi bi-search me-1"></i>Cargar
          </button>
        </div>
      <% end %>
    </div>
  </div>
  <% if @product %>
    <%= form_tag procurement_config_save_by_product_path, method: :post do %>
      <%= hidden_field_tag :product_id, @product.id %>
      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-box-seam me-2"></i><%= @product.name %>
          </h5>
          <span class="badge bg-white text-primary rounded-pill px-3">
            <%= @variant_types.sum { |vt| vt.variants.size } %> variantes
          </span>
        </div>
        <% @variant_types.each do |variant_type| %>
          <% next if variant_type.consolidated? %>
          <div class="px-4 py-2 bg-light border-bottom d-flex align-items-center gap-2">
            <span class="fw-bold text-dark small text-uppercase">
              <i class="bi bi-tag me-1 text-primary"></i><%= variant_type.name %>
            </span>
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="bg-white border-bottom small text-muted text-uppercase"
                     style="font-size: 0.7rem;">
                <tr>
                  <th class="ps-4" style="width: 25%;">Variante</th>
                  <th style="width: 42%;">Pieza de Proveedor</th>
                  <th class="text-center" style="width: 13%;">Cantidad</th>
                  <th class="pe-4 text-center" style="width: 20%;">Estado</th>
                </tr>
              </thead>
              <tbody>
                <% variant_type.variants.where(active: true).order(:name).each do |variant| %>
                  <% form_key = "#{variant_type.id}_#{variant.id}" %>
                  <% rule = @existing_rules[form_key] %>
                  <% global_rule = SupplyRule.find_by(
                       variant_type: variant_type,
                       variant:      variant,
                       product_id:   nil
                     ) %>
                  <tr>
                    <td class="ps-4 py-2">
                      <div class="fw-bold small">
                        <%= variant.display_name.presence || variant.name %>
                      </div>
                      <% if global_rule %>
                        <span class="badge bg-info-subtle text-info border border-info-subtle"
                              style="font-size: 0.65rem;">
                          <i class="bi bi-globe me-1"></i>
                          Global: <%= global_rule.supplier_item.name %>
                        </span>
                      <% end %>
                    </td>
                    <td class="py-2">
                      <%= select_tag "rules[#{form_key}][supplier_item_id]",
                            options_for_select(
                              @supplier_items.map { |i| ["#{i.name} (#{i.provider.name})", i.id] },
                              rule&.supplier_item_id
                            ),
                            include_blank: global_rule ? "— Usar regla global —" : "— No comprar —",
                            class: "form-select form-select-sm border-0 bg-light shadow-none fw-bold" %>
                    </td>
                    <td class="py-2">
                      <%= number_field_tag "rules[#{form_key}][quantity_needed]",
                            rule&.quantity_needed || global_rule&.quantity_for(@product) || 1.0,
                            step: 0.01, min: 0.01,
                            class: "form-control form-control-sm text-center border-0 bg-light shadow-none" %>
                    </td>
                    <td class="pe-4 py-2 text-center">
                      <% if rule %>
                        <span class="badge bg-success-subtle text-success rounded-pill small">
                          <i class="bi bi-check-circle me-1"></i>Específica
                        </span>
                      <% elsif global_rule %>
                        <span class="badge bg-info-subtle text-info rounded-pill small">
                          <i class="bi bi-globe me-1"></i>Global
                        </span>
                      <% else %>
                        <span class="badge bg-secondary-subtle text-secondary rounded-pill small">
                          Sin regla
                        </span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
        <div class="card-footer bg-white p-4 d-flex justify-content-between align-items-center border-top">
          <span class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            "Usar regla global" significa que se usará la asignación configurada en
            <strong>Por Tipo de Variante</strong>.
          </span>
          <%= submit_tag "Guardar Reglas del Producto",
                class: "btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>