<%
  variants  = variant_type.variants.where(active: true).order(:name)
  pvr_label = pvr.label.presence || variant_type.name
%>
<div class="p-4">
  <%# ── Alerta de fallback global ── %>
  <% if rule.nil? && global_rule.present? %>
    <div class="alert alert-info border-0 rounded-3 small py-2 px-3 mb-3 d-flex align-items-center gap-2">
      <i class="bi bi-globe text-info flex-shrink-0"></i>
      <div>
        Usando regla global:
        <strong><%= global_rule.supplier_item.name %></strong>
        (<%= global_rule.supplier_item.provider.name %>) —
        <%= global_rule.quantity_needed %> <%= global_rule.supplier_item.unit %>.
        Podés sobreescribirla seleccionando una pieza abajo.
      </div>
    </div>
  <% end %>

  <%# ── Selector de pieza ── %>
  <div class="row g-3 mb-4">
    <div class="col-md-8">
      <label class="form-label small fw-bold text-muted">Pieza de Proveedor</label>
      <%= select_tag "consolidated_rules[#{variant_type.id}][supplier_item_id]",
            options_for_select(
              supplier_items.map { |i| ["#{i.name} (#{i.provider.name})", i.id] },
              rule&.supplier_item_id
            ),
            include_blank: global_rule ? "— Usar regla global —" : "— No comprar —",
            class: "form-select border-2 shadow-none" %>
    </div>
    <div class="col-md-4">
      <label class="form-label small fw-bold text-muted">Cantidad</label>
      <%= number_field_tag "consolidated_rules[#{variant_type.id}][quantity_needed]",
            rule&.quantity_needed || global_rule&.quantity_needed || 1.0,
            step: 0.01, min: 0.01,
            class: "form-control border-2 shadow-none" %>
    </div>
  </div>

  <%# ── Info de variantes que se consolidan ── %>
  <div class="alert alert-info border-0 rounded-3 small mb-0">
    <div class="d-flex align-items-start gap-2">
      <i class="bi bi-info-circle-fill text-info mt-1 flex-shrink-0"></i>
      <div>
        <strong>¿Cómo funciona?</strong><br>
        Todas las variantes de <strong><%= variant_type.name %></strong> que tenga este
        producto se agruparán en <strong>una sola línea de compra</strong> con
        especificaciones automáticas.<br>
        <% if pvr.label.present? %>
          La posición de este tipo en el producto es
          <span class="badge bg-info text-white ms-1"><%= pvr.label %></span>
        <% end %>
        <div class="d-flex flex-wrap gap-1 mt-2">
          <% variants.each do |v| %>
            <span class="badge bg-white text-dark border fw-normal">
              <%= v.display_name.presence || v.name %>
            </span>
          <% end %>
        </div>
        <% active_rule = rule || global_rule %>
        <% if active_rule %>
          <div class="mt-2 pt-2 border-top border-info border-opacity-25">
            <% if rule %>
              <i class="bi bi-check-circle-fill text-success me-1"></i>
              Regla específica: <strong><%= rule.supplier_item.name %></strong>
              (<%= rule.supplier_item.provider.name %>) —
              <%= rule.quantity_needed %> <%= rule.supplier_item.unit %>
            <% else %>
              <i class="bi bi-globe text-info me-1"></i>
              Global activa: <strong><%= global_rule.supplier_item.name %></strong>
              (<%= global_rule.supplier_item.provider.name %>) —
              <%= global_rule.quantity_needed %> <%= global_rule.supplier_item.unit %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
