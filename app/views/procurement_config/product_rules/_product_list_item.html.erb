<%
  pvrs        = product.product_variant_rules.includes(:variant_type)
  total_types = pvrs.size
  rules_count = SupplyRule.where(product: product).count

  status = if total_types == 0
    :no_variants
  elsif rules_count == 0
    :no_rules
  else
    # Verificar si todos los tipos tienen al menos una regla
    covered = pvrs.count do |pvr|
      if pvr.variant_type.consolidated?
        SupplyRule.exists?(product: product, variant_type_id: pvr.variant_type_id, rule_type: "consolidated")
      else
        SupplyRule.exists?(product: product, variant_type_id: pvr.variant_type_id, rule_type: "individual")
      end
    end
    covered == total_types ? :complete : :partial
  end
%>
<%= link_to procurement_config_product_rules_path(product_id: product.id),
    data: {
      turbo_frame:  "product_rules_workspace",
      product_name: product.name.downcase
    },
    class: "list-group-item list-group-item-action border-0 px-3 py-3 product-rule-row
            #{'product-rule-row-active' if selected}",
    id: "product-rule-item-#{product.id}" do %>
  <div class="d-flex justify-content-between align-items-start">
    <div class="flex-grow-1 me-2 overflow-hidden">
      <div class="fw-bold text-dark small text-truncate"><%= product.name %></div>
      <div class="text-muted mt-1" style="font-size: 0.68rem;">
        <%= total_types %> tipo<%= total_types == 1 ? "" : "s" %> de variante
      </div>
    </div>
    <div class="flex-shrink-0">
      <% case status %>
      <% when :complete %>
        <span class="badge bg-success-subtle text-success rounded-pill px-2"
              style="font-size: 0.6rem;">
          <i class="bi bi-check-circle me-1"></i>Completo
        </span>
      <% when :partial %>
        <span class="badge bg-warning-subtle text-warning rounded-pill px-2"
              style="font-size: 0.6rem;">
          <i class="bi bi-exclamation-circle me-1"></i>Parcial
        </span>
      <% when :no_rules %>
        <span class="badge bg-danger-subtle text-danger rounded-pill px-2"
              style="font-size: 0.6rem;">
          <i class="bi bi-x-circle me-1"></i>Sin reglas
        </span>
      <% when :no_variants %>
        <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2"
              style="font-size: 0.6rem;">
          <i class="bi bi-dash-circle me-1"></i>Sin variantes
        </span>
      <% end %>
    </div>
  </div>
<% end %>
<style>
  .product-rule-row-active { background-color: #f0f7ff; border-left: 3px solid #0d6efd !important; }
  .product-rule-row        { border-left: 3px solid transparent; transition: background 0.15s; }
  .product-rule-row:hover  { background-color: #f8f9fa; }
</style>