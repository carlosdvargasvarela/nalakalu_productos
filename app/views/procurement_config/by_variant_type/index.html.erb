<div class="container-fluid py-4" style="max-width: 1100px;">
  <%= render "procurement_config/shared/nav" %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">
        <i class="bi bi-palette text-primary me-2"></i>Reglas por Tipo de Variante
      </h2>
      <p class="text-muted small mb-0">
        Asigna qué pieza de proveedor corresponde a cada variante (telas, cueros, tiraderas…).
      </p>
    </div>
  </div>
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <%= form_tag procurement_config_by_variant_type_path, method: :get,
            class: "row g-2 align-items-end" do %>
        <div class="col-md-9">
          <label class="form-label small fw-bold text-muted">Tipo de Variante:</label>
          <%= select_tag :variant_type_id,
                options_from_collection_for_select(@variant_types, :id, :name, params[:variant_type_id]),
                include_blank: "Seleccionar tipo...",
                class: "form-select form-select-lg border-2 shadow-none",
                onchange: "this.form.submit()" %>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold">
            <i class="bi bi-search me-1"></i>Cargar
          </button>
        </div>
      <% end %>
    </div>
  </div>
  <% if @variant_type %>
    <%= form_tag procurement_config_save_by_variant_type_path, method: :post do %>
      <%= hidden_field_tag :variant_type_id, @variant_type.id %>
      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-tag me-2"></i><%= @variant_type.name %>
          </h5>
          <span class="badge bg-white text-primary rounded-pill px-3">
            <%= @variants.count %> variantes
          </span>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-white border-bottom small text-muted text-uppercase"
                   style="font-size: 0.7rem;">
              <tr>
                <th class="ps-4" style="width: 22%;">Variante</th>
                <th style="width: 42%;">Pieza de Proveedor</th>
                <th class="text-center" style="width: 14%;">Cantidad (fallback)</th>
                <th class="text-center" style="width: 12%;">Estado</th>
                <th class="pe-4 text-center" style="width: 10%;">Cantidades</th>
              </tr>
            </thead>
            <tbody>
              <% @variants.each do |variant| %>
                <% rule = @existing_rules[variant.id] %>
                <tr>
                  <td class="ps-4 py-2">
                    <div class="fw-bold small">
                      <%= variant.display_name.presence || variant.name %>
                    </div>
                    <% if variant.code.present? %>
                      <code class="text-muted" style="font-size: 0.7rem;"><%= variant.code %></code>
                    <% end %>
                  </td>
                  <td class="py-2">
                    <%= select_tag "rules[#{variant.id}][supplier_item_id]",
                          options_for_select(
                            @supplier_items.map { |i| ["#{i.name} (#{i.provider.name})", i.id] },
                            rule&.supplier_item_id
                          ),
                          include_blank: "— No comprar —",
                          class: "form-select form-select-sm border-0 bg-light shadow-none fw-bold" %>
                  </td>
                  <td class="py-2">
                    <%= number_field_tag "rules[#{variant.id}][quantity_needed]",
                          rule&.quantity_needed || 1.0,
                          step: 0.01, min: 0.01,
                          class: "form-control form-control-sm text-center border-0 bg-light shadow-none" %>
                  </td>
                  <td class="py-2 text-center">
                    <% if rule %>
                      <span class="badge bg-success-subtle text-success rounded-pill small">
                        <i class="bi bi-check-circle me-1"></i>Asignada
                      </span>
                    <% else %>
                      <span class="badge bg-secondary-subtle text-secondary rounded-pill small">
                        Sin regla
                      </span>
                    <% end %>
                  </td>
                  <td class="pe-4 py-2 text-center">
                    <% if rule %>
                      <%= link_to procurement_config_quantities_by_variant_type_path(rule),
                            class: "btn btn-sm btn-outline-primary rounded-pill px-2",
                            title: "Cantidades por producto" do %>
                        <i class="bi bi-list-ol"></i>
                        <% qty_count = rule.supply_rule_quantities.size %>
                        <% if qty_count > 0 %>
                          <span class="badge bg-primary rounded-pill ms-1"><%= qty_count %></span>
                        <% end %>
                      <% end %>
                    <% else %>
                      <span class="text-muted small">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="card-footer bg-white p-4 d-flex justify-content-between align-items-center border-top">
          <span class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            La cantidad aquí es el <strong>fallback</strong> cuando no hay cantidad específica por producto.
          </span>
          <%= submit_tag "Guardar Asignaciones",
                class: "btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>