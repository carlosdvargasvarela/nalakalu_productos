<div id="provider-show-<%= provider.id %>">
  <%# ── HEADER ── %>
  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body p-4">
      <div class="d-flex align-items-start gap-3">
        <div class="bg-primary bg-opacity-10 p-3 rounded-3 flex-shrink-0">
          <i class="bi bi-truck fs-3 text-primary"></i>
        </div>
        <div class="flex-grow-1">
          <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
            <h5 class="fw-bold mb-0"><%= provider.name %></h5>
            <span class="badge bg-primary rounded-pill px-2"><%= provider.category %></span>
            <span class="badge <%= provider.active ? 'bg-success' : 'bg-secondary' %> rounded-pill px-2">
              <%= provider.active ? 'Activo' : 'Inactivo' %>
            </span>
          </div>
          <% if provider.contact_name.present? %>
            <div class="text-muted small">
              <i class="bi bi-person me-1"></i><%= provider.contact_name %>
              <% if provider.email.present? %>
                · <%= mail_to provider.email, provider.email, class: "text-decoration-none text-muted" %>
              <% end %>
              <% if provider.phone.present? %>
                · <i class="bi bi-telephone me-1"></i><%= provider.phone %>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="d-flex gap-2 flex-shrink-0 flex-wrap justify-content-end">
          <%= link_to new_supplier_item_path(provider_id: provider.id),
            data: { turbo_frame: "_top" },
            class: "btn btn-sm btn-outline-primary rounded-pill px-4" do %>
            <i class="bi bi-plus-lg me-1"></i>Nueva Pieza
          <% end %>
          <%= link_to edit_provider_path(provider),
              data: { turbo_frame: "provider_workspace" },
              class: "btn btn-outline-primary rounded-pill px-3 btn-sm shadow-sm" do %>
            <i class="bi bi-pencil me-1"></i>Editar
          <% end %>
          <%= button_to provider_path(provider), method: :delete,
              form: { data: { turbo_confirm: "¿Eliminar este proveedor? Se eliminarán también sus piezas y reglas asociadas." } },
              class: "btn btn-outline-danger rounded-pill px-3 btn-sm shadow-sm" do %>
            <i class="bi bi-trash"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <%# ── CONTENIDO ── %>
  <div class="row g-3">
    <%# Columna izquierda: Contacto + Notas %>
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 mb-3">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-person-lines-fill me-2 text-primary"></i>Contacto
          </h6>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-3">
            <div class="x-small text-muted fw-bold mb-1 text-uppercase">Persona</div>
            <div class="fw-bold small"><%= provider.contact_name.presence || "—" %></div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="x-small text-muted fw-bold mb-1 text-uppercase">Email</div>
            <div class="small">
              <% if provider.email.present? %>
                <%= mail_to provider.email, provider.email, class: "text-decoration-none" %>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="x-small text-muted fw-bold mb-1 text-uppercase">Teléfono</div>
            <div class="small"><%= provider.phone.presence || "—" %></div>
          </div>
        </div>
      </div>
      <% if provider.notes.present? %>
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white py-3 border-bottom">
            <h6 class="fw-bold mb-0">
              <i class="bi bi-sticky me-2 text-warning"></i>Notas Internas
            </h6>
          </div>
          <div class="card-body p-4">
            <p class="small text-muted mb-0"><%= provider.notes %></p>
          </div>
        </div>
      <% end %>
    </div>
    <%# Columna derecha: Catálogo de Piezas %>
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-box-seam me-2 text-primary"></i>Catálogo de Piezas
          </h6>
          <span class="badge bg-primary rounded-pill px-3">
            <%= supplier_items.count %> piezas
          </span>
        </div>
        <div class="card-body p-0">
          <% if supplier_items.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="px-4 py-3 text-muted x-small fw-bold text-uppercase">Pieza / Material</th>
                    <th class="py-3 text-muted x-small fw-bold text-uppercase">SKU</th>
                    <th class="py-3 text-muted x-small fw-bold text-uppercase text-center">Unidad</th>
                    <th class="py-3 text-muted x-small fw-bold text-uppercase text-end">Costo Ref.</th>
                    <th class="py-3 pe-4 text-end text-muted x-small fw-bold text-uppercase">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% supplier_items.each do |item| %>
                    <tr>
                      <td class="px-4 py-3">
                        <div class="fw-bold text-dark small"><%= item.name %></div>
                        <% if item.supplier_item_properties.any? %>
                          <div class="d-flex flex-wrap gap-1 mt-1">
                            <% item.supplier_item_properties.order(:position).each do |prop| %>
                              <span class="badge bg-light text-dark border fw-normal"
                                    style="font-size: 0.62rem;">
                                <%= prop.label %>: <%= prop.value %>
                              </span>
                            <% end %>
                          </div>
                        <% end %>
                      </td>
                      <td class="py-3">
                        <code class="small text-muted"><%= item.sku.presence || "—" %></code>
                      </td>
                      <td class="py-3 text-center">
                        <span class="badge bg-secondary-subtle text-secondary">
                          <%= item.unit %>
                        </span>
                      </td>
                      <td class="py-3 text-end">
                        <% if item.default_cost.present? && item.default_cost > 0 %>
                          <span class="fw-bold small">
                            <%= number_to_currency(item.default_cost,
                                unit: "₡", delimiter: ".", separator: ",") %>
                          </span>
                        <% else %>
                          <span class="text-muted small">—</span>
                        <% end %>
                      </td>
                      <td class="py-3 pe-4 text-end">
                        <%= link_to supplier_item_path(item),
                            data: { turbo_frame: "_top" },
                            class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                        <%= link_to edit_supplier_item_path(item),
                            data: { turbo_frame: "_top" },
                            class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                          <i class="bi bi-pencil"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-25"></i>
              <p class="small mb-3">Este proveedor no tiene piezas en su catálogo.</p>
              <%= link_to new_supplier_item_path(provider_id: provider.id),
                data: { turbo_frame: "_top" },
                class: "btn btn-sm btn-outline-primary rounded-pill px-4" do %>
                <i class="bi bi-plus-lg me-1"></i>Agregar primera pieza
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .x-small { font-size: 0.7rem; }
</style>