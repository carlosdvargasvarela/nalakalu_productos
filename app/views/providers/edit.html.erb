<%= turbo_frame_tag "provider_workspace" do %>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white py-3 border-bottom">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 small">
          <li class="breadcrumb-item">
            <%= link_to "Proveedores", providers_path, class: "text-decoration-none" %>
          </li>
          <li class="breadcrumb-item">
            <%= link_to @provider.name,
                providers_path(selected_id: @provider.id),
                data: { turbo_frame: "provider_workspace" },
                class: "text-decoration-none" %>
          </li>
          <li class="breadcrumb-item active fw-bold">Editar</li>
        </ol>
      </nav>
      <h5 class="fw-bold mb-0 mt-2">
        Editando: <span class="text-primary"><%= @provider.name %></span>
      </h5>
    </div>
    <div class="card-body p-4">
      <%= render "form", provider: @provider %>
    </div>
  </div>
<% end %>