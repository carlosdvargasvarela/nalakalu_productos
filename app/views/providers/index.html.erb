<%# app/views/providers/index.html.erb %>
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0 text-dark">Proveedores</h1>
      <p class="text-muted mb-0">Gestión de suministros, materiales y órdenes de compra.</p>
    </div>
    <%= link_to new_provider_path, class: "btn btn-primary shadow-sm rounded-pill px-4 fw-bold" do %>
      <i class="bi bi-plus-lg me-2"></i>Nuevo Proveedor
    <% end %>
  </div>
  <div class="row g-4">
    <% @providers.each do |provider| %>
      <div class="col-md-6 col-xl-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 hover-card">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="bg-primary bg-opacity-10 p-3 rounded-3">
                <i class="bi bi-truck fs-3 text-primary"></i>
              </div>
              <span class="badge <%= provider.active ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' %> rounded-pill px-3">
                <%= provider.active ? 'Activo' : 'Inactivo' %>
              </span>
            </div>
            <h5 class="fw-bold mb-1"><%= provider.name %></h5>
            <div class="d-flex align-items-center gap-2 mb-3">
              <span class="badge bg-light text-muted border rounded-pill px-2 small">
                <%= provider.category %>
              </span>
              <% if provider.contact_name.present? %>
                <span class="text-muted small">
                  <i class="bi bi-person me-1"></i><%= provider.contact_name %>
                </span>
              <% end %>
            </div>
            <div class="bg-light rounded-3 p-3 mb-4">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="small text-muted fw-bold">Piezas en Catálogo:</span>
                <span class="badge bg-primary rounded-pill"><%= provider.supplier_items.count %></span>
              </div>
              <div class="d-flex flex-wrap gap-1">
                <% provider.supplier_items.limit(5).each do |item| %>
                  <span class="badge bg-white border text-dark rounded-pill px-2" style="font-size: 0.65rem;">
                    <%= item.name.truncate(20) %>
                  </span>
                <% end %>
                <% extra = provider.supplier_items.count - 5 %>
                <% if extra > 0 %>
                  <span class="text-muted" style="font-size: 0.7rem;">+<%= extra %> más</span>
                <% end %>
              </div>
            </div>
            <div class="d-flex gap-2 mt-auto">
              <%= link_to provider, class: "btn btn-sm btn-outline-primary rounded-pill flex-fill fw-bold" do %>
                <i class="bi bi-eye me-1"></i>Ver Perfil
              <% end %>
              <%= link_to edit_provider_path(provider), class: "btn btn-sm btn-outline-secondary rounded-pill px-3" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>