<div class="container-fluid py-4" data-controller="provider-filters">
  <%# ── HEADER ── %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h4 class="fw-bold mb-0 text-dark">Proveedores</h4>
      <p class="text-muted mb-0 small">
        <span class="text-success fw-bold"><%= @stats[:active] %> activos</span>
        de <%= @stats[:total] %> totales ·
        <span class="text-muted"><%= @stats[:internal] %> internos</span> ·
        <span class="text-muted"><%= @stats[:external] %> externos</span>
      </p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to new_provider_path,
          data: { turbo_frame: "provider_workspace" },
          class: "btn btn-primary shadow-sm rounded-pill px-4 fw-bold" do %>
        <i class="bi bi-plus-lg me-2"></i>Nuevo Proveedor
      <% end %>
    </div>
  </div>
  <% if @providers.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-truck d-block fs-1 mb-3 opacity-25"></i>
      <p class="fw-bold">No hay proveedores registrados aún.</p>
      <%= link_to new_provider_path, class: "btn btn-primary rounded-pill px-4" do %>
        <i class="bi bi-plus-lg me-2"></i>Crear primer proveedor
      <% end %>
    </div>
  <% else %>
    <div class="row g-4" style="min-height: 70vh;">
      <%# ── PANEL IZQUIERDO ── %>
      <div class="col-lg-4 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <%# Filtros %>
          <div class="card-header bg-white py-3 border-bottom">
            <div class="input-group input-group-sm mb-2">
              <span class="input-group-text bg-light border-0 rounded-start-3">
                <i class="bi bi-search text-muted"></i>
              </span>
              <input type="text"
                     class="form-control bg-light border-0 shadow-none rounded-end-3"
                     placeholder="Buscar proveedor..."
                     data-provider-filters-target="search"
                     data-action="input->provider-filters#filter">
            </div>
            <div class="d-flex gap-2">
              <select class="form-select form-select-sm bg-light border-0 shadow-none rounded-3"
                      data-provider-filters-target="categoryFilter"
                      data-action="change->provider-filters#filter">
                <option value="">Todas las categorías</option>
                <option value="interno">Interno</option>
                <option value="externo">Externo</option>
              </select>
              <select class="form-select form-select-sm bg-light border-0 shadow-none rounded-3"
                      data-provider-filters-target="statusFilter"
                      data-action="change->provider-filters#filter">
                <option value="">Todos</option>
                <option value="active">Activos</option>
                <option value="inactive">Inactivos</option>
              </select>
            </div>
          </div>
          <%# Lista de proveedores %>
          <div class="card-body p-0 overflow-auto" style="max-height: calc(100vh - 300px);">
            <div id="providers-list">
              <% @providers.each do |provider| %>
                <%= render "providers/provider_list_item",
                    provider: provider,
                    selected: @selected&.id == provider.id %>
              <% end %>
            </div>
          </div>
          <%# Importador CSV %>
          <div class="card-footer bg-white border-top p-3">
            <%= form_with url: import_providers_path, multipart: true, local: true do |f| %>
              <p class="small text-muted fw-bold mb-2">
                <i class="bi bi-file-earmark-spreadsheet me-1 text-info"></i>Importar CSV
              </p>
              <div class="input-group input-group-sm shadow-sm">
                <%= f.file_field :file,
                    class: "form-control rounded-start-pill small", accept: ".csv" %>
                <button class="btn btn-info text-white rounded-end-pill fw-bold px-3" type="submit">
                  <i class="bi bi-cloud-upload"></i>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <%# ── PANEL DERECHO (Turbo Frame) ── %>
      <div class="col-lg-8 col-xl-9">
        <%= turbo_frame_tag "provider_workspace" do %>
          <% if @selected %>
            <%= render "providers/show_panel",
                provider: @selected,
                supplier_items: @selected.supplier_items.active
                  .includes(:supplier_item_properties).order(:name) %>
          <% else %>
            <%= render "providers/workspace_placeholder" %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
<style>
  .provider-row-active { background-color: #f0f7ff; border-left: 3px solid #0d6efd !important; }
  .provider-row        { border-left: 3px solid transparent; transition: background 0.15s; }
  .provider-row:hover  { background-color: #f8f9fa; }
  .bg-success-soft     { background-color: #e1f6eb; }
  .bg-secondary-soft   { background-color: #f0f2f5; }
</style>