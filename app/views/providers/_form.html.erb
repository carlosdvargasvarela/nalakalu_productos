<%= form_with(model: provider) do |f| %>
  <% if provider.errors.any? %>
    <div class="alert alert-danger border-0 rounded-3 shadow-sm">
      <div class="fw-bold mb-2"><i class="bi bi-exclamation-triangle me-2"></i><%= pluralize(provider.errors.count, "error") %> impidieron guardar:</div>
      <ul class="mb-0 ps-3">
        <% provider.errors.each do |error| %>
          <li class="small"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <!-- Columna Info -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">Estado</h5>
          <div class="mb-0">
            <%= f.label :active, "Estado del Proveedor", class: "form-label small fw-bold" %>
            <%= f.select :active, [["Activo", true], ["Inactivo", false]], {}, { class: "form-select border-2" } %>
          </div>
          <hr class="my-4 opacity-25">
          <p class="small text-muted mb-0">
            <i class="bi bi-info-circle me-1"></i>
            Solo los proveedores activos aparecerán disponibles al asignar variantes.
          </p>
        </div>
      </div>
    </div>
    <!-- Columna Formulario -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">Datos del Proveedor</h5>
          <div class="mb-3">
            <%= f.label :name, "Nombre de la Empresa", class: "form-label small fw-bold" %>
            <%= f.text_field :name, class: "form-control border-2", placeholder: "Ej: Textiles del Sur" %>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <%= f.label :contact_name, "Nombre del Contacto", class: "form-label small fw-bold" %>
              <%= f.text_field :contact_name, class: "form-control border-2", placeholder: "Ej: Juan Pérez" %>
            </div>
            <div class="col-md-6">
              <%= f.label :phone, "Teléfono", class: "form-label small fw-bold" %>
              <%= f.text_field :phone, class: "form-control border-2", placeholder: "+506 1234-5678" %>
            </div>
          </div>
          <div class="mb-3">
            <%= f.label :email, "Email", class: "form-label small fw-bold" %>
            <%= f.email_field :email, class: "form-control border-2", placeholder: "contacto@empresa.com" %>
          </div>
          <div class="mb-0">
            <%= f.label :notes, "Notas Internas", class: "form-label small fw-bold" %>
            <%= f.text_area :notes, rows: 4, class: "form-control border-2", placeholder: "Observaciones, condiciones de pago, tiempos de entrega..." %>
          </div>
        </div>
      </div>
      <div class="d-flex justify-content-between align-items-center mt-4">
        <%= link_to providers_path, class: "btn btn-link text-decoration-none text-muted" do %>
          <i class="bi bi-arrow-left me-2"></i>Cancelar
        <% end %>
        <%= f.submit "Guardar Proveedor", class: "btn btn-primary btn-lg px-5 shadow rounded-pill fw-bold" %>
      </div>
    </div>
  </div>
<% end %>