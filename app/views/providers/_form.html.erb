<%= form_with(model: provider, class: "needs-validation", novalidate: true) do |form| %>
  <% if provider.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(provider.errors.count, "error") %> impidieron guardar:</h4>
      <ul>
        <% provider.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "Nombre de la Empresa", class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Ej: Textiles del Sur", required: true %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :contact_name, "Nombre del Contacto", class: "form-label" %>
      <%= form.text_field :contact_name, class: "form-control", placeholder: "Ej: Juan Pérez" %>
    </div>
    
    <div class="col-md-6 mb-3">
      <%= form.label :phone, "Teléfono", class: "form-label" %>
      <%= form.text_field :phone, class: "form-control", placeholder: "Ej: +506 1234-5678" %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :email, "Email", class: "form-label" %>
    <%= form.email_field :email, class: "form-control", placeholder: "contacto@empresa.com" %>
  </div>

  <div class="mb-3">
    <%= form.label :notes, "Notas", class: "form-label" %>
    <%= form.text_area :notes, rows: 4, class: "form-control", placeholder: "Observaciones sobre el proveedor..." %>
  </div>

  <div class="mb-3 form-check">
    <%= form.check_box :active, class: "form-check-input" %>
    <%= form.label :active, "Proveedor Activo", class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit "Guardar", class: "btn btn-primary" %>
    <%= link_to "Cancelar", providers_path, class: "btn btn-secondary" %>
  </div>
<% end %>