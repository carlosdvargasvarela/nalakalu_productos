<%= form_with(model: provider, 
              data: { 
                controller: "nested-form", 
                nested_form_wrapper_selector_value: ".variant-row" 
              }) do |f| %>
  <% if provider.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar:</h6>
      <ul class="mb-0 ps-3 small">
        <% provider.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <!-- Columna Izquierda: Datos del Proveedor -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-info-circle-fill me-2 text-primary"></i>Datos del Proveedor</h5>
          <div class="mb-3">
            <%= f.label :name, "Nombre de la Empresa", class: "form-label small fw-bold text-muted" %>
            <%= f.text_field :name, class: "form-control border-2 shadow-none", placeholder: "Ej: Textiles del Sur S.A." %>
          </div>
          <div class="mb-3">
            <%= f.label :category, "Tipo de Proveedor", class: "form-label small fw-bold text-muted" %>
            <%= f.select :category, [["Interno (Nalakalú)", "interno"], ["Externo (Terceros)", "externo"]], 
                {}, { class: "form-select border-2 shadow-none fw-bold" } %>
          </div>
          <div class="mb-3">
            <%= f.label :contact_name, "Persona de Contacto", class: "form-label small fw-bold text-muted" %>
            <%= f.text_field :contact_name, class: "form-control border-2 shadow-none", placeholder: "Nombre y apellido" %>
          </div>
          <div class="row">
            <div class="col-md-12 mb-3">
              <%= f.label :email, "Email de Contacto", class: "form-label small fw-bold text-muted" %>
              <%= f.email_field :email, class: "form-control border-2 shadow-none", placeholder: "correo@ejemplo.com" %>
            </div>
            <div class="col-md-12 mb-3">
              <%= f.label :phone, "Teléfono", class: "form-label small fw-bold text-muted" %>
              <%= f.text_field :phone, class: "form-control border-2 shadow-none", placeholder: "+506 0000-0000" %>
            </div>
          </div>
          <div class="mb-3">
            <%= f.label :notes, "Notas Internas", class: "form-label small fw-bold text-muted" %>
            <%= f.text_area :notes, class: "form-control border-2 shadow-none", rows: 3, placeholder: "Observaciones sobre tiempos de entrega, calidad, etc." %>
          </div>
          <div class="mb-0">
            <%= f.label :active, "Estado", class: "form-label small fw-bold text-muted" %>
            <div class="d-flex gap-3 mt-1">
              <div class="form-check">
                <%= f.radio_button :active, true, class: "form-check-input" %>
                <%= f.label :active_true, "Activo", class: "form-check-label small" %>
              </div>
              <div class="form-check">
                <%= f.radio_button :active, false, class: "form-check-input" %>
                <%= f.label :active_false, "Inactivo", class: "form-check-label small" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Columna Derecha: Variantes -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <div>
            <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-box-seam-fill me-2"></i>Variantes Suministradas</h5>
            <p class="text-muted small mb-0">Define qué variantes provee esta empresa y sus costos.</p>
          </div>
          <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" data-action="nested-form#add">
            <i class="bi bi-plus-lg me-2"></i>Agregar Variante
          </button>
        </div>
        <div class="card-body p-0 bg-light bg-opacity-50">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="bg-white border-bottom">
                <tr>
                  <th class="ps-4 py-3 small fw-bold text-muted text-uppercase" style="width: 25%;">Tipo</th>
                  <th class="py-3 small fw-bold text-muted text-uppercase" style="width: 30%;">Nombre</th>
                  <th class="py-3 small fw-bold text-muted text-uppercase text-center" style="width: 15%;">Código</th>
                  <th class="py-3 small fw-bold text-muted text-uppercase text-center" style="width: 15%;">Costo ($)</th>
                  <th class="py-3 text-center small fw-bold text-muted text-uppercase" style="width: 10%;">Activa</th>
                  <th class="py-3 pe-4" style="width: 5%;"></th>
                </tr>
              </thead>
              <tbody data-nested-form-target="target">
                <%= f.fields_for :variants do |variant_form| %>
                  <%= render "variant_fields", f: variant_form %>
                <% end %>
              </tbody>
            </table>
          </div>
          <template data-nested-form-target="template">
            <%= f.fields_for :variants, Variant.new, child_index: "NEW_RECORD" do |variant_form| %>
              <%= render "variant_fields", f: variant_form %>
            <% end %>
          </template>
          <div class="p-4 text-center border-top bg-white rounded-bottom-4">
            <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-4" data-action="nested-form#add">
              <i class="bi bi-plus-circle me-2"></i>Agregar otra fila de variante
            </button>
          </div>
        </div>
      </div>
      <!-- Footer de Acciones -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
          <%= link_to providers_path, class: "btn btn-link text-muted text-decoration-none fw-bold" do %>
            <i class="bi bi-x-lg me-2"></i>Descartar
          <% end %>
          <%= f.submit provider.new_record? ? "Crear Proveedor" : "Guardar Cambios", 
              class: "btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow" %>
        </div>
      </div>
    </div>
  </div>
<% end %>