<%# app/views/providers/_form.html.erb %>
<%= form_with(model: provider) do |f| %>
  <% if provider.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar:</h6>
      <ul class="mb-0 ps-3 small">
        <% provider.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4 text-dark">
            <i class="bi bi-info-circle-fill me-2 text-primary"></i>Datos del Proveedor
          </h5>
          <div class="mb-3">
            <%= f.label :name, "Nombre de la Empresa", class: "form-label small fw-bold text-muted" %>
            <%= f.text_field :name,
                  class: "form-control border-2 shadow-none",
                  placeholder: "Ej: Textiles del Sur S.A." %>
          </div>
          <div class="mb-3">
            <%= f.label :category, "Tipo de Proveedor", class: "form-label small fw-bold text-muted" %>
            <%= f.select :category,
                  [["Interno (Nalakalú)", "interno"], ["Externo (Terceros)", "externo"]],
                  {},
                  { class: "form-select border-2 shadow-none fw-bold" } %>
          </div>
          <div class="mb-3">
            <%= f.label :contact_name, "Persona de Contacto", class: "form-label small fw-bold text-muted" %>
            <%= f.text_field :contact_name,
                  class: "form-control border-2 shadow-none",
                  placeholder: "Nombre y apellido" %>
          </div>
          <div class="mb-3">
            <%= f.label :email, "Email de Contacto", class: "form-label small fw-bold text-muted" %>
            <%= f.email_field :email,
                  class: "form-control border-2 shadow-none",
                  placeholder: "correo@ejemplo.com" %>
          </div>
          <div class="mb-3">
            <%= f.label :phone, "Teléfono", class: "form-label small fw-bold text-muted" %>
            <%= f.text_field :phone,
                  class: "form-control border-2 shadow-none",
                  placeholder: "+506 0000-0000" %>
          </div>
          <div class="mb-3">
            <%= f.label :notes, "Notas Internas", class: "form-label small fw-bold text-muted" %>
            <%= f.text_area :notes,
                  class: "form-control border-2 shadow-none",
                  rows: 3,
                  placeholder: "Tiempos de entrega, condiciones, observaciones..." %>
          </div>
          <div class="mb-4">
            <%= f.label :active, "Estado", class: "form-label small fw-bold text-muted" %>
            <div class="d-flex gap-3 mt-1">
              <div class="form-check">
                <%= f.radio_button :active, true, class: "form-check-input" %>
                <%= f.label :active_true, "Activo", class: "form-check-label small" %>
              </div>
              <div class="form-check">
                <%= f.radio_button :active, false, class: "form-check-input" %>
                <%= f.label :active_false, "Inactivo", class: "form-check-label small" %>
              </div>
            </div>
          </div>
          <div class="d-flex justify-content-between align-items-center border-top pt-3">
            <%= link_to providers_path,
                data: { turbo_frame: "_top" },
                class: "btn btn-link text-muted text-decoration-none fw-bold" do %>
              <i class="bi bi-x-lg me-1"></i>Descartar
            <% end %>
            <%= f.submit provider.new_record? ? "Crear Proveedor" : "Guardar Cambios",
                class: "btn btn-primary px-5 rounded-pill fw-bold shadow-sm" %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 text-center text-muted py-5">
          <i class="bi bi-box-seam fs-1 d-block mb-3 opacity-25"></i>
          <h6 class="fw-bold text-dark">Catálogo de Piezas</h6>
          <p class="small mb-3">
            Las piezas y materiales que suministra este proveedor se gestionan
            desde la sección <strong>Piezas de Proveedor</strong> una vez creado el registro.
          </p>
          <% unless provider.new_record? %>
            <%= link_to new_supplier_item_path(provider_id: provider.id),
                  class: "btn btn-outline-primary rounded-pill px-4 btn-sm" do %>
              <i class="bi bi-plus-lg me-1"></i>Agregar Pieza a este Proveedor
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>