<%= link_to provider_path(provider),
    data: {
      turbo_frame:     "provider_workspace",
      provider_id:     provider.id,
      provider_name:   provider.name.downcase,
      category:        provider.category,
      status:          provider.active ? "active" : "inactive"
    },
    class: "list-group-item list-group-item-action border-0 px-3 py-3 provider-row
            #{'provider-row-active' if selected}",
    id: "provider-list-item-#{provider.id}" do %>
  <div class="d-flex justify-content-between align-items-start">
    <div class="flex-grow-1 me-2 overflow-hidden">
      <div class="fw-bold text-dark small text-truncate"><%= provider.name %></div>
      <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
        <span class="badge bg-light text-muted border rounded-pill px-2"
              style="font-size: 0.6rem;">
          <%= provider.category %>
        </span>
        <% if provider.contact_name.present? %>
          <span class="text-muted" style="font-size: 0.68rem;">
            <i class="bi bi-person me-1"></i><%= provider.contact_name.truncate(20) %>
          </span>
        <% end %>
      </div>
    </div>
    <div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">
      <% if provider.active %>
        <span class="badge bg-success-soft text-success rounded-pill px-2"
              style="font-size: 0.6rem;">Activo</span>
      <% else %>
        <span class="badge bg-secondary-soft text-secondary rounded-pill px-2"
              style="font-size: 0.6rem;">Inactivo</span>
      <% end %>
      <span class="badge bg-light text-primary border rounded-pill px-2"
            style="font-size: 0.6rem;">
        <i class="bi bi-box-seam me-1"></i><%= provider.supplier_items.count %> piezas
      </span>
    </div>
  </div>
<% end %>