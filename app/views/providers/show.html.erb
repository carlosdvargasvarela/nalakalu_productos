<div class="container-fluid py-4">
  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i><%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>
  <!-- Header -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item"><%= link_to "Proveedores", providers_path, class: "text-decoration-none" %></li>
              <li class="breadcrumb-item active fw-bold"><%= @provider.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="bg-primary bg-opacity-10 p-3 rounded-3">
              <i class="bi bi-building fs-3 text-primary"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0"><%= @provider.name %></h2>
              <span class="badge <%= @provider.active ? 'bg-success' : 'bg-secondary' %> rounded-pill mt-1">
                <%= @provider.active ? 'Activo' : 'Inactivo' %>
              </span>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-2 justify-content-md-end">
            <%= link_to edit_provider_path(@provider), class: "btn btn-white border shadow-sm rounded-pill px-4" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar
            <% end %>
            <%= button_to @provider, method: :delete, class: "btn btn-outline-danger rounded-circle p-2",
                form: { data: { turbo_confirm: "¿Eliminar este proveedor?" } } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- Info del Proveedor -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2 text-primary"></i>Información de Contacto</h5>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Empresa</div>
            <div class="fw-bold fs-5"><%= @provider.name %></div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Contacto</div>
            <div><%= @provider.contact_name.presence || "—" %></div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Email</div>
            <% if @provider.email.present? %>
              <a href="mailto:<%= @provider.email %>" class="text-decoration-none">
                <i class="bi bi-envelope me-1"></i><%= @provider.email %>
              </a>
            <% else %>
              <span class="text-muted">—</span>
            <% end %>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Teléfono</div>
            <% if @provider.phone.present? %>
              <a href="tel:<%= @provider.phone %>" class="text-decoration-none">
                <i class="bi bi-telephone me-1"></i><%= @provider.phone %>
              </a>
            <% else %>
              <span class="text-muted">—</span>
            <% end %>
          </div>
          <% if @provider.notes.present? %>
            <div class="list-group-item px-4 py-3">
              <div class="small text-muted fw-bold mb-1">Notas</div>
              <div class="text-muted small"><%= simple_format(@provider.notes) %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <!-- Variantes Asociadas -->
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-tags me-2 text-primary"></i>Variantes Asociadas</h5>
            <span class="badge bg-primary rounded-pill"><%= @provider.variants.count %></span>
          </div>
        </div>
        <div class="card-body p-0">
          <% if @provider.variants.any? %>
            <div class="list-group list-group-flush rounded-4">
              <% @provider.variants.each do |variant| %>
                <div class="list-group-item px-4 py-3 d-flex align-items-center justify-content-between">
                  <div class="d-flex align-items-center gap-3">
                    <div class="bg-secondary bg-opacity-10 rounded-3 p-2">
                      <i class="bi bi-tag text-secondary"></i>
                    </div>
                    <div>
                      <div class="fw-bold"><%= variant.name %></div>
                      <div class="small text-muted"><%= variant.variant_type.name %></div>
                    </div>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <code class="bg-light px-2 py-1 rounded small"><%= variant.code %></code>
                    <span class="badge <%= variant.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill">
                      <%= variant.active ? 'Activa' : 'Inactiva' %>
                    </span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-tags fs-1 d-block mb-2 opacity-25"></i>
              No hay variantes asociadas a este proveedor.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .bg-success-soft { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
</style>