<div class="container-fluid py-4">
  <!-- Header -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item"><%= link_to "Proveedores", providers_path, class: "text-decoration-none" %></li>
              <li class="breadcrumb-item active fw-bold"><%= @provider.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="bg-primary bg-opacity-10 p-3 rounded-3 flex-shrink-0">
              <i class="bi bi-truck fs-3 text-primary"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0"><%= @provider.name %></h2>
              <div class="d-flex gap-2 mt-1">
                <span class="badge bg-primary rounded-pill px-3"><%= @provider.category %></span>
                <span class="badge <%= @provider.active ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3">
                  <%= @provider.active ? 'Activo' : 'Inactivo' %>
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <%= link_to edit_provider_path(@provider), class: "btn btn-outline-primary rounded-pill px-4 shadow-sm" do %>
            <i class="bi bi-pencil-square me-2"></i>Editar Proveedor
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- Info de Contacto -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Contacto</h5>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Persona de Contacto</div>
            <div class="fw-bold"><%= @provider.contact_name.presence || "—" %></div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Email</div>
            <div><%= mail_to @provider.email, @provider.email, class: "text-decoration-none" if @provider.email.present? %></div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Teléfono</div>
            <div><%= @provider.phone.presence || "—" %></div>
          </div>
        </div>
      </div>
      <% if @provider.notes.present? %>
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 fw-bold"><i class="bi bi-sticky me-2 text-warning"></i>Notas Internas</h5>
          </div>
          <div class="card-body p-4">
            <p class="small text-muted mb-0"><%= @provider.notes %></p>
          </div>
        </div>
      <% end %>
    </div>
    <!-- Catálogo de Variantes -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold"><i class="bi bi-palette me-2 text-primary"></i>Catálogo de Suministros</h5>
          <span class="badge bg-primary rounded-pill px-3"><%= @provider.variants.count %> variantes</span>
        </div>
        <div class="card-body p-0">
          <% if @provider.variants.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="px-4 py-3 text-muted small fw-bold text-uppercase">Variante</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">Tipo</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">SKU Prov.</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase text-end">Costo</th>
                    <th class="py-3 pe-4 text-end text-muted small fw-bold text-uppercase">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% @provider.variants.includes(:variant_type).order("variant_types.name, variants.name").each do |variant| %>
                    <tr>
                      <td class="px-4 py-3">
                        <div class="fw-bold text-dark"><%= variant.name %></div>
                        <code class="x-small text-muted"><%= variant.code %></code>
                      </td>
                      <td class="py-3">
                        <span class="badge bg-light text-dark border rounded-pill px-2 small"><%= variant.variant_type.name %></span>
                      </td>
                      <td class="py-3">
                        <span class="text-muted small font-monospace"><%= variant.provider_sku.presence || "—" %></span>
                      </td>
                      <td class="py-3 text-end">
                        <span class="fw-bold">$<%= number_with_precision(variant.cost, precision: 2, delimiter: ",") %></span>
                      </td>
                      <td class="py-3 pe-4 text-end">
                        <%= link_to variant, class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-palette fs-1 d-block mb-2 opacity-25"></i>
              <p>Este proveedor no tiene variantes asignadas.</p>
              <%= link_to variants_path, class: "btn btn-sm btn-outline-primary rounded-pill px-4" do %>
                Ir a Variantes para asignar
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>