<%# app/views/providers/show.html.erb %>
<div class="container-fluid py-4">
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item">
                <%= link_to "Proveedores", providers_path, class: "text-decoration-none" %>
              </li>
              <li class="breadcrumb-item active fw-bold"><%= @provider.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="bg-primary bg-opacity-10 p-3 rounded-3 flex-shrink-0">
              <i class="bi bi-truck fs-3 text-primary"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0"><%= @provider.name %></h2>
              <div class="d-flex gap-2 mt-1">
                <span class="badge bg-primary rounded-pill px-3"><%= @provider.category %></span>
                <span class="badge <%= @provider.active ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3">
                  <%= @provider.active ? 'Activo' : 'Inactivo' %>
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0 d-flex gap-2 justify-content-md-end flex-wrap">
          <%= link_to new_supplier_item_path(provider_id: @provider.id),
                class: "btn btn-success rounded-pill px-4 shadow-sm btn-sm fw-bold" do %>
            <i class="bi bi-plus-lg me-1"></i>Nueva Pieza
          <% end %>
          <%= link_to edit_provider_path(@provider),
                class: "btn btn-outline-primary rounded-pill px-4 shadow-sm" do %>
            <i class="bi bi-pencil-square me-2"></i>Editar
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <%# Columna izquierda: Contacto %>
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-person-lines-fill me-2 text-primary"></i>Contacto
          </h5>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Persona de Contacto</div>
            <div class="fw-bold"><%= @provider.contact_name.presence || "—" %></div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Email</div>
            <div>
              <% if @provider.email.present? %>
                <%= mail_to @provider.email, @provider.email, class: "text-decoration-none" %>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </div>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Teléfono</div>
            <div><%= @provider.phone.presence || "—" %></div>
          </div>
        </div>
      </div>
      <% if @provider.notes.present? %>
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 fw-bold">
              <i class="bi bi-sticky me-2 text-warning"></i>Notas Internas
            </h5>
          </div>
          <div class="card-body p-4">
            <p class="small text-muted mb-0"><%= @provider.notes %></p>
          </div>
        </div>
      <% end %>
    </div>
    <%# Columna derecha: Catálogo de Piezas %>
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-box-seam me-2 text-primary"></i>Catálogo de Piezas
          </h5>
          <span class="badge bg-primary rounded-pill px-3">
            <%= @supplier_items.count %> piezas
          </span>
        </div>
        <div class="card-body p-0">
          <% if @supplier_items.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="px-4 py-3 text-muted small fw-bold text-uppercase">Pieza / Material</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">SKU</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase text-center">Unidad</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase text-end">Costo Ref.</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase text-center">Estado</th>
                    <th class="py-3 pe-4 text-end text-muted small fw-bold text-uppercase">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% @supplier_items.each do |item| %>
                    <tr>
                      <td class="px-4 py-3">
                        <div class="fw-bold text-dark"><%= item.name %></div>
                        <%# Propiedades EAV de la pieza (ej: N1: MS-01, N2: MS-07) %>
                        <% if item.supplier_item_properties.loaded? ? item.supplier_item_properties.any? : item.supplier_item_properties.exists? %>
                          <div class="d-flex flex-wrap gap-1 mt-1">
                            <% item.supplier_item_properties.order(:position).each do |prop| %>
                              <span class="badge bg-light text-dark border fw-normal"
                                    style="font-size: 0.65rem;">
                                <%= prop.label %>: <%= prop.value %>
                              </span>
                            <% end %>
                          </div>
                        <% end %>
                      </td>
                      <td class="py-3">
                        <code class="small text-muted"><%= item.sku.presence || "—" %></code>
                      </td>
                      <td class="py-3 text-center">
                        <span class="badge bg-secondary-subtle text-secondary">
                          <%= item.unit %>
                        </span>
                      </td>
                      <td class="py-3 text-end">
                        <%# default_cost es el campo correcto en el nuevo schema %>
                        <% if item.default_cost.present? && item.default_cost > 0 %>
                          <span class="fw-bold small">
                            <%= number_to_currency(item.default_cost, unit: "₡", delimiter: ".", separator: ",") %>
                          </span>
                        <% else %>
                          <span class="text-muted small">—</span>
                        <% end %>
                      </td>
                      <td class="py-3 text-center">
                        <span class="badge <%= item.active ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' %> rounded-pill">
                          <%= item.active ? 'Activa' : 'Inactiva' %>
                        </span>
                      </td>
                      <td class="py-3 pe-4 text-end">
                        <%= link_to edit_supplier_item_path(item),
                              class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                          <i class="bi bi-pencil"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-25"></i>
              <p class="mb-3">Este proveedor no tiene piezas en su catálogo.</p>
              <%= link_to new_supplier_item_path(provider_id: @provider.id),
                    class: "btn btn-sm btn-outline-primary rounded-pill px-4" do %>
                <i class="bi bi-plus-lg me-1"></i>Agregar primera pieza
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>