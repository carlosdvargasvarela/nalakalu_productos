<div class="container-fluid py-4">
  <!-- HEADER (Igual al anterior pero con breadcrumbs limpios) -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item"><%= link_to "Proveedores", providers_path, class: "text-decoration-none" %></li>
              <li class="breadcrumb-item active fw-bold"><%= @provider.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="bg-primary bg-opacity-10 p-3 rounded-3">
              <i class="bi bi-building fs-3 text-primary"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0"><%= @provider.name %></h2>
              <div class="d-flex gap-2 mt-1">
                <span class="badge <%= @provider.active ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3">
                  <%= @provider.active ? 'Activo' : 'Inactivo' %>
                </span>
                <span class="badge bg-info-soft text-info rounded-pill px-3">
                  <i class="bi bi-tag me-1"></i><%= @provider.category.capitalize %>
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex justify-content-md-end gap-2">
            <%= link_to edit_provider_path(@provider), class: "btn btn-outline-primary rounded-pill px-4 shadow-sm" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar Datos
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- CONTACT CARD -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="fw-bold mb-0"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Información de Contacto</h5>
        </div>
        <div class="card-body p-0">
          <div class="list-group list-group-flush">
            <div class="list-group-item px-4 py-3 border-0">
              <div class="small text-muted fw-bold mb-1">Persona de Contacto</div>
              <div class="fw-semibold"><%= @provider.contact_name.presence || "—" %></div>
            </div>
            <div class="list-group-item px-4 py-3 border-0">
              <div class="small text-muted fw-bold mb-1">Email</div>
              <%= @provider.email.present? ? mail_to(@provider.email, nil, class: "text-primary text-decoration-none") : "—" %>
            </div>
            <div class="list-group-item px-4 py-3 border-0">
              <div class="small text-muted fw-bold mb-1">Teléfono</div>
              <div><%= @provider.phone.presence || "—" %></div>
            </div>
            <% if @provider.notes.present? %>
              <div class="list-group-item px-4 py-3 border-0">
                <div class="small text-muted fw-bold mb-1">Notas Internas</div>
                <div class="text-muted small"><%= @provider.notes %></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <!-- PANEL DE GESTIÓN DE VARIANTES (Lógica similar a Familias) -->
    <div class="col-lg-8">
      <div class="row g-4">
        <!-- Variantes Asignadas -->
        <div class="col-12">
          <%= render "assigned_variants", provider: @provider %>
        </div>
        <!-- Asignador Masivo (Variantes sin proveedor) -->
        <div class="col-12">
          <%= render "bulk_assigner", provider: @provider %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .bg-success-soft { background-color:#e1f6eb }
  .bg-secondary-soft { background-color:#f0f2f5 }
  .bg-info-soft { background-color:#e0f4ff }
</style>