<div class="card shadow-sm border-0 rounded-4 border-start border-4 border-success">
  <div class="card-header bg-white py-3 border-bottom">
    <h5 class="mb-0 fw-bold text-success">
      <i class="bi bi-plus-circle me-2"></i>Asignar Variantes Existentes
    </h5>
    <p class="text-muted small mb-0 mt-1">Variantes registradas como "Uso Interno" que puedes asignar a este proveedor.</p>
  </div>
  <div class="card-body p-0">
    <% unassigned = Variant.where(provider_id: nil).includes(:variant_type).order("variant_types.name, variants.name") %>
    <% if unassigned.any? %>
      <div class="table-responsive" style="max-height: 400px;">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4 py-2 small fw-bold text-muted text-uppercase">Tipo / Nombre</th>
              <th class="py-2 small fw-bold text-muted text-uppercase text-center">Código</th>
              <th class="py-2 pe-4 text-end small fw-bold text-muted text-uppercase">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% unassigned.each do |variant| %>
              <tr>
                <td class="ps-4">
                  <span class="badge bg-info-soft text-info rounded-pill px-2 mb-1" style="font-size: 0.7rem;">
                    <%= variant.variant_type.name %>
                  </span>
                  <div class="fw-bold small"><%= variant.display_name.presence || variant.name %></div>
                </td>
                <td class="text-center">
                  <code class="small fw-bold text-dark"><%= variant.code %></code>
                </td>
                <td class="text-end pe-4">
                  <%= button_to assign_variant_provider_path(provider, variant_id: variant.id),
                      method: :post,
                      class: "btn btn-sm btn-success rounded-pill px-3 text-white fw-bold" do %>
                    <i class="bi bi-plus-lg me-1"></i>Asignar
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4 text-muted">
        <i class="bi bi-check2-all fs-2 d-block mb-2 opacity-25"></i>
        <p class="small mb-0">No hay variantes disponibles para asignar.</p>
      </div>
    <% end %>
  </div>
</div>