<%# app/views/purchase_orders/index.html.erb %>
<div class="container-fluid mt-4 pb-5" style="max-width: 1100px;">
  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
      <h1 class="h2 fw-bold mb-0">
        <i class="bi bi-file-earmark-text-fill text-primary me-2"></i>Órdenes de Compra
      </h1>
      <p class="text-muted mb-0 small">Historial y seguimiento de órdenes enviadas a proveedores.</p>
    </div>
    <%= link_to supply_managements_path, class: "btn btn-outline-primary btn-sm" do %>
      <i class="bi bi-cart-plus me-1"></i>Ir a Panel de Proveeduría
    <% end %>
  </div>
  <%# FILTROS %>
  <%= form_tag purchase_orders_path, method: :get, class: "row g-2 mb-4 align-items-end" do %>
    <div class="col-md-3">
      <label class="form-label small text-muted mb-1">Proveedor</label>
      <%= select_tag :provider_id,
            options_from_collection_for_select(@providers, :id, :name, params[:provider_id]),
            include_blank: "Todos los proveedores",
            class: "form-select form-select-sm" %>
    </div>
    <div class="col-md-3">
      <label class="form-label small text-muted mb-1">Estado</label>
      <%= select_tag :status,
            options_for_select(@statuses.map { |s| [s.capitalize, s] }, params[:status]),
            include_blank: "Todos los estados",
            class: "form-select form-select-sm" %>
    </div>
    <div class="col-md-2">
      <%= submit_tag "Filtrar", class: "btn btn-dark btn-sm w-100" %>
    </div>
    <% if params[:status].present? || params[:provider_id].present? %>
      <div class="col-md-2">
        <%= link_to "Limpiar", purchase_orders_path, class: "btn btn-outline-secondary btn-sm w-100" %>
      </div>
    <% end %>
  <% end %>
  <%# RESUMEN DE ESTADOS %>
  <% status_counts = @purchase_orders.unscope(:order).group(:status).count %>
  <% status_colors = {
       "borrador"   => "secondary",
       "enviado"    => "info",
       "confirmado" => "primary",
       "recibido"   => "success",
       "cancelado"  => "danger"
     } %>
  <div class="row g-3 mb-4">
    <% PurchaseOrder::STATUSES.each do |s| %>
      <div class="col">
        <%= link_to purchase_orders_path(status: s), class: "text-decoration-none" do %>
          <div class="card border-0 shadow-sm text-center py-2 px-1 <%= params[:status] == s ? "border border-#{status_colors[s]} border-2" : "" %>">
            <div class="h4 mb-0 fw-bold text-<%= status_colors[s] %>"><%= status_counts[s] || 0 %></div>
            <div class="small text-muted"><%= s.capitalize %></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
  <% if @purchase_orders.empty? %>
    <div class="text-center py-5 border rounded bg-white shadow-sm">
      <i class="bi bi-inbox display-1 text-muted opacity-25"></i>
      <p class="text-muted mt-3">No hay órdenes de compra con estos filtros.</p>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm overflow-hidden">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light small text-muted text-uppercase">
          <tr>
            <th class="ps-4">N° Orden</th>
            <th>Proveedor</th>
            <th class="text-center">Estado</th>
            <th class="text-center">Líneas</th>
            <th class="text-end">Total Estimado</th>
            <th>Emisión</th>
            <th>Entrega Esp.</th>
            <th class="pe-4 text-end">Acción</th>
          </tr>
        </thead>
        <tbody>
          <% @purchase_orders.each do |po| %>
            <tr id="purchase_order_<%= po.id %>">
              <td class="ps-4 fw-bold text-dark"><%= po.number %></td>
              <td><%= po.provider.name %></td>
              <td class="text-center">
                <%= render "purchase_orders/status_badge", status: po.status %>
              </td>
              <td class="text-center text-muted small"><%= po.purchase_order_items.length %></td>
              <td class="text-end fw-bold text-dark small">
                <%= number_to_currency(po.total_amount, unit: "₡", delimiter: ".", separator: ",") %>
              </td>
              <td class="small text-muted"><%= po.issued_date&.strftime("%d/%m/%Y") || "—" %></td>
              <td class="small text-muted"><%= po.delivery_deadline&.strftime("%d/%m/%Y") || "—" %></td>
              <td class="pe-4 text-end">
                <%= link_to "Ver →", purchase_order_path(po), class: "btn btn-outline-primary btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>