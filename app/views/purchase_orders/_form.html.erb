<%# app/views/purchase_orders/_form.html.erb %>
<%= form_with(model: purchase_order,
              data: { controller: "purchase-order-calculator" }) do |f| %>
  <%# ── Cabecera ── %>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <p class="small fw-bold text-muted mb-1">Proveedor</p>
      <p class="fs-5 fw-bold mb-0">
        <i class="bi bi-building me-1 text-secondary"></i>
        <%= purchase_order.provider.name %>
      </p>
    </div>
    <div class="col-md-3">
      <p class="small fw-bold text-muted mb-1">N° OC</p>
      <p class="fs-6 fw-bold font-monospace mb-0 text-primary">
        <%= purchase_order.number %>
      </p>
    </div>
    <div class="col-md-3">
      <%= f.label :delivery_deadline, "Fecha Límite de Entrega",
            class: "small fw-bold text-muted mb-1 d-block" %>
      <%= f.date_field :delivery_deadline, class: "form-control form-control-sm" %>
    </div>
  </div>
  <%# ── Tabla de ítems ── %>
  <div class="table-responsive rounded border">
    <table class="table table-sm align-middle mb-0">
      <thead class="table-dark">
        <tr>
          <th class="ps-3 py-2">Ítem</th>
          <th class="py-2" width="90">Cant.</th>
          <th class="py-2" width="110">Unidad</th>
          <th class="py-2" width="140">Costo Unit.</th>
          <th class="py-2 text-end pe-3" width="120">Subtotal</th>
          <th class="py-2" width="40"></th>
        </tr>
      </thead>
      <tbody>
        <%= f.fields_for :purchase_order_items do |item_f| %>
          <%= item_f.hidden_field :_destroy,
                data: { purchase_order_calculator_target: "destroyCheckbox" } %>
          <tr data-purchase-order-calculator-target="row">
            <td class="ps-3 py-2">
              <div class="fw-semibold lh-sm">
                <%= item_f.object.variant.name %>
              </div>
              <% if item_f.object.description_override.present? %>
                <small class="text-muted">
                  <%= item_f.object.description_override %>
                </small>
              <% end %>
            </td>
            <td>
              <%= item_f.number_field :quantity,
                    min: 0, step: :any,
                    class: "form-control form-control-sm text-center",
                    data: {
                      purchase_order_calculator_target: "qtyInput",
                      action: "input->purchase-order-calculator#calculate"
                    } %>
            </td>
            <td>
              <%= item_f.select :unit,
                    [["und", "und"], ["rol", "rol"], ["mt", "mt"],
                     ["kg", "kg"], ["m²", "m2"], ["lt", "lt"]],
                    {},
                    class: "form-select form-select-sm",
                    data: {
                      purchase_order_calculator_target: "unitSelect",
                      action: "change->purchase-order-calculator#onUnitChange"
                    } %>
            </td>
            <td>
              <div class="input-group input-group-sm">
                <span class="input-group-text text-muted">₡</span>
                <%= item_f.number_field :unit_cost,
                      min: 0, step: :any,
                      class: "form-control form-control-sm",
                      data: {
                        purchase_order_calculator_target: "costInput",
                        action: "input->purchase-order-calculator#calculate"
                      } %>
              </div>
            </td>
            <td class="text-end pe-3 fw-bold"
                data-purchase-order-calculator-target="rowTotal">
              ₡0,00
            </td>
            <td class="text-center">
              <button type="button"
                      class="btn btn-sm btn-link text-danger p-0"
                      title="Quitar ítem"
                      data-action="click->purchase-order-calculator#removeItem">
                <i class="bi bi-x-circle"></i>
              </button>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="table-light border-top border-2">
        <tr>
          <td colspan="4" class="text-end fw-bold pe-3 py-2">Total Estimado:</td>
          <td class="text-end pe-3 fw-bold text-success fs-6 py-2"
              data-purchase-order-calculator-target="grandTotal">
            ₡0,00
          </td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <%# ── Notas ── %>
  <div class="mt-3">
    <%= f.label :notes, "Notas internas", class: "small fw-bold text-muted mb-1 d-block" %>
    <%= f.text_area :notes, rows: 2,
          class: "form-control form-control-sm",
          placeholder: "Observaciones, referencias, condiciones de entrega..." %>
  </div>
  <%# ── Footer de acciones ── %>
  <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-3">
    <% if purchase_order.persisted? && purchase_order.status == "borrador" %>
      <button type="button"
              class="btn btn-outline-danger btn-sm"
              data-controller="purchase-order-discard"
              data-purchase-order-discard-url-value="<%= purchase_order_path(purchase_order) %>"
        data-purchase-order-discard-confirm-value="¿Descartar este borrador? Se eliminará permanentemente."
        data-action="click->purchase-order-discard#discard">
        <i class="bi bi-trash me-1"></i> Descartar Borrador
      </button>
    <% else %>
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="click->print#closeModal">
        <i class="bi bi-x me-1"></i> Cerrar
      </button>
    <% end %>
    <div class="d-flex gap-2">
      <%= f.submit "Guardar Borrador",
            class: "btn btn-outline-primary px-4",
            name: "commit",
            value: "Guardar Borrador" %>
      <%= f.submit "Confirmar OC →",
            class: "btn btn-success px-4 fw-bold",
            name: "commit",
            value: "Confirmar OC",
            data: { turbo_confirm: "¿Confirmar esta Orden de Compra? Ya no podrá editarse." } %>
    </div>
  </div>
<% end %>