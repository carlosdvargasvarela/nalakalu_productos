<%# app/views/purchase_orders/_modal_edit.html.erb %>
<%= turbo_frame_tag "remote_modal" do %>
  <div class="modal fade show d-block"
       tabindex="-1"
       style="background: rgba(0,0,0,0.55); backdrop-filter: blur(2px);">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content shadow border-0 rounded-3 overflow-hidden">
        <div class="modal-header bg-dark text-white px-4 py-3">
          <div>
            <h5 class="modal-title mb-0">
              <i class="bi bi-pencil-square me-2"></i>
              Borrador OC
              <span class="badge bg-warning text-dark ms-2 font-monospace fw-bold">
                <%= purchase_order.number %>
              </span>
            </h5>
            <small class="text-white-50">
              <%= purchase_order.provider.name %> ·
              Creada <%= purchase_order.created_at.strftime("%d/%m/%Y %H:%M") %>
            </small>
          </div>
          <button type="button"
                  class="btn-close btn-close-white ms-auto"
                  data-action="click->print#closeModal"
            title="Cerrar sin guardar">
          </button>
        </div>
        <div class="modal-body p-4 bg-light">
          <%= render "form", purchase_order: purchase_order %>
        </div>
      </div>
    </div>
  </div>
<% end %>