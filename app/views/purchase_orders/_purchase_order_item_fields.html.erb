<%# app/views/purchase_orders/_purchase_order_item_fields.html.erb %>
<tr class="po-item-row border-bottom">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy, class: "destroy-flag" %>
  <td class="ps-4 py-3">
    <div class="fw-bold small"><%= f.object.supplier_item&.name %></div>
    <% if f.object.specifications.present? %>
      <div class="mt-1">
        <% f.object.specifications.each do |k, v| %>
          <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle rounded-pill me-1">
            <%= k %>: <%= v %>
          </span>
        <% end %>
      </div>
    <% end %>
    <%= f.hidden_field :supplier_item_id %>
    <%= f.hidden_field :specifications %>
    <div class="mt-1">
      <%= f.text_field :description_override,
            class: "form-control form-control-sm border-1 text-muted",
            placeholder: "Descripción personalizada (opcional)" %>
    </div>
  </td>
  <td class="text-center">
    <%= f.number_field :quantity,
          class: "form-control form-control-sm text-center border-2 fw-bold",
          step: "0.01", min: "0.01" %>
  </td>
  <td class="text-center">
    <span class="text-muted small"><%= f.object.unit %></span>  
  </td>
  <td class="text-center">
    <div class="input-group input-group-sm">
      <span class="input-group-text">₡</span>
      <%= f.number_field :unit_cost,
            class: "form-control text-end border-2",
            step: "1", min: "0" %>
    </div>
  </td>
  <td class="text-end pe-4 fw-bold text-primary">
    ₡<%= number_with_delimiter(f.object.total.to_i, delimiter: ".") %>
  </td>
  <td class="text-center">
    <button type="button"
            class="btn btn-sm btn-outline-danger border-0"
            onclick="this.closest('tr').querySelector('.destroy-flag').value='1'; this.closest('tr').style.opacity='0.3'">
      <i class="bi bi-trash"></i>
    </button>
  </td>
</tr>