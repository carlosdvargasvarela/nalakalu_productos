<%# app/views/purchase_orders/edit.html.erb %>
<div class="container-fluid mt-4 pb-5" style="max-width: 1100px;">
  <%# Breadcrumb %>
  <div class="mb-3 d-flex align-items-center gap-2">
    <%= link_to purchase_order_path(@purchase_order), class: "text-decoration-none text-muted small" do %>
      <i class="bi bi-arrow-left me-1"></i>Volver a <%= @purchase_order.number %>
    <% end %>
    <span class="text-muted small">·</span>
    <span class="small text-muted">Editar Orden</span>
  </div>
  <%# Header %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0"><%= @purchase_order.number %></h2>
      <p class="text-muted small mb-0">
        Proveedor: <strong><%= @purchase_order.provider.name %></strong>
        · Emitida: <%= @purchase_order.issued_date&.strftime("%d/%m/%Y") %>
      </p>
    </div>
    <%= render "purchase_orders/status_badge", status: @purchase_order.status %>
  </div>
  <%# Aviso: solo borradores %>
  <% unless @purchase_order.status == "borrador" %>
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
      <i class="bi bi-exclamation-triangle-fill"></i>
      <span>Esta orden ya fue enviada. Solo se pueden editar órdenes en estado <strong>Borrador</strong>.</span>
    </div>
  <% end %>
  <%= form_with model: @purchase_order, method: :patch,
        data: { controller: "po-editor", turbo: false } do |f| %>
    <div class="row g-4">
      <%# ══════════════════════════════════════════
          COLUMNA PRINCIPAL — LÍNEAS
      ══════════════════════════════════════════ %>
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm overflow-hidden">
          <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">
              <i class="bi bi-list-ul me-2 text-secondary"></i>Líneas de la Orden
            </h6>
            <span class="small text-muted">
              <%= @items.size %> ítem<%= @items.size == 1 ? "" : "s" %>
            </span>
          </div>
          <%# Cabecera de columnas %>
          <div class="d-flex px-4 py-2 bg-light border-bottom small text-muted text-uppercase fw-bold">
            <div style="flex: 3;">Material / Pieza</div>
            <div style="flex: 1; text-align: center;">Cantidad</div>
            <div style="flex: 0.7; text-align: center;">U/M</div>
            <div style="flex: 1.2; text-align: right;">Costo Unit.</div>
            <div style="flex: 1; text-align: right;">Total</div>
            <div style="width: 40px;"></div>
          </div>
          <%# Filas de ítems %>
          <div data-po-editor-target="itemsContainer">
            <%= f.fields_for :purchase_order_items, @items do |item_f| %>
              <% item = item_f.object %>
              <div class="d-flex px-4 py-3 border-bottom align-items-center gap-2"
                   data-po-editor-target="itemRow">
                <%= item_f.hidden_field :id %>
                <%= item_f.hidden_field :supplier_item_id %>
                <%= item_f.hidden_field :specifications %>
                <%= item_f.hidden_field :_destroy, value: false,
                      data: { "po-editor-target": "destroyCheck" } %>
                <%# Descripción %>
                <div style="flex: 3;" class="pe-2">
                  <div class="fw-bold text-dark small">
                    <%= item.supplier_item&.name %>
                  </div>
                  <% if item.supplier_item&.sku.present? %>
                    <code class="small text-muted bg-transparent p-0">
                      <%= item.supplier_item.sku %>
                    </code>
                  <% end %>
                  <% if item.specifications.present? %>
                    <div class="d-flex flex-wrap gap-1 mt-1">
                      <% item.specifications.each do |k, v| %>
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle fw-normal"
                              style="font-size: 0.65rem;">
                          <%= k %>: <strong><%= v %></strong>
                        </span>
                      <% end %>
                    </div>
                  <% end %>
                  <div class="mt-1">
                    <%= item_f.text_field :description_override,
                          class: "form-control form-control-sm text-muted border-0 bg-light px-2",
                          placeholder: "Descripción personalizada (opcional)" %>
                  </div>
                </div>
                <%# Cantidad %>
                <div style="flex: 1; text-align: center;">
                  <%= item_f.number_field :quantity,
                        class: "form-control form-control-sm text-center fw-bold",
                        step: 0.01, min: 0.01,
                        data: {
                          "po-editor-target": "quantity",
                          action: "input->po-editor#calculate"
                        } %>
                </div>
                <%# U/M %>
                <div style="flex: 0.7; text-align: center;">
                  <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle fw-normal">
                    <%= item.unit %>
                  </span>
                </div>
                <%# Costo Unitario %>
                <div style="flex: 1.2;">
                  <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0 text-muted small">₡</span>
                    <%= item_f.number_field :unit_cost,
                          class: "form-control form-control-sm border-start-0 text-end",
                          step: 0.01, min: 0, placeholder: "0.00",
                          data: {
                            "po-editor-target": "cost",
                            action: "input->po-editor#calculate"
                          } %>
                  </div>
                </div>
                <%# Total de línea %>
                <div style="flex: 1; text-align: right;">
                  <span class="small fw-bold text-dark"
                        data-po-editor-target="lineTotal">
                    <%= number_to_currency(item.total, unit: "₡", delimiter: ".", separator: ",") %>
                  </span>
                </div>
                <%# Eliminar %>
                <div style="width: 40px; text-align: center;">
                  <button type="button"
                          class="btn btn-sm btn-outline-danger border-0 p-1"
                          title="Eliminar línea"
                          data-action="click->po-editor#removeLine">
                    <i class="bi bi-trash" style="font-size: 0.8rem;"></i>
                  </button>
                </div>
              </div>
            <% end %>
          </div>
          <%# Footer con Total %>
          <div class="d-flex justify-content-between align-items-center px-4 py-3 bg-light">
            <span class="small text-muted">
              <i class="bi bi-info-circle me-1"></i>
              Los cambios no se guardan hasta presionar <strong>Guardar</strong>.
            </span>
            <div class="text-end">
              <span class="small text-muted text-uppercase fw-bold me-3">Total Estimado</span>
              <span class="h5 fw-bold text-dark mb-0"
                    data-po-editor-target="grandTotal">
                <%= number_to_currency(@purchase_order.total_amount, unit: "₡", delimiter: ".", separator: ",") %>
              </span>
            </div>
          </div>
        </div>
      </div>
      <%# ══════════════════════════════════════════
          COLUMNA LATERAL — METADATOS + GUARDAR
      ══════════════════════════════════════════ %>
      <div class="col-lg-4">
        <div style="position: sticky; top: 1rem;">
          <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-2">
              <span class="small fw-bold text-muted text-uppercase">
                <i class="bi bi-info-circle me-1"></i>Detalles de la Orden
              </span>
            </div>
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase mb-1">Proveedor</label>
                <div class="fw-bold text-dark"><%= @purchase_order.provider.name %></div>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase mb-1">Fecha de Emisión</label>
                <div class="text-dark small"><%= @purchase_order.issued_date&.strftime("%d/%m/%Y") %></div>
              </div>
              <div class="mb-3">
                <%= f.label :delivery_deadline, "Fecha Máx. de Entrega",
                      class: "form-label small fw-bold text-muted text-uppercase mb-1" %>
                <%= f.date_field :delivery_deadline,
                      class: "form-control form-control-sm" %>
              </div>
              <div class="mb-0">
                <%= f.label :notes, "Notas al Proveedor",
                      class: "form-label small fw-bold text-muted text-uppercase mb-1" %>
                <%= f.text_area :notes,
                      class: "form-control form-control-sm",
                      rows: 3,
                      placeholder: "Instrucciones especiales, condiciones de entrega..." %>
              </div>
            </div>
          </div>
          <%# Acciones %>
          <div class="d-grid gap-2">
            <%= f.submit "Guardar Cambios",
                  class: "btn btn-primary fw-bold py-2" %>
            <%= link_to purchase_order_path(@purchase_order),
                  class: "btn btn-outline-secondary py-2" do %>
              <i class="bi bi-x me-1"></i>Cancelar
            <% end %>
          </div>
          <%# Aviso de seguridad %>
          <div class="mt-3 p-3 bg-warning-subtle border border-warning-subtle rounded small text-warning-emphasis">
            <i class="bi bi-shield-exclamation me-1"></i>
            Solo se pueden editar órdenes en estado <strong>Borrador</strong>.
            Una vez enviada, los cambios deben coordinarse directamente con el proveedor.
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>