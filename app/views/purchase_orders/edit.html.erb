<%# app/views/purchase_orders/edit.html.erb %>
<div class="container-fluid mt-4 pb-5" style="max-width: 1100px;">
  <div class="mb-3">
    <%= link_to purchase_order_path(@purchase_order), class: "text-decoration-none text-muted small" do %>
      <i class="bi bi-arrow-left me-1"></i>Volver a <%= @purchase_order.number %>
    <% end %>
  </div>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">Editar <%= @purchase_order.number %></h2>
      <p class="text-muted small mb-0">Proveedor: <strong><%= @purchase_order.provider.name %></strong></p>
    </div>
    <%= render "purchase_orders/status_badge", status: @purchase_order.status %>
  </div>
  <%= form_with model: @purchase_order, method: :patch,
        data: { controller: "po-editor", turbo: false } do |f| %>
    <div class="row g-4">
      <%# ── COLUMNA PRINCIPAL: ÍTEMS ── %>
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm overflow-hidden">
          <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">
              <i class="bi bi-list-ul me-2 text-secondary"></i>Líneas de la Orden
            </h6>
            <span class="small text-muted">Ajusta cantidades y costos antes de enviar</span>
          </div>
          <%# Cabecera de columnas %>
          <div class="row g-0 px-4 py-2 bg-light border-bottom small text-muted text-uppercase fw-bold">
            <div class="col-5">Material / Pieza</div>
            <div class="col-2 text-center">Cantidad</div>
            <div class="col-2 text-center">U/M</div>
            <div class="col-2 text-end">Costo Unit.</div>
            <div class="col-1 text-end">Total</div>
          </div>
          <%= f.fields_for :purchase_order_items, @items do |item_f| %>
            <% item = item_f.object %>
            <div class="row g-0 px-4 py-3 border-bottom align-items-center"
                 data-po-editor-target="itemRow">
              <%= item_f.hidden_field :id %>
              <%# Descripción %>
              <div class="col-5 pe-3">
                <div class="fw-bold text-dark small"><%= item.supplier_item&.name %></div>
                <code class="small text-muted bg-transparent p-0">
                  <%= item.supplier_item&.sku %>
                </code>
                <% if item.specifications.present? %>
                  <div class="d-flex flex-wrap gap-1 mt-1">
                    <% item.specifications.each do |k, v| %>
                      <span class="badge bg-light text-dark border fw-normal" style="font-size: 0.68rem;">
                        <span class="text-muted"><%= k %>:</span> <%= v %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <%# Cantidad %>
              <div class="col-2 text-center">
                <%= item_f.number_field :quantity,
                      class: "form-control form-control-sm text-center fw-bold",
                      step: 0.01, min: 0,
                      data: { "po-editor-target": "quantity", action: "input->po-editor#calculate" } %>
              </div>
              <%# U/M %>
              <div class="col-2 text-center">
                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle fw-normal">
                  <%= item.unit %>
                </span>
              </div>
              <%# Costo Unitario %>
              <div class="col-2">
                <div class="input-group input-group-sm">
                  <span class="input-group-text bg-light border-end-0 text-muted small">₡</span>
                  <%= item_f.number_field :unit_cost,
                        class: "form-control form-control-sm border-start-0 text-end",
                        step: 0.01, min: 0, placeholder: "0.00",
                        data: { "po-editor-target": "cost", action: "input->po-editor#calculate" } %>
                </div>
              </div>
              <%# Total de línea (calculado) %>
              <div class="col-1 text-end">
                <span class="small fw-bold text-dark"
                      data-po-editor-target="lineTotal">
                  <%= number_to_currency(item.total, unit: "₡", delimiter: ".", separator: ",") %>
                </span>
              </div>
              <%# Eliminar (oculto, se activa con el botón) %>
              <%= item_f.hidden_field :_destroy, value: false,
                    data: { "po-editor-target": "destroyCheck" } %>
            </div>
          <% end %>
          <%# Footer con Total %>
          <div class="d-flex justify-content-between align-items-center px-4 py-3 bg-light">
            <span class="small text-muted">
              <%= @items.size %> línea<%= @items.size == 1 ? "" : "s" %>
            </span>
            <div class="text-end">
              <span class="small text-muted text-uppercase fw-bold me-3">Total Estimado</span>
              <span class="h5 fw-bold text-dark mb-0"
                    data-po-editor-target="grandTotal">
                <%= number_to_currency(@purchase_order.total_amount, unit: "₡", delimiter: ".", separator: ",") %>
              </span>
            </div>
          </div>
        </div>
      </div>
      <%# ── COLUMNA LATERAL: METADATOS ── %>
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
          <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-bold">
              <i class="bi bi-info-circle me-2 text-secondary"></i>Detalles de la Orden
            </h6>
          </div>
          <div class="card-body">
            <div class="mb-3">
              <label class="form-label small fw-bold text-muted text-uppercase">Proveedor</label>
              <div class="fw-bold text-dark"><%= @purchase_order.provider.name %></div>
            </div>
            <div class="mb-3">
              <label class="form-label small fw-bold text-muted text-uppercase">Fecha de Emisión</label>
              <div class="text-dark"><%= @purchase_order.issued_date&.strftime("%d/%m/%Y") %></div>
            </div>
            <div class="mb-3">
              <%= f.label :delivery_deadline, "Fecha Máx. de Entrega",
                    class: "form-label small fw-bold text-muted text-uppercase" %>
              <%= f.date_field :delivery_deadline,
                    class: "form-control form-control-sm" %>
            </div>
            <div class="mb-0">
              <%= f.label :notes, "Notas al Proveedor",
                    class: "form-label small fw-bold text-muted text-uppercase" %>
              <%= f.text_area :notes,
                    class: "form-control form-control-sm",
                    rows: 3,
                    placeholder: "Instrucciones especiales, condiciones de entrega..." %>
            </div>
          </div>
        </div>
        <%# Acciones %>
        <div class="d-grid gap-2">
          <%= f.submit "Guardar Cambios",
                class: "btn btn-primary fw-bold py-2" %>
          <%= link_to purchase_order_path(@purchase_order),
                class: "btn btn-outline-secondary py-2" do %>
            Cancelar
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>