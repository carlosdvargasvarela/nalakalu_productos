<div class="card auth-card p-4">
  <div class="card-body">
    <h4 class="card-title mb-4 fw-bold text-center">Iniciar Sesión</h4>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), data: { turbo: false }) do |f| %>
      <div class="mb-3">
        <%= f.label :email, "Correo Electrónico", class: "form-label small fw-bold text-muted" %>
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", 
              class: "form-control border-start-0 ps-0", placeholder: "nombre@ejemplo.com" %>
        </div>
      </div>
      <div class="mb-3">
        <div class="d-flex justify-content-between">
          <%= f.label :password, "Contraseña", class: "form-label small fw-bold text-muted" %>
          <%- if devise_mapping.recoverable? %>
            <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: "small text-decoration-none" %>
          <% end %>
        </div>
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock text-muted"></i></span>
          <%= f.password_field :password, autocomplete: "current-password", 
              class: "form-control border-start-0 ps-0", placeholder: "••••••••" %>
        </div>
      </div>
      <% if devise_mapping.rememberable? %>
        <div class="mb-4 form-check">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, "Recordarme en este equipo", class: "form-check-label small text-muted" %>
        </div>
      <% end %>
      <div class="d-grid">
        <%= f.submit "Entrar al Sistema", class: "btn btn-primary btn-lg fw-bold shadow-sm py-2" %>
      </div>
    <% end %>
  </div>
</div>