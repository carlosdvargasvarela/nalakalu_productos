<div class="card auth-card p-4">
  <div class="card-body text-center">
    <h4 class="fw-bold mb-3">¿Problemas para entrar?</h4>
    <p class="text-muted small mb-4">Ingresa tu correo y te enviaremos instrucciones para restablecer tu contraseña.</p>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="mb-4 text-start">
        <%= f.label :email, "Correo Electrónico", class: "form-label small fw-bold text-muted" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", placeholder: "tu@correo.com" %>
      </div>
      <div class="d-grid gap-2">
        <%= f.submit "Enviar instrucciones", class: "btn btn-primary fw-bold py-2" %>
        <%= link_to "Volver al inicio", new_session_path(resource_name), class: "btn btn-link btn-sm text-decoration-none text-muted" %>
      </div>
    <% end %>
  </div>
</div>