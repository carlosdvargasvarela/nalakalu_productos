<div class="container-fluid py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item">
        <%= link_to "Variantes", variants_path, class: "text-decoration-none" %>
      </li>
      <li class="breadcrumb-item">
        <%= link_to @variant.name, @variant, class: "text-decoration-none" %>
      </li>
      <li class="breadcrumb-item active fw-bold">Editar</li>
    </ol>
  </nav>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0 text-dark">
        Editando: <span class="text-primary"><%= @variant.name %></span>
      </h2>
      <p class="text-muted small mb-0">
        Tipo: <strong><%= @variant.variant_type.name %></strong> &middot;
        Código: <code><%= @variant.code %></code>
      </p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to @variant, class: "btn btn-outline-secondary rounded-pill px-4" do %>
        <i class="bi bi-eye me-2"></i>Ver Variante
      <% end %>
    </div>
  </div>
  <%= render "form", variant: @variant %>
</div>