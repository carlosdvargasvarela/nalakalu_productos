<%= turbo_frame_tag "variant_workspace" do %>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white py-3 border-bottom">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 small">
          <li class="breadcrumb-item">
            <%= link_to "Variantes", variants_path, class: "text-decoration-none" %>
          </li>
          <li class="breadcrumb-item">
            <%= link_to @variant.display_name.presence || @variant.name,
                variants_path(selected_id: @variant.id),
                data: { turbo_frame: "variant_workspace" },
                class: "text-decoration-none" %>
          </li>
          <li class="breadcrumb-item active fw-bold">Editar</li>
        </ol>
      </nav>
      <h5 class="fw-bold mb-0 mt-2">
        Editando: <span class="text-primary">
          <%= @variant.display_name.presence || @variant.name %>
        </span>
      </h5>
      <p class="text-muted small mb-0">
        Tipo: <strong><%= @variant.variant_type.name %></strong> ·
        Código: <code><%= @variant.code %></code>
      </p>
    </div>
    <div class="card-body p-4">
      <%= render "form", variant: @variant %>
    </div>
  </div>
<% end %>