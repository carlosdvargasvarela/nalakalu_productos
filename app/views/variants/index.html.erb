<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><i class="bi bi-palette"></i> Variantes</h1>
  <%= link_to new_variant_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-circle"></i> Nueva Variante
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-dark">
          <tr>
            <th>Tipo</th>
            <th>Nombre</th>
            <th>Código</th>
            <th>Proveedor</th>
            <th>SKU Proveedor</th>
            <th>Costo</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @variants.each do |variant| %>
            <tr>
              <td><span class="badge bg-secondary"><%= variant.variant_type.name %></span></td>
              <td><strong><%= variant.name %></strong></td>
              <td><code class="bg-light p-1"><%= variant.code %></code></td>
              <td><%= variant.provider.name %></td>
              <td><%= variant.provider_sku %></td>
              <td>
                <% if variant.cost.present? %>
                  <%= number_to_currency(variant.cost, unit: "$") %>
                <% else %>
                  <span class="text-muted">-</span>
                <% end %>
              </td>
              <td>
                <% if variant.active %>
                  <span class="badge bg-success">Activo</span>
                <% else %>
                  <span class="badge bg-secondary">Inactivo</span>
                <% end %>
              </td>
              <td class="text-end">
                <%= link_to variant, class: "btn btn-sm btn-info" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
                <%= link_to edit_variant_path(variant), class: "btn btn-sm btn-warning" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= button_to variant, method: :delete, class: "btn btn-sm btn-danger", 
                    data: { turbo_confirm: "¿Está seguro?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>