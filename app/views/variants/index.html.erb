<div class="container-fluid py-4" data-controller="variant-filters">
  <%# ── HEADER ── %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h4 class="fw-bold mb-0 text-dark">Variantes</h4>
      <p class="text-muted mb-0 small">
        <%= @stats[:types] %> tipos ·
        <span class="text-success fw-bold"><%= @stats[:active] %> activas</span>
        de <%= @stats[:total] %> totales
        <% if @stats[:no_rules] > 0 %>
          · <span class="text-warning fw-bold">
            <i class="bi bi-exclamation-circle me-1"></i><%= @stats[:no_rules] %> sin regla
          </span>
        <% end %>
      </p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to new_variant_path,
          data: { turbo_frame: "variant_workspace" },
          class: "btn btn-primary shadow-sm rounded-pill px-4 fw-bold" do %>
        <i class="bi bi-plus-lg me-2"></i>Nueva Variante
      <% end %>
    </div>
  </div>
  <% if @variants.empty? && !params[:search].present? && !params[:type_id].present? && !params[:status].present? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-palette d-block fs-1 mb-3 opacity-25"></i>
      <p class="fw-bold">No hay variantes registradas aún.</p>
      <%= link_to new_variant_path, class: "btn btn-primary rounded-pill px-4" do %>
        <i class="bi bi-plus-lg me-2"></i>Crear primera variante
      <% end %>
    </div>
  <% else %>
    <div class="row g-4" style="min-height: 70vh;">
      <%# ── PANEL IZQUIERDO ── %>
      <div class="col-lg-4 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 d-flex flex-column">
          <%# ── Filtros (server-side GET) ── %>
          <div class="card-header bg-white py-3 border-bottom flex-shrink-0">
            <%= form_with url: variants_path, method: :get,
                data: { turbo_action: "advance" } do |f| %>
              <div class="input-group input-group-sm mb-2">
                <span class="input-group-text bg-light border-0 rounded-start-3">
                  <i class="bi bi-search text-muted"></i>
                </span>
                <%= f.text_field :search,
                    value: params[:search],
                    class: "form-control bg-light border-0 shadow-none rounded-end-3",
                    placeholder: "Buscar variante...",
                    autocomplete: "off",
                    data: { action: "input->variant-filters#debounceSubmit" } %>
              </div>
              <div class="d-flex gap-2">
                <%= f.select :type_id,
                    VariantType.order(:name).map { |vt| [vt.name, vt.id] },
                    { include_blank: "Todos los tipos", selected: params[:type_id] },
                    class: "form-select form-select-sm bg-light border-0 shadow-none rounded-3",
                    data: { action: "change->variant-filters#submit" } %>
                <%= f.select :status,
                    [["Activas","active"],["Inactivas","inactive"],["Sin regla","no_rule"]],
                    { include_blank: "Todos", selected: params[:status] },
                    class: "form-select form-select-sm bg-light border-0 shadow-none rounded-3",
                    data: { action: "change->variant-filters#submit" } %>
              </div>
              <%= f.hidden_field :selected_id, value: params[:selected_id] %>
            <% end %>
          </div>
          <%# ── Lista agrupada por tipo ── %>
          <div class="card-body p-0 overflow-auto flex-grow-1" style="max-height: calc(100vh - 360px);">
            <% if @variants.empty? %>
              <div class="text-center py-5 text-muted">
                <i class="bi bi-funnel d-block fs-2 mb-2 opacity-25"></i>
                <p class="small fw-bold mb-0">Sin resultados para estos filtros.</p>
              </div>
            <% else %>
              <% @variants.group_by(&:variant_type).each do |type, variants| %>
                <div class="variant-type-group" data-type-id="<%= type.id %>">
                  <div class="px-3 py-2 bg-light border-bottom sticky-top">
                    <span class="small fw-bold text-muted text-uppercase">
                      <i class="bi bi-tags me-1 text-info"></i><%= type.name %>
                    </span>
                    <span class="badge bg-info bg-opacity-10 text-info rounded-pill ms-1"
                          style="font-size: 0.6rem;">
                      <%= variants.count %>
                    </span>
                  </div>
                  <% variants.each do |variant| %>
                    <%= render "variants/variant_list_item",
                        variant: variant,
                        selected: @selected&.id == variant.id %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
          <%# ── Paginación ── %>
          <% if @pagy.pages > 1 %>
            <% prev_page = (@pagy.page > 1) ? (@pagy.page - 1) : nil %>
            <% next_page = (@pagy.page < @pagy.pages) ? (@pagy.page + 1) : nil %>
            <div class="px-3 py-2 border-top bg-white d-flex justify-content-between align-items-center flex-wrap gap-1">
              <small class="text-muted">
                <%= @pagy.count %> · pág. <%= @pagy.page %>/<%= @pagy.pages %>
              </small>
              <nav>
                <ul class="pagination pagination-sm mb-0 gap-1">
                  <% if prev_page %>
                    <li class="page-item">
                      <%= link_to variants_path(params.permit(:search, :type_id, :status, :selected_id).merge(page: prev_page)),
                          class: "page-link rounded-pill px-2" do %>
                        <i class="bi bi-chevron-left"></i>
                      <% end %>
                    </li>
                  <% end %>
                  <% pagy_pages = ([@pagy.page - 1, 1].max..[@pagy.page + 1, @pagy.pages].min) %>
                  <% if pagy_pages.first > 1 %>
                    <li class="page-item">
                      <%= link_to "1", variants_path(params.permit(:search, :type_id, :status, :selected_id).merge(page: 1)),
                          class: "page-link rounded-pill px-2" %>
                    </li>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                  <% end %>
                  <% pagy_pages.each do |p| %>
                    <li class="page-item <%= 'active' if p == @pagy.page %>">
                      <%= link_to p, variants_path(params.permit(:search, :type_id, :status, :selected_id).merge(page: p)),
                          class: "page-link rounded-pill px-2" %>
                    </li>
                  <% end %>
                  <% if pagy_pages.last < @pagy.pages %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                    <li class="page-item">
                      <%= link_to @pagy.pages, variants_path(params.permit(:search, :type_id, :status, :selected_id).merge(page: @pagy.pages)),
                          class: "page-link rounded-pill px-2" %>
                    </li>
                  <% end %>
                  <% if next_page %>
                    <li class="page-item">
                      <%= link_to variants_path(params.permit(:search, :type_id, :status, :selected_id).merge(page: next_page)),
                          class: "page-link rounded-pill px-2" do %>
                        <i class="bi bi-chevron-right"></i>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </nav>
            </div>
          <% end %>
          <%# ── Importador CSV ── %>
          <div class="card-footer bg-white border-top p-3 flex-shrink-0">
            <%= form_with url: import_variants_path, multipart: true, local: true do |f| %>
              <p class="small text-muted fw-bold mb-2">
                <i class="bi bi-file-earmark-spreadsheet me-1 text-info"></i>Importar CSV
              </p>
              <div class="input-group input-group-sm shadow-sm">
                <%= f.file_field :file,
                    class: "form-control rounded-start-pill small", accept: ".csv" %>
                <button class="btn btn-info text-white rounded-end-pill fw-bold px-3" type="submit">
                  <i class="bi bi-cloud-upload"></i>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <%# ── PANEL DERECHO (Turbo Frame) ── %>
      <div class="col-lg-8 col-xl-9">
        <%= turbo_frame_tag "variant_workspace" do %>
          <% if @selected %>
            <%= render "variants/show_panel",
                variant: @selected,
                compatible_products: compatible_products_for(@selected) %>
          <% else %>
            <%= render "variants/workspace_placeholder" %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
<style>
  .variant-row-active { background-color: #f0f7ff; border-left: 3px solid #0d6efd !important; }
  .variant-row        { border-left: 3px solid transparent; transition: background 0.15s; }
  .variant-row:hover  { background-color: #f8f9fa; }
  .bg-success-soft    { background-color: #e1f6eb; }
  .bg-warning-soft    { background-color: #fff8e1; }
  .bg-secondary-soft  { background-color: #f0f2f5; }
  .x-small            { font-size: 0.72rem; }
</style>