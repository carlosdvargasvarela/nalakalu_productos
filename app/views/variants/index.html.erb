<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0 text-dark">Variantes</h1>
      <p class="text-muted mb-0">Opciones individuales disponibles para configurar productos.</p>
    </div>
    <%= link_to new_variant_path, class: "btn btn-primary shadow-sm rounded-pill px-4 fw-bold" do %>
      <i class="bi bi-plus-lg me-2"></i>Nueva Variante
    <% end %>
  </div>
  <% if @variants.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-palette d-block fs-1 mb-3 opacity-25"></i>
      <p class="fw-bold">No hay variantes registradas aún.</p>
      <%= link_to new_variant_path, class: "btn btn-primary rounded-pill px-4" do %>
        <i class="bi bi-plus-lg me-2"></i>Crear primera variante
      <% end %>
    </div>
  <% else %>
    <% @variants.group_by(&:variant_type).each do |type, variants| %>
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center gap-2">
            <div class="bg-info bg-opacity-10 p-2 rounded-3">
              <i class="bi bi-tags text-info"></i>
            </div>
            <div>
              <span class="fw-bold text-dark"><%= type.name %></span>
              <span class="text-muted small ms-2">
                <%= variants.count(&:active) %> activas · <%= variants.count %> totales
              </span>
            </div>
          </div>
          <%= link_to new_variant_path(variant_type_id: type.id),
              class: "btn btn-sm btn-outline-primary rounded-pill px-3" do %>
            <i class="bi bi-plus-lg me-1"></i>Agregar
          <% end %>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="bg-light border-bottom">
                <tr>
                  <th class="px-4 py-3 text-muted small fw-bold text-uppercase">Variante</th>
                  <th class="py-3 text-muted small fw-bold text-uppercase">Código QB</th>
                  <th class="py-3 text-muted small fw-bold text-uppercase">Propiedades</th>
                  <th class="py-3 text-muted small fw-bold text-uppercase text-center">Estado</th>
                  <th class="py-3 pe-4 text-end text-muted small fw-bold text-uppercase">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% variants.each do |variant| %>
                  <%= render "variant_row", variant: variant %>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
  <!-- Importador CSV -->
  <div class="card border-0 shadow-sm rounded-4 border-start border-4 mt-2" style="border-color: #7c3aed !important;">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h5 class="fw-bold mb-1">
            <i class="bi bi-file-earmark-spreadsheet me-2" style="color: #7c3aed;"></i>Importación Masiva
          </h5>
          <p class="text-muted small mb-1">
            Columnas requeridas:
            <code class="bg-light px-1 rounded">tipo_de_variante</code>
            <code class="bg-light px-1 rounded">nombre</code>
            <code class="bg-light px-1 rounded">codigo</code>
          </p>
          <p class="text-muted small mb-0">
            Opcionales:
            <code class="bg-light px-1 rounded">proveedor</code>
            <code class="bg-light px-1 rounded">sku_proveedor</code>
            <code class="bg-light px-1 rounded">costo</code>
          </p>
        </div>
        <div class="col-md-4 mt-3 mt-md-0">
          <%= form_with url: import_variants_path, multipart: true, local: true do |f| %>
            <div class="input-group shadow-sm">
              <%= f.file_field :file, class: "form-control rounded-start-pill small", accept: ".csv" %>
              <button class="btn text-white rounded-end-pill fw-bold px-3"
                      style="background-color: #7c3aed;" type="submit">
                <i class="bi bi-cloud-upload me-1"></i>Importar
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .bg-success-soft   { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
  .x-small { font-size: 0.7rem; }
</style>