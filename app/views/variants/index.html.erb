<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0 text-dark">Variantes</h1>
      <p class="text-muted mb-0">Opciones individuales disponibles para configurar productos.</p>
    </div>
    <%= link_to new_variant_path, class: "btn btn-primary shadow-sm rounded-pill px-4 fw-bold" do %>
      <i class="bi bi-plus-lg me-2"></i>Nueva Variante
    <% end %>
  </div>
  <% if @variants.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-palette d-block fs-1 mb-3 opacity-25"></i>
      <p class="fw-bold">No hay variantes registradas aún.</p>
      <%= link_to new_variant_path, class: "btn btn-primary rounded-pill px-4" do %>
        <i class="bi bi-plus-lg me-2"></i>Crear primera variante
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-light border-bottom">
              <tr>
                <th class="px-4 py-3 text-muted small fw-bold text-uppercase">Variante (Comercial / Técnico)</th>
                <th class="py-3 text-muted small fw-bold text-uppercase">Tipo</th>
                <th class="py-3 text-muted small fw-bold text-uppercase">Código</th>
                <th class="py-3 text-muted small fw-bold text-uppercase">Proveedor</th>
                <th class="py-3 text-muted small fw-bold text-uppercase">SKU Prov.</th>
                <th class="py-3 text-muted small fw-bold text-uppercase text-end">Costo</th>
                <th class="py-3 text-muted small fw-bold text-uppercase text-center">Estado</th>
                <th class="py-3 pe-4 text-end text-muted small fw-bold text-uppercase">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @variants.each do |variant| %>
                <tr>
                  <td class="px-4 py-3">
                    <div class="d-flex align-items-center gap-3">
                      <div class="rounded-3 p-2 flex-shrink-0" style="background-color: #f0ebff;">
                        <i class="bi bi-palette fs-5" style="color: #7c3aed;"></i>
                      </div>
                      <div>
                        <div class="fw-bold text-dark"><%= variant.display_name.presence || variant.name %></div>
                        <% if variant.display_name.present? %>
                          <div class="text-muted" style="font-size: 0.75rem;">Técnico: <%= variant.name %></div>
                        <% end %>
                      </div>
                    </div>
                  </td>
                  <td class="py-3">
                    <span class="badge bg-secondary-soft text-secondary rounded-pill px-3">
                      <%= variant.variant_type.name %>
                    </span>
                  </td>
                  <td class="py-3">
                    <code class="bg-light px-2 py-1 rounded text-dark fw-bold">
                      <%= variant.code %>
                    </code>
                  </td>
                  <td class="py-3">
                    <% if variant.provider %>
                      <%= link_to variant.provider.name, variant.provider, class: "text-decoration-none text-muted small" %>
                    <% else %>
                      <span class="text-muted small fst-italic">Interno / Genérico</span>
                    <% end %>
                  </td>
                  <td class="py-3">
                    <span class="text-muted small font-monospace">
                      <%= variant.provider_sku.presence || "—" %>
                    </span>
                  </td>
                  <td class="py-3 text-end">
                    <% if variant.cost.present? %>
                      <span class="fw-bold"><%= number_to_currency(variant.cost, unit: "$") %></span>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="py-3 text-center">
                    <span class="badge <%= variant.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill px-3">
                      <%= variant.active ? 'Activa' : 'Inactiva' %>
                    </span>
                  </td>
                  <td class="py-3 pe-4 text-end">
                    <div class="d-flex gap-1 justify-content-end">
                      <%= link_to variant, class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                      <%= link_to edit_variant_path(variant), class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                        <i class="bi bi-pencil"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>
<style>
  .bg-success-soft { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
</style>