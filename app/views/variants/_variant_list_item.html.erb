<%= link_to variant_path(variant),
    data: {
      turbo_frame:    "variant_workspace",
      variant_id:     variant.id,
      type_id:        variant.variant_type_id,
      status:         variant.active ? "active" : "inactive",
      has_rule:       variant.has_supply_rules? ? "true" : "false",
      variant_name:   (variant.display_name.presence || variant.name).downcase
    },
    class: "list-group-item list-group-item-action border-0 px-3 py-2 variant-row
            #{'variant-row-active' if selected}",
    id: "variant-list-item-#{variant.id}" do %>
  <div class="d-flex justify-content-between align-items-center">
    <div class="flex-grow-1 me-2 overflow-hidden">
      <div class="fw-bold text-dark small text-truncate">
        <%= variant.display_name.presence || variant.name %>
      </div>
      <div class="d-flex align-items-center gap-1 mt-1">
        <code class="text-muted" style="font-size: 0.65rem;"><%= variant.code %></code>
        <% if variant.display_name.present? && variant.display_name != variant.name %>
          <span class="text-muted" style="font-size: 0.62rem;">
            · <i class="bi bi-truck"></i> <%= variant.name %>
          </span>
        <% end %>
      </div>
    </div>
    <div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">
      <% if variant.active %>
        <span class="badge bg-success-soft text-success rounded-pill px-2"
              style="font-size: 0.6rem;">Activa</span>
      <% else %>
        <span class="badge bg-secondary-soft text-secondary rounded-pill px-2"
              style="font-size: 0.6rem;">Inactiva</span>
      <% end %>
      <% if variant.has_supply_rules? %>
        <span class="badge bg-light text-success border rounded-pill px-2"
              style="font-size: 0.6rem;">
          <i class="bi bi-check-circle"></i>
        </span>
      <% else %>
        <span class="badge bg-warning-soft text-warning rounded-pill px-2"
              style="font-size: 0.6rem;">
          <i class="bi bi-exclamation-circle"></i>
        </span>
      <% end %>
    </div>
  </div>
<% end %>