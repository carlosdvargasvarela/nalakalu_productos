<%= turbo_frame_tag "variant_workspace" do %>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white py-3 border-bottom">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 small">
          <li class="breadcrumb-item">
            <%= link_to "Variantes", variants_path, class: "text-decoration-none" %>
          </li>
          <li class="breadcrumb-item active fw-bold">Nueva Variante</li>
        </ol>
      </nav>
      <h5 class="fw-bold mb-0 mt-2">Nueva Variante</h5>
      <p class="text-muted small mb-0">
        Define el código, tipo, proveedor y compatibilidades.
      </p>
    </div>
    <div class="card-body p-4">
      <%= render "form", variant: @variant %>
    </div>
  </div>
<% end %>