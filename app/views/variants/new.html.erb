<div class="container-fluid py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item">
        <%= link_to "Variantes", variants_path, class: "text-decoration-none" %>
      </li>
      <li class="breadcrumb-item active fw-bold">Nueva Variante</li>
    </ol>
  </nav>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0 text-dark">Nueva Variante</h2>
      <p class="text-muted small mb-0">Define el código, tipo, proveedor y compatibilidades.</p>
    </div>
    <%= link_to variants_path, class: "btn btn-outline-secondary rounded-pill px-4" do %>
      <i class="bi bi-arrow-left me-2"></i>Volver
    <% end %>
  </div>
  <%= render "form", variant: @variant %>
</div>