<tr id="<%= dom_id(variant) %>" class="<%= 'opacity-50' unless variant.active %>">
  <td class="px-4 py-3">
    <div class="d-flex align-items-center gap-3">
      <div class="rounded-3 p-2 flex-shrink-0" style="background-color: #f0ebff;">
        <i class="bi bi-palette fs-5" style="color: #7c3aed;"></i>
      </div>
      <div>
        <div class="fw-bold text-dark">
          <%= variant.display_name.presence || variant.name %>
        </div>
        <% if variant.display_name.present? && variant.display_name != variant.name %>
          <div class="text-muted" style="font-size: 0.72rem;">
            <i class="bi bi-truck me-1"></i><%= variant.name %>
          </div>
        <% end %>
      </div>
    </div>
  </td>
  <td class="py-3">
    <code class="bg-light px-2 py-1 rounded text-dark fw-bold">
      <%= variant.code %>
    </code>
  </td>
  <td class="py-3">
    <%# Reemplaza property_values — ahora mostramos estado de abastecimiento %>
    <% if variant.has_supply_rules? %>
      <span class="badge bg-success-soft text-success rounded-pill px-2 py-1"
            style="font-size: 0.65rem;">
        <i class="bi bi-check-circle me-1"></i>Configurada
      </span>
    <% else %>
      <span class="badge bg-warning-soft text-warning rounded-pill px-2 py-1"
            style="font-size: 0.65rem;">
        <i class="bi bi-exclamation-circle me-1"></i>Sin regla
      </span>
    <% end %>
  </td>
  <td class="py-3 text-center">
    <span class="badge <%= variant.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill px-3">
      <%= variant.active ? 'Activa' : 'Inactiva' %>
    </span>
  </td>
  <td class="py-3 pe-4 text-end">
    <div class="d-flex gap-1 justify-content-end">
      <%= link_to variant,
          class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
        <i class="bi bi-eye"></i>
      <% end %>
      <%= link_to edit_variant_path(variant),
          class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
        <i class="bi bi-pencil"></i>
      <% end %>
      <%= button_to variant_path(variant), method: :delete,
          form: { data: { turbo_confirm: "¿Eliminar '#{variant.display_name.presence || variant.name}'? Se borrarán sus compatibilidades y reglas. Esta acción no se puede deshacer." } },
          class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm text-danger" do %>
        <i class="bi bi-trash"></i>
      <% end %>
    </div>
  </td>
</tr>