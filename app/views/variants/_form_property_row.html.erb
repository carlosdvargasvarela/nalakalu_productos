<%# Recibe: prop, variant, selected_map, existing_vp %>
<%
  values   = prop.property_values.where(active: true).order(:value)
  selected = selected_map[prop.id]
%>
<div class="col-md-6" id="prop-row-<%= prop.id %>">
  <label class="form-label small fw-bold text-muted mb-1 d-flex align-items-center gap-1">
    <i class="bi bi-tag text-primary" style="font-size: 0.7rem;"></i>
    <%= prop.name %>
    <% if values.empty? %>
      <span class="badge bg-warning text-dark ms-1" style="font-size: 0.6rem;">Sin valores</span>
    <% end %>
  </label>
  <% if values.any? %>
    <%= select_tag "variant[variant_properties_attributes][#{prop.id}][property_value_id]",
          options_from_collection_for_select(values, :id, :value, selected),
          include_blank: "— Sin asignar —",
          class: "form-select border-2 shadow-none",
          data: {
            variant_props_preview_target: "select",
            action: "change->variant-props-preview#update",
            prop_name: prop.name
          } %>
    <% if existing_vp&.persisted? %>
      <input type="hidden"
             name="variant[variant_properties_attributes][<%= prop.id %>][id]"
             value="<%= existing_vp.id %>">
    <% end %>
  <% else %>
    <div class="form-control border-2 bg-light text-muted small d-flex align-items-center" style="height: 38px;">
      <i class="bi bi-exclamation-circle me-2 opacity-50"></i>Sin valores definidos
    </div>
  <% end %>
</div>