<%
  properties  = Property.includes(:property_values).where(active: true).order(:name)
  selected_map = variant.variant_properties.includes(:property_value)
                        .each_with_object({}) do |vp, h|
                          h[vp.property_value.property_id] = vp.property_value_id if vp.property_value
                        end
%>
<div class="card border-0 shadow-sm rounded-4 mb-4"
     data-controller="quick-property"
     data-quick-property-target="???">
  <%# El controller vive aquí para tener scope sobre el modal y el grid %>
  <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
    <div>
      <h5 class="fw-bold mb-0">
        <i class="bi bi-sliders me-2 text-primary"></i>Propiedades / Ficha Técnica
      </h5>
      <p class="text-muted small mb-0 mt-1">
        Describe esta variante con atributos como <strong>Acabado, Material, Grosor</strong>, etc.
      </p>
    </div>
    <div class="d-flex align-items-center gap-2">
      <% if properties.any? %>
        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">
          <%= properties.count %> propiedades
        </span>
      <% end %>
      <button type="button"
              class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold"
              data-action="click->quick-property#openModal">
        <i class="bi bi-plus-lg me-1"></i>Nueva
      </button>
    </div>
  </div>
  <div class="card-body p-4">
    <% if properties.any? %>
      <div class="row g-3" id="eav-properties-grid">
        <% properties.each do |prop| %>
          <%
            existing_vp = variant.variant_properties.find { |vp| vp.property_value&.property_id == prop.id }
          %>
          <%= render "variants/form_property_row",
                prop: prop,
                variant: variant,
                selected_map: selected_map,
                existing_vp: existing_vp %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5 text-muted" id="eav-properties-grid">
        <i class="bi bi-sliders2-vertical fs-2 d-block mb-2 opacity-25"></i>
        <p class="mb-3 small fw-bold">Aún no hay propiedades definidas.</p>
        <button type="button"
                class="btn btn-sm btn-outline-primary rounded-pill px-4"
                data-action="click->quick-property#openModal">
          <i class="bi bi-plus-lg me-1"></i>Crear primera propiedad
        </button>
      </div>
    <% end %>
    <div class="mt-3 pt-3 border-top">
      <p class="x-small text-muted mb-0">
        <i class="bi bi-lightbulb me-1 text-warning"></i>
        ¿Falta una propiedad o un valor?
        Usá el botón <strong>Nueva</strong> para crearla sin salir de esta página.
      </p>
    </div>
  </div>
  <!-- Modal -->
  <div class="modal fade" id="quickPropertyModal" tabindex="-1" aria-hidden="true"
       data-quick-property-target="modal">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow-lg rounded-4">
        <div class="modal-header border-bottom-0 pb-0">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-plus-circle-fill me-2 text-primary"></i>Nueva Propiedad
          </h5>
          <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <%= render "properties/quick_form", property: Property.new %>
          <span id="quick-property-status" data-quick-property-target="status"></span>
        </div>
      </div>
    </div>
  </div>
</div>