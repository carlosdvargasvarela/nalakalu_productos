<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-header bg-white py-3 border-bottom">
    <h5 class="fw-bold mb-0">
      <i class="bi bi-info-circle me-2 text-primary"></i>Datos de la Variante
    </h5>
  </div>
  <div class="list-group list-group-flush rounded-4">
    <div class="list-group-item px-4 py-3">
      <div class="small text-muted fw-bold mb-1">Código en CRM / QB</div>
      <code class="fs-4 text-dark"><%= variant.code %></code>
    </div>
    <div class="list-group-item px-4 py-3">
      <div class="small text-muted fw-bold mb-1">Nombre Comercial (Vendedor)</div>
      <span class="fw-bold text-primary">
        <%= variant.display_name.presence || "Igual al técnico" %>
      </span>
    </div>
    <div class="list-group-item px-4 py-3">
      <div class="small text-muted fw-bold mb-1">Nombre Técnico (Compra)</div>
      <span class="fw-bold"><%= variant.name %></span>
    </div>
  </div>
</div>