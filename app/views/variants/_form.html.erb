<%= form_with(model: variant, data: { controller: "variant-form" }) do |f| %>
  <% if variant.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar:</h6>
      <ul class="mb-0 ps-3 small">
        <% variant.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <!-- Sidebar: Clasificación -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4 text-dark">
            <i class="bi bi-tags-fill me-2 text-primary"></i>Clasificación
          </h5>
          <div class="mb-3">
            <%= f.label :variant_type_id, "Tipo de Variante", class: "form-label small fw-bold text-muted" %>
            <%= f.collection_select :variant_type_id,
                VariantType.where(active: true).order(:name), :id, :name,
                { prompt: "Seleccione un tipo..." },
                { class: "form-select border-2 shadow-none fw-bold" } %>
          </div>
          <div class="mb-3">
            <%= f.label :provider_id, "Proveedor", class: "form-label small fw-bold text-muted" %>
            <%= f.collection_select :provider_id,
                Provider.where(active: true).order(:name), :id, :name,
                { include_blank: "Sin proveedor (Uso interno / Genérico)" },
                { class: "form-select border-2 shadow-none" } %>
            <div class="form-text x-small">Opcional para materiales genéricos o internos.</div>
          </div>
          <div class="mb-0">
            <%= f.label :active, "Estado", class: "form-label small fw-bold text-muted" %>
            <div class="d-flex gap-3 mt-1">
              <div class="form-check">
                <%= f.radio_button :active, true, class: "form-check-input" %>
                <%= f.label :active_true, "Activa", class: "form-check-label small" %>
              </div>
              <div class="form-check">
                <%= f.radio_button :active, false, class: "form-check-input" %>
                <%= f.label :active_false, "Inactiva", class: "form-check-label small" %>
              </div>
            </div>
          </div>
          <hr class="my-4 opacity-25">
          <p class="small text-muted mb-0">
            <i class="bi bi-info-circle me-1"></i>
            Solo las variantes <strong>activas</strong> aparecerán en el generador de códigos.
          </p>
        </div>
      </div>
    </div>
    <!-- Columna Principal -->
    <div class="col-lg-8">
      <!-- Identificación de la Variante -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-pencil-square me-2 text-primary"></i>Identificación de la Variante
          </h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3">
            <%# ── SECCIÓN VENDEDOR ── %>
            <div class="col-12">
              <p class="small fw-bold text-uppercase text-primary mb-0">
                <i class="bi bi-person me-1"></i>Lo que ve el Vendedor
              </p>
            </div>
            <div class="col-md-8">
              <%= f.label :display_name, "Nombre Comercial", class: "form-label small fw-bold text-muted" %>
              <%= f.text_field :display_name,
                  class: "form-control border-2 shadow-none",
                  placeholder: "Ej: Azul Petróleo",
                  data: {
                    "variant-form-target": "displayName",
                    action: "blur->variant-form#syncName"
                  } %>
              <div class="form-text x-small">Este es el nombre que verá el vendedor en el generador.</div>
            </div>
            <div class="col-md-4">
              <%= f.label :code, "Código Quickbooks", class: "form-label small fw-bold text-muted" %>
              <%= f.text_field :code,
                  class: "form-control border-2 font-monospace text-center fw-bold shadow-none",
                  placeholder: "AZP",
                  data: {
                    "variant-form-target": "code",
                    action: "blur->variant-form#syncCode"
                  } %>
              <div class="form-text x-small">Se usará en el código final (Ej: DAL-AZP).</div>
            </div>
            <div class="col-12">
              <hr class="my-1 opacity-25">
            </div>
            <%# ── SECCIÓN COMPRA/TÉCNICA ── %>
            <div class="col-12">
              <p class="small fw-bold text-uppercase text-secondary mb-0">
                <i class="bi bi-truck me-1"></i>Datos para Compra / Logística
              </p>
            </div>
            <div class="col-md-8">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <%= f.label :name, "Nombre Técnico / Compra", class: "form-label small fw-bold text-muted mb-0" %>
                <span class="badge bg-warning text-dark d-none x-small"
                      data-variant-form-target="nameWarning">
                  <i class="bi bi-exclamation-triangle me-1"></i>Usando nombre comercial
                </span>
              </div>
              <%= f.text_field :name,
                  class: "form-control border-2 shadow-none",
                  placeholder: "Ej: Lino Pesado Azul Petróleo",
                  data: {
                    "variant-form-target": "name",
                    action: "input->variant-form#onNameInput"
                  } %>
              <div class="form-text x-small">Nombre exacto para Órdenes de Compra o Inventario.</div>
            </div>
            <div class="col-md-4">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <%= f.label :provider_sku, "Código Color / SKU Prov.", class: "form-label small fw-bold text-muted mb-0" %>
                <span class="badge bg-warning text-dark d-none x-small"
                      data-variant-form-target="skuWarning">
                  <i class="bi bi-exclamation-triangle me-1"></i>Usando código quickbooks
                </span>
              </div>
              <%= f.text_field :provider_sku,
                  class: "form-control border-2 font-monospace shadow-none",
                  placeholder: "Ej: COL-742",
                  data: {
                    "variant-form-target": "providerSku",
                    action: "input->variant-form#onSkuInput"
                  } %>
            </div>
            <div class="col-md-6">
              <%= f.label :cost, "Costo de Compra", class: "form-label small fw-bold text-muted" %>
              <div class="input-group shadow-none">
                <span class="input-group-text border-2 bg-light fw-bold text-muted">$</span>
                <%= f.number_field :cost, step: 0.01,
                    class: "form-control border-2 shadow-none",
                    placeholder: "0.00" %>
              </div>
            </div>
            <div class="col-12">
              <%= f.label :technical_description, "Notas Técnicas Internas", class: "form-label small fw-bold text-muted" %>
              <%= f.text_area :technical_description,
                  class: "form-control border-2 shadow-none",
                  rows: 2,
                  placeholder: "Detalles adicionales sobre el material, composición, etc." %>
            </div>
          </div>
        </div>
      </div>
      <!-- Compatibilidades -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-link-45deg me-2 text-primary"></i>Reglas de Compatibilidad
          </h5>
          <p class="text-muted small mb-0 mt-1">
            Si defines compatibilidades, esta variante <strong>solo aparecerá</strong> cuando una de las variantes marcadas haya sido seleccionada primero.
          </p>
        </div>
        <div class="card-body p-4">
          <% other_types = VariantType.where.not(id: variant.variant_type_id).where(active: true) %>
          <% if other_types.any? %>
            <div class="row g-3">
              <% other_types.each do |type| %>
                <div class="col-md-4">
                  <p class="small fw-bold text-uppercase text-muted mb-2">
                    <i class="bi bi-tags me-1"></i><%= type.name %>
                  </p>
                  <div class="border rounded-3 bg-light p-2" style="max-height: 160px; overflow-y: auto;">
                    <%= f.collection_check_boxes(
                        :compatible_variant_ids,
                        type.variants.where(active: true).where.not(id: variant.id).order(:name),
                        :id, :name
                      ) do |b| %>
                      <div class="form-check py-1">
                        <%= b.check_box(class: "form-check-input") %>
                        <%= b.label(class: "form-check-label small") %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4 text-muted">
              <i class="bi bi-tags fs-2 d-block mb-2 opacity-25"></i>
              No hay otros tipos de variante activos para definir compatibilidades.
            </div>
          <% end %>
        </div>
      </div>
      <!-- Footer Acciones -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
          <%= link_to variants_path, class: "btn btn-link text-muted text-decoration-none fw-bold" do %>
            <i class="bi bi-x-lg me-2"></i>Descartar
          <% end %>
          <%= f.submit variant.new_record? ? "Crear Variante" : "Guardar Cambios",
                  class: "btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
<style>
  .x-small { font-size: 0.75rem; }
</style>