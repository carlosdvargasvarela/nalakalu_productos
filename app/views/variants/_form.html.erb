<%= form_with(model: variant, data: { controller: "variant-form" }) do |f| %>
  <% if variant.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar:</h6>
      <ul class="mb-0 ps-3 small">
        <% variant.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <!-- ── SIDEBAR: Clasificación ── -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4 text-dark">
            <i class="bi bi-tags-fill me-2 text-primary"></i>Clasificación
          </h5>
          <div class="mb-3">
            <%= f.label :variant_type_id, "Tipo de Variante",
                class: "form-label small fw-bold text-muted" %>
            <%= f.collection_select :variant_type_id,
                VariantType.where(active: true).order(:name), :id, :name,
                { prompt: "Seleccione un tipo..." },
                { class: "form-select border-2 shadow-none fw-bold" } %>
          </div>
          <div class="mb-0">
            <%= f.label :active, "Estado", class: "form-label small fw-bold text-muted" %>
            <div class="d-flex gap-3 mt-1">
              <div class="form-check">
                <%= f.radio_button :active, true, class: "form-check-input" %>
                <%= f.label :active_true, "Activa", class: "form-check-label small" %>
              </div>
              <div class="form-check">
                <%= f.radio_button :active, false, class: "form-check-input" %>
                <%= f.label :active_false, "Inactiva", class: "form-check-label small" %>
              </div>
            </div>
          </div>
          <hr class="my-4 opacity-25">
          <p class="small text-muted mb-0">
            <i class="bi bi-info-circle me-1"></i>
            Solo las variantes <strong>activas</strong> aparecerán en el generador de códigos.
          </p>
        </div>
      </div>
    </div>
    <!-- ── COLUMNA PRINCIPAL ── -->
    <div class="col-lg-8">
      <!-- 1. Identificación -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-pencil-square me-2 text-primary"></i>Identificación de la Variante
          </h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3">
            <div class="col-12">
              <p class="small fw-bold text-uppercase text-primary mb-0">
                <i class="bi bi-person me-1"></i>Lo que ve el Vendedor
              </p>
            </div>
            <div class="col-md-8">
              <%= f.label :display_name, "Nombre Comercial",
                  class: "form-label small fw-bold text-muted" %>
              <%= f.text_field :display_name,
                  class: "form-control border-2 shadow-none",
                  placeholder: "Ej: Bottega Caliza",
                  data: {
                    "variant-form-target": "displayName",
                    action: "blur->variant-form#syncName"
                  } %>
              <div class="form-text x-small">
                Nombre que verá el vendedor en el generador de códigos.
              </div>
            </div>
            <div class="col-md-4">
              <%= f.label :code, "Código Quickbooks",
                  class: "form-label small fw-bold text-muted" %>
              <%= f.text_field :code,
                  class: "form-control border-2 font-monospace text-center fw-bold shadow-none",
                  placeholder: "BTC",
                  data: {
                    "variant-form-target": "code",
                    action: "blur->variant-form#syncCode"
                  } %>
              <div class="form-text x-small">Se usará en el código final (Ej: RIO-BTC).</div>
            </div>
            <div class="col-12"><hr class="my-1 opacity-25"></div>
            <div class="col-12">
              <p class="small fw-bold text-uppercase text-secondary mb-0">
                <i class="bi bi-truck me-1"></i>Datos para Compra / Logística
              </p>
            </div>
            <div class="col-md-8">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <%= f.label :name, "Nombre Técnico / Compra",
                    class: "form-label small fw-bold text-muted mb-0" %>
                <span class="badge bg-warning text-dark d-none x-small"
                      data-variant-form-target="nameWarning">
                  <i class="bi bi-exclamation-triangle me-1"></i>Usando nombre comercial
                </span>
              </div>
              <%= f.text_field :name,
                  class: "form-control border-2 shadow-none",
                  placeholder: "Ej: Acabado Bottega Caliza",
                  data: {
                    "variant-form-target": "name",
                    action: "input->variant-form#onNameInput"
                  } %>
              <div class="form-text x-small">
                Nombre exacto para Órdenes de Compra o Inventario.
              </div>
            </div>
            <div class="col-12">
              <%= f.label :technical_description, "Notas Técnicas Internas",
                  class: "form-label small fw-bold text-muted" %>
              <%= f.text_area :technical_description,
                  class: "form-control border-2 shadow-none",
                  rows: 2,
                  placeholder: "Detalles adicionales sobre el material, composición, etc." %>
            </div>
          </div>
        </div>
      </div>
      <%# Propiedades EAV eliminadas — ahora viven en SupplierItem %>
      <div class="alert alert-info border-0 rounded-4 bg-info bg-opacity-10 mb-4">
        <div class="d-flex gap-2 align-items-start">
          <i class="bi bi-info-circle-fill text-info mt-1 flex-shrink-0"></i>
          <div class="small">
            Las <strong>propiedades técnicas</strong> (acabado, material, etc.) ahora se
            configuran en la <strong>Pieza de Proveedor</strong> correspondiente, no en la variante.
            <%= link_to "Ver piezas de proveedor", supplier_items_path, class: "fw-bold" %>
          </div>
        </div>
      </div>
      <!-- Productos compatibles -->
      <%= render "variants/form_compatible_products", variant: variant %>
      <!-- Compatibilidades entre Variantes -->
      <%= render "variants/form_compatible_variants", f: f, variant: variant %>
      <!-- Footer Acciones -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
          <%= link_to variants_path,
              class: "btn btn-link text-muted text-decoration-none fw-bold" do %>
            <i class="bi bi-x-lg me-2"></i>Descartar
          <% end %>
          <%= f.submit variant.new_record? ? "Crear Variante" : "Guardar Cambios",
              class: "btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
<style>
  .x-small { font-size: 0.75rem; }
</style>