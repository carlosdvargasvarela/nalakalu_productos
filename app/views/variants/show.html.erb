<div class="container-fluid py-4">
  <!-- HEADER -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item"><%= link_to "Variantes", variants_path, class: "text-decoration-none" %></li>
              <li class="breadcrumb-item active fw-bold"><%= @variant.display_name.presence || @variant.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="rounded-3 p-3 flex-shrink-0" style="background-color: #f0ebff;">
              <i class="bi bi-palette fs-3" style="color: #7c3aed;"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0"><%= @variant.display_name.presence || @variant.name %></h2>
              <div class="d-flex gap-2 mt-1 flex-wrap">
                <span class="badge bg-secondary rounded-pill px-3"><%= @variant.variant_type.name %></span>
                <span class="badge <%= @variant.active ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3">
                  <%= @variant.active ? 'Activa' : 'Inactiva' %>
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-2 justify-content-md-end">
            <%= link_to edit_variant_path(@variant), class: "btn btn-outline-primary rounded-pill px-4 shadow-sm" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- DATOS PRINCIPALES -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="fw-bold mb-0"><i class="bi bi-info-circle me-2 text-primary"></i>Datos de la Variante</h5>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Código en CRM</div>
            <code class="fs-4 text-dark"><%= @variant.code %></code>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Nombre Comercial (Vendedor)</div>
            <span class="fw-bold text-primary"><%= @variant.display_name.presence || "Igual al técnico" %></span>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Nombre Técnico (Compra)</div>
            <span class="fw-bold"><%= @variant.name %></span>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Proveedor</div>
            <% if @variant.provider %>
              <%= link_to @variant.provider.name, @variant.provider, class: "text-decoration-none fw-bold text-primary" %>
            <% else %>
              <span class="badge bg-light text-dark border">Uso Interno / Genérico</span>
            <% end %>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">SKU / Código Color Prov.</div>
            <code class="bg-light px-2 py-1 rounded"><%= @variant.provider_sku.presence || "—" %></code>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Costo</div>
            <span class="fw-bold fs-5"><%= @variant.cost.present? ? number_to_currency(@variant.cost, unit: "$") : "No especificado" %></span>
          </div>
        </div>
      </div>
      <% if @variant.technical_description.present? %>
        <div class="card border-0 shadow-sm rounded-4 mt-4">
          <div class="card-header bg-white py-3 border-bottom">
            <h5 class="fw-bold mb-0"><i class="bi bi-card-text me-2 text-primary"></i>Notas Técnicas</h5>
          </div>
          <div class="card-body">
            <p class="mb-0 small text-muted"><%= @variant.technical_description %></p>
          </div>
        </div>
      <% end %>
    </div>
    <!-- COMPATIBILIDADES -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <div>
            <h5 class="fw-bold mb-0"><i class="bi bi-link-45deg me-2 text-primary"></i>Compatibilidades</h5>
            <p class="text-muted small mb-0 mt-1">Variantes con las que esta opción puede combinarse.</p>
          </div>
          <span class="badge bg-primary rounded-pill px-3"><%= @variant.compatible_variants.count %></span>
        </div>
        <div class="card-body p-0">
          <% if @variant.compatible_variants.any? %>
            <% @variant.compatible_variants.includes(:variant_type).group_by(&:variant_type).each do |type, variants| %>
              <div class="px-4 py-3 border-bottom">
                <p class="small fw-bold text-muted text-uppercase mb-2"><i class="bi bi-tags me-1"></i><%= type.name %></p>
                <div class="d-flex flex-wrap gap-2">
                  <% variants.each do |v| %>
                    <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                      <code class="me-1 text-primary"><%= v.code %></code>
                      <%= v.display_name.presence || v.name %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-link fs-1 d-block mb-2 opacity-25"></i>
              <p class="mb-1 fw-bold">Sin restricciones de compatibilidad.</p>
              <small>Esta variante es compatible con todas las demás por defecto.</small>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>