<div class="container-fluid py-4">
  <!-- HEADER -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item">
                <%= link_to "Variantes", variants_path, class: "text-decoration-none" %>
              </li>
              <li class="breadcrumb-item active fw-bold">
                <%= @variant.display_name.presence || @variant.name %>
              </li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="rounded-3 p-3 flex-shrink-0" style="background-color: #f0ebff;">
              <i class="bi bi-palette fs-3" style="color: #7c3aed;"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0">
                <%= @variant.display_name.presence || @variant.name %>
              </h2>
              <div class="d-flex gap-2 mt-1 flex-wrap">
                <span class="badge bg-secondary rounded-pill px-3">
                  <%= @variant.variant_type.name %>
                </span>
                <span class="badge <%= @variant.active ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3">
                  <%= @variant.active ? 'Activa' : 'Inactiva' %>
                </span>
                <% if @variant.display_name.present? && @variant.display_name != @variant.name %>
                  <span class="badge bg-light text-muted border rounded-pill px-3">
                    <i class="bi bi-truck me-1"></i><%= @variant.name %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-2 justify-content-md-end">
            <%= link_to edit_variant_path(@variant),
                class: "btn btn-outline-primary rounded-pill px-4 shadow-sm" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- COLUMNA IZQUIERDA: Datos + Propiedades -->
    <div class="col-lg-4">
      <!-- Datos de la Variante -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-info-circle me-2 text-primary"></i>Datos de la Variante
          </h5>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Código en CRM / QB</div>
            <code class="fs-4 text-dark"><%= @variant.code %></code>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Nombre Comercial (Vendedor)</div>
            <span class="fw-bold text-primary">
              <%= @variant.display_name.presence || "Igual al técnico" %>
            </span>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Nombre Técnico (Compra)</div>
            <span class="fw-bold"><%= @variant.name %></span>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">SKU / Código Color Prov.</div>
            <code class="bg-light px-2 py-1 rounded">
              <%= @variant.provider_sku.presence || "—" %>
            </code>
          </div>
          <div class="list-group-item px-4 py-3">
            <div class="small text-muted fw-bold mb-1">Proveedor</div>
            <% if @variant.provider %>
              <%= link_to @variant.provider.name, @variant.provider,
                  class: "text-decoration-none fw-bold text-primary" %>
            <% else %>
              <span class="badge bg-light text-dark border">Uso Interno / Genérico</span>
            <% end %>
          </div>
        </div>
      </div>
      <!-- Propiedades EAV -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-sliders me-2 text-primary"></i>Propiedades
          </h5>
        </div>
        <div class="card-body p-4">
          <% pvs = @variant.property_values.includes(:property) %>
          <% if pvs.any? %>
            <div class="d-flex flex-column gap-2">
              <% pvs.each do |pv| %>
                <div class="d-flex justify-content-between align-items-center
                            bg-light rounded-3 px-3 py-2">
                  <span class="small text-muted fw-bold"><%= pv.property.name %></span>
                  <span class="badge bg-white border text-dark rounded-pill px-3 fw-bold">
                    <%= pv.value %>
                  </span>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-3 text-muted">
              <i class="bi bi-sliders2-vertical d-block fs-3 mb-2 opacity-25"></i>
              <small>Sin propiedades asignadas.</small>
            </div>
          <% end %>
        </div>
      </div>
      <!-- Notas Técnicas -->
      <% if @variant.technical_description.present? %>
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white py-3 border-bottom">
            <h5 class="fw-bold mb-0">
              <i class="bi bi-card-text me-2 text-primary"></i>Notas Técnicas
            </h5>
          </div>
          <div class="card-body p-4">
            <p class="mb-0 small text-muted"><%= @variant.technical_description %></p>
          </div>
        </div>
      <% end %>
    </div>
    <!-- COLUMNA DERECHA: Compatibilidades -->
    <div class="col-lg-8">
      <!-- Productos donde se usa -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <div>
            <h5 class="fw-bold mb-0">
              <i class="bi bi-box-seam me-2 text-success"></i>Productos donde se usa
            </h5>
            <p class="text-muted small mb-0 mt-1">
              Esta variante aparecerá en el generador de códigos para estos productos.
            </p>
          </div>
          <span class="badge bg-success rounded-pill px-3"><%= @compatible_products.count %></span>
        </div>
        <div class="card-body p-0">
          <% if @compatible_products.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom">
                  <tr>
                    <th class="px-4 py-3 text-muted small fw-bold text-uppercase">Producto</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">Código Base</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase text-center">Estado</th>
                    <th class="py-3 pe-4 text-end text-muted small fw-bold text-uppercase">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% @compatible_products.each do |product| %>
                    <tr>
                      <td class="px-4 py-3">
                        <div class="d-flex align-items-center gap-2">
                          <div class="bg-primary bg-opacity-10 p-2 rounded-3 flex-shrink-0">
                            <i class="bi bi-box-seam text-primary"></i>
                          </div>
                          <span class="fw-bold"><%= product.name %></span>
                        </div>
                      </td>
                      <td class="py-3">
                        <code class="bg-light px-2 py-1 rounded fw-bold">
                          <%= product.base_code %>
                        </code>
                      </td>
                      <td class="py-3 text-center">
                        <span class="badge <%= product.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill px-3">
                          <%= product.active ? 'Activo' : 'Inactivo' %>
                        </span>
                      </td>
                      <td class="py-3 pe-4 text-end">
                        <%= link_to product,
                            class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-25"></i>
              <p class="mb-1 fw-bold">No está asignada a ningún producto.</p>
              <small>Edita la variante para asignarla a productos.</small>
            </div>
          <% end %>
        </div>
      </div>
      <!-- Compatibilidades entre Variantes -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <div>
            <h5 class="fw-bold mb-0">
              <i class="bi bi-link-45deg me-2 text-primary"></i>Compatibilidades entre Variantes
            </h5>
            <p class="text-muted small mb-0 mt-1">
              Variantes con las que esta opción puede combinarse.
            </p>
          </div>
          <span class="badge bg-primary rounded-pill px-3">
            <%= @variant.compatible_variants.count %>
          </span>
        </div>
        <div class="card-body p-0">
          <% if @variant.compatible_variants.any? %>
            <% @variant.compatible_variants.includes(:variant_type).group_by(&:variant_type).each do |type, variants| %>
              <div class="px-4 py-3 border-bottom">
                <p class="small fw-bold text-muted text-uppercase mb-2">
                  <i class="bi bi-tags me-1"></i><%= type.name %>
                </p>
                <div class="d-flex flex-wrap gap-2">
                  <% variants.each do |v| %>
                    <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                      <code class="me-1 text-primary"><%= v.code %></code>
                      <%= v.display_name.presence || v.name %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-link fs-1 d-block mb-2 opacity-25"></i>
              <p class="mb-1 fw-bold">Sin restricciones de compatibilidad.</p>
              <small>Esta variante es compatible con todas las demás por defecto.</small>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .bg-success-soft   { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
</style>