<div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
  <div class="card-body p-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><%= link_to "Familias", families_path, class: "text-decoration-none" %></li>
            <li class="breadcrumb-item active fw-bold"><%= family.name %></li>
          </ol>
        </nav>
        <h2 class="fw-bold mb-1"><%= family.name %></h2>
        <p class="text-muted mb-0"><%= family.description %></p>
      </div>
      <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <div class="d-flex gap-2 justify-content-md-end">
          <%= link_to edit_family_path(family), class: "btn btn-white border shadow-sm rounded-pill px-4" do %>
            <i class="bi bi-pencil-square me-2"></i>Editar DNA
          <% end %>
          <%= button_to family, method: :delete, class: "btn btn-outline-danger rounded-circle p-2", 
              form: { data: { turbo_confirm: "¿Eliminar esta familia y desvincular sus productos?" } } do %>
            <i class="bi bi-trash"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>