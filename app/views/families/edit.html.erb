<div class="container-fluid py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Familias", families_path, class: "text-decoration-none" %></li>
      <li class="breadcrumb-item"><%= link_to @family.name, family_path(@family), class: "text-decoration-none" %></li>
      <li class="breadcrumb-item active fw-bold">Editar</li>
    </ol>
  </nav>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">Editar Familia</h2>
      <p class="text-muted small mb-0">Modifica el nombre y la estructura de variantes.</p>
    </div>
    <%= link_to family_path(@family), class: "btn btn-outline-secondary rounded-pill px-4" do %>
      <i class="bi bi-eye me-2"></i>Ver
    <% end %>
  </div>
  <%= render "form", family: @family %>
</div>