<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0">Editar Familia</h1>
      <p class="text-muted">Modifica la información y estructura de esta familia.</p>
    </div>
  </div>
  <%= render "form", family: @family %>
  <div class="mt-4 d-flex justify-content-between align-items-center">
    <%= link_to families_path, class: "btn btn-link text-decoration-none text-muted" do %>
      <i class="bi bi-arrow-left me-2"></i>Cancelar y volver
    <% end %>
    <%= link_to family_path(@family), class: "btn btn-outline-primary rounded-pill px-4" do %>
      <i class="bi bi-eye me-2"></i>Ver Familia
    <% end %>
  </div>
</div>