<div class="container-fluid py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item">
        <%= link_to "Productos", products_path, class: "text-decoration-none" %>
      </li>
      <li class="breadcrumb-item">
        <%= link_to @product.name, @product, class: "text-decoration-none" %>
      </li>
      <li class="breadcrumb-item active fw-bold">Editar</li>
    </ol>
  </nav>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">Editando: <span class="text-primary"><%= @product.name %></span></h2>
      <p class="text-muted small mb-0">Código base: <code><%= @product.base_code %></code></p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to @product, class: "btn btn-outline-secondary rounded-pill px-4" do %>
        <i class="bi bi-eye me-2"></i>Ver Producto
      <% end %>
      <%= link_to products_path, class: "btn btn-link text-muted text-decoration-none" do %>
        <i class="bi bi-arrow-left me-1"></i>Cancelar
      <% end %>
    </div>
  </div>
  <%= render "form", product: @product %>
</div>