<div class="container-fluid py-4">
  <!-- Header -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item"><%= link_to "Familias", families_path, class: "text-decoration-none" %></li>
              <li class="breadcrumb-item active fw-bold"><%= @family.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="bg-info bg-opacity-10 p-3 rounded-3 flex-shrink-0">
              <i class="bi bi-diagram-3 fs-3 text-info"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0"><%= @family.name %></h2>
              <p class="text-muted mb-0"><%= @family.description %></p>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-2 justify-content-md-end">
            <%= link_to edit_family_path(@family), class: "btn btn-outline-primary rounded-pill px-4 shadow-sm" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar Familia
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- Estructura de la Familia -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="mb-0 fw-bold"><i class="bi bi-layers me-2 text-info"></i>Estructura de Código Base</h5>
        </div>
        <div class="card-body p-4">
          <% if @family.family_variant_rules.any? %>
            <div class="list-group list-group-flush">
              <% @family.family_variant_rules.order(:position).each_with_index do |rule, i| %>
                <div class="list-group-item px-0 py-3 d-flex align-items-center gap-3 border-0">
                  <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width: 28px; height: 28px; font-size: 0.75rem;">
                    <%= i + 1 %>
                  </div>
                  <div class="flex-grow-1">
                    <div class="fw-bold small"><%= rule.label.presence || rule.variant_type.name %></div>
                    <div class="text-muted" style="font-size: 0.7rem;">Separador: <code><%= rule.separator %></code></div>
                  </div>
                  <span class="badge <%= rule.required ? 'bg-danger-subtle text-danger' : 'bg-secondary-subtle text-secondary' %> rounded-pill x-small">
                    <%= rule.required ? 'Obligatorio' : 'Opcional' %>
                  </span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted small text-center py-3">No hay reglas definidas para esta familia.</p>
          <% end %>
        </div>
      </div>
      <!-- Asignar Productos -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-success"></i>Asignar Productos</h5>
        </div>
        <div class="card-body p-4">
          <%= form_with url: assign_products_family_path(@family), method: :post do |f| %>
            <div class="mb-3">
              <label class="form-label small fw-bold text-muted">Selecciona productos sin familia:</label>
              <div class="border rounded-3 p-3 bg-light" style="max-height: 200px; overflow-y: auto;">
                <% Product.where(family_id: nil).order(:name).each do |p| %>
                  <div class="form-check mb-2">
                    <%= check_box_tag "product_ids[]", p.id, false, class: "form-check-input", id: "prod_#{p.id}" %>
                    <label class="form-check-label small" for="prod_<%= p.id %>">
                      <%= p.name %> <code class="text-muted ms-1"><%= p.base_code %></code>
                    </label>
                  </div>
                <% end %>
              </div>
            </div>
            <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold">
              Asignar y Aplicar Reglas
            </button>
            <div class="form-text x-small mt-2 text-center">
              <i class="bi bi-info-circle me-1"></i>Esto clonará las reglas de la familia a los productos.
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <!-- Productos en esta Familia -->
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>Productos Vinculados</h5>
          <span class="badge bg-primary rounded-pill px-3"><%= @family.products.count %></span>
        </div>
        <div class="card-body p-0">
          <% if @family.products.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="px-4 py-3 text-muted small fw-bold text-uppercase">Producto</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">Código Base</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase text-center">Reglas</th>
                    <th class="py-3 pe-4 text-end text-muted small fw-bold text-uppercase">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% @family.products.order(:name).each do |product| %>
                    <tr>
                      <td class="px-4 py-3">
                        <%= link_to product.name, product, class: "text-decoration-none fw-bold text-dark" %>
                      </td>
                      <td class="py-3"><code><%= product.base_code %></code></td>
                      <td class="py-3 text-center">
                        <% if product.product_variant_rules.any? %>
                          <span class="badge bg-warning-soft text-warning rounded-pill px-2" title="Tiene reglas personalizadas que anulan las de la familia">Personalizadas</span>
                        <% else %>
                          <span class="badge bg-info-soft text-info rounded-pill px-2">Heredadas</span>
                        <% end %>
                      </td>
                      <td class="py-3 pe-4 text-end">
                        <%= button_to unassign_product_family_path(@family, product_id: product.id), method: :delete, class: "btn btn-sm btn-outline-danger border-0 rounded-circle", data: { turbo_confirm: "¿Desvincular #{product.name} de esta familia?" } do %>
                          <i class="bi bi-x-circle"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
              <p>No hay productos asignados a esta familia.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .x-small { font-size: 0.7rem; }
  .bg-warning-soft { background-color: #fff8e6; }
</style>