<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0">Familias de Productos</h1>
      <p class="text-muted">Gestiona las estructuras de código base por categorías.</p>
    </div>
    <%= link_to new_family_path, class: "btn btn-primary shadow-sm rounded-pill px-4" do %>
      <i class="bi bi-plus-lg me-2"></i>Nueva Familia
    <% end %>
  </div>
  <div class="row g-4">
    <% @families.each do |family| %>
      <div class="col-md-6 col-xl-4">
        <div class="card h-100 border-0 shadow-sm hover-shadow transition-all rounded-4">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="bg-primary bg-opacity-10 p-3 rounded-3">
                <i class="bi bi-diagram-3 fs-3 text-primary"></i>
              </div>
              <span class="badge <%= family.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill px-3">
                <%= family.active ? 'Activa' : 'Inactiva' %>
              </span>
            </div>
            <h4 class="fw-bold mb-2"><%= family.name %></h4>
            <p class="text-muted small mb-4 text-truncate-2" style="height: 3rem;">
              <%= family.description.presence || "Sin descripción disponible." %>
            </p>
            <div class="row g-2 mb-4">
              <div class="col-6">
                <div class="p-2 border rounded-3 bg-light text-center">
                  <div class="fw-bold text-dark"><%= family.products.count %></div>
                  <div class="text-muted x-small uppercase fw-bold">Productos</div>
                </div>
              </div>
              <div class="col-6">
                <div class="p-2 border rounded-3 bg-light text-center">
                  <div class="fw-bold text-dark"><%= family.family_variant_rules.count %></div>
                  <div class="text-muted x-small uppercase fw-bold">Reglas DNA</div>
                </div>
              </div>
            </div>
            <div class="d-grid">
              <%= link_to family, class: "btn btn-outline-primary rounded-pill" do %>
                Gestionar Familia <i class="bi bi-arrow-right ms-2"></i>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <div class="mt-4">
    <%= link_to root_path, class: "btn btn-link text-decoration-none text-muted" do %>
      <i class="bi bi-arrow-left me-2"></i>Volver al Inicio
    <% end %>
  </div>
</div>