<div class="container-fluid py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item">
        <%= link_to "Productos", products_path, class: "text-decoration-none" %>
      </li>
      <li class="breadcrumb-item active fw-bold">Nuevo Producto</li>
    </ol>
  </nav>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">Nuevo Producto</h2>
      <p class="text-muted small mb-0">Define el código base, la familia y la estructura de variantes.</p>
    </div>
    <%= link_to products_path, class: "btn btn-outline-secondary rounded-pill px-4" do %>
      <i class="bi bi-arrow-left me-2"></i>Cancelar
    <% end %>
  </div>
  <%= render "form", product: @product %>
</div>