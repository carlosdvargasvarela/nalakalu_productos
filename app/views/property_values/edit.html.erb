<div class="container-fluid py-4">
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item"><%= link_to "Propiedades", properties_path, class: "text-decoration-none" %></li>
          <li class="breadcrumb-item"><%= link_to @property.name, @property, class: "text-decoration-none" %></li>
          <li class="breadcrumb-item active">Editar "<%= @property_value.value %>"</li>
        </ol>
      </nav>
    </div>
  </div>
  <div class="row justify-content-center">
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <%= form_with model: @property_value do |f| %>
            <div class="mb-3">
              <%= f.label :value, "Valor", class: "form-label fw-bold" %>
              <%= f.text_field :value, class: "form-control border-2 shadow-none" %>
            </div>
            <div class="form-check form-switch mb-4">
              <%= f.check_box :active, class: "form-check-input" %>
              <%= f.label :active, "Activo", class: "form-check-label fw-bold" %>
            </div>
            <div class="d-flex justify-content-between">
              <%= link_to @property, class: "btn btn-link text-muted text-decoration-none" do %>
                <i class="bi bi-arrow-left me-1"></i>Volver
              <% end %>
              <%= f.submit "Guardar Cambios", class: "btn btn-primary rounded-pill px-4 fw-bold shadow-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>