<div class="row g-4">
  <div class="col-12">
    <h5 class="text-primary border-bottom pb-2 mb-3">Límites del CRM</h5>
  </div>
  <div class="col-md-6">
    <%= f.label :max_chars_per_line, "Caracteres por línea", class: "form-label fw-bold" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-distribute-horizontal"></i></span>
      <%= f.number_field :max_chars_per_line, class: "form-control" %>
    </div>
    <div class="form-text">Ej: 30 caracteres.</div>
  </div>
  <div class="col-md-6">
    <%= f.label :max_lines, "Máximo de líneas", class: "form-label fw-bold" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-distribute-vertical"></i></span>
      <%= f.number_field :max_lines, class: "form-control" %>
    </div>
    <div class="form-text">Ej: 5 líneas.</div>
  </div>
  <div class="col-12 mt-2">
    <h5 class="text-primary border-bottom pb-2 mb-3">Formato y Prefijos</h5>
  </div>
  <div class="col-md-6">
    <%= f.label :default_separator, "Separador por defecto", class: "form-label fw-bold" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-slash-lg"></i></span>
      <%= f.text_field :default_separator, class: "form-control" %>
    </div>
    <div class="form-text">Ej: <code>-</code> o <code>/</code></div>
  </div>
  <div class="col-md-6">
    <%= f.label :prefix_length, "Longitud del prefijo de etiqueta", class: "form-label fw-bold" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-type"></i></span>
      <%= f.number_field :prefix_length, class: "form-control", min: 1, max: 9 %>
    </div>
    <div class="form-text">
      Cuántas letras de la etiqueta se usan como prefijo.<br>
      Ej: Con <strong>2</strong> y etiqueta "Frente" → <code>FR-AZUL MARINO</code>
    </div>
  </div>
  <div class="col-12">
    <div class="form-check form-switch">
      <%= f.check_box :use_prefixes, class: "form-check-input", role: "switch" %>
      <%= f.label :use_prefixes, "Usar prefijos de etiquetas (Label)", class: "form-check-label fw-bold" %>
    </div>
  </div>
  <div class="col-12 mt-2">
    <h5 class="text-primary border-bottom pb-2 mb-3">Stock de Sala</h5>
  </div>
  <div class="col-12" data-controller="stock-options">
    <label class="form-label fw-bold">Opciones de Stock de Sala</label>
    <div class="form-text mb-3">
      Cada opción aparecerá como alternativa en el generador de códigos.
    </div>
    <div data-stock-options-target="list" class="d-flex flex-column gap-2 mb-3">
      <% (@code_setting.stock_sala_options_array.presence || [""]).each do |opt| %>
        <div class="input-group" data-stock-options-target="item">
          <span class="input-group-text bg-white">
            <i class="bi bi-box-seam text-muted"></i>
          </span>
          <input type="text"
                 name="code_setting[stock_sala_options][]"
                 value="<%= opt %>"
          class="form-control"
          placeholder="Ej: STOCK DE SALA">
          <button type="button"
                  class="btn btn-outline-danger"
                  data-action="click->stock-options#remove">
            <i class="bi bi-trash"></i>
          </button>
        </div>
      <% end %>
    </div>
    <button type="button"
            class="btn btn-outline-secondary btn-sm"
            data-action="click->stock-options#add">
      <i class="bi bi-plus-circle me-1"></i>Agregar opción
    </button>
  </div>
  <div class="col-12 mt-3">
    <div class="form-check form-switch">
      <%= f.check_box :show_stock_sala, class: "form-check-input", role: "switch" %>
      <%= f.label :show_stock_sala, "Mostrar opción Stock de Sala en el generador", class: "form-check-label fw-bold" %>
    </div>
  </div>
</div>