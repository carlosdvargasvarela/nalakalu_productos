<div class="modal-header border-0 pb-0">
  <h5 class="modal-title fw-bold">
    <i class="bi bi-clock-history me-2 text-primary"></i>Historial: <%= product.name %>
  </h5>
  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body p-0">
  <% if movements.empty? %>
    <div class="text-center text-muted py-4">Sin movimientos confirmados.</div>
  <% else %>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Fecha</th>
            <th>Tipo</th>
            <th>Sala</th>
            <th class="text-center">Cant.</th>
            <th>Pedido</th>
          </tr>
        </thead>
        <tbody>
          <% movements.each do |m| %>
            <tr>
              <td class="text-muted small"><%= m.delivery_date&.strftime("%d/%m/%Y") || "—" %></td>
              <td>
                <span class="badge <%= m.movement_type == 'entry' || m.movement_type == 'initial' ? 'bg-success' : 'bg-danger' %>">
                  <%= m.type_label %>
                </span>
              </td>
              <td><span class="badge bg-secondary"><%= m.sala_label %></span></td>
              <td class="text-center fw-semibold"><%= m.quantity %></td>
              <td class="text-muted small"><%= m.order_number.presence || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
