<%# ── HEADER ──────────────────────────────────────────────────────────────── %>
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div>
    <h1 class="fw-bold mb-1">
      <i class="bi bi-box-arrow-in-down me-2 text-primary"></i>Cargar Stock Inicial
    </h1>
    <p class="text-muted mb-0">Registra múltiples productos de una sala en un solo cargue.</p>
  </div>
  <%= link_to inventory_path, class: "btn btn-outline-secondary btn-sm align-self-start" do %>
    <i class="bi bi-arrow-left me-1"></i>Volver
  <% end %>
</div>

<%# ── FORMULARIO PRINCIPAL ────────────────────────────────────────────────── %>
<div data-controller="initial-stock-form"
     data-initial-stock-form-quick-create-url-value="<%= inventory_quick_create_product_path %>">

<%= form_with url: inventory_initial_stock_path, method: :post do |f| %>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3">
      <h5 class="mb-0 fw-bold"><i class="bi bi-gear me-2 text-muted"></i>Parámetros del cargue</h5>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold">Sala <span class="text-danger">*</span></label>
          <%= select_tag :showroom_id,
                options_for_select(@showrooms.map { |s| [s.name, s.id] }),
                include_blank: "— Selecciona una sala —",
                class: "form-select shadow-sm",
                required: true %>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Fecha de referencia</label>
          <%= date_field_tag :delivery_date, Date.current, class: "form-control shadow-sm" %>
          <div class="form-text">Fecha del conteo o toma de inventario.</div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Notas <span class="text-muted fw-normal">(opcional)</span></label>
          <%= text_area_tag :notes, nil, rows: 2, class: "form-control shadow-sm",
                placeholder: "Ej: Toma de inventario apertura junio 2026" %>
        </div>
      </div>
    </div>
  </div>

  <%# ── TABLA DE PRODUCTOS ──────────────────────────────────────────────────── %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
      <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2 text-muted"></i>Productos</h5>
      <button type="button"
              class="btn btn-sm btn-outline-primary"
              data-action="click->initial-stock-form#addRow">
        <i class="bi bi-plus-circle me-1"></i>Agregar producto
      </button>
    </div>
    <div class="card-body p-0">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 55%">Producto</th>
            <th style="width: 20%">Cantidad</th>
            <th style="width: 20%"></th>
            <th style="width: 5%"></th>
          </tr>
        </thead>
        <tbody data-initial-stock-form-target="body">
          <tr data-initial-stock-form-target="row">
            <td>
              <div class="d-flex gap-2 align-items-center">
                <%= select_tag "items[0][product_id]",
                      options_for_select(@products.map { |p| [p.name, p.id] }),
                      include_blank: "— Seleccionar producto —",
                      class: "form-select form-select-sm",
                      "data-initial-stock-form-target": "productSelect" %>
                <button type="button"
                        class="btn btn-sm btn-outline-secondary text-nowrap"
                        title="Crear producto nuevo"
                        data-action="click->initial-stock-form#openQuickCreate">
                  <i class="bi bi-plus-lg"></i> Nuevo
                </button>
              </div>
            </td>
            <td>
              <input type="number"
                     name="items[0][quantity]"
                     min="0.01" step="0.01" value="1"
                     class="form-control form-control-sm"
                     placeholder="Ej: 3"
                     required>
            </td>
            <td></td>
            <td>
              <button type="button"
                      class="btn btn-sm btn-outline-danger"
                      disabled
                      data-action="click->initial-stock-form#removeRow">
                <i class="bi bi-trash3"></i>
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center py-3">
      <button type="button"
              class="btn btn-outline-primary btn-sm"
              data-action="click->initial-stock-form#addRow">
        <i class="bi bi-plus-circle me-1"></i>Agregar otra fila
      </button>
      <div class="d-flex gap-2">
        <%= link_to "Cancelar", inventory_path, class: "btn btn-outline-secondary" %>
        <button type="submit" class="btn btn-primary px-4 fw-bold">
          <i class="bi bi-cloud-check me-1"></i>Guardar stock inicial
        </button>
      </div>
    </div>
  </div>

<% end %>

<%# ── MODAL: CREAR PRODUCTO RÁPIDO (dentro del scope del controlador Stimulus) ── %>
<div class="modal fade" id="quickCreateProductModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header border-0 bg-primary text-white">
        <h5 class="modal-title fw-bold">
          <i class="bi bi-plus-circle me-2"></i>Crear nuevo producto
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">

        <div class="alert alert-danger d-none"
             data-initial-stock-form-target="quickCreateError"></div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
          <input type="text"
                 class="form-control"
                 placeholder="Ej: Sofá 3 puestos Oslo"
                 data-initial-stock-form-target="newProductName">
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Código interno <span class="text-danger">*</span></label>
          <input type="text"
                 class="form-control"
                 placeholder="Ej: SOF-001"
                 data-initial-stock-form-target="newProductCode">
          <div class="form-text">Código único que identifica este producto en el sistema.</div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Familia <span class="text-muted fw-normal">(opcional)</span></label>
          <%= select_tag nil,
                options_for_select(@families.map { |f| [f.name, f.id] }),
                include_blank: "— Sin familia —",
                class: "form-select",
                "data-initial-stock-form-target": "newProductFamily" %>
        </div>

        <div class="alert alert-info small mb-0 py-2">
          <i class="bi bi-info-circle me-1"></i>
          El producto se creará activo y disponible inmediatamente en todos los formularios.
          Puedes editar sus detalles completos desde <strong>Administración → Productos Base</strong>.
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button"
                class="btn btn-primary fw-bold"
                data-action="click->initial-stock-form#submitQuickCreate">
          <i class="bi bi-check-lg me-1"></i>Crear producto
        </button>
      </div>
    </div>
  </div>
</div>

</div><%# cierre del div data-controller="initial-stock-form" %>
