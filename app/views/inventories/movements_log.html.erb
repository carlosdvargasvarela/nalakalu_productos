<%# ── HEADER ──────────────────────────────────────────────────────────────── %>
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div>
    <h1 class="fw-bold mb-1">
      <i class="bi bi-journal-text me-2 text-primary"></i>Log de Movimientos
    </h1>
    <p class="text-muted mb-0">
      Historial de movimientos confirmados.
      <% if @movements.size == 300 %>
        <span class="badge bg-warning text-dark ms-1">Mostrando los últimos 300</span>
      <% else %>
        <strong><%= @movements.size %></strong> movimiento(s) encontrado(s).
      <% end %>
    </p>
  </div>
  <%= link_to inventory_path, class: "btn btn-outline-secondary btn-sm align-self-start" do %>
    <i class="bi bi-arrow-left me-1"></i>Volver
  <% end %>
</div>

<%# ── FILTROS ─────────────────────────────────────────────────────────────── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: inventory_movements_log_path, method: :get,
          class: "row g-3 align-items-end" do |f| %>
      <div class="col-md-2">
        <label class="form-label fw-semibold small">Sala</label>
        <%= select_tag :showroom_id,
              options_for_select(
                [["Todas", ""]] + @showrooms.map { |s| [s.name, s.id] },
                @filter[:showroom_id]
              ),
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small">Producto</label>
        <%= select_tag :product_id,
              options_for_select(
                [["Todos", ""]] + @products.map { |p| [p.name, p.id] },
                @filter[:product_id]
              ),
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label fw-semibold small">Tipo</label>
        <%= select_tag :movement_type,
              options_for_select(
                [["Todos", ""], ["Entrada", "entry"], ["Salida", "exit"], ["Stock inicial", "initial"]],
                @filter[:movement_type]
              ),
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label fw-semibold small">Desde</label>
        <%= date_field_tag :from, @filter[:from], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label fw-semibold small">Hasta</label>
        <%= date_field_tag :to, @filter[:to], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-1 d-flex gap-1">
        <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
          <i class="bi bi-search"></i>
        </button>
        <% if @filter.values.any?(&:present?) %>
          <%= link_to inventory_movements_log_path, class: "btn btn-outline-secondary btn-sm", title: "Limpiar filtros" do %>
            <i class="bi bi-x-lg"></i>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ── TABLA DE MOVIMIENTOS (con bulk delete) ──────────────────────────────── %>
<% manual_ids = @movements.select { |m| m.source == "manual" }.map(&:id) %>

<%= form_with url: bulk_destroy_inventory_movements_path, method: :delete,
      data: { controller: "bulk-check" } do |f| %>

  <%# Barra bulk — siempre visible, botón deshabilitado si no hay selección %>
  <div class="d-flex align-items-center gap-3 mb-3 p-3 bg-light border rounded-3">
    <% if manual_ids.any? %>
      <div class="form-check mb-0">
        <input class="form-check-input" type="checkbox" id="select-all-movements"
               data-bulk-check-target="selectAll"
               data-action="change->bulk-check#toggleAll">
        <label class="form-check-label fw-semibold small" for="select-all-movements">
          Seleccionar todo
        </label>
      </div>
      <span class="text-muted small">
        <span data-bulk-check-target="countBadge"></span>
        seleccionado(s)
      </span>
      <button type="submit" class="btn btn-sm btn-outline-danger"
              data-bulk-check-target="bulkButton"
              data-turbo-confirm="¿Eliminar los movimientos manuales seleccionados? Esta acción no se puede deshacer.">
        <i class="bi bi-trash me-1"></i>Eliminar manuales seleccionados
      </button>
    <% end %>
    <span class="text-muted small ms-auto fst-italic">
      <i class="bi bi-info-circle me-1"></i>Solo se pueden eliminar movimientos de origen <strong>manual</strong>
    </span>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <% if @movements.empty? %>
        <div class="text-center text-muted py-5">
          <i class="bi bi-inbox fs-2 d-block mb-2"></i>
          Sin movimientos para los filtros seleccionados.
        </div>
      <% else %>
        <table class="table table-sm table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th style="width:40px;"></th>
              <th>Fecha</th>
              <th>Tipo</th>
              <th>Sala</th>
              <th>Producto</th>
              <th class="text-center">Cant.</th>
              <th>Origen</th>
              <th>Pedido</th>
              <th>Notas</th>
            </tr>
          </thead>
          <tbody>
            <% @movements.each do |m| %>
              <%
                row_class = case m.movement_type
                  when "entry"   then "table-success-subtle"
                  when "exit"    then "table-danger-subtle"
                  when "initial" then "table-info-subtle"
                end
                badge_class = case m.movement_type
                  when "entry"   then "bg-success"
                  when "exit"    then "bg-danger"
                  when "initial" then "bg-info text-dark"
                end
                is_manual = m.source == "manual"
              %>
              <tr class="<%= row_class %>">
                <td>
                  <% if is_manual %>
                    <input class="form-check-input" type="checkbox"
                           name="ids[]" value="<%= m.id %>"
                           data-bulk-check-target="checkbox"
                           data-action="change->bulk-check#updateBulkButton"
                           aria-label="Seleccionar movimiento <%= m.id %>">
                  <% end %>
                </td>
                <td class="text-nowrap small">
                  <%= m.delivery_date&.strftime("%d/%m/%Y") || "—" %>
                </td>
                <td>
                  <span class="badge <%= badge_class %>"><%= m.type_label %></span>
                </td>
                <td class="small"><%= m.showroom&.name || "—" %></td>
                <td class="fw-semibold small"><%= m.product&.name || m.product_name_raw || "—" %></td>
                <td class="text-center fw-bold"><%= m.quantity.round(2) %></td>
                <td>
                  <span class="badge <%= is_manual ? 'bg-secondary' : 'bg-light text-dark border' %> small">
                    <%= is_manual ? "Manual" : "Sync" %>
                  </span>
                  <% if m.flag == "stock_missing" %>
                    <span class="badge bg-warning text-dark ms-1" title="Stock insuficiente al registrar">
                      <i class="bi bi-exclamation-triangle-fill"></i>
                    </span>
                  <% end %>
                </td>
                <td class="small text-muted"><%= m.order_number&.truncate(20) || "—" %></td>
                <td class="small text-muted" style="max-width: 180px;">
                  <span title="<%= m.notes %>"><%= m.notes&.truncate(40) %></span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>
<% end %>
