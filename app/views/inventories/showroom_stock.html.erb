<%# ── HEADER ──────────────────────────────────────────────────────────────── %>
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div>
    <nav aria-label="breadcrumb" class="mb-1">
      <ol class="breadcrumb mb-0 small">
        <li class="breadcrumb-item"><%= link_to "Inventario", inventory_path %></li>
        <li class="breadcrumb-item active"><%= @showroom.name %></li>
      </ol>
    </nav>
    <h1 class="fw-bold mb-1">
      <i class="bi bi-shop me-2 text-primary"></i><%= @showroom.name %>
    </h1>
    <p class="text-muted mb-0">
      Stock actual confirmado ·
      <strong><%= @products.size %></strong> producto(s) ·
      <strong><%= @stock.values.sum.round(2) %></strong> unidades totales
    </p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <%= link_to inventory_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="bi bi-arrow-left me-1"></i>Volver
    <% end %>
    <%= link_to inventory_movements_log_path(showroom_id: @showroom.id),
          class: "btn btn-outline-info btn-sm" do %>
      <i class="bi bi-journal-text me-1"></i>Ver movimientos
    <% end %>
    <%= link_to new_inventory_exit_path(showroom_id: @showroom.id),
          class: "btn btn-outline-danger btn-sm" do %>
      <i class="bi bi-box-arrow-up me-1"></i>Registrar salida
    <% end %>
  </div>
</div>

<%# ── SELECTOR DE SALA ────────────────────────────────────────────────────── %>
<div class="mb-4">
  <div class="d-flex gap-2 flex-wrap">
    <% @showrooms.each do |s| %>
      <%= link_to inventory_showroom_stock_path(s),
            class: "btn btn-sm #{s.id == @showroom.id ? 'btn-primary' : 'btn-outline-secondary'}" do %>
        <i class="bi bi-shop me-1"></i><%= s.name %>
      <% end %>
    <% end %>
  </div>
</div>

<%# ── TABLA DE STOCK ──────────────────────────────────────────────────────── %>
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if @products.empty? %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
        Sin stock confirmado para esta sala. Carga stock inicial o confirma una sincronización.
      </div>
    <% else %>
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Producto</th>
            <th class="text-center" style="width:120px;">Stock actual</th>
          </tr>
        </thead>
        <tbody>
          <% @products.values.each do |product| %>
            <% qty = @stock[product.id] || 0 %>
            <tr>
              <td class="fw-semibold"><%= product.name %></td>
              <td class="text-center">
                <% if qty > 0 %>
                  <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle px-3 py-2 fs-6">
                    <%= qty.round(2) %>
                  </span>
                <% elsif qty < 0 %>
                  <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle px-3 py-2 fs-6">
                    <%= qty.round(2) %>
                  </span>
                <% else %>
                  <span class="text-muted">0</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="table-light fw-bold">
          <tr>
            <td>Total</td>
            <td class="text-center"><%= @stock.values.sum.round(2) %></td>
          </tr>
        </tfoot>
      </table>
    <% end %>
  </div>
</div>
