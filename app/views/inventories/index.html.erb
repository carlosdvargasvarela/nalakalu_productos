<%# ── HEADER ──────────────────────────────────────────────────────────────── %>
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div>
    <h1 class="fw-bold mb-1"><i class="bi bi-boxes me-2 text-primary"></i>Inventario de Salas</h1>
    <p class="text-muted mb-0">Stock actual por sala. Solo movimientos de syncs confirmados.</p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <%= link_to inventory_movements_log_path, class: "btn btn-outline-info" do %>
      <i class="bi bi-journal-text me-1"></i>Movimientos
    <% end %>
    <%= link_to new_inventory_initial_stock_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-plus-circle me-1"></i>Stock Inicial
    <% end %>
    <%= link_to new_inventory_exit_path, class: "btn btn-outline-danger" do %>
      <i class="bi bi-box-arrow-up me-1"></i>Registrar salida
    <% end %>
    <%= link_to inventory_alerts_path, class: "btn btn-outline-warning" do %>
      <i class="bi bi-exclamation-triangle me-1"></i>Alertas
      <% if @flagged_count > 0 %>
        <span class="badge rounded-pill bg-danger ms-1"><%= @flagged_count %></span>
      <% end %>
    <% end %>
    <button class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#syncForm">
      <i class="bi bi-arrow-repeat me-1"></i>Sincronizar
    </button>
  </div>
</div>

<%# ── SYNC FORM (colapsable) ──────────────────────────────────────────────── %>
<div class="collapse mb-4" id="syncForm">
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <%= form_with url: sync_inventory_path, method: :post, class: "row g-3 align-items-end",
            data: {
              controller: "loading-button",
              action: "turbo:submit-start->loading-button#submit"
            } do |f| %>
        <div class="col-md-4">
          <label class="form-label fw-semibold small">Desde</label>
          <input type="date" name="from" value="<%= @from %>" class="form-control shadow-sm">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold small">Hasta</label>
          <input type="date" name="to" value="<%= @to %>" class="form-control shadow-sm">
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-primary w-100"
                  data-turbo-confirm="¿Iniciar sincronización de inventario para este rango?"
                  data-loading-button-target="button">
            <i class="bi bi-cloud-download me-1"></i>Iniciar sincronización
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── SYNCS PENDIENTES ────────────────────────────────────────────────────── %>
<% if @pending_syncs.any? %>
  <div class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert">
    <i class="bi bi-exclamation-triangle-fill fs-5 mt-1"></i>
    <div>
      <strong><%= @pending_syncs.size %> sincronización(es) pendiente(s) de revisión.</strong>
      El inventario mostrado abajo no incluye estos movimientos hasta que sean confirmados.
      <div class="mt-2 d-flex flex-wrap gap-2">
        <% @pending_syncs.each do |s| %>
          <%= link_to inventory_sync_path(s), class: "btn btn-sm btn-warning" do %>
            <i class="bi bi-eye me-1"></i>
            Revisar: <%= s.from_date.strftime("%d/%m") %> – <%= s.to_date.strftime("%d/%m/%Y") %>
            <span class="badge bg-dark ms-1"><%= s.unresolved_count %> sin resolver</span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# ── TABLA DE STOCK ──────────────────────────────────────────────────────── %>
<div class="card border-0 shadow-sm mb-5">
  <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h5 class="mb-0 fw-bold"><i class="bi bi-table me-2"></i>Stock actual por sala</h5>
    <% if @products.any? %>
      <div class="input-group input-group-sm" style="max-width: 260px;">
        <span class="input-group-text bg-white border-end-0">
          <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" id="stock-search" class="form-control border-start-0 ps-0"
               placeholder="Buscar producto…" autocomplete="off">
        <button class="btn btn-outline-secondary" type="button" onclick="clearStockSearch()" title="Limpiar">
          <i class="bi bi-x"></i>
        </button>
      </div>
    <% end %>
  </div>
  <div class="card-body p-0">
    <% if @products.empty? %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
        Sin movimientos confirmados aún. Sincroniza y confirma un lote para ver el stock.
      </div>
    <% else %>
      <div id="no-results-stock" class="text-center text-muted py-4 d-none">
        <i class="bi bi-search fs-2 d-block mb-2"></i>
        Sin productos que coincidan con la búsqueda.
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="stock-table">
          <thead class="table-light">
            <tr>
              <th>Producto</th>
              <% @showrooms.each do |showroom| %>
                <th class="text-center">
                  <%= link_to showroom.name, inventory_showroom_stock_path(showroom),
                        class: "text-decoration-none fw-semibold" %>
                </th>
              <% end %>
              <th class="text-center fw-bold">Total</th>
            </tr>
          </thead>
          <tbody id="stock-tbody">
            <% @products.each_value do |product| %>
              <tr data-product-name="<%= product.name.downcase %>">
                <td class="fw-semibold">
                  <a href="#" class="text-decoration-none"
                     data-bs-toggle="modal"
                     data-bs-target="#productHistoryModal"
                     data-product-id="<%= product.id %>"
                     data-product-name="<%= product.name %>">
                    <%= product.name %>
                    <i class="bi bi-clock-history ms-1 text-muted small"></i>
                  </a>
                </td>
                <% total = 0 %>
                <% @showrooms.each do |showroom| %>
                  <% qty = @stock[[ product.id, showroom.id ]] || 0 %>
                  <% total += qty %>
                  <td class="text-center">
                    <% if qty > 0 %>
                      <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle px-2"><%= qty %></span>
                    <% elsif qty < 0 %>
                      <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle px-2"><%= qty %></span>
                    <% else %>
                      <span class="text-muted small">—</span>
                    <% end %>
                  </td>
                <% end %>
                <td class="text-center fw-bold">
                  <% if total > 0 %>
                    <span class="text-success"><%= total %></span>
                  <% elsif total < 0 %>
                    <span class="text-danger"><%= total %></span>
                  <% else %>
                    <span class="text-muted">0</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>

<%# ── SYNCS RECIENTES ─────────────────────────────────────────────────────── %>
<% if @recent_syncs.any? %>
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
      <h5 class="mb-0 fw-bold text-muted"><i class="bi bi-clock-history me-2"></i>Últimas sincronizaciones confirmadas</h5>
    </div>
    <div class="card-body p-0">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Rango</th>
            <th class="text-center">Entregas</th>
            <th class="text-center">Movimientos</th>
            <th>Fecha sync</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_syncs.each do |s| %>
            <tr>
              <td><%= s.from_date.strftime("%d/%m/%Y") %> – <%= s.to_date.strftime("%d/%m/%Y") %></td>
              <td class="text-center"><%= s.deliveries_processed %></td>
              <td class="text-center"><%= s.movements_count %></td>
              <td class="text-muted small"><%= s.synced_at&.strftime("%d/%m/%Y %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<%# ── MODAL HISTORIAL ────────────────────────────────────────────────────── %>
<div class="modal fade" id="productHistoryModal" tabindex="-1" aria-hidden="true"
     data-controller="product-history">
  <div class="modal-dialog modal-lg">
    <div class="modal-content border-0 shadow">
      <div id="productHistoryContent">
        <div class="modal-body text-center py-5 text-muted">
          <span class="spinner-border spinner-border-sm me-2"></span>Cargando historial...
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    <%# Búsqueda en tabla de stock %>
    const searchInput = document.getElementById("stock-search")
    const noResults   = document.getElementById("no-results-stock")

    if (searchInput) {
      searchInput.addEventListener("input", filterStock)
    }

    function filterStock() {
      const term = searchInput.value.toLowerCase().trim()
      const rows = document.querySelectorAll("#stock-tbody tr")
      let visible = 0
      rows.forEach(row => {
        const match = !term || row.dataset.productName.includes(term)
        row.style.display = match ? "" : "none"
        if (match) visible++
      })
      if (noResults) noResults.classList.toggle("d-none", visible > 0)
    }

    window.clearStockSearch = function () {
      if (searchInput) { searchInput.value = ""; filterStock() }
    }

    <%# Modal historial de movimientos %>
    const historyModal = document.getElementById("productHistoryModal")
    if (historyModal) {
      historyModal.addEventListener("show.bs.modal", function (event) {
        const link      = event.relatedTarget
        const productId = link.dataset.productId
        const content   = document.getElementById("productHistoryContent")
        content.innerHTML = '<div class="modal-body text-center py-5 text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Cargando historial...</div>'
        fetch(`/inventory/product/${productId}/movements`, { headers: { Accept: "text/html" } })
          .then(r => r.text())
          .then(html => content.innerHTML = html)
          .catch(() => content.innerHTML = '<div class="modal-body text-danger">Error al cargar el historial.</div>')
      })
    }
  })()
</script>
