<%# ── HEADER ──────────────────────────────────────────────────────────────── %>
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div>
    <h1 class="fw-bold mb-1"><i class="bi bi-boxes me-2 text-primary"></i>Inventario de Salas</h1>
    <p class="text-muted mb-0">Stock actual por sala. Solo movimientos de syncs confirmados.</p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <%= link_to new_inventory_initial_stock_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-plus-circle me-1"></i>Stock Inicial
    <% end %>
    <button class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#syncForm">
      <i class="bi bi-arrow-repeat me-1"></i>Sincronizar
    </button>
  </div>
</div>

<%# ── SYNC FORM (colapsable) ──────────────────────────────────────────────── %>
<div class="collapse mb-4" id="syncForm">
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <%= form_with url: sync_inventory_path, method: :post, class: "row g-3 align-items-end" do |f| %>
        <div class="col-md-4">
          <label class="form-label fw-semibold small">Desde</label>
          <input type="date" name="from" value="<%= @from %>" class="form-control shadow-sm">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold small">Hasta</label>
          <input type="date" name="to" value="<%= @to %>" class="form-control shadow-sm">
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-primary w-100"
                  data-turbo-confirm="¿Iniciar sincronización de inventario para este rango?">
            <i class="bi bi-cloud-download me-1"></i>Iniciar sincronización
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── SYNCS PENDIENTES ────────────────────────────────────────────────────── %>
<% if @pending_syncs.any? %>
  <div class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert">
    <i class="bi bi-exclamation-triangle-fill fs-5 mt-1"></i>
    <div>
      <strong><%= @pending_syncs.size %> sincronización(es) pendiente(s) de revisión.</strong>
      El inventario mostrado abajo no incluye estos movimientos hasta que sean confirmados.
      <div class="mt-2 d-flex flex-wrap gap-2">
        <% @pending_syncs.each do |s| %>
          <%= link_to inventory_sync_path(s), class: "btn btn-sm btn-warning" do %>
            <i class="bi bi-eye me-1"></i>
            Revisar: <%= s.from_date.strftime("%d/%m") %> – <%= s.to_date.strftime("%d/%m/%Y") %>
            <span class="badge bg-dark ms-1"><%= s.unresolved_count %> sin resolver</span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# ── TABLA DE STOCK ──────────────────────────────────────────────────────── %>
<div class="card border-0 shadow-sm mb-5">
  <div class="card-header bg-white py-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-table me-2"></i>Stock actual por sala</h5>
  </div>
  <div class="card-body p-0">
    <% if @products.empty? %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
        Sin movimientos confirmados aún. Sincroniza y confirma un lote para ver el stock.
      </div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Producto</th>
              <% @salas.each do |sala| %>
                <th class="text-center"><%= InventoryMovement::SALA_LABELS[sala] %></th>
              <% end %>
              <th class="text-center fw-bold">Total</th>
            </tr>
          </thead>
          <tbody>
            <% @products.each_value do |product| %>
              <tr>
                <td class="fw-semibold"><%= product.name %></td>
                <% total = 0 %>
                <% @salas.each do |sala| %>
                  <% qty = @stock[[ product.id, sala ]] || 0 %>
                  <% total += qty %>
                  <td class="text-center">
                    <% if qty > 0 %>
                      <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle px-2"><%= qty %></span>
                    <% elsif qty < 0 %>
                      <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle px-2"><%= qty %></span>
                    <% else %>
                      <span class="text-muted small">—</span>
                    <% end %>
                  </td>
                <% end %>
                <td class="text-center fw-bold">
                  <% if total > 0 %>
                    <span class="text-success"><%= total %></span>
                  <% elsif total < 0 %>
                    <span class="text-danger"><%= total %></span>
                  <% else %>
                    <span class="text-muted">0</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>

<%# ── SYNCS RECIENTES ─────────────────────────────────────────────────────── %>
<% if @recent_syncs.any? %>
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
      <h5 class="mb-0 fw-bold text-muted"><i class="bi bi-clock-history me-2"></i>Últimas sincronizaciones confirmadas</h5>
    </div>
    <div class="card-body p-0">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Rango</th>
            <th class="text-center">Entregas</th>
            <th class="text-center">Movimientos</th>
            <th>Fecha sync</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_syncs.each do |s| %>
            <tr>
              <td><%= s.from_date.strftime("%d/%m/%Y") %> – <%= s.to_date.strftime("%d/%m/%Y") %></td>
              <td class="text-center"><%= s.deliveries_processed %></td>
              <td class="text-center"><%= s.movements_count %></td>
              <td class="text-muted small"><%= s.synced_at&.strftime("%d/%m/%Y %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
