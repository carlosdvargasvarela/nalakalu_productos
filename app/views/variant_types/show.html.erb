<div class="container-fluid py-4">
  <!-- HEADER -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item">
                <%= link_to "Tipos de Variante", variant_types_path, class: "text-decoration-none" %>
              </li>
              <li class="breadcrumb-item active fw-bold"><%= @variant_type.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="bg-info bg-opacity-10 p-3 rounded-3 flex-shrink-0">
              <i class="bi bi-tags fs-3 text-info"></i>
            </div>
            <div>
              <h2 class="fw-bold mb-0"><%= @variant_type.name %></h2>
              <p class="text-muted small mb-0 mt-1">
                Tipo de variante &middot;
                <span class="fw-bold text-success">
                  <%= @variant_type.variants.where(active: true).count %> activas
                </span>
                de
                <span class="fw-bold text-info">
                  <%= @variant_type.variants.count %> totales
                </span>
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-2 justify-content-md-end">
            <%= link_to new_variant_path(variant_type_id: @variant_type.id),
                class: "btn btn-info text-white rounded-pill px-4 fw-bold shadow-sm" do %>
              <i class="bi bi-plus-lg me-2"></i>Agregar Variante
            <% end %>
            <%= link_to edit_variant_type_path(@variant_type),
                class: "btn btn-outline-primary rounded-pill px-4" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar
            <% end %>
            <%= button_to @variant_type, method: :delete,
                class: "btn btn-outline-danger rounded-circle p-2",
                form: { data: { turbo_confirm: "¿Eliminar '#{@variant_type.name}'? Esto podría afectar reglas de productos existentes." } } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- TABLA DE VARIANTES -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-list-ul me-2 text-info"></i>Variantes de este tipo
          </h5>
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3">
              <%= @variant_type.variants.count %> registradas
            </span>
            <%= link_to new_variant_path(variant_type_id: @variant_type.id),
                class: "btn btn-sm btn-info text-white rounded-pill px-3 shadow-sm" do %>
              <i class="bi bi-plus-lg me-1"></i>Agregar
            <% end %>
          </div>
        </div>
        <div class="card-body p-0">
          <% variants = @variant_type.variants
               .includes(:provider, :property_values, :compatibilities)
               .order(:name) %>
          <% if variants.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom">
                  <tr>
                    <th class="px-4 py-3 text-muted small fw-bold text-uppercase">Variante</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">Código</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">Propiedades</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase">Proveedor</th>
                    <th class="py-3 text-muted small fw-bold text-uppercase text-center">Productos</th>
                    <th class="py-3 pe-4 text-muted small fw-bold text-uppercase text-center">Estado</th>
                    <th class="py-3 pe-4 text-end text-muted small fw-bold text-uppercase">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% variants.each do |variant| %>
                    <tr class="<%= 'opacity-50' unless variant.active %>">
                      <td class="px-4 py-3">
                        <div>
                          <div class="fw-bold text-dark">
                            <%= link_to variant.display_name.presence || variant.name,
                                variant, class: "text-decoration-none text-dark" %>
                          </div>
                          <% if variant.display_name.present? && variant.display_name != variant.name %>
                            <div class="text-muted" style="font-size: 0.72rem;">
                              <i class="bi bi-truck me-1"></i><%= variant.name %>
                            </div>
                          <% end %>
                        </div>
                      </td>
                      <td class="py-3">
                        <code class="bg-light px-2 py-1 rounded text-dark fw-bold">
                          <%= variant.code %>
                        </code>
                      </td>
                      <td class="py-3">
                        <% pvs = variant.property_values %>
                        <% if pvs.any? %>
                          <div class="d-flex flex-wrap gap-1">
                            <% pvs.includes(:property).each do |pv| %>
                              <span class="badge bg-light text-dark border rounded-pill px-2"
                                    style="font-size: 0.68rem;"
                                    title="<%= pv.property.name %>">
                                <%= pv.value %>
                              </span>
                            <% end %>
                          </div>
                        <% else %>
                          <span class="text-muted small">—</span>
                        <% end %>
                      </td>
                      <td class="py-3">
                        <% if variant.provider %>
                          <%= link_to variant.provider.name, variant.provider,
                              class: "text-decoration-none text-muted small" %>
                        <% else %>
                          <span class="text-muted small fst-italic">Interno</span>
                        <% end %>
                      </td>
                      <td class="py-3 text-center">
                        <% prod_count = variant.compatibilities
                             .where(compatible_type: "Product").count %>
                        <% if prod_count > 0 %>
                          <span class="badge bg-success-soft text-success rounded-pill px-2 fw-bold">
                            <%= prod_count %>
                          </span>
                        <% else %>
                          <span class="badge bg-secondary-soft text-secondary rounded-pill px-2">
                            0
                          </span>
                        <% end %>
                      </td>
                      <td class="py-3 pe-4 text-center">
                        <span class="badge <%= variant.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill px-3">
                          <%= variant.active ? 'Activa' : 'Inactiva' %>
                        </span>
                      </td>
                      <td class="py-3 pe-4 text-end">
                        <div class="d-flex gap-1 justify-content-end">
                          <%= link_to variant,
                              class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm",
                              title: "Ver" do %>
                            <i class="bi bi-eye"></i>
                          <% end %>
                          <%= link_to edit_variant_path(variant),
                              class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm",
                              title: "Editar" do %>
                            <i class="bi bi-pencil"></i>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-tag fs-1 d-block mb-2 opacity-25"></i>
              <p class="fw-bold mb-2">No hay variantes creadas para este tipo.</p>
              <%= link_to new_variant_path(variant_type_id: @variant_type.id),
                  class: "btn btn-info text-white rounded-pill px-4" do %>
                <i class="bi bi-plus-lg me-2"></i>Crear primera variante
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <!-- SIDEBAR -->
    <div class="col-lg-4">
      <!-- Resumen -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-bar-chart me-2 text-info"></i>Resumen
          </h6>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
            <span class="small text-muted fw-bold">Total variantes</span>
            <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 fw-bold">
              <%= @variant_type.variants.count %>
            </span>
          </div>
          <div class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
            <span class="small text-muted fw-bold">Activas</span>
            <span class="badge bg-success-soft text-success rounded-pill px-3 fw-bold">
              <%= @variant_type.variants.where(active: true).count %>
            </span>
          </div>
          <div class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
            <span class="small text-muted fw-bold">Inactivas</span>
            <span class="badge bg-secondary-soft text-secondary rounded-pill px-3 fw-bold">
              <%= @variant_type.variants.where(active: false).count %>
            </span>
          </div>
          <div class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
            <span class="small text-muted fw-bold">Con propiedades EAV</span>
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 fw-bold">
              <%= @variant_type.variants.joins(:variant_properties).distinct.count %>
            </span>
          </div>
          <div class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
            <span class="small text-muted fw-bold">Asignadas a productos</span>
            <span class="badge bg-success-soft text-success rounded-pill px-3 fw-bold">
              <%= @variant_type.variants
                    .joins(:compatibilities)
                    .where(compatibilities: { compatible_type: "Product" })
                    .distinct.count %>
            </span>
          </div>
        </div>
      </div>
      <!-- Productos que usan este tipo -->
      <% products_using_type = Product
           .joins(product_variant_rules: :variant_type)
           .where(variant_types: { id: @variant_type.id })
           .distinct
           .order(:name) %>
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-box-seam me-2 text-primary"></i>Productos que lo usan
          </h6>
          <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2">
            <%= products_using_type.count %>
          </span>
        </div>
        <div class="card-body p-3">
          <% if products_using_type.any? %>
            <div class="d-flex flex-column gap-1">
              <% products_using_type.limit(8).each do |p| %>
                <div class="d-flex align-items-center justify-content-between
                            bg-light rounded-3 px-3 py-2">
                  <span class="small fw-bold text-dark"><%= p.name %></span>
                  <code class="text-muted" style="font-size: 0.7rem;"><%= p.base_code %></code>
                </div>
              <% end %>
              <% if products_using_type.count > 8 %>
                <p class="text-muted small text-center mb-0 mt-1">
                  +<%= products_using_type.count - 8 %> productos más
                </p>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted small fst-italic mb-0 text-center py-2">
              Ningún producto usa este tipo aún.
            </p>
          <% end %>
        </div>
      </div>
      <!-- Acciones -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-3 d-grid gap-2">
          <%= link_to new_variant_path(variant_type_id: @variant_type.id),
              class: "btn btn-info text-white rounded-pill fw-bold" do %>
            <i class="bi bi-plus-lg me-2"></i>Agregar Variante
          <% end %>
          <%= link_to edit_variant_type_path(@variant_type),
              class: "btn btn-outline-primary rounded-pill" do %>
            <i class="bi bi-pencil-square me-2"></i>Editar Tipo
          <% end %>
          <%= link_to variant_types_path,
              class: "btn btn-link text-muted text-decoration-none" do %>
            <i class="bi bi-arrow-left me-2"></i>Volver a Tipos
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .bg-success-soft   { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
</style>