<div class="container-fluid py-4">
  <!-- Header -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item"><%= link_to "Tipos de Variante", variant_types_path, class: "text-decoration-none" %></li>
              <li class="breadcrumb-item active fw-bold"><%= @variant_type.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3">
            <div class="bg-info bg-opacity-10 p-3 rounded-3">
              <i class="bi bi-tags fs-3 text-info"></i>
            </div>
            <h2 class="fw-bold mb-0"><%= @variant_type.name %></h2>
          </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-2 justify-content-md-end">
            <%= link_to edit_variant_type_path(@variant_type), class: "btn btn-white border shadow-sm rounded-pill px-4" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar Nombre
            <% end %>
            <%= button_to @variant_type, method: :delete, class: "btn btn-outline-danger rounded-circle p-2",
                form: { data: { turbo_confirm: "¿Eliminar este tipo?" } } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white py-3 border-bottom">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2 text-info"></i>Variantes de este tipo</h5>
        <span class="badge bg-info rounded-pill px-3"><%= @variant_type.variants.count %> registradas</span>
      </div>
    </div>
    <div class="card-body p-0">
      <% if @variant_type.variants.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
              <tr>
                <th class="px-4 py-2 text-muted small fw-bold">Nombre</th>
                <th class="py-2 text-muted small fw-bold">Código</th>
                <th class="py-2 text-muted small fw-bold">Proveedor</th>
                <th class="py-2 pe-4 text-end text-muted small fw-bold">Estado</th>
              </tr>
            </thead>
            <tbody>
              <% @variant_type.variants.each do |variant| %>
                <tr>
                  <td class="px-4 py-3 fw-bold"><%= variant.name %></td>
                  <td class="py-3"><code class="bg-light px-2 py-1 rounded text-dark"><%= variant.code %></code></td>
                  <td class="py-3">
                    <%= link_to variant.provider.name, variant.provider, class: "text-decoration-none text-muted" %>
                  </td>
                  <td class="py-3 pe-4 text-end">
                    <span class="badge <%= variant.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill px-3">
                      <%= variant.active ? 'Activa' : 'Inactiva' %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5 text-muted">
          <i class="bi bi-tag fs-1 d-block mb-2 opacity-25"></i>
          No hay variantes creadas para este tipo todavía.
        </div>
      <% end %>
    </div>
  </div>
</div>
<style>
  .bg-success-soft { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
</style>