<div class="card border-0 shadow-sm rounded-4 h-100">
  <div class="card-body d-flex flex-column align-items-center justify-content-center
              text-center py-5 text-muted" style="min-height: 400px;">
    <div class="bg-info bg-opacity-10 rounded-4 p-4 mb-4">
      <i class="bi bi-tags-fill fs-1 text-info opacity-50"></i>
    </div>
    <h5 class="fw-bold text-dark mb-2">Selecciona un tipo de variante</h5>
    <p class="small mb-4 px-4">
      Haz clic en cualquier tipo de la lista para ver sus variantes,
      estadísticas y acciones disponibles.
    </p>
    <%= link_to new_variant_type_path,
        class: "btn btn-primary rounded-pill px-4 fw-bold shadow-sm" do %>
      <i class="bi bi-plus-lg me-2"></i>Crear nuevo tipo
    <% end %>
  </div>
</div>