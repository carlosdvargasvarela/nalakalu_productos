<tr id="<%= dom_id(variant) %>" class="<%= 'opacity-50' unless variant.active %>">
  <td class="px-4 py-3">
    <input type="checkbox"
           class="form-check-input"
           value="<%= variant.id %>"
      data-bulk-select-target="checkbox"
      data-action="change->bulk-select#toggle">
  </td>
  <td class="px-4 py-3">
    <div class="fw-bold text-dark"><%= variant.display_name.presence || variant.name %></div>
    <% if variant.display_name.present? && variant.display_name != variant.name %>
      <div class="text-muted" style="font-size: 0.72rem;">
        <i class="bi bi-truck me-1"></i><%= variant.name %>
      </div>
    <% end %>
  </td>
  <td class="py-3">
    <code class="bg-light px-2 py-1 rounded text-primary fw-bold"><%= variant.code %></code>
  </td>
  <td class="py-3">
    <% if variant.has_supply_rules? %>
      <span class="badge bg-success-soft text-success rounded-pill px-2" style="font-size: 0.65rem;">
        <i class="bi bi-check-circle me-1"></i>Con regla
      </span>
    <% else %>
      <span class="badge bg-warning-soft text-warning rounded-pill px-2" style="font-size: 0.65rem;">
        <i class="bi bi-exclamation-circle me-1"></i>Sin regla
      </span>
    <% end %>
  </td>
  <td class="py-3 text-center">
    <span class="badge <%= variant.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill">
      <%= variant.active ? 'Activa' : 'Inactiva' %>
    </span>
  </td>
  <td class="py-3 pe-4 text-end">
    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
      <%# Editar — abre modal inline, sin turbo_frame externo %>
      <%= link_to edit_variant_path(variant),
          data: { action: "click->variant-modal#openEdit" },
          class: "btn btn-sm btn-white border-end", title: "Editar" do %>
        <i class="bi bi-pencil text-primary"></i>
      <% end %>
      <%# Ver — navega a página completa, fuera del frame vt_workspace %>
      <%= link_to variant_path(variant),
          data: { turbo_frame: "_top" },
          class: "btn btn-sm btn-white border-end", title: "Ver" do %>
        <i class="bi bi-eye text-info"></i>
      <% end %>
      <%= button_to variant_path(variant), method: :delete,
          form: { data: { turbo_confirm: "¿Eliminar permanentemente?" } },
          class: "btn btn-sm btn-white text-danger", title: "Eliminar" do %>
        <i class="bi bi-trash"></i>
      <% end %>
    </div>
  </td>
</tr>