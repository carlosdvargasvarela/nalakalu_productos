<%# Fila del panel izquierdo del workspace %>
<% active_count = vt.variants.where(active: true).count %>
<% total_count  = vt.variants.count %>
<%= link_to variant_type_path(vt),
    data: { turbo_frame: "vt_workspace" },
    class: "list-group-item list-group-item-action border-0 px-3 py-3 vt-row
            #{'vt-row-active' if selected}",
    "data-vt-name": vt.name.downcase do %>
  <div class="d-flex justify-content-between align-items-start">
    <div class="flex-grow-1 me-2">
      <div class="fw-bold text-dark small"><%= vt.name %></div>
      <%# Preview de variantes activas %>
      <% sample = vt.variants.where(active: true).order(:name).limit(3) %>
      <% if sample.any? %>
        <div class="d-flex flex-wrap gap-1 mt-1">
          <% sample.each do |v| %>
            <span class="badge bg-light text-dark border rounded-pill"
                  style="font-size: 0.62rem;">
              <%= v.display_name.presence || v.name %>
            </span>
          <% end %>
          <% remaining = active_count - sample.count %>
          <% if remaining > 0 %>
            <span class="badge bg-secondary-soft text-secondary rounded-pill"
                  style="font-size: 0.62rem;">+<%= remaining %></span>
          <% end %>
        </div>
      <% else %>
        <span class="text-muted fst-italic" style="font-size: 0.72rem;">Sin variantes aún</span>
      <% end %>
    </div>
    <div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">
      <span class="badge bg-success-soft text-success rounded-pill px-2"
            style="font-size: 0.65rem;">
        <%= active_count %> activas
      </span>
      <span class="badge bg-secondary-soft text-secondary rounded-pill px-2"
            style="font-size: 0.65rem;">
        <%= total_count %> total
      </span>
    </div>
  </div>
<% end %>