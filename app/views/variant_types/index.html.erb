<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><i class="bi bi-tags"></i> Tipos de Variante</h1>
  <%= link_to new_variant_type_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-circle"></i> Nuevo Tipo
  <% end %>
</div>
<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-dark">
          <tr>
            <th>Nombre</th>
            <th>Cantidad de Variantes</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @variant_types.each do |variant_type| %>
            <tr>
              <td><strong><%= variant_type.name %></strong></td>
              <td><span class="badge bg-info"><%= variant_type.variants.count %></span></td>
              <td class="text-end">
                <%= link_to variant_type, class: "btn btn-sm btn-info" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
                <%= link_to edit_variant_type_path(variant_type), class: "btn btn-sm btn-warning" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= button_to variant_type, method: :delete, class: "btn btn-sm btn-danger", 
                    data: { turbo_confirm: "¿Está seguro?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<div class="card mt-4 border-secondary">
  <div class="card-body">
    <h5 class="card-title">
      <i class="bi bi-file-earmark-spreadsheet"></i>
      Importación Masiva de Tipos de Variante
    </h5>
    <p class="text-muted small mb-2">
      Formato mínimo CSV: <code>Nombre</code>
    </p>
    <%= form_with url: import_variant_types_path, multipart: true, local: true do |f| %>
      <div class="input-group">
        <%= f.file_field :file, class: "form-control", accept: ".csv" %>
        <button class="btn btn-secondary" type="submit">
          <i class="bi bi-cloud-upload"></i> Subir e Importar
        </button>
      </div>
    <% end %>
  </div>
</div>