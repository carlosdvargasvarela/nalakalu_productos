<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0 text-dark">Tipos de Variante</h1>
      <p class="text-muted mb-0">Categorías generales para agrupar las opciones de los productos.</p>
    </div>
    <%= link_to new_variant_type_path, class: "btn btn-primary shadow-sm rounded-pill px-4 fw-bold" do %>
      <i class="bi bi-plus-lg me-2"></i>Nuevo Tipo
    <% end %>
  </div>
  <% if @variant_types.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-tags d-block fs-1 mb-3 opacity-25"></i>
      <p class="fw-bold">No hay tipos de variante registrados aún.</p>
      <p class="small mb-3">Los tipos agrupan las opciones: Tela, Madera, Acabado, Color, etc.</p>
      <%= link_to new_variant_type_path, class: "btn btn-primary rounded-pill px-4" do %>
        <i class="bi bi-plus-lg me-2"></i>Crear primer tipo
      <% end %>
    </div>
  <% else %>
    <div class="row g-3 mb-4">
      <% @variant_types.each do |vt| %>
        <div class="col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-sm rounded-4 hover-card">
            <div class="card-body p-4">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="bg-info bg-opacity-10 p-3 rounded-3 flex-shrink-0">
                  <i class="bi bi-tags fs-4 text-info"></i>
                </div>
                <div class="d-flex gap-1">
                  <%= link_to vt,
                      class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm",
                      title: "Ver detalle" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  <%= link_to edit_variant_type_path(vt),
                      class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm",
                      title: "Editar" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to vt, method: :delete,
                      class: "btn btn-sm btn-light text-danger rounded-pill px-3 border shadow-sm",
                      form: { data: { turbo_confirm: "¿Eliminar '#{vt.name}'? Esto podría afectar reglas de productos existentes." } } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </div>
              <h5 class="fw-bold mb-1">
                <%= link_to vt.name, vt, class: "text-decoration-none text-dark" %>
              </h5>
              <%# Preview de variantes activas %>
              <% sample = vt.variants.where(active: true).order(:name).limit(4) %>
              <% if sample.any? %>
                <div class="d-flex flex-wrap gap-1 mb-3 mt-2">
                  <% sample.each do |v| %>
                    <span class="badge bg-light text-dark border rounded-pill px-2"
                          style="font-size: 0.7rem;">
                      <%= v.display_name.presence || v.name %>
                    </span>
                  <% end %>
                  <% remaining = vt.variants.where(active: true).count - sample.count %>
                  <% if remaining > 0 %>
                    <span class="badge bg-secondary-soft text-secondary rounded-pill px-2"
                          style="font-size: 0.7rem;">
                      +<%= remaining %> más
                    </span>
                  <% end %>
                </div>
              <% else %>
                <p class="text-muted small fst-italic mt-2 mb-3">Sin variantes activas aún.</p>
              <% end %>
              <div class="d-flex gap-3 pt-2 border-top">
                <div class="text-center">
                  <div class="fw-bold text-success fs-5">
                    <%= vt.variants.where(active: true).count %>
                  </div>
                  <div class="text-muted" style="font-size: 0.7rem;">Activas</div>
                </div>
                <div class="text-center">
                  <div class="fw-bold text-info fs-5">
                    <%= vt.variants.count %>
                  </div>
                  <div class="text-muted" style="font-size: 0.7rem;">Total</div>
                </div>
                <div class="ms-auto d-flex align-items-end">
                  <%= link_to new_variant_path(variant_type_id: vt.id),
                      class: "btn btn-sm btn-info text-white rounded-pill px-3 fw-bold" do %>
                    <i class="bi bi-plus-lg me-1"></i>Agregar
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
  <!-- Importador CSV -->
  <div class="card border-0 shadow-sm rounded-4 border-start border-info border-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h5 class="fw-bold mb-1">
            <i class="bi bi-file-earmark-spreadsheet text-info me-2"></i>Importación Masiva
          </h5>
          <p class="text-muted small mb-0">
            Formato CSV esperado: <code class="bg-light px-2 py-1 rounded">nombre</code>
          </p>
        </div>
        <div class="col-md-4 mt-3 mt-md-0">
          <%= form_with url: import_variant_types_path, multipart: true, local: true do |f| %>
            <div class="input-group shadow-sm">
              <%= f.file_field :file, class: "form-control rounded-start-pill small", accept: ".csv" %>
              <button class="btn btn-info text-white rounded-end-pill fw-bold px-3" type="submit">
                <i class="bi bi-cloud-upload me-1"></i>Importar
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .hover-card { transition: all 0.2s ease; }
  .hover-card:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1.25rem rgba(0,0,0,.1) !important; }
  .bg-success-soft   { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
  .bg-info-soft      { background-color: #e0f4ff; }
</style>