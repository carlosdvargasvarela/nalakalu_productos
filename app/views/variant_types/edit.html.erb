<%# Turbo Frame aware: si viene del workspace carga dentro del frame %>
<%= turbo_frame_tag "vt_workspace" do %>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
      <div>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item">
              <%= link_to "Tipos de Variante", variant_types_path, class: "text-decoration-none" %>
            </li>
            <li class="breadcrumb-item">
              <%= link_to @variant_type.name, variant_types_path(selected_id: @variant_type.id),
                  data: { turbo_frame: "vt_workspace" }, class: "text-decoration-none" %>
            </li>
            <li class="breadcrumb-item active fw-bold">Editar</li>
          </ol>
        </nav>
        <h5 class="fw-bold mb-0 mt-2">
          Editando: <span class="text-primary"><%= @variant_type.name %></span>
        </h5>
        <p class="text-muted small mb-0">
          <span class="fw-bold text-info"><%= @variant_type.variants.count %> variantes</span>
          asociadas a este tipo.
        </p>
      </div>
    </div>
    <div class="card-body p-4">
      <%= render "form", variant_type: @variant_type %>
    </div>
  </div>
<% end %>