<%# app/views/supply_managements/_logistics_view.html.erb %>
<div class="d-flex flex-column gap-3">
  <% if deliveries.any? %>
    <% deliveries.each do |delivery| %>
      <%
        req_statuses = requirement_statuses[delivery["order_number"]] || []

        status_cfg = if req_statuses.empty?
          {label: "Sin procesar", style: "bg-secondary-subtle text-secondary border-secondary-subtle", icon: "bi-hourglass"}
        elsif req_statuses.all? { |s| s.in?(%w[ordered received in_draft]) }
          {label: "En OC", style: "bg-success-subtle text-success-emphasis border-success-subtle", icon: "bi-check2-circle"}
        elsif req_statuses.include?("pending")
          {label: "Pendiente", style: "bg-warning-subtle text-warning-emphasis border-warning-subtle", icon: "bi-clock"}
        else
          {label: "Parcial", style: "bg-info-subtle text-info-emphasis border-info-subtle", icon: "bi-dash-circle"}
        end
      %>
      <div class="card border-0 shadow-sm overflow-hidden">
        <%# ── Header: Pedido ── %>
        <div class="card-header bg-white border-bottom py-3">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
              <%# Número de pedido — protagonista %>
              <span class="badge border px-3 py-2 fw-bold"
                    style="font-size:0.9rem; background:#fff8e1; color:#b45309; border-color:#fcd34d !important;">
                <i class="bi bi-receipt me-1"></i><%= delivery["order_number"] %>
              </span>
              <div>
                <div class="fw-semibold text-dark">
                  <%= delivery.dig("client", "name") %>
                </div>
                <div class="text-muted small">
                  <i class="bi bi-calendar3 me-1"></i>
                  <%= Date.parse(delivery["delivery_date"]).strftime("%d/%m/%Y") %>
                  <span class="ms-2">
                    <i class="bi bi-person-badge me-1"></i>Vendedor: <%= delivery["seller_code"] %>
                  </span>
                </div>
              </div>
            </div>
            <div class="d-flex align-items-center gap-2">
              <span class="badge border rounded-pill px-3 py-1 <%= status_cfg[:style] %>">
                <i class="bi <%= status_cfg[:icon] %> me-1"></i><%= status_cfg[:label] %>
              </span>
              <span class="badge bg-light text-secondary border">
                <i class="bi bi-truck me-1"></i><%= delivery["status_label"] %>
              </span>
            </div>
          </div>
        </div>

        <%# ── Items del pedido ── %>
        <div class="card-body p-0">
          <% delivery["items"].each_with_index do |item, idx| %>
            <% decoding = presenter.decoded(item["product_name"]) %>
            <div class="border-bottom <%= idx.even? ? '' : 'bg-light bg-opacity-50' %> px-4 py-3">
              <%# Producto comercial %>
              <div class="d-flex align-items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <span class="badge <%= decoding.has_variants ? 'bg-primary text-white' : 'bg-secondary text-white' %>"
                        style="font-size:0.75rem; min-width:36px; text-align:center;">
                    <%= item["quantity_delivered"] %>
                  </span>
                </div>
                <div class="flex-grow-1">
                  <%# Nombre del producto %>
                  <code class="text-dark fw-bold" style="font-size:0.85rem;">
                    <%= item["product_name"] %>
                  </code>
                  <% if decoding.base_product %>
                    <span class="badge bg-dark-subtle text-dark border ms-2" style="font-size:0.65rem;">
                      <i class="bi bi-box-seam me-1"></i><%= decoding.base_product.name %>
                    </span>
                  <% end %>

                  <%# ── Variantes y sus proveedores ── %>
                  <% if decoding.has_variants %>
                    <div class="mt-2 d-flex flex-column gap-1">
                      <% decoding.variants.each do |variant| %>
                        <% rule   = presenter.find_rule_in_cache(variant, decoding.base_product) %>
                        <% detail = presenter.details_for(delivery["order_number"], item["product_name"], rule&.supplier_item_id) %>
                        <div class="d-flex align-items-center gap-2 flex-wrap rounded px-2 py-1"
                             style="background:<%= rule ? '#f0fdf4' : '#fffbeb' %>; border: 1px solid <%= rule ? '#bbf7d0' : '#fde68a' %>;">
                          <%# Variante %>
                          <div style="min-width:160px;">
                            <span class="text-muted fw-bold" style="font-size:0.62rem; text-transform:uppercase; letter-spacing:0.04em;">
                              <%= variant.variant_type.name %>
                            </span>
                            <span class="text-dark fw-semibold small ms-1">
                              <%= variant.display_name.presence || variant.name %>
                            </span>
                            <% if variant.code.present? %>
                              <code class="text-muted ms-1" style="font-size:0.65rem;"><%= variant.code %></code>
                            <% end %>
                          </div>
                          <%# Flecha %>
                          <i class="bi bi-arrow-right text-muted" style="font-size:0.7rem;"></i>
                          <%# Pieza del proveedor %>
                          <% if rule %>
                            <div class="d-flex align-items-center gap-2">
                              <div>
                                <span class="fw-semibold text-dark small">
                                  <%= rule.supplier_item&.name %>
                                </span>
                                <span class="text-muted small ms-1">
                                  · <%= rule.supplier_item&.provider&.name %>
                                </span>
                              </div>
                              <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill"
                                    style="font-size:0.62rem;">
                                <%= detail[:quantity] %> <%= detail[:unit] %>
                              </span>
                            </div>
                          <% else %>
                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle"
                                  style="font-size:0.65rem;">
                              <i class="bi bi-exclamation-triangle me-1"></i>Sin regla configurada
                            </span>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <div class="mt-1">
                      <span class="badge bg-secondary-subtle text-secondary border" style="font-size:0.65rem;">
                        <i class="bi bi-dash me-1"></i>Sin variantes reconocidas
                      </span>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5 text-muted">
        <i class="bi bi-truck d-block fs-1 mb-3 opacity-25"></i>
        <p class="fw-bold mb-1">Sin datos de logística</p>
        <p class="small mb-0">No hay entregas para el rango de fechas seleccionado.</p>
      </div>
    </div>
  <% end %>
</div>
