<div class="d-flex justify-content-between align-items-center p-3 bg-white border-start border-4 border-primary shadow-sm rounded-top">
  <div>
    <h4 class="mb-0 fw-bold text-dark"><%= provider.name %></h4>
    <span class="badge bg-primary-subtle text-primary">
      <%= count %> piezas pendientes
    </span>
  </div>
  <%= submit_tag "Generar Orden de Compra",
        class: "btn btn-success fw-bold shadow-sm",
        data: { procurement_target: "submitBtn" } %>
</div>