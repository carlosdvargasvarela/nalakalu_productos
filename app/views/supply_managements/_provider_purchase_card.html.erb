<div class="card mb-4 shadow-sm border-0 overflow-hidden"
     data-controller="procurement"
     data-procurement-provider-id-value="<%= provider.id %>">
  <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
    <div>
      <h5 class="mb-0 fw-bold text-primary">
        <i class="bi bi-building me-2"></i><%= provider.name %>
      </h5>
      <small class="text-muted">Materiales pendientes de compra</small>
    </div>
    <%= form_tag create_purchase_order_supply_managements_path, method: :post do %>
      <%= hidden_field_tag :provider_id, provider.id %>
      <div data-procurement-target="hiddenContainer"></div>
      <button type="submit"
              data-procurement-target="submitBtn"
              disabled
              class="btn btn-primary fw-bold shadow-sm btn-sm px-4">
        Generar Orden de Compra
      </button>
    <% end %>
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="bg-light">
        <tr>
          <th width="50" class="text-center">
            <input type="checkbox"
                   class="form-check-input"
                   data-procurement-target="selectAll"
                   data-action="change->procurement#toggleAll">
          </th>
          <th>Pieza / Material</th>
          <th>Especificaciones</th>
          <th class="text-center">Cantidad Total</th>
          <th>Pedidos Origen</th>
        </tr>
      </thead>
      <tbody>
        <% items.each do |item| %>
          <tr>
            <td class="text-center">
              <input type="checkbox"
                     class="form-check-input"
                     value="<%= item[:requirement_ids].join(",") %>"
              data-procurement-target="check"
              data-action="change->procurement#toggleOne">
            </td>
            <td>
              <div class="fw-bold text-dark"><%= item[:supplier_item].name %></div>
              <code class="small text-muted">SKU: <%= item[:supplier_item].sku %></code>
            </td>
            <td>
              <% item[:specifications]&.each do |k, v| %>
                <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle rounded-pill">
                  <%= k %>: <%= v %>
                </span>
              <% end %>
            </td>
            <td class="text-center">
              <span class="h6 mb-0 fw-bold text-primary"><%= item[:total_quantity] %></span>
              <small class="text-muted d-block"><%= item[:supplier_item].unit %></small>
            </td>
            <td>
              <div class="d-flex flex-wrap gap-1">
                <% item[:origin_orders].each do |order| %>
                  <span class="badge bg-light text-dark border" style="font-size: 0.7rem;"><%= order %></span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>