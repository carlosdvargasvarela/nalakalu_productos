<%# app/views/supply_managements/_provider_purchase_card.html.erb %>
<div class="card mb-4 shadow-sm border-0 overflow-hidden"
     data-controller="procurement"
     data-procurement-provider-id-value="<%= provider.id %>">

  <%# ── HEADER DEL PROVEEDOR ── %>
  <div class="card-header bg-white border-bottom py-3">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h5 class="mb-0 fw-bold text-primary">
          <i class="bi bi-building me-2"></i><%= provider.name %>
        </h5>
        <small class="text-muted">
          <%= items.size %> <%= items.size == 1 ? "línea pendiente de compra" : "líneas pendientes de compra" %>
        </small>
      </div>
      <div class="d-flex align-items-center gap-3">
        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle px-3 py-2"
              data-procurement-target="grandTotal">
          ₡0,00
        </span>
        <%= form_tag create_purchase_order_supply_managements_path,
              method: :post,
              id: "oc-form-#{provider.id}" do %>
          <%= hidden_field_tag :provider_id, provider.id %>
          <div data-procurement-target="hiddenContainer"></div>
          <button type="button"
                  data-procurement-target="submitBtn"
                  data-action="click->procurement#openConfirmModal"
                  disabled
                  class="btn btn-primary fw-bold shadow-sm btn-sm px-4">
            <i class="bi bi-cart-check me-1"></i> Generar OC
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── TABLA DE MATERIALES ── %>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead style="background: #f8f9fa; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; color: #6c757d;">
        <tr>
          <th width="40" class="text-center ps-3 py-3">
            <input type="checkbox"
                   class="form-check-input"
                   data-procurement-target="selectAll"
                   data-action="change->procurement#toggleAll"
                   title="Seleccionar todos">
          </th>
          <th class="py-3 ps-1" style="min-width: 140px;">Pedido</th>
          <th class="py-3" style="min-width: 220px;">Material a comprar</th>
          <th class="py-3" style="min-width: 180px;">Producto solicitado</th>
          <th class="text-center py-3" style="min-width: 100px;">Cantidad</th>
          <th class="text-end py-3" style="min-width: 130px;">Precio unit.</th>
          <th class="text-end pe-4 py-3" style="min-width: 110px;">Total</th>
        </tr>
      </thead>
      <tbody>
        <% items.each do |item| %>
          <%
            order_number = item[:origin_orders].first
            origin       = Array(item[:origin_products]).first || {}
          %>
          <tr data-quantity="<%= item[:total_quantity] %>"
              class="border-bottom"
              style="border-left: 3px solid #dee2e6;">

            <%# ── Checkbox ── %>
            <td class="text-center ps-3">
              <input type="checkbox"
                     class="form-check-input"
                     value="<%= item[:requirement_ids].join(",") %>"
                     data-procurement-target="check"
                     data-action="change->procurement#toggleOne">
            </td>

            <%# ── PEDIDO — columna protagonista ── %>
            <td class="ps-1 py-3">
              <div class="d-flex flex-column gap-1">
                <span class="badge border px-2 py-1 fw-bold"
                      style="font-size: 0.8rem; background:#fff8e1; color:#b45309; border-color:#fcd34d !important; letter-spacing:0.01em;">
                  <i class="bi bi-receipt me-1"></i><%= order_number %>
                </span>
              </div>
            </td>

            <%# ── Material: nombre + SKU + specs ── %>
            <td class="py-3">
              <div class="fw-bold text-dark" data-item-name style="font-size:0.95rem;">
                <%= item[:supplier_item].name %>
              </div>
              <% if item[:supplier_item].sku.present? %>
                <code class="text-muted" style="font-size:0.7rem;" data-item-sku>
                  <%= item[:supplier_item].sku %>
                </code>
              <% end %>
              <% if item[:specifications].present? %>
                <div class="mt-1 d-flex flex-wrap gap-1">
                  <% item[:specifications].each do |spec| %>
                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle rounded-pill"
                          style="font-size:0.62rem;"
                          data-item-spec>
                      <%= spec["label"] || spec[:label] %>: <%= spec["value"] || spec[:value] %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </td>

            <%# ── Producto solicitado ── %>
            <td class="py-3">
              <% if origin[:product_name].present? && origin[:product_name] != "—" %>
                <div class="d-flex flex-column gap-1">
                  <span class="text-dark small fw-semibold" data-origin-product>
                    <i class="bi bi-box-seam text-secondary me-1"></i><%= origin[:product_name] %>
                  </span>
                  <span class="text-muted" style="font-size:0.72rem;">
                    <%= origin[:quantity] %> <%= item[:supplier_item].unit %>
                    necesarios para este pedido
                  </span>
                </div>
              <% else %>
                <span class="text-muted small">—</span>
              <% end %>
            </td>

            <%# ── Cantidad ── %>
            <td class="text-center py-3">
              <span class="fw-bold text-primary fs-6" data-item-qty>
                <%= item[:total_quantity] %>
              </span>
              <small class="text-muted d-block" data-item-unit>
                <%= item[:supplier_item].unit %>
              </small>
            </td>

            <%# ── Precio editable ── %>
            <td class="text-end py-3">
              <div class="input-group input-group-sm justify-content-end" style="max-width: 140px; margin-left: auto;">
                <span class="input-group-text bg-light border-end-0 text-muted" style="font-size:0.75rem;">₡</span>
                <input type="text"
                       class="form-control border-start-0 text-end fw-bold"
                       style="font-size:0.85rem; max-width:100px;"
                       value="<%= number_with_delimiter(item[:supplier_item].default_cost&.to_i || 0, delimiter: ".") %>"
                       placeholder="0"
                       data-price-input
                       data-procurement-target="priceInput"
                       data-action="input->procurement#updatePrice">
              </div>
            </td>

            <%# ── Total línea ── %>
            <td class="text-end pe-4 py-3">
              <%
                default_cost = item[:supplier_item].default_cost&.to_f || 0
                line_total   = item[:total_quantity].to_f * default_cost
              %>
              <span class="fw-bold text-dark" data-line-total>
                ₡<%= number_with_delimiter(line_total.round(2), delimiter: ".", separator: ",") %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# ── MODAL DE CONFIRMACIÓN ── %>
  <div class="modal fade" id="confirmModal-<%= provider.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content border-0 shadow-lg">
        <div class="modal-header border-0 pb-0 pt-4 px-4">
          <div>
            <h5 class="modal-title fw-bold mb-0">
              <i class="bi bi-cart-check me-2 text-primary"></i>Confirmar Orden de Compra
            </h5>
            <p class="text-muted small mb-0 mt-1">
              <i class="bi bi-building me-1"></i><%= provider.name %>
            </p>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body px-4 py-3">
          <div class="alert alert-info border-0 py-2 px-3 mb-3" style="font-size:0.8rem;">
            <i class="bi bi-info-circle me-1"></i>
            La OC quedará en <strong>Borrador</strong>. Podés ajustar costos antes de enviarla al proveedor.
          </div>
          <div data-procurement-target="modalBody"></div>
        </div>
        <div class="modal-footer border-0 bg-light px-4 py-3">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
            <i class="bi bi-x me-1"></i> Cancelar
          </button>
          <button type="button"
                  class="btn btn-primary fw-bold px-4"
                  data-action="click->procurement#confirmSubmit">
            <i class="bi bi-check2 me-1"></i> Confirmar y Generar OC
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
