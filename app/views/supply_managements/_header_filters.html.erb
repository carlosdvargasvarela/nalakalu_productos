<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 fw-bold mb-0">
      <i class="bi bi-cpu-fill text-primary me-2"></i>
      Centro de Abastecimiento
    </h1>
    <p class="text-muted small mb-0">
      Sincronización automática con Logística
    </p>
  </div>
  <%= form_with url: supply_managements_path, method: :get, class: "d-flex gap-2" do |f| %>
    <%= f.date_field :from, value: @from, class: "form-control form-control-sm" %>
    <%= f.date_field :to, value: @to, class: "form-control form-control-sm" %>
    <%= f.submit "Filtrar", class: "btn btn-primary btn-sm px-3" %>
  <% end %>
</div>