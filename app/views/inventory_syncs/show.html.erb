<div data-controller="sync-review"
     data-sync-review-quick-create-url-value="<%= inventory_quick_create_product_path %>">

<%# ── HEADER ──────────────────────────────────────────────────────────────── %>
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div>
    <h1 class="fw-bold mb-1">
      <i class="bi bi-arrow-repeat me-2 text-primary"></i>Revisión de Sincronización
    </h1>
    <p class="text-muted mb-0">
      Rango: <strong><%= @sync.from_date.strftime("%d/%m/%Y") %></strong> –
      <strong><%= @sync.to_date.strftime("%d/%m/%Y") %></strong>
      &nbsp;·&nbsp; <%= @sync.deliveries_processed %> entregas procesadas
      &nbsp;·&nbsp; <strong><%= @sync.movements_count %></strong> movimientos detectados
    </p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <%= link_to inventory_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="bi bi-arrow-left me-1"></i>Volver
    <% end %>
    <% if @sync.confirmable? %>
      <%= button_to confirm_inventory_sync_path(@sync), method: :patch,
            class: "btn btn-success",
            data: { turbo_confirm: "¿Confirmar esta sincronización? Los movimientos afectarán el stock en tiempo real." } do %>
        <i class="bi bi-check-circle me-1"></i>Confirmar y aplicar al inventario
      <% end %>
    <% else %>
      <button class="btn btn-success" disabled title="Resuelve todos los ítems pendientes primero">
        <i class="bi bi-check-circle me-1"></i>Confirmar
      </button>
    <% end %>
    <%= button_to inventory_sync_path(@sync), method: :delete,
          class: "btn btn-outline-danger btn-sm",
          data: { turbo_confirm: "¿Eliminar esta sincronización? Se perderán todos los movimientos del lote." } do %>
      <i class="bi bi-trash me-1"></i>Eliminar
    <% end %>
  </div>
</div>

<%# ── RESUMEN DE ESTADOS ──────────────────────────────────────────────────── %>
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card border-0 text-center shadow-sm h-100 <%= @stat_confirmed > 0 ? 'bg-success-subtle' : 'bg-light' %>">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold <%= @stat_confirmed > 0 ? 'text-success' : 'text-muted' %>"><%= @stat_confirmed %></div>
        <div class="small fw-semibold <%= @stat_confirmed > 0 ? 'text-success-emphasis' : 'text-muted' %>">
          <i class="bi bi-check-circle me-1"></i>Confirmados
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-0 text-center shadow-sm h-100 <%= @stat_suggested > 0 ? 'bg-info-subtle' : 'bg-light' %>">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold <%= @stat_suggested > 0 ? 'text-info-emphasis' : 'text-muted' %>"><%= @stat_suggested %></div>
        <div class="small fw-semibold <%= @stat_suggested > 0 ? 'text-info-emphasis' : 'text-muted' %>">
          <i class="bi bi-lightbulb me-1"></i>Sugeridos
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-0 text-center shadow-sm h-100 <%= @stat_unassigned > 0 ? 'bg-warning-subtle' : 'bg-light' %>">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold <%= @stat_unassigned > 0 ? 'text-warning-emphasis' : 'text-muted' %>"><%= @stat_unassigned %></div>
        <div class="small fw-semibold <%= @stat_unassigned > 0 ? 'text-warning-emphasis' : 'text-muted' %>">
          <i class="bi bi-question-circle me-1"></i>Sin asignar
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-0 text-center shadow-sm h-100 bg-light">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold text-muted"><%= @stat_ignored %></div>
        <div class="small fw-semibold text-muted">
          <i class="bi bi-eye-slash me-1"></i>Ignorados
        </div>
      </div>
    </div>
  </div>
</div>

<%# ── ALERTA: CONFIRMAR SUGERIDOS EN LOTE ────────────────────────────────── %>
<% if @stat_suggested > 0 %>
  <div class="alert alert-info d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <i class="bi bi-lightbulb-fill me-2"></i>
      <strong><%= @stat_suggested %> movimiento(s)</strong> tienen producto detectado automáticamente.
      Revisa y confirma individualmente o usa el botón para aprobarlos todos.
    </div>
    <%= button_to confirm_matched_inventory_sync_path(@sync), method: :patch,
          class: "btn btn-info btn-sm text-white",
          data: { turbo_confirm: "¿Confirmar todos los movimientos con producto detectado?" } do %>
      <i class="bi bi-check-all me-1"></i>Confirmar todos los sugeridos (<%= @stat_suggested %>)
    <% end %>
  </div>
<% end %>

<%# ── ALERTA: TODO LISTO ───────────────────────────────────────────────────── %>
<% if @sync.confirmable? %>
  <div class="alert alert-success mb-4">
    <i class="bi bi-check-circle-fill me-2"></i>
    Todos los movimientos están revisados. Puedes confirmar la sincronización y aplicarla al inventario.
  </div>
<% end %>

<%# ── GRUPOS DE MOVIMIENTOS ───────────────────────────────────────────────── %>
<% @movement_groups.each do |order_number, movements| %>
  <% exits            = movements.select { |m| m.movement_type == "exit" } %>
  <% entries          = movements.select { |m| m.movement_type == "entry" } %>
  <% is_transfer      = exits.any? && entries.any? %>
  <% group_date       = movements.first&.delivery_date %>
  <% pending_count    = movements.count { |m| m.status == "unresolved" } %>
  <% client_name      = movements.first&.client_name %>
  <% delivery_status  = movements.first&.delivery_status %>
  <% delivery_badge   = case delivery_status&.downcase
      when /entregad|delivered/   then "bg-success"
      when /cancelad|cancelled/   then "bg-danger"
      when /parcial|partial/      then "bg-warning text-dark"
      when /transit|en_ruta/      then "bg-info text-dark"
      else                             "bg-secondary"
     end %>

  <div class="card border-0 shadow-sm mb-3">
    <%# ── Cabecera del grupo ──────────────────────────────────────── %>
    <div class="card-header py-3 d-flex justify-content-between align-items-center flex-wrap gap-2
                <%= is_transfer ? 'bg-primary-subtle' : (entries.any? ? 'bg-success-subtle' : 'bg-danger-subtle') %>">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <% if is_transfer %>
          <i class="bi bi-arrow-left-right fs-5 text-primary"></i>
          <strong class="text-primary-emphasis">Transferencia entre salas</strong>
          <span class="badge bg-primary"><%= exits.first&.showroom&.name || "?" %></span>
          <i class="bi bi-arrow-right text-primary"></i>
          <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle">
            <%= entries.first&.showroom&.name || "?" %>
          </span>
        <% elsif entries.any? %>
          <i class="bi bi-arrow-down-circle fs-5 text-success"></i>
          <strong class="text-success-emphasis">Entrada</strong>
          <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">
            <%= entries.first&.showroom&.name || "?" %>
          </span>
        <% else %>
          <i class="bi bi-arrow-up-circle fs-5 text-danger"></i>
          <strong class="text-danger-emphasis">Salida</strong>
          <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">
            <%= exits.first&.showroom&.name || "?" %>
          </span>
        <% end %>
        <span class="text-muted small">
          <%= group_date&.strftime("%d/%m/%Y") %>
          &middot; <code class="small"><%= order_number %></code>
          <% if client_name.present? %>
            &middot; <i class="bi bi-person me-1"></i><%= client_name %>
          <% end %>
        </span>
        <% if delivery_status.present? %>
          <span class="badge <%= delivery_badge %> ms-1">
            <i class="bi bi-truck me-1"></i><%= delivery_status %>
          </span>
        <% end %>
      </div>
      <% if pending_count > 0 %>
        <span class="badge bg-warning text-dark">
          <i class="bi bi-clock me-1"></i><%= pending_count %> pendiente(s)
        </span>
      <% else %>
        <span class="badge bg-success">
          <i class="bi bi-check-lg me-1"></i>Completo
        </span>
      <% end %>
    </div>

    <%# ── Tabla de movimientos del grupo ────────────────────────── %>
    <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Nombre recibido</th>
            <th>Tipo</th>
            <% if is_transfer %><th>Sala</th><% end %>
            <th class="text-center">Cant.</th>
            <th style="min-width: 300px">Producto a confirmar</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% movements.each do |m| %>
            <%
              row_class = case m.status
                when "resolved" then "table-success"
                when "ignored"  then "table-secondary opacity-75"
                else m.product_id.present? ? "table-info" : "table-warning"
              end
            %>
            <tr class="<%= row_class %>">
              <td><code class="small text-dark"><%= m.product_name_raw %></code></td>
              <td>
                <span class="badge <%= m.movement_type == 'entry' ? 'bg-success' : 'bg-danger' %>">
                  <%= m.type_label %>
                </span>
              </td>
              <% if is_transfer %>
                <td><small class="text-muted"><%= m.showroom&.name %></small></td>
              <% end %>
              <td class="text-center fw-semibold"><%= m.quantity %></td>
              <td>
                <% if m.status == "resolved" %>
                  <span class="text-success-emphasis fw-semibold">
                    <i class="bi bi-check-circle-fill me-1"></i><%= m.product&.name || "—" %>
                  </span>
                <% elsif m.status == "ignored" %>
                  <span class="text-muted fst-italic small">
                    <i class="bi bi-eye-slash me-1"></i>Ignorado — no afectará el stock
                  </span>
                <% else %>
                  <%= form_with url: inventory_movement_path(m), method: :patch,
                        class: "d-flex gap-1 align-items-center" do |f| %>
                    <%= select_tag "inventory_movement[product_id]",
                          options_for_select(@products_for_select.map { |p| [p.name, p.id] }, m.product_id),
                          include_blank: "— Seleccionar —",
                          class: "form-select form-select-sm",
                          data: { "sync-review-target": "productSelect" } %>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary text-nowrap"
                            title="Crear producto nuevo"
                            data-action="click->sync-review#openQuickCreate">
                      <i class="bi bi-plus-lg"></i>
                    </button>
                    <button type="submit"
                            class="btn btn-sm <%= m.product_id.present? ? 'btn-primary' : 'btn-success' %> text-nowrap">
                      <i class="bi bi-check-lg"></i>
                      <%= m.product_id.present? ? "Confirmar" : "Asignar" %>
                    </button>
                  <% end %>
                <% end %>
              </td>
              <td class="text-end">
                <% if m.status == "unresolved" %>
                  <%= button_to inventory_movement_path(m), method: :patch,
                        params: { ignore: true },
                        class: "btn btn-sm btn-outline-secondary",
                        title: "Ignorar este movimiento",
                        data: { turbo_confirm: "¿Ignorar este ítem? No afectará el inventario." } do %>
                    <i class="bi bi-eye-slash"></i>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
  </div>
<% end %>

<% if @movement_groups.empty? %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
    Esta sincronización no tiene movimientos registrados.
  </div>
<% end %>

<%# ── MODAL: CREAR PRODUCTO RÁPIDO ───────────────────────────────────────── %>
<div class="modal fade" id="quickCreateProductModal" tabindex="-1"
     aria-labelledby="quickCreateProductModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="quickCreateProductModalLabel">
          <i class="bi bi-plus-circle me-2 text-primary"></i>Nuevo producto
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-danger d-none small py-2"
             data-sync-review-target="quickCreateError"></div>
        <div class="mb-3">
          <label class="form-label fw-semibold">
            Nombre <span class="text-danger">*</span>
          </label>
          <input type="text" class="form-control"
                 placeholder="Ej: Sofá 3 plazas gris"
                 data-sync-review-target="newProductName">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">
            Código base <span class="text-danger">*</span>
          </label>
          <input type="text" class="form-control font-monospace"
                 placeholder="Ej: SOF-3P-GR"
                 data-sync-review-target="newProductCode">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Familia</label>
          <select class="form-select" data-sync-review-target="newProductFamily">
            <option value="">— Sin familia —</option>
            <% @families.each do |f| %>
              <option value="<%= f.id %>"><%= f.name %></option>
            <% end %>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary"
                data-action="click->sync-review#submitQuickCreate">
          <i class="bi bi-check-lg me-1"></i>Crear y seleccionar
        </button>
      </div>
    </div>
  </div>
</div>

</div><%# cierre data-controller="sync-review" %>
