<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="fw-bold mb-1"><i class="bi bi-lightbulb me-2 text-warning"></i>Recomendaciones</h1>
    <p class="text-muted mb-0">Solicitudes de nuevas variantes o asociaciones de tipo a producto.</p>
  </div>
</div>

<%# TABS %>
<ul class="nav nav-tabs mb-4" id="recommendationTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending-pane" type="button" role="tab">
      Pendientes
      <% if @pending.any? %><span class="badge bg-warning text-dark ms-1"><%= @pending.size %></span><% end %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="approved-tab" data-bs-toggle="tab" data-bs-target="#approved-pane" type="button" role="tab">
      Aprobadas
      <span class="badge bg-success ms-1"><%= @approved.size %></span>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="rejected-tab" data-bs-toggle="tab" data-bs-target="#rejected-pane" type="button" role="tab">
      Rechazadas
      <span class="badge bg-secondary ms-1"><%= @rejected.size %></span>
    </button>
  </li>
</ul>

<div class="tab-content" id="recommendationTabsContent">

  <%# TAB PENDIENTES %>
  <div class="tab-pane fade show active" id="pending-pane" role="tabpanel">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <% if @pending.empty? %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-check-circle-fill fs-2 text-success mb-2 d-block"></i>No hay recomendaciones pendientes.
          </div>
        <% else %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Tipo</th><th>Tipo de variante</th><th>Detalle</th><th>Solicitante</th><th>Notas</th><th>Fecha</th><th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% @pending.each do |rec| %>
                  <tr id="recommendation_<%= rec.id %>">
                    <td>
                      <% if rec.recommendation_type == "new_variant" %>
                        <span class="badge bg-info text-dark"><i class="bi bi-plus-circle me-1"></i>Nueva variante</span>
                      <% else %>
                        <span class="badge bg-primary"><i class="bi bi-link-45deg me-1"></i>Asociar tipo</span>
                      <% end %>
                    </td>
                    <td class="fw-semibold"><%= rec.variant_type.name %></td>
                    <td>
                      <% if rec.recommendation_type == "new_variant" %>
                        <div><span class="text-muted small">Nombre:</span> <strong><%= rec.suggested_variant_name %></strong></div>
                        <% if rec.suggested_variant_code.present? %>
                          <div><span class="text-muted small">Código:</span> <code><%= rec.suggested_variant_code %></code></div>
                        <% end %>
                      <% else %>
                        <div><span class="text-muted small">Producto:</span> <strong><%= rec.product&.name %></strong></div>
                      <% end %>
                    </td>
                    <td><%= rec.requester_name.presence || "<span class='text-muted'>—</span>".html_safe %></td>
                    <td class="text-muted small" style="max-width:200px;"><%= rec.notes.presence || "—" %></td>
                    <td class="text-muted small"><%= rec.created_at.strftime("%d/%m/%Y") %></td>
                    <td class="text-end">
                      <div class="d-flex gap-1 justify-content-end">
                        <%= button_to "Aprobar", approve_recommendation_path(rec), method: :patch,
                              class: "btn btn-sm btn-success",
                              data: { turbo_confirm: "¿Aplicar esta recomendación automáticamente?" } %>
                        <%= button_to "Rechazar", reject_recommendation_path(rec), method: :patch,
                              class: "btn btn-sm btn-outline-danger" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# TAB APROBADAS %>
  <div class="tab-pane fade" id="approved-pane" role="tabpanel">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <% if @approved.empty? %>
          <div class="text-center text-muted py-4 small">Sin recomendaciones aprobadas aún.</div>
        <% else %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0 table-hover">
              <thead class="table-light">
                <tr><th>Tipo de variante</th><th>Detalle</th><th>Solicitante</th><th>Fecha</th></tr>
              </thead>
              <tbody>
                <% @approved.each do |rec| %>
                  <tr>
                    <td><span class="badge bg-success me-1"><i class="bi bi-check me-1"></i>OK</span> <%= rec.variant_type.name %></td>
                    <td>
                      <% if rec.recommendation_type == "new_variant" %>
                        <strong><%= rec.suggested_variant_name %></strong>
                        <% if rec.suggested_variant_code.present? %><code class="ms-1 text-muted small">(<%= rec.suggested_variant_code %>)</code><% end %>
                      <% else %>
                        <%= rec.product&.name %>
                      <% end %>
                    </td>
                    <td class="text-muted small"><%= rec.requester_name.presence || "—" %></td>
                    <td class="text-muted small"><%= rec.created_at.strftime("%d/%m/%Y") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# TAB RECHAZADAS %>
  <div class="tab-pane fade" id="rejected-pane" role="tabpanel">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <% if @rejected.empty? %>
          <div class="text-center text-muted py-4 small">Sin recomendaciones rechazadas.</div>
        <% else %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0 table-hover">
              <thead class="table-light">
                <tr><th>Tipo de variante</th><th>Detalle</th><th>Solicitante</th><th>Fecha</th></tr>
              </thead>
              <tbody>
                <% @rejected.each do |rec| %>
                  <tr>
                    <td><span class="badge bg-secondary me-1"><i class="bi bi-x me-1"></i></span> <%= rec.variant_type.name %></td>
                    <td>
                      <% if rec.recommendation_type == "new_variant" %>
                        <strong><%= rec.suggested_variant_name %></strong>
                      <% else %>
                        <%= rec.product&.name %>
                      <% end %>
                    </td>
                    <td class="text-muted small"><%= rec.requester_name.presence || "—" %></td>
                    <td class="text-muted small"><%= rec.created_at.strftime("%d/%m/%Y") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
