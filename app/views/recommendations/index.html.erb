<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="fw-bold mb-1"><i class="bi bi-lightbulb me-2 text-warning"></i>Recomendaciones</h1>
    <p class="text-muted mb-0">Solicitudes de nuevas variantes o asociaciones de tipo a producto.</p>
  </div>
</div>

<%# PENDIENTES %>
<div class="card border-0 shadow-sm mb-5">
  <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
    <h5 class="mb-0 fw-bold">
      <i class="bi bi-hourglass-split text-warning me-2"></i>Pendientes
    </h5>
    <span class="badge bg-warning text-dark"><%= @pending.size %></span>
  </div>
  <div class="card-body p-0">
    <% if @pending.empty? %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-check-circle-fill fs-2 text-success mb-2 d-block"></i>
        No hay recomendaciones pendientes.
      </div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Tipo</th>
              <th>Tipo de variante</th>
              <th>Detalle</th>
              <th>Solicitante</th>
              <th>Notas</th>
              <th>Fecha</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @pending.each do |rec| %>
              <tr id="recommendation_<%= rec.id %>">
                <td>
                  <% if rec.recommendation_type == "new_variant" %>
                    <span class="badge bg-info text-dark"><i class="bi bi-plus-circle me-1"></i>Nueva variante</span>
                  <% else %>
                    <span class="badge bg-primary"><i class="bi bi-link-45deg me-1"></i>Asociar tipo</span>
                  <% end %>
                </td>
                <td class="fw-semibold"><%= rec.variant_type.name %></td>
                <td>
                  <% if rec.recommendation_type == "new_variant" %>
                    <div><span class="text-muted small">Nombre:</span> <strong><%= rec.suggested_variant_name %></strong></div>
                    <% if rec.suggested_variant_code.present? %>
                      <div><span class="text-muted small">Código:</span> <code><%= rec.suggested_variant_code %></code></div>
                    <% end %>
                  <% else %>
                    <div><span class="text-muted small">Producto:</span> <strong><%= rec.product&.name %></strong></div>
                  <% end %>
                </td>
                <td><%= rec.requester_name.presence || "<span class='text-muted'>—</span>".html_safe %></td>
                <td class="text-muted small" style="max-width:200px;"><%= rec.notes.presence || "—" %></td>
                <td class="text-muted small"><%= rec.created_at.strftime("%d/%m/%Y") %></td>
                <td class="text-end">
                  <div class="d-flex gap-1 justify-content-end">
                    <%= button_to "Aprobar", approve_recommendation_path(rec), method: :patch,
                          class: "btn btn-sm btn-success",
                          data: { turbo_confirm: "¿Aplicar esta recomendación automáticamente?" } %>
                    <%= button_to "Rechazar", reject_recommendation_path(rec), method: :patch,
                          class: "btn btn-sm btn-outline-danger" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>

<%# HISTORIAL %>
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
    <h5 class="mb-0 fw-bold text-muted">
      <i class="bi bi-archive me-2"></i>Historial
    </h5>
    <span class="badge bg-secondary"><%= @resolved.size %></span>
  </div>
  <div class="card-body p-0">
    <% if @resolved.empty? %>
      <div class="text-center text-muted py-4 small">Sin historial aún.</div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0 table-hover">
          <thead class="table-light">
            <tr>
              <th>Estado</th>
              <th>Tipo</th>
              <th>Tipo de variante</th>
              <th>Detalle</th>
              <th>Solicitante</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            <% @resolved.each do |rec| %>
              <tr>
                <td>
                  <% if rec.status == "approved" %>
                    <span class="badge bg-success"><i class="bi bi-check me-1"></i>Aprobada</span>
                  <% else %>
                    <span class="badge bg-secondary"><i class="bi bi-x me-1"></i>Rechazada</span>
                  <% end %>
                </td>
                <td class="text-muted small"><%= rec.type_label %></td>
                <td><%= rec.variant_type.name %></td>
                <td>
                  <% if rec.recommendation_type == "new_variant" %>
                    <strong><%= rec.suggested_variant_name %></strong>
                    <% if rec.suggested_variant_code.present? %>
                      <code class="ms-1 text-muted small">(<%= rec.suggested_variant_code %>)</code>
                    <% end %>
                  <% else %>
                    <%= rec.product&.name %>
                  <% end %>
                </td>
                <td class="text-muted small"><%= rec.requester_name.presence || "—" %></td>
                <td class="text-muted small"><%= rec.created_at.strftime("%d/%m/%Y") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
