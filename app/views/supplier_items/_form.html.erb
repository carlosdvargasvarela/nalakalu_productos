<%
  fixed_properties = supplier_item.supplier_item_properties.to_a.select { |sip| sip.spec_type == "property" }
  specs = supplier_item.supplier_item_properties.to_a.select { |sip| sip.spec_type == "spec" }
  cancel_path = supplier_item.persisted? ? supplier_item_path(supplier_item) : supplier_items_path
  cancel_data = supplier_item.persisted? ? { turbo_frame: "supplier_item_workspace" } : { turbo_frame: "_top" }
%>
<%= form_with(
  model: supplier_item,
  data: {
    controller: "supplier-item-specs",
    turbo_frame: "_top"
  }
) do |f| %>
  <% if supplier_item.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold mb-2">
        <i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar
      </h6>
      <ul class="mb-0 ps-3 small">
        <% supplier_item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 5rem;">
        <div class="card-body p-4">
          <h6 class="fw-bold text-uppercase text-muted small mb-3">
            <i class="bi bi-box-seam-fill me-2 text-primary"></i>Resumen de la pieza
          </h6>
          <div class="mb-3">
            <%= f.label :provider_id, "Proveedor", class: "form-label fw-semibold small text-muted" %>
            <%= f.collection_select :provider_id,
              Provider.order(:name),
              :id, :name,
              { prompt: "Seleccionar proveedor..." },
              { class: "form-select border-2 shadow-none" } %>
          </div>
          <div class="mb-3">
            <%= f.label :name, "Nombre", class: "form-label fw-semibold small text-muted" %>
            <%= f.text_field :name,
              class: "form-control border-2 shadow-none",
              placeholder: "Nombre de la pieza",
              data: { action: "input->supplier-item-specs#updatePreview" } %>
          </div>
          <div class="mb-3">
            <%= f.label :sku, "SKU", class: "form-label fw-semibold small text-muted" %>
            <%= f.text_field :sku,
              class: "form-control border-2 font-monospace shadow-none",
              placeholder: "SKU",
              data: { action: "input->supplier-item-specs#updatePreview" } %>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-7">
              <%= f.label :unit, "Unidad", class: "form-label fw-semibold small text-muted" %>
              <%= f.select :unit,
                SupplierItem::UNITS.map { |u| [u.capitalize, u] },
                {},
                {
                  class: "form-select border-2 shadow-none",
                  data: { action: "change->supplier-item-specs#updatePreview" }
                } %>
            </div>
            <div class="col-5">
              <%= f.label :default_cost, "Costo ref.", class: "form-label fw-semibold small text-muted" %>
              <%= f.number_field :default_cost,
                step: 0.01,
                min: 0,
                class: "form-control border-2 shadow-none",
                placeholder: "₡0.00" %>
            </div>
          </div>
          <div class="form-check form-switch mb-4">
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, "Pieza activa", class: "form-check-label fw-semibold small" %>
          </div>
          <div class="rounded-4 bg-light p-3 mb-4">
            <p class="small text-muted mb-1 fw-semibold">Vista previa de configuración</p>
            <pre class="small text-dark mb-0 font-monospace" data-supplier-item-specs-target="previewText"><%= supplier_item.name.presence || "—" %></pre>
          </div>
          <% if supplier_item.persisted? %>
            <div class="rounded-4 border p-3 mb-4">
              <p class="small text-uppercase text-muted fw-bold mb-2">Estado rápido</p>
              <div class="d-flex flex-column gap-2 small">
                <div class="d-flex justify-content-between">
                  <span class="text-muted">Propiedades</span>
                  <span class="fw-semibold"><%= fixed_properties.size %></span>
                </div>
                <div class="d-flex justify-content-between">
                  <span class="text-muted">Specs</span>
                  <span class="fw-semibold"><%= specs.size %></span>
                </div>
                <div class="d-flex justify-content-between">
                  <span class="text-muted">Reglas</span>
                  <span class="fw-semibold"><%= supplier_item.supply_rules.size %></span>
                </div>
              </div>
            </div>
          <% end %>
          <div class="d-grid gap-2">
            <%= f.submit(
              supplier_item.persisted? ? "Guardar cambios" : "Crear pieza",
              class: "btn btn-primary fw-bold"
            ) %>
            <%= link_to cancel_path, class: "btn btn-outline-secondary", data: cancel_data do %>
              Cancelar
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 px-4 border-bottom">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="fw-bold mb-0">Propiedades fijas</h6>
              <p class="text-muted small mb-0">
                Atributos estructurales del item comprado al proveedor.
              </p>
            </div>
            <button
              type="button"
              class="btn btn-sm btn-outline-primary rounded-pill"
              data-action="click->supplier-item-specs#addProperty">
              <i class="bi bi-plus-lg me-1"></i>Agregar
            </button>
          </div>
        </div>
        <div class="card-body p-4" data-supplier-item-specs-target="propertiesList">
          <% if fixed_properties.any? %>
            <% fixed_properties.each do |sip| %>
              <div class="spec-row border rounded-4 p-3 mb-3">
                <div class="d-flex justify-content-between align-items-start gap-3">
                  <div class="flex-grow-1">
                    <label class="form-label fw-semibold small text-muted">
                      <%= sip.property_value.property.name %>
                    </label>
                    <select
                      name="property_value_ids[<%= sip.property_value.property_id %>]"
                      class="form-select shadow-none"
                      data-action="change->supplier-item-specs#updatePreview">
                      <% sip.property_value.property.property_values.each do |pv| %>
                        <option value="<%= pv.id %>" <%= "selected" if pv.id == sip.property_value_id %>>
                          <%= pv.value %>
                        </option>
                        <% end %>
                      </select>
                    </div>
                    <button
                    type="button"
                    class="btn btn-outline-danger btn-sm mt-4"
                    data-action="click->supplier-item-specs#removeProperty">
                      <i class="bi bi-x-lg"></i>
                    </button>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="text-center text-muted py-4 border rounded-4 bg-light">
                <i class="bi bi-sliders fs-3 d-block mb-2"></i>
                <p class="mb-1 fw-semibold">No hay propiedades configuradas</p>
                <p class="small mb-0">Agrega atributos como material, acabado, medida o color.</p>
              </div>
            <% end %>
          </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-header bg-white py-3 px-4 border-bottom">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="fw-bold mb-0">Especificaciones dinámicas</h6>
                <p class="text-muted small mb-0">
                  Labels permitidos para procurement consolidado, por ejemplo: F1, F2, F3.
                </p>
              </div>
              <button
              type="button"
              class="btn btn-sm btn-outline-info rounded-pill"
              data-action="click->supplier-item-specs#addSpec">
                <i class="bi bi-plus-lg me-1"></i>Agregar
              </button>
            </div>
          </div>
          <div class="card-body p-4" data-supplier-item-specs-target="specList">
            <% if specs.any? %>
              <% specs.each do |spec| %>
                <div class="spec-row border rounded-4 p-3 mb-3">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div class="flex-grow-1">
                      <label class="form-label fw-semibold small text-muted">Label permitida</label>
                      <input
                      type="text"
                      name="spec_labels[]"
                      value="<%= spec.label %>"
                      class="form-control shadow-none"
                      placeholder="Ej: F1"
                      data-action="input->supplier-item-specs#updatePreview">
                      </div>
                      <button
                    type="button"
                    class="btn btn-outline-danger btn-sm mt-4"
                    data-action="click->supplier-item-specs#removeSpec">
                        <i class="bi bi-x-lg"></i>
                      </button>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <div class="text-center text-muted py-4 border rounded-4 bg-light">
                  <i class="bi bi-tags fs-3 d-block mb-2"></i>
                  <p class="mb-1 fw-semibold">No hay specs configuradas</p>
                  <p class="small mb-0">Úsalas cuando este item participe en reglas consolidadas.</p>
                </div>
              <% end %>
            </div>
          </div>
          <% if supplier_item.persisted? %>
            <div class="card border-0 shadow-sm rounded-4">
              <div class="card-header bg-white py-3 px-4 border-bottom">
                <h6 class="fw-bold mb-0">Impacto actual</h6>
              </div>
              <div class="card-body p-4">
                <div class="row g-3">
                  <div class="col-md-4">
                    <div class="rounded-4 border bg-light p-3 h-100">
                      <p class="small text-uppercase text-muted fw-bold mb-1">Reglas</p>
                      <h5 class="mb-0 fw-bold"><%= supplier_item.supply_rules.size %></h5>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="rounded-4 border bg-light p-3 h-100">
                      <p class="small text-uppercase text-muted fw-bold mb-1">Propiedades</p>
                      <h5 class="mb-0 fw-bold"><%= fixed_properties.size %></h5>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="rounded-4 border bg-light p-3 h-100">
                      <p class="small text-uppercase text-muted fw-bold mb-1">Specs</p>
                      <h5 class="mb-0 fw-bold"><%= specs.size %></h5>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <template data-supplier-item-specs-target="propertyTemplate">
        <div class="spec-row border rounded-4 p-3 mb-3">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div class="flex-grow-1">
              <label class="form-label fw-semibold small text-muted">Propiedad</label>
              <select
            class="form-select shadow-none property-group-select"
            data-action="change->supplier-item-specs#propertyChanged">
                <option value="">— Seleccionar —</option>
                <% @properties.each do |prop| %>
                  <optgroup label="<%= prop.name %>">
                    <% prop.property_values.each do |pv| %>
                      <option value="<%= pv.id %>" data-property-id="<%= prop.id %>">
                        <%= pv.value %>
                      </option>
                    <% end %>
                  </optgroup>
                <% end %>
              </select>
            </div>
            <button
          type="button"
          class="btn btn-outline-danger btn-sm mt-4"
          data-action="click->supplier-item-specs#removeProperty">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        </div>
      </template>
      <template data-supplier-item-specs-target="specTemplate">
        <div class="spec-row border rounded-4 p-3 mb-3">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div class="flex-grow-1">
              <label class="form-label fw-semibold small text-muted">Label permitida</label>
              <input
            type="text"
            name="spec_labels[]"
            class="form-control shadow-none"
            placeholder="Ej: F1"
            data-action="input->supplier-item-specs#updatePreview">
              </div>
              <button
          type="button"
          class="btn btn-outline-danger btn-sm mt-4"
          data-action="click->supplier-item-specs#removeSpec">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
          </div>
        </template>
      <% end %>