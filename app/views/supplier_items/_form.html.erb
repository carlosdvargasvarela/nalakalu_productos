<%= form_with(model: supplier_item, data: { controller: "supplier-item-specs" }) do |f| %>
  <% if supplier_item.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold">
        <i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar:
      </h6>
      <ul class="mb-0 ps-3 small">
        <% supplier_item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <!-- ───────── IZQUIERDA ───────── -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 5rem; z-index: 1000;">        
        <div class="card-body p-4">
          <h6 class="fw-bold text-uppercase text-muted small mb-3">
            <i class="bi bi-box-seam-fill me-2 text-primary"></i>Datos Base
          </h6>
          <div class="mb-3">
            <%= f.collection_select :provider_id,
                  Provider.where(active: true).order(:name),
                  :id, :name,
                  { prompt: "Seleccionar proveedor..." },
                  { class: "form-select border-2 shadow-none" } %>
          </div>
          <div class="mb-3">
            <%= f.text_field :name,
                  class: "form-control border-2 shadow-none",
                  placeholder: "Nombre de la pieza",
                  data: { action: "input->supplier-item-specs#updatePreview" } %>
          </div>
          <div class="mb-3">
            <%= f.text_field :sku,
                  class: "form-control border-2 font-monospace shadow-none",
                  placeholder: "SKU" %>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-7">
              <%= f.select :unit,
                    SupplierItem::UNITS.map { |u| [u.capitalize, u] },
                    {},
                    { class: "form-select border-2 shadow-none" } %>
            </div>
            <div class="col-5">
              <%= f.number_field :default_cost,
                    step: 0.01,
                    min: 0,
                    class: "form-control border-2 shadow-none",
                    placeholder: "₡0.00" %>
            </div>
          </div>
          <div class="rounded-3 bg-light p-3 mb-4">
            <p class="small text-muted mb-1 fw-semibold">Vista previa en OC:</p>
            <pre class="small text-dark mb-0 font-monospace"
                 data-supplier-item-specs-target="previewText"><%= supplier_item.name.presence || "—" %></pre>
          </div>
          <%= f.submit "Guardar", class: "btn btn-primary w-100 rounded-pill fw-bold" %>
        </div>
      </div>
    </div>
    <!-- ───────── DERECHA ───────── -->
    <div class="col-lg-8">
      <!-- ───── PROPIEDADES ───── -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0">Propiedades</h6>
          <button type="button"
                  class="btn btn-sm btn-outline-primary rounded-pill"
                  data-action="click->supplier-item-specs#addProperty">
            + Agregar
          </button>
        </div>
        <div class="card-body" data-supplier-item-specs-target="propertiesList">
          <% supplier_item.supplier_item_properties.properties.each do |sip| %>
            <div class="spec-row d-flex gap-2 mb-2">
              <select name="property_value_ids[<%= sip.property_value.property_id %>]"
                      class="form-select form-select-sm"
                      data-action="change->supplier-item-specs#updatePreview">
                <% sip.property_value.property.property_values.each do |pv| %>
                  <option value="<%= pv.id %>" <%= "selected" if pv.id == sip.property_value_id %>>
                    <%= pv.value %>
                  </option>
                  <% end %>
                </select>
                <button type="button"
                      class="btn btn-outline-danger btn-sm"
                      data-action="click->supplier-item-specs#removeProperty">
                  ✕
                </button>
              </div>
            <% end %>
          </div>
        </div>
        <!-- ───── ESPECIFICACIONES (LABELS) ───── -->
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="fw-bold mb-0">Especificaciones</h6>
            <button type="button"
                  class="btn btn-sm btn-outline-info rounded-pill"
                  data-action="click->supplier-item-specs#addSpec">
              + Agregar
            </button>
          </div>
          <div class="card-body" data-supplier-item-specs-target="specList">
            <% supplier_item.supplier_item_properties.specs.each do |spec| %>
              <div class="spec-row d-flex gap-2 mb-2">
                <input type="text"
                     name="spec_labels[]"
                     value="<%= spec.label %>"
              class="form-control form-control-sm"
              placeholder="Ej: F1"
              data-action="input->supplier-item-specs#updatePreview">
                <button type="button"
                      class="btn btn-outline-danger btn-sm"
                      data-action="click->supplier-item-specs#removeSpec">
                  ✕
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <!-- ───── TEMPLATE PROPERTIES ───── -->
    <template data-supplier-item-specs-target="propertyTemplate">
      <div class="spec-row d-flex gap-2 mb-2">
        <select class="form-select form-select-sm property-group-select"
              data-action="change->supplier-item-specs#propertyChanged">
          <option value="">— Seleccionar —</option>
          <% @properties.each do |prop| %>
            <optgroup label="<%= prop.name %>">
              <% prop.property_values.each do |pv| %>
                <option value="<%= pv.id %>" data-property-id="<%= prop.id %>">
                  <%= pv.value %>
                </option>
              <% end %>
            </optgroup>
          <% end %>
        </select>
        <button type="button"
              class="btn btn-outline-danger btn-sm"
              data-action="click->supplier-item-specs#removeProperty">
          ✕
        </button>
      </div>
    </template>
    <!-- ───── TEMPLATE SPECS ───── -->
    <template data-supplier-item-specs-target="specTemplate">
      <div class="spec-row d-flex gap-2 mb-2">
        <input type="text"
             name="spec_labels[]"
             class="form-control form-control-sm"
             placeholder="Ej: F1"
             data-action="input->supplier-item-specs#updatePreview">
        <button type="button"
              class="btn btn-outline-danger btn-sm"
              data-action="click->supplier-item-specs#removeSpec">
          ✕
        </button>
      </div>
    </template>
  <% end %>