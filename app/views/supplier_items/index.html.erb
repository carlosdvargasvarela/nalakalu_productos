<%# app/views/supplier_items/index.html.erb %>
<div class="container-fluid py-4" style="max-width: 1200px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0">
        <i class="bi bi-box-seam text-primary me-2"></i>Piezas de Proveedor
      </h1>
      <p class="text-muted small mb-0">
        Catálogo global de materiales y piezas que se compran a proveedores.
      </p>
    </div>
    <%= link_to new_supplier_item_path, class: "btn btn-primary rounded-pill px-4 fw-bold" do %>
      <i class="bi bi-plus-lg me-2"></i>Nueva Pieza
    <% end %>
  </div>
  <% if @supplier_items.empty? %>
    <div class="text-center py-5 text-muted border rounded bg-white shadow-sm">
      <i class="bi bi-box display-1 opacity-25"></i>
      <p class="mt-3">No hay piezas registradas.</p>
      <%= link_to new_supplier_item_path, class: "btn btn-outline-primary rounded-pill px-4" do %>
        <i class="bi bi-plus-lg me-1"></i>Crear primera pieza
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm overflow-hidden">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light small text-muted text-uppercase">
          <tr>
            <th class="ps-4">Pieza / Material</th>
            <th>Proveedor</th>
            <th>SKU</th>
            <th class="text-center">Unidad</th>
            <th class="text-end">Costo Ref.</th>
            <th class="text-center">Estado</th>
            <th class="pe-4 text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @supplier_items.each do |item| %>
            <tr class="<%= 'opacity-50' unless item.active %>">
              <td class="ps-4 py-3">
                <div class="fw-bold text-dark"><%= item.name %></div>
                <% props = item.supplier_item_properties.includes(property_value: :property) %>
                <% if props.any? %>
                  <div class="d-flex flex-wrap gap-1 mt-1">
                    <% props.each do |prop| %>
                      <span class="badge bg-light text-dark border fw-normal" style="font-size: 0.65rem;">
                        <%= prop.label %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              </td>
              <td class="py-3">
                <%= link_to item.provider.name, item.provider,
                      class: "text-decoration-none text-dark fw-bold small" %>
              </td>
              <td class="py-3">
                <code class="small text-muted"><%= item.sku.presence || "—" %></code>
              </td>
              <td class="py-3 text-center">
                <span class="badge bg-secondary-subtle text-secondary">
                  <%= item.unit %>
                </span>
              </td>
              <td class="py-3 text-end small">
                <%# default_cost es el campo correcto %>
                <% if item.default_cost.present? && item.default_cost > 0 %>
                  <span class="fw-bold">
                    <%= number_to_currency(item.default_cost, unit: "₡", delimiter: ".", separator: ",") %>
                  </span>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td class="py-3 text-center">
                <span class="badge <%= item.active ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' %> rounded-pill">
                  <%= item.active ? 'Activa' : 'Inactiva' %>
                </span>
              </td>
              <td class="py-3 pe-4 text-end">
                <div class="d-flex gap-1 justify-content-end">
                  <%= link_to edit_supplier_item_path(item),
                        class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to supplier_item_path(item), method: :delete,
                        form: { data: { turbo_confirm: "¿Eliminar '#{item.name}'? Se borrarán sus reglas de abastecimiento." } },
                        class: "btn btn-sm btn-light rounded-pill px-3 border shadow-sm text-danger" do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>