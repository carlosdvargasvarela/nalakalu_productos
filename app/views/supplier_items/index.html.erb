<%# app/views/supplier_items/index.html.erb %>
<div class="container-fluid py-4" style="max-width: 1200px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0">
        <i class="bi bi-box-seam text-primary me-2"></i>Piezas de Proveedor
      </h1>
      <p class="text-muted mb-0">
        Catálogo global de materiales y piezas que se compran a proveedores.
      </p>
    </div>
    <%= link_to new_supplier_item_path, class: "btn btn-primary shadow-sm rounded-pill px-4 fw-bold" do %>
      <i class="bi bi-plus-lg me-2"></i>Nueva Pieza
    <% end %>
  </div>
  <% if @supplier_items.empty? %>
    <div class="text-center py-5 text-muted border-0 shadow-sm rounded-4 bg-white mb-4">
      <i class="bi bi-box display-1 opacity-25 d-block mb-3"></i>
      <p class="fw-bold fs-5">No hay piezas registradas aún.</p>
      <%= link_to new_supplier_item_path, class: "btn btn-primary rounded-pill px-4 fw-bold" do %>
        <i class="bi bi-plus-lg me-2"></i>Crear primera pieza
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light small text-muted text-uppercase">
            <tr>
              <th class="ps-4 py-3">Pieza / Material</th>
              <th>Proveedor</th>
              <th>SKU</th>
              <th class="text-center">Unidad</th>
              <th class="text-end">Costo Ref.</th>
              <th class="text-center">Estado</th>
              <th class="pe-4 text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @supplier_items.each do |item| %>
              <tr class="<​%= 'opacity-50' unless item.active %>">
                <td class="ps-4 py-3">
                  <div class="fw-bold text-dark"><%= item.name %></div>
                  <% if item.supplier_item_properties.any? %>
                    <div class="d-flex flex-wrap gap-1 mt-1">
                      <% item.supplier_item_properties.each do |sip| %>
                        <span class="badge bg-info-soft text-info border border-info border-opacity-10 fw-normal" style="font-size: 0.7rem;">
                          <%= sip.label %>
                        </span>
                      <% end %>
                    </div>
                  <% end %>
                </td>
                <td class="py-3">
                  <span class="badge bg-light text-dark border rounded-pill px-3">
                    <i class="bi bi-building me-1 text-muted"></i>
                    <%= link_to item.provider.name, item.provider, class: "text-decoration-none text-dark fw-bold" %>
                  </span>
                </td>
                <td class="py-3">
                  <code class="small text-muted"><%= item.sku.presence || "—" %></code>
                </td>
                <td class="py-3 text-center">
                  <span class="badge bg-secondary-soft text-secondary rounded-pill px-3">
                    <%= item.unit %>
                  </span>
                </td>
                <td class="py-3 text-end">
                  <% if item.default_cost.present? && item.default_cost > 0 %>
                    <span class="fw-bold text-dark">
                      <%= number_to_currency(item.default_cost, unit: "₡", delimiter: ".", separator: ",") %>
                    </span>
                  <% else %>
                    <span class="text-muted small">—</span>
                  <% end %>
                </td>
                <td class="py-3 text-center">
                  <span class="badge <%= item.active ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary' %> rounded-pill px-3">
                    <%= item.active ? 'Activa' : 'Inactiva' %>
                  </span>
                </td>
                <td class="py-3 pe-4 text-end">
                  <div class="d-flex gap-2 justify-content-end">
                    <%= link_to edit_supplier_item_path(item), class: "btn btn-sm btn-outline-secondary rounded-pill border-0 shadow-none" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= button_to supplier_item_path(item), method: :delete,
                          form: { data: { turbo_confirm: "¿Eliminar '#{item.name}'? Se borrarán sus reglas de abastecimiento." }, class: "d-inline" },
                          class: "btn btn-sm btn-outline-danger rounded-pill border-0 shadow-none" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
  <!-- Importador CSV de Piezas -->
  <div class="card border-0 shadow-sm rounded-4 border-start border-4 border-primary bg-white">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h5 class="fw-bold mb-1">
            <i class="bi bi-file-earmark-spreadsheet text-primary me-2"></i>Importación Masiva de Piezas
          </h5>
          <p class="text-muted small mb-2">
            Formato CSV requerido: 
            <code class="bg-light px-2 py-1 rounded text-primary">provider_name, name, sku, unit, default_cost, properties</code>
          </p>
          <div class="d-flex flex-wrap gap-3 text-muted small">
            <span><i class="bi bi-check2-circle text-success me-1"></i><strong>provider_name</strong> y <strong>name</strong> obligatorios.</span>
            <span><i class="bi bi-info-circle text-info me-1"></i><strong>properties</strong> formato: <code>Ancho: 50mm | Color: Natural</code></span>
          </div>
        </div>
        <div class="col-md-4 mt-3 mt-md-0">
          <%= form_with url: import_supplier_items_path, multipart: true, local: true do |f| %>
            <div class="input-group shadow-sm">
              <%= f.file_field :file, class: "form-control rounded-start-pill border-end-0", accept: ".csv" %>
              <button class="btn btn-primary rounded-end-pill fw-bold px-4" type="submit">
                <i class="bi bi-cloud-upload me-2"></i>Importar
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .bg-success-soft   { background-color: #e1f6eb; }
  .bg-secondary-soft { background-color: #f0f2f5; }
  .bg-info-soft      { background-color: #e0f4ff; }
  .bg-primary-soft   { background-color: #e7f0ff; }

  .table-hover tbody tr:hover {
    background-color: rgba(0,0,0,.01);
  }

  .btn-outline-secondary:hover, .btn-outline-danger:hover {
    background-color: #f8f9fa;
  }
</style>