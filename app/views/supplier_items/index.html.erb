<div class="container-fluid py-4" style="max-width: 1100px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0">
        <i class="bi bi-box-seam text-primary me-2"></i>Piezas de Proveedor
      </h1>
      <p class="text-muted small mb-0">
        Catálogo de materiales reales que se compran a proveedores.
      </p>
    </div>
    <%= link_to new_supplier_item_path, class: "btn btn-primary rounded-pill px-4 fw-bold" do %>
      <i class="bi bi-plus-lg me-2"></i>Nueva Pieza
    <% end %>
  </div>
  <% if @supplier_items.empty? %>
    <div class="text-center py-5 text-muted border rounded bg-white">
      <i class="bi bi-box display-1 opacity-25"></i>
      <p class="mt-3">No hay piezas registradas.</p>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light small text-muted text-uppercase">
          <tr>
            <th class="ps-4">Pieza</th>
            <th>Proveedor</th>
            <th>SKU</th>
            <th class="text-center">Unidad</th>
            <th class="text-end">Costo</th>
            <th class="pe-4 text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @supplier_items.includes(:provider).each do |item| %>
            <tr>
              <td class="ps-4">
                <div class="fw-bold"><%= item.name %></div>
              </td>
              <td><%= item.provider.name %></td>
              <td><code><%= item.sku.presence || "—" %></code></td>
              <td class="text-center">
                <span class="badge bg-secondary-subtle text-secondary">
                  <%= item.unit %>
                </span>
              </td>
              <td class="text-end small">
                <% if item.cost.present? %>
                  <%= number_to_currency(item.cost, unit: "₡", delimiter: ".", separator: ",") %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="pe-4 text-end">
                <%= link_to "Editar", edit_supplier_item_path(item),
                      class: "btn btn-sm btn-outline-primary rounded-pill px-3" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>