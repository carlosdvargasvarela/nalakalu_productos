<%
  total_items = @supplier_items.size
  incomplete_items = @supplier_items.count do |item|
    rules = item.supply_rules.to_a
    props = item.supplier_item_properties.to_a
    specs = props.select { |sip| sip.spec_type == "spec" }

    !item.active ||
      item.default_cost.to_f <= 0 ||
      rules.empty? ||
      (rules.any? { |r| r.rule_type == "consolidated" } && specs.empty?)
  end

  items_without_rules = @supplier_items.count { |item| item.supply_rules.empty? }
  items_with_specs = @supplier_items.count do |item|
    item.supplier_item_properties.to_a.any? { |sip| sip.spec_type == "spec" }
  end
%>
<div class="container-fluid mt-4 pb-5" data-controller="supplier-item-filters">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">
        <i class="bi bi-box-seam-fill text-primary me-2"></i>
        Piezas de Proveedor
      </h1>
      <p class="text-muted small mb-0">
        Catálogo central de materiales y piezas compradas a proveedores.
      </p>
    </div>
    <%= link_to new_supplier_item_path,
      class: "btn btn-primary btn-sm fw-bold shadow-sm",
      data: { turbo_frame: "supplier_item_workspace" } do %>
      <i class="bi bi-plus-lg me-1"></i>Nueva Pieza
    <% end %>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="small text-uppercase text-muted fw-bold mb-1">Total de piezas</p>
          <h3 class="mb-0 fw-bold"><%= total_items %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="small text-uppercase text-muted fw-bold mb-1">Incompletas</p>
          <h3 class="mb-0 fw-bold text-warning"><%= incomplete_items %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="small text-uppercase text-muted fw-bold mb-1">Con specs</p>
          <h3 class="mb-0 fw-bold text-info"><%= items_with_specs %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="small text-uppercase text-muted fw-bold mb-1">Sin reglas</p>
          <h3 class="mb-0 fw-bold text-danger"><%= items_without_rules %></h3>
        </div>
      </div>
    </div>
  </div>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="row g-3 align-items-end">
        <div class="col-lg-4">
          <label class="form-label fw-bold small text-uppercase text-muted">Buscar</label>
          <input
            type="text"
            class="form-control border-2 shadow-none"
            placeholder="Nombre, SKU o proveedor..."
            data-supplier-item-filters-target="search"
            data-action="input->supplier-item-filters#filter">
          </div>
          <div class="col-lg-3">
            <label class="form-label fw-bold small text-uppercase text-muted">Proveedor</label>
            <select
            class="form-select border-2 shadow-none"
            data-supplier-item-filters-target="provider"
            data-action="change->supplier-item-filters#filter">
              <option value="">Todos</option>
              <% @providers.each do |provider| %>
                <option value="<%= provider.id %>"><%= provider.name %></option>
              <% end %>
            </select>
          </div>
          <div class="col-lg-2">
            <label class="form-label fw-bold small text-uppercase text-muted">Uso</label>
            <select
            class="form-select border-2 shadow-none"
            data-supplier-item-filters-target="mode"
            data-action="change->supplier-item-filters#filter">
              <option value="">Todos</option>
              <option value="individual">Individual</option>
              <option value="consolidated">Consolidado</option>
              <option value="mixed">Mixto</option>
              <option value="unused">Sin uso</option>
            </select>
          </div>
          <div class="col-lg-2">
            <label class="form-label fw-bold small text-uppercase text-muted">Estado</label>
            <select
            class="form-select border-2 shadow-none"
            data-supplier-item-filters-target="status"
            data-action="change->supplier-item-filters#filter">
              <option value="">Todos</option>
              <option value="ready">Lista</option>
              <option value="incomplete">Incompleta</option>
              <option value="inactive">Inactiva</option>
            </select>
          </div>
          <div class="col-lg-1">
            <button
            type="button"
            class="btn btn-outline-secondary w-100"
            data-action="click->supplier-item-filters#reset">
              Limpiar
            </button>
          </div>
        </div>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-xl-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
          <div class="card-header bg-white py-3 px-4 border-bottom">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="fw-bold mb-0">Catálogo de piezas</h6>
                <p class="text-muted small mb-0">
                  <span data-supplier-item-filters-target="visibleCount"><%= @supplier_items.size %></span> visibles
                </p>
              </div>
              <%= link_to new_supplier_item_path,
              class: "btn btn-sm btn-outline-primary rounded-pill",
              data: { turbo_frame: "supplier_item_workspace" } do %>
                <i class="bi bi-plus-lg me-1"></i>Nueva
              <% end %>
            </div>
          </div>
          <% if @supplier_items.any? %>
            <div class="list-group list-group-flush">
              <% @supplier_items.each do |item| %>
                <%= render "supplier_item_row", item: item %>
              <% end %>
            </div>
            <div class="p-4 text-center text-muted" data-supplier-item-filters-target="emptyState" hidden>
              <i class="bi bi-search fs-1 d-block mb-2 opacity-50"></i>
              <p class="mb-1 fw-semibold">No hay resultados para esos filtros.</p>
              <p class="small mb-0">Prueba otro proveedor, estado o término de búsqueda.</p>
            </div>
          <% else %>
            <div class="p-5 text-center text-muted">
              <i class="bi bi-box display-5 d-block mb-3 opacity-25"></i>
              <p class="fw-bold fs-5 mb-2">No hay piezas registradas aún.</p>
              <p class="small mb-3">Comienza creando la primera pieza del catálogo.</p>
              <%= link_to new_supplier_item_path,
              class: "btn btn-primary rounded-pill px-4 fw-bold",
              data: { turbo_frame: "supplier_item_workspace" } do %>
                <i class="bi bi-plus-lg me-2"></i>Crear primera pieza
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="card border-0 shadow-sm rounded-4 mt-4 border-start border-4 border-primary bg-white">
          <div class="card-body p-4">
            <div class="d-flex align-items-start gap-3">
              <div class="pt-1">
                <i class="bi bi-file-earmark-spreadsheet text-primary fs-4"></i>
              </div>
              <div class="flex-grow-1">
                <h6 class="fw-bold mb-1">Importación masiva de piezas</h6>
                <p class="text-muted small mb-2">
                  Formato:
                  <code class="bg-light px-2 py-1 rounded">provider_name, name, sku, unit, default_cost, properties</code>
                </p>
                <p class="text-muted small mb-3">
                  <strong>properties</strong> con formato:
                  <code class="bg-light px-2 py-1 rounded">Ancho: 50mm | Color: Natural</code>
                </p>
                <%= form_with url: import_supplier_items_path, multipart: true, local: true do |f| %>
                  <div class="input-group">
                    <%= f.file_field :file, class: "form-control", accept: ".csv" %>
                    <button class="btn btn-primary fw-bold" type="submit">
                      <i class="bi bi-cloud-upload me-1"></i>Importar
                    </button>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xl-7">
        <%= turbo_frame_tag "supplier_item_workspace" do %>
          <% if @selected_supplier_item.present? %>
            <%= render "detail_panel",
            supplier_item: @selected_supplier_item,
            supply_rules: @selected_supply_rules %>
          <% else %>
            <%= render "workspace_placeholder" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
  <style>
    .supplier-item-card.is-selected {
      border-left: 4px solid var(--bs-primary);
      background-color: #f8fbff;
    }

    .supplier-item-card:hover {
      background-color: rgba(0, 0, 0, 0.015);
    }

    .supplier-item-card[hidden] {
      display: none !important;
    }
  </style>