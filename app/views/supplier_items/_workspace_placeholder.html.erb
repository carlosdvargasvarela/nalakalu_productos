<div class="card border-0 shadow-sm rounded-4 h-100">
  <div class="card-body p-5 text-center">
    <div class="mb-4">
      <i class="bi bi-box-seam-fill text-primary" style="font-size: 3rem;"></i>
    </div>
    <h4 class="fw-bold mb-2">Selecciona una pieza</h4>
    <p class="text-muted mb-4">
      Aquí podrás ver su configuración, propiedades, specs permitidas y reglas de abastecimiento.
    </p>
    <div class="row g-3 text-start mb-4">
      <div class="col-md-4">
        <div class="rounded-4 border bg-light p-3 h-100">
          <p class="small text-uppercase text-muted fw-bold mb-1">1. Datos base</p>
          <p class="small mb-0">Proveedor, nombre, unidad, SKU y costo de referencia.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="rounded-4 border bg-light p-3 h-100">
          <p class="small text-uppercase text-muted fw-bold mb-1">2. Configuración</p>
          <p class="small mb-0">Propiedades fijas del item y specs dinámicas para procurement.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="rounded-4 border bg-light p-3 h-100">
          <p class="small text-uppercase text-muted fw-bold mb-1">3. Uso e impacto</p>
          <p class="small mb-0">Reglas asociadas y alcance dentro del sistema de abastecimiento.</p>
        </div>
      </div>
    </div>
    <%= link_to new_supplier_item_path,
      class: "btn btn-primary rounded-pill px-4 fw-bold",
      data: { turbo_frame: "supplier_item_workspace" } do %>
      <i class="bi bi-plus-lg me-2"></i>Crear nueva pieza
    <% end %>
  </div>
</div>