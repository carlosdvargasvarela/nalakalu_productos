<%# app/views/supplier_items/edit.html.erb %>
<div class="container-fluid py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Proveedores", providers_path, class: "text-decoration-none" %></li>
      <li class="breadcrumb-item">
        <%= link_to @supplier_item.provider.name, @supplier_item.provider, class: "text-decoration-none" %>
      </li>
      <li class="breadcrumb-item active fw-bold">Editar: <%= @supplier_item.name %></li>
    </ol>
  </nav>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0 text-dark">
      Editando: <span class="text-primary"><%= @supplier_item.name %></span>
    </h2>
    <%= link_to @supplier_item.provider, class: "btn btn-outline-secondary rounded-pill px-4" do %>
      <i class="bi bi-arrow-left me-2"></i>Volver al Proveedor
    <% end %>
  </div>
  <%= render "form", supplier_item: @supplier_item %>
</div>