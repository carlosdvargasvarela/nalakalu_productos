<div class="container-fluid py-4">
  <!-- Header -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
              <li class="breadcrumb-item">
                <%= link_to "Productos", products_path, class: "text-decoration-none" %>
              </li>
              <li class="breadcrumb-item active fw-bold"><%= @product.name %></li>
            </ol>
          </nav>
          <div class="d-flex align-items-center gap-3 flex-wrap">
            <h2 class="fw-bold mb-0"><%= @product.name %></h2>
            <span class="badge <%= @product.active ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3">
              <%= @product.active ? 'Activo' : 'Inactivo' %>
            </span>
            <%= supplier_type_badge(@product) %>
          </div>
          <% if @product.family.present? %>
            <p class="text-muted mb-0 mt-1 small">
              <i class="bi bi-diagram-3 me-1 text-info"></i>
              Familia:
              <%= link_to @product.family.name, @product.family,
                  class: "text-decoration-none fw-bold text-info" %>
            </p>
          <% end %>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-2 justify-content-md-end flex-wrap">
            <%= link_to new_sale_path(product_id: @product.id),
                class: "btn btn-success rounded-pill px-4 fw-bold shadow-sm" do %>
              <i class="bi bi-qr-code me-2"></i>Generar Código
            <% end %>
            <%= link_to edit_product_path(@product),
                class: "btn btn-outline-primary rounded-pill px-4" do %>
              <i class="bi bi-pencil-square me-2"></i>Editar
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-4">
    <!-- ===== COLUMNA IZQUIERDA ===== -->
    <div class="col-lg-7">
      <!-- Estructura del Código -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-diagram-3 me-2 text-primary"></i>Estructura del Código
          </h5>
          <%= link_to edit_product_path(@product),
              class: "btn btn-sm btn-outline-secondary rounded-pill px-3" do %>
            <i class="bi bi-pencil me-1"></i>Modificar
          <% end %>
        </div>
        <div class="card-body p-4">
          <% rules = @product.effective_rules %>
          <% if rules.any? %>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
              <span class="badge bg-dark fs-6 rounded-pill px-3">
                <%= @product.base_code %>
              </span>
              <% rules.each do |rule| %>
                <i class="bi bi-plus text-muted"></i>
                <div class="d-flex align-items-center gap-1">
                  <span class="badge bg-secondary rounded-pill px-2 fs-6">
                    <%= rule.separator %>
                  </span>
                  <span class="badge bg-primary rounded-pill px-3 fs-6">
                    <%= rule.label.presence || rule.variant_type.name %>
                  </span>
                </div>
              <% end %>
            </div>
            <div class="bg-light rounded-3 p-3">
              <p class="small text-muted mb-1 fw-bold">Ejemplo de código generado:</p>
              <code class="fs-5 text-dark"><%= @product.code_structure_preview %></code>
            </div>
          <% else %>
            <div class="text-center py-4 text-muted">
              <i class="bi bi-exclamation-circle d-block fs-2 mb-2 opacity-25"></i>
              <p class="mb-3 small">Este producto no tiene estructura de código definida.</p>
              <%= link_to edit_product_path(@product), class: "btn btn-sm btn-primary rounded-pill px-4" do %>
                <i class="bi bi-plus-lg me-1"></i>Definir estructura
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
      <!-- Pasos del Código + Gestión de Compatibilidad -->
      <% if rules.any? %>
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 fw-bold">
              <i class="bi bi-list-ol me-2 text-primary"></i>Gestión de Variantes Compatibles
            </h5>
            <p class="text-muted small mb-0 mt-1">
              Define qué opciones de cada tipo están disponibles para este producto.
            </p>
          </div>
          <div class="list-group list-group-flush rounded-4">
            <% rules.each_with_index do |rule, i| %>
              <div class="list-group-item px-4 py-3">
                <div class="d-flex justify-content-between align-items-center">
                  <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                         style="width: 32px; height: 32px; font-size: 0.8rem;">
                      <%= i + 1 %>
                    </div>
                    <div>
                      <span class="fw-bold"><%= rule.label.presence || rule.variant_type.name %></span>
                      <% count = rule.allowed_variants.where(active: true).count %>
                      <div class="text-muted small">
                        <%= count %> variante<%= 's' if count != 1 %> asignada<%= 's' if count != 1 %>
                      </div>
                    </div>
                  </div>
                  <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold"
                          data-bs-toggle="modal" data-bs-target="#modalRule<%= rule.id %>">
                    <i class="bi bi-gear-fill me-1"></i>Gestionar
                  </button>
                </div>
                <!-- Vista previa rápida de variantes asignadas -->
                <% compatible = @product.compatible_variants_for(rule.variant_type).where(active: true).limit(10) %>
                <% if compatible.any? %>
                  <div class="d-flex flex-wrap gap-1 mt-2">
                    <% compatible.each do |v| %>
                      <span class="badge bg-light text-dark border rounded-pill px-2" style="font-size: 0.65rem;">
                        <%= v.display_name.presence || v.name %>
                      </span>
                    <% end %>
                    <% if count > 10 %>
                      <span class="text-muted small ms-1">...y <%= count - 10 %> más</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <%= render "compatibility_modal", product: @product, rule: rule %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <!-- ===== COLUMNA DERECHA ===== -->
    <div class="col-lg-5">
      <!-- Información del Producto -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-info-circle me-2 text-primary"></i>Información
          </h5>
        </div>
        <div class="list-group list-group-flush rounded-4">
          <div class="list-group-item px-4 py-2 border-0">
            <div class="small text-muted fw-bold">Código Base</div>
            <code class="fs-5"><%= @product.base_code %></code>
          </div>
          <div class="list-group-item px-4 py-2 border-0">
            <div class="small text-muted fw-bold">Familia</div>
            <div class="fw-bold"><%= @product.family&.name || "Sin familia" %></div>
          </div>
          <div class="list-group-item px-4 py-2 border-0">
            <div class="small text-muted fw-bold">Origen</div>
            <%= supplier_type_badge(@product) %>
          </div>
        </div>
      </div>
      <!-- Variantes Asignadas (Resumen) -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-bold">
            <i class="bi bi-palette me-2 text-primary"></i>Catálogo Aplicable
          </h5>
          <% rule_ids = @product.product_variant_rules.pluck(:id) %>
          <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">
            <%= Compatibility.where(compatible_type: "ProductVariantRule", compatible_id: rule_ids).count %>
          </span>
        </div>
        <div class="card-body p-3">
          <% assigned_variants = Variant.joins(:compatibilities)
              .where(compatibilities: { compatible_type: "ProductVariantRule", compatible_id: rule_ids })
              .includes(:variant_type).distinct.order("variant_types.name, variants.name") %>
          <% if assigned_variants.any? %>
            <% assigned_variants.group_by(&:variant_type).each do |type, variants| %>
              <div class="mb-3">
                <p class="x-small fw-bold text-uppercase text-muted mb-2 border-bottom pb-1">
                  <%= type.name %>
                </p>
                <div class="d-flex flex-column gap-1">
                  <% variants.each do |v| %>
                    <div class="d-flex align-items-center justify-content-between bg-light rounded-3 px-3 py-1">
                      <span class="small fw-bold"><%= v.display_name.presence || v.name %></span>
                      <code class="text-primary x-small fw-bold"><%= v.code %></code>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-3 text-muted small">
              No hay variantes asignadas. Usa el botón "Gestionar" en los pasos del código.
            </div>
          <% end %>
        </div>
      </div>
      <!-- Acciones Peligrosas -->
      <div class="card border-0 shadow-sm rounded-4 border-start border-4 border-danger">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
          <span class="small fw-bold text-danger">Zona de Peligro</span>
          <%= form_with url: product_path(@product), method: :delete,
              data: { turbo_confirm: "¿Eliminar '#{@product.name}'? Esta acción no se puede deshacer." } do %>
            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
              <i class="bi bi-trash me-1"></i>Eliminar Producto
            </button>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .x-small { font-size: 0.7rem; }
  .cursor-pointer { cursor: pointer; }
</style>