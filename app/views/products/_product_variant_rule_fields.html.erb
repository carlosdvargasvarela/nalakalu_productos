<div class="nested-form-wrapper mb-3 p-3 border border-2 rounded-4 bg-white shadow-sm transition-all hover-border-primary"
     data-new-record="<​%= f.object.new_record? %>">
  <div class="row g-3 align-items-center">
    <%= f.hidden_field :position, data: { role: "position" } %>
    <!-- Indicador de Orden -->
    <div class="col-auto">
      <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold"
           style="width: 38px; height: 38px; border: 2px solid currentColor;">
        <span class="step-number">#</span>
      </div>
    </div>
    <!-- Selección de Tipo -->
    <div class="col-md-4">
      <%= f.label :variant_type_id, "Tipo de Variante", class: "x-small fw-bold text-muted d-block mb-1" %>
      <%= f.collection_select :variant_type_id, VariantType.where(active: true).order(:name), :id, :name,
          { prompt: "Seleccionar tipo..." },
          { class: "form-select border-0 bg-light fw-bold shadow-none" } %>
    </div>
    <!-- Etiqueta Visual -->
    <div class="col-md-3">
      <%= f.label :label, "Etiqueta en Formulario", class: "x-small fw-bold text-muted d-block mb-1" %>
      <%= f.text_field :label, class: "form-control border-0 bg-light shadow-none", placeholder: "Ej: Color de Tela" %>
    </div>
    <!-- Separador -->
    <div class="col-md-1 text-center">
      <%= f.label :separator, "Sep.", class: "x-small fw-bold text-muted d-block mb-1" %>
      <%= f.text_field :separator, class: "form-control border-0 bg-light text-center fw-bold shadow-none", placeholder: "-" %>
    </div>
    <!-- Switch Obligatorio -->
    <div class="col-md-2">
      <div class="form-check form-switch pt-4">
        <%= f.check_box :required, class: "form-check-input cursor-pointer" %>
        <%= f.label :required, "Obligatorio", class: "form-check-label small fw-bold text-muted" %>
      </div>
    </div>
    <!-- Botón Eliminar -->
    <div class="col-auto ms-auto">
      <%= f.hidden_field :_destroy %>
      <button type="button" class="btn btn-outline-danger border-0 rounded-circle p-2 hover-bg-danger" 
              data-action="nested-form#remove" title="Eliminar este paso">
        <i class="bi bi-trash3-fill"></i>
      </button>
    </div>
  </div>
</div>
<style>
  .hover-border-primary:hover { border-color: var(--bs-primary) !important; }
  .hover-bg-danger:hover { background-color: #fff5f5; }
  .cursor-pointer { cursor: pointer; }
</style>