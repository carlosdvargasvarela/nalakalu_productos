<%= form_with(model: product,
    data: {
      controller: "nested-form",
      nested_form_wrapper_selector_value: ".nested-form-wrapper",
      turbo_frame: "_top"
    }) do |f| %>
  <% if product.errors.any? %>
    <div class="alert alert-danger border-0 rounded-3 mb-4">
      <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Corrige los siguientes errores:</h6>
      <ul class="mb-0 small">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%# ── CONFIGURACIÓN BASE ── %>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <%= f.label :name, "Nombre del Producto", class: "form-label small fw-bold text-muted" %>
      <%= f.text_field :name,
          class: "form-control border-2 shadow-none",
          placeholder: "Ej: Sofá Milano 3 Cuerpos" %>
    </div>
    <div class="col-md-3">
      <%= f.label :base_code, "Código Base", class: "form-label small fw-bold text-muted" %>
      <%= f.text_field :base_code,
          class: "form-control border-2 font-monospace shadow-none",
          placeholder: "MIL" %>
    </div>
    <div class="col-md-3">
      <%= f.label :active, "Estado", class: "form-label small fw-bold text-muted" %>
      <div class="d-flex gap-3 mt-1">
        <div class="form-check">
          <%= f.radio_button :active, true, class: "form-check-input" %>
          <%= f.label :active_true, "Activo", class: "form-check-label small" %>
        </div>
        <div class="form-check">
          <%= f.radio_button :active, false, class: "form-check-input" %>
          <%= f.label :active_false, "Inactivo", class: "form-check-label small" %>
        </div>
      </div>
    </div>
    <div class="col-12">
      <%= f.label :family_id, "Familia de Producto", class: "form-label small fw-bold text-muted" %>
      <%= f.collection_select :family_id,
          Family.where(active: true), :id, :name,
          { include_blank: "Sin Familia (Independiente)" },
          { class: "form-select border-2 shadow-none" } %>
      <div class="form-text x-small">
        Al asignar una familia, el producto hereda su estructura de código automáticamente.
      </div>
    </div>
  </div>
  <%# ── DNA BUILDER ── %>
  <div class="card border-0 bg-light rounded-4 mb-4">
    <div class="card-header bg-transparent border-bottom py-3 d-flex justify-content-between align-items-center">
      <div>
        <h6 class="fw-bold mb-0 text-primary">
          <i class="bi bi-diagram-3-fill me-2"></i>Estructura DNA del Código
        </h6>
        <p class="text-muted x-small mb-0">Define el orden y tipo de variantes que componen el código final.</p>
      </div>
      <button type="button"
              class="btn btn-sm btn-primary rounded-pill px-3 fw-bold"
              data-action="nested-form#add">
        <i class="bi bi-plus-lg me-1"></i>Agregar Paso
      </button>
    </div>
    <div class="card-body p-3">
      <% if product.family.present? %>
        <div class="alert alert-info border-0 rounded-3 mb-3 py-2 px-3 small">
          <i class="bi bi-info-circle-fill me-2"></i>
          Familia: <strong><%= product.family.name %></strong>.
          <% if product.product_variant_rules.empty? %>
            Actualmente hereda la estructura de la familia.
            <strong>Si agregas pasos aquí, se ignorarán los de la familia.</strong>
          <% else %>
            Tiene reglas personalizadas que <strong>anulan</strong> las de la familia.
          <% end %>
        </div>
      <% end %>
      <template data-nested-form-target="template">
        <%= f.fields_for :product_variant_rules, ProductVariantRule.new, child_index: "NEW_RECORD" do |rule_f| %>
          <%= render "product_variant_rule_fields", f: rule_f %>
        <% end %>
      </template>
      <div data-nested-form-target="target">
        <%= f.fields_for :product_variant_rules do |rule_f| %>
          <%= render "product_variant_rule_fields", f: rule_f %>
        <% end %>
      </div>
      <% if product.product_variant_rules.empty? %>
        <div class="text-center py-4 border border-2 border-dashed rounded-4 text-muted bg-white">
          <i class="bi bi-layers fs-2 d-block mb-2 opacity-25"></i>
          <p class="fw-bold small mb-1">No hay reglas específicas definidas.</p>
          <small class="x-small">Haz clic en "Agregar Paso" para personalizar el código.</small>
        </div>
      <% end %>
    </div>
  </div>
  <%# ── ACCIONES ── %>
  <div class="d-flex justify-content-between align-items-center">
    <%= link_to products_path,
        class: "btn btn-link text-muted text-decoration-none fw-bold" do %>
      <i class="bi bi-x-lg me-1"></i>Descartar
    <% end %>
    <%= f.submit product.new_record? ? "Crear Producto" : "Actualizar Producto",
        class: "btn btn-primary px-5 rounded-pill fw-bold shadow" %>
  </div>
<% end %>
<style>
  .x-small { font-size: 0.72rem; }
  .border-dashed { border-style: dashed !important; }
</style>