<%= form_with(model: family,
              data: {
                controller: "nested-form",
                nested_form_wrapper_selector_value: ".nested-fields"
              }) do |f| %>
  <% if family.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
      <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Errores al guardar:</h6>
      <ul class="mb-0 ps-3 small">
        <% family.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row g-4">
    <!-- Columna Info -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">
            <i class="bi bi-info-circle-fill me-2 text-info"></i>Información General
          </h5>
          <div class="mb-3">
            <%= f.label :name, "Nombre de la Familia", class: "form-label small fw-bold text-muted" %>
            <%= f.text_field :name,
                class: "form-control border-2 shadow-none",
                placeholder: "Ej: Línea Río, Sillas de Oficina..." %>
          </div>
          <div class="mb-3">
            <%= f.label :active, "Estado de la Familia", class: "form-label small fw-bold text-muted" %>
            <%= f.select :active,
                [["Activa", true], ["Inactiva", false]],
                {},
                { class: "form-select border-2 shadow-none" } %>
          </div>
          <div class="mb-4">
            <%= f.label :description, "Descripción", class: "form-label small fw-bold text-muted" %>
            <%= f.text_area :description,
                class: "form-control border-2 shadow-none",
                rows: 4,
                placeholder: "Detalles internos sobre esta familia de productos..." %>
          </div>
          <div class="alert alert-info border-0 rounded-3 bg-info bg-opacity-10 mb-0">
            <div class="d-flex gap-2 align-items-start">
              <i class="bi bi-lightbulb-fill text-info mt-1 flex-shrink-0"></i>
              <div class="small">
                Los productos de esta familia <strong>heredarán automáticamente</strong>
                la estructura de código definida aquí, a menos que tengan reglas propias.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Columna DNA Builder -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0 fw-bold text-primary">
                <i class="bi bi-diagram-3 me-2"></i>Constructor de Estructura (DNA)
              </h5>
              <p class="text-muted small mb-0 mt-1">
                Define los pasos que formarán el código de los productos de esta familia.
              </p>
            </div>
            <button type="button"
                    class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm"
                    data-action="nested-form#add">
              <i class="bi bi-plus-lg me-1"></i>Agregar Paso
            </button>
          </div>
        </div>
        <div class="card-body p-4">
          <div id="rules-container" data-nested-form-target="target">
            <%= f.fields_for :family_variant_rules do |rule_f| %>
              <%= render "family_variant_rule_fields", f: rule_f %>
            <% end %>
          </div>
          <template data-nested-form-target="template">
            <%= f.fields_for :family_variant_rules, FamilyVariantRule.new, child_index: "NEW_RECORD" do |rule_f| %>
              <%= render "family_variant_rule_fields", f: rule_f %>
            <% end %>
          </template>
          <% if family.family_variant_rules.empty? %>
            <div class="text-center py-5 border border-2 border-dashed rounded-4 text-muted"
                 id="empty-rules-placeholder">
              <i class="bi bi-stack fs-1 d-block mb-2 opacity-25"></i>
              <p class="fw-bold mb-1">Aún no has definido pasos.</p>
              <p class="small mb-3">
                Cada paso representa un segmento del código.<br>
                Ej: <code>BASE</code> + <code>-TELA</code> + <code>-ACABADO</code>
              </p>
              <button type="button"
                      class="btn btn-sm btn-primary rounded-pill px-4"
                      data-action="nested-form#add">
                <i class="bi bi-plus-lg me-2"></i>Agregar primer paso
              </button>
            </div>
          <% end %>
        </div>
      </div>
      <div class="mt-4 d-flex justify-content-between align-items-center">
        <%= link_to families_path, class: "btn btn-link text-decoration-none text-muted fw-bold" do %>
          <i class="bi bi-arrow-left me-2"></i>Cancelar y volver
        <% end %>
        <%= f.submit family.new_record? ? "Crear Familia" : "Guardar Cambios",
            class: "btn btn-primary btn-lg px-5 shadow rounded-pill fw-bold" %>
      </div>
    </div>
  </div>
<% end %>