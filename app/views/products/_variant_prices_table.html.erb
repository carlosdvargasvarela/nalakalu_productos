<%
  prices_index = product.product_variant_prices
                        .includes(:variant)
                        .index_by(&:variant_id)
  rules = product.effective_rules
  compatible_by_type = rules.map do |rule|
    [rule, product.compatible_variants_for(rule.variant_type).where(active: true).order(:name)]
  end
  total_variants = compatible_by_type.sum { |_, vs| vs.count }
%>
<div class="card border-0 shadow-sm rounded-4 mt-4" id="variant-prices">
  <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
    <div>
      <h5 class="mb-0 fw-bold">
        <i class="bi bi-cash-stack me-2 text-success"></i>Precios por Variante
      </h5>
      <p class="text-muted small mb-0 mt-1">
        Deja el campo vacío para eliminar el precio de esa variante.
      </p>
    </div>
    <% if total_variants > 0 %>
      <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 fw-normal">
        <%= total_variants %> variante<%= 's' if total_variants != 1 %>
      </span>
    <% end %>
  </div>
  <%= form_with url: product_variant_prices_path, method: :post, local: true do %>
    <%= hidden_field_tag :product_id, product.id %>
    <% if compatible_by_type.any? && compatible_by_type.any? { |_, vs| vs.any? } %>
      <div class="card-body p-0">
        <% compatible_by_type.each do |rule, variants| %>
          <% next if variants.empty? %>
          <%# ── Encabezado de tipo ── %>
          <div class="px-4 pt-3 pb-1 d-flex align-items-center gap-2">
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 small fw-bold">
              <i class="bi bi-tag me-1"></i><%= rule.label.presence || rule.variant_type.name %>
            </span>
            <span class="text-muted x-small"><%= variants.count %> opciones</span>
          </div>
          <%# ── Filas de variantes ── %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <tbody>
                <% variants.each do |variant| %>
                  <% pvp = prices_index[variant.id] %>
                  <% has_price = pvp&.price.present? %>
                  <tr>
                    <td class="ps-4 py-2" style="width: 45%">
                      <div class="small fw-bold"><%= variant.seller_name %></div>
                      <% if variant.provider.present? %>
                        <div class="x-small text-muted">
                          <i class="bi bi-building me-1"></i><%= variant.provider.name %>
                        </div>
                      <% end %>
                    </td>
                    <td class="py-2 text-center">
                      <code class="x-small fw-bold text-primary bg-light rounded px-2 py-1">
                        <%= variant.code %>
                      </code>
                    </td>
                    <td class="py-2 pe-4 text-end">
                      <div class="input-group input-group-sm ms-auto" style="max-width: 150px;">
                        <span class="input-group-text bg-light border-end-0 text-muted fw-bold">₡</span>
                        <%= number_field_tag "prices[#{variant.id}]",
                            pvp&.price,
                            step: 1,
                            min: 0,
                            class: "form-control border-start-0 text-end shadow-none #{'fw-bold text-success' if has_price}",
                            placeholder: "—" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <%# Separador entre tipos (excepto el último) %>
          <% unless rule == compatible_by_type.last&.first %>
            <hr class="mx-4 my-0 opacity-25">
          <% end %>
        <% end %>
      </div>
      <div class="card-footer bg-white border-top py-3 px-4 d-flex justify-content-end">
        <button type="submit" class="btn btn-success btn-sm rounded-pill px-4 fw-bold shadow-sm">
          <i class="bi bi-save me-2"></i>Guardar Precios
        </button>
      </div>
    <% else %>
      <div class="card-body text-center py-5 text-muted">
        <i class="bi bi-<%= rules.empty? ? 'diagram-3' : 'palette' %> d-block fs-2 mb-2 opacity-25"></i>
        <p class="mb-3 small">
          <%= rules.empty? ? "Este producto no tiene estructura de código definida." : "No hay variantes compatibles asignadas." %>
        </p>
        <%= link_to edit_product_path(product), class: "btn btn-sm btn-outline-primary rounded-pill px-4" do %>
          <i class="bi bi-pencil me-1"></i><%= rules.empty? ? "Definir estructura" : "Configurar variantes" %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>