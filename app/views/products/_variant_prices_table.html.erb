<%
  # Pre-cargamos los precios para evitar N+1
  prices_index = product.product_variant_prices
                        .includes(:variant)
                        .index_by(&:variant_id)
%>
<div class="card border-0 shadow-sm rounded-4 mt-4">
  <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
    <div>
      <h5 class="mb-0 fw-bold text-primary">
        <i class="bi bi-cash-stack me-2"></i>Precios por Variante
      </h5>
      <p class="text-muted small mb-0">
        Configura el precio de venta de cada variante aplicable a este producto.
      </p>
    </div>
  </div>
  <%= form_with url: product_variant_prices_path, method: :post, local: true do %>
    <%= hidden_field_tag :product_id, product.id %>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4 py-3 small fw-bold text-muted text-uppercase">Tipo / Variante</th>
              <th class="py-3 small fw-bold text-muted text-uppercase text-center">Código</th>
              <th class="py-3 small fw-bold text-muted text-uppercase text-center" style="width: 200px;">
                Precio (₡)
              </th>
            </tr>
          </thead>
          <tbody>
            <%
              # Obtenemos todas las variantes compatibles agrupadas por tipo
              rules = product.effective_rules
              compatible_by_type = rules.map do |rule|
                [rule, product.compatible_variants_for(rule.variant_type).where(active: true).order(:name)]
              end
            %>
            <% if compatible_by_type.any? && compatible_by_type.any? { |_, vs| vs.any? } %>
              <% compatible_by_type.each do |rule, variants| %>
                <% next if variants.empty? %>
                <!-- Separador de tipo -->
                <tr class="table-light">
                  <td colspan="3" class="ps-4 py-2">
                    <span class="small fw-bold text-uppercase text-muted">
                      <i class="bi bi-tag me-1"></i>
                      <%= rule.variant_type.name %>
                      <% if rule.label.present? %>
                        <span class="badge bg-secondary rounded-pill ms-1 fw-normal">
                          <%= rule.label %>
                        </span>
                      <% end %>
                    </span>
                  </td>
                </tr>
                <% variants.each do |variant| %>
                  <% pvp = prices_index[variant.id] %>
                  <tr>
                    <td class="ps-4 py-2">
                      <div class="small fw-bold"><%= variant.seller_name %></div>
                      <% if variant.provider.present? %>
                        <div class="x-small text-muted">
                          <i class="bi bi-building me-1"></i><%= variant.provider.name %>
                        </div>
                      <% end %>
                    </td>
                    <td class="text-center py-2">
                      <code class="small fw-bold text-primary"><%= variant.code %></code>
                    </td>
                    <td class="text-center py-2 pe-4">
                      <div class="input-group input-group-sm justify-content-center"
                           style="max-width: 160px; margin: 0 auto;">
                        <span class="input-group-text bg-light border-end-0">₡</span>
                        <%= number_field_tag "prices[#{variant.id}]",
                            pvp&.price,
                            step: 1,
                            min: 0,
                            class: "form-control border-start-0 text-end shadow-none",
                            placeholder: "0" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            <% else %>
              <tr>
                <td colspan="3" class="text-center py-5 text-muted">
                  <i class="bi bi-info-circle d-block fs-2 mb-2 opacity-50"></i>
                  <p class="mb-2">
                    <% if rules.empty? %>
                      Este producto aún no tiene reglas de variantes configuradas.
                    <% else %>
                      No hay variantes compatibles asignadas a este producto.
                    <% end %>
                  </p>
                  <%= link_to edit_product_path(product),
                      class: "btn btn-sm btn-outline-primary rounded-pill px-3" do %>
                    <i class="bi bi-pencil me-1"></i>Configurar estructura
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card-footer bg-white border-top py-3 d-flex justify-content-between align-items-center">
      <span class="small text-muted">
        <i class="bi bi-info-circle me-1"></i>
        Deja el campo vacío para eliminar el precio de esa variante.
      </span>
      <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm">
        <i class="bi bi-save me-2"></i>Guardar Precios
      </button>
    </div>
  <% end %>
</div>
<style>
  .x-small { font-size: 0.72rem; }
</style>