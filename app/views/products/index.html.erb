<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><i class="bi bi-box"></i> Productos Base</h1>
  <%= link_to new_product_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-circle"></i> Nuevo Producto
  <% end %>
</div>
<div class="row">
  <% @products.each do |product| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title"><%= product.name %></h5>
          <h6 class="card-subtitle mb-2 text-muted">Código Base: <code><%= product.base_code %></code></h6>
          <hr>
          <p class="small mb-1"><strong>Estructura:</strong></p>
          <div class="d-flex flex-wrap gap-1">
            <span class="badge bg-dark"><%= product.base_code %></span>
            <% product.product_variant_rules.each do |rule| %>
              <span class="badge bg-secondary">
                <%= rule.separator %><%= rule.variant_type.name %>
              </span>
            <% end %>
          </div>
        </div>
        <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
          <%= link_to "Editar", edit_product_path(product), class: "btn btn-sm btn-outline-warning" %>
          <%= button_to "Eliminar", product, method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "¿Seguro?" } %>
        </div>
      </div>
    </div>
  <% end %>
</div>
<div class="card mt-5 border-warning">
  <div class="card-body">
    <h5 class="card-title text-warning">
      <i class="bi bi-file-earmark-spreadsheet"></i>
      Importación Masiva de Productos y Variantes
    </h5>
    <p class="text-muted small mb-2">
      Formato CSV recomendado:
      <code>Producto,Código Base,Tipo Variante,Etiqueta,Separador,Variante Nombre,Variante Código,Proveedor,Costo,SKU Proveedor,Obligatorio,Activo</code>
    </p>
    <%= form_with url: import_products_path, multipart: true, local: true do |f| %>
      <div class="input-group">
        <%= f.file_field :file, class: "form-control", accept: ".csv" %>
        <button class="btn btn-warning" type="submit">
          <i class="bi bi-cloud-upload"></i> Subir e Importar
        </button>
      </div>
    <% end %>
  </div>
</div>