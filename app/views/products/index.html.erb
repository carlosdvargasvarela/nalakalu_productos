<div class="container-fluid py-4" data-controller="product-filters">
  <%# ── HEADER ── %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0">Productos Base</h1>
      <p class="text-muted mb-0 small">Catálogo, estructura de códigos y configuración de abastecimiento.</p>
    </div>
    <%= link_to new_product_path, class: "btn btn-primary rounded-pill px-4 fw-bold shadow-sm",
        data: { turbo_frame: "product_workspace" } do %>
      <i class="bi bi-plus-lg me-2"></i>Nuevo Producto
    <% end %>
  </div>
  <%# ── STATS ── %>
  <div class="row g-3 mb-4">
    <% [
      ["Total", @stats[:total],             "bi-box-seam",          "primary"],
      ["Activos", @stats[:active],           "bi-check-circle",      "success"],
      ["Listos para compra", @stats[:procurement_ready], "bi-cart-check", "info"],
      ["Sin variantes", @stats[:no_variants],"bi-exclamation-circle","warning"],
    ].each do |label, value, icon, color| %>
      <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-3 d-flex align-items-center gap-3">
            <div class="bg-<%= color %> bg-opacity-10 rounded-3 p-2 flex-shrink-0">
              <i class="bi <%= icon %> fs-4 text-<%= color %>"></i>
            </div>
            <div>
              <div class="fw-bold fs-5 lh-1"><%= value %></div>
              <div class="text-muted x-small"><%= label %></div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <%# ── WORKSPACE ── %>
  <div class="row g-4">
    <%# ── PANEL IZQUIERDO ── %>
    <div class="col-xl-5">
      <div class="card border-0 shadow-sm rounded-4">
        <%# Filtros %>
        <div class="card-header bg-white border-bottom p-3 rounded-top-4">
          <div class="input-group mb-2 shadow-sm">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text"
                   class="form-control bg-light border-0 shadow-none"
                   placeholder="Buscar por nombre o código..."
                   data-action="input->product-filters#filter"
            data-product-filters-target="search">
          </div>
          <div class="row g-2">
            <div class="col-6">
              <select class="form-select form-select-sm border-0 bg-light shadow-none"
                      data-action="change->product-filters#filter"
                data-product-filters-target="family">
                <option value="">Todas las familias</option>
                <% Family.where(active: true).order(:name).each do |f| %>
                  <option value="<%= f.id %>"><%= f.name %></option>
                <% end %>
              </select>
            </div>
            <div class="col-6">
              <select class="form-select form-select-sm border-0 bg-light shadow-none"
                      data-action="change->product-filters#filter"
                data-product-filters-target="status">
                <option value="">Todos los estados</option>
                <option value="active">Activos</option>
                <option value="inactive">Inactivos</option>
                <option value="ready">Listos para compra</option>
                <option value="incomplete">Incompletos</option>
              </select>
            </div>
          </div>
        </div>
        <%# Lista %>
        <div class="list-group list-group-flush rounded-bottom-4"
             style="max-height: calc(100vh - 320px); overflow-y: auto;"
             data-product-filters-target="list">
          <% if @products.empty? %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-box-seam d-block fs-1 mb-2 opacity-25"></i>
              <p class="fw-bold">No hay productos registrados.</p>
            </div>
          <% else %>
            <% @products.each do |product| %>
              <%= render "product_row", product: product,
                    selected: @selected_product&.id == product.id,
                    supplier_type_map: @supplier_type_map,
                    procurement_ready_map: @procurement_ready_map %>
            <% end %>
          <% end %>
        </div>
      </div>
      <%# Importador %>
      <div class="card border-0 shadow-sm rounded-4 border-start border-4 border-warning mt-3">
        <div class="card-body p-3">
          <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="flex-grow-1">
              <p class="fw-bold small mb-0">
                <i class="bi bi-file-earmark-spreadsheet text-warning me-1"></i>Importación CSV
              </p>
              <code class="x-small text-muted">nombre, codigo_base, descripcion</code>
            </div>
            <%= form_with url: import_products_path, multipart: true, local: true do |f| %>
              <div class="input-group input-group-sm shadow-sm">
                <%= f.file_field :file, class: "form-control rounded-start-pill", accept: ".csv" %>
                <button class="btn btn-warning rounded-end-pill fw-bold text-white" type="submit">
                  <i class="bi bi-cloud-upload"></i>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <%# ── PANEL DERECHO ── %>
    <div class="col-xl-7">
      <%= turbo_frame_tag "product_workspace",
          class: "d-block h-100",
          data: { turbo_action: "advance" } do %>
        <% if @selected_product %>
          <%= render "detail_panel", product: @selected_product %>
        <% else %>
          <%= render "workspace_placeholder" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
<style>
  .x-small { font-size: 0.72rem; }
  .rounded-top-4 { border-radius: 1rem 1rem 0 0 !important; }
  .rounded-bottom-4 { border-radius: 0 0 1rem 1rem !important; }
</style>