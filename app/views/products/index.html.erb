<div class="container-fluid py-4" data-controller="product-filters">
  <%# ── HEADER ── %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0">Productos Base</h1>
      <p class="text-muted mb-0 small">Catálogo, estructura de códigos y configuración de abastecimiento.</p>
    </div>
    <%= link_to new_product_path, class: "btn btn-primary rounded-pill px-4 fw-bold shadow-sm",
        data: { turbo_frame: "product_workspace" } do %>
      <i class="bi bi-plus-lg me-2"></i>Nuevo Producto
    <% end %>
  </div>
  <%# ── STATS ── %>
  <div class="row g-3 mb-4">
    <% [
      ["Total",              @stats[:total],              "bi-box-seam",           "primary"],
      ["Activos",            @stats[:active],             "bi-check-circle",       "success"],
      ["Listos para compra", @stats[:procurement_ready],  "bi-cart-check",         "info"],
      ["Sin variantes",      @stats[:no_variants],        "bi-exclamation-circle", "warning"],
    ].each do |label, value, icon, color| %>
      <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-3 d-flex align-items-center gap-3">
            <div class="bg-<%= color %> bg-opacity-10 rounded-3 p-2 flex-shrink-0">
              <i class="bi <%= icon %> fs-4 text-<%= color %>"></i>
            </div>
            <div>
              <div class="fw-bold fs-5 lh-1"><%= value %></div>
              <div class="text-muted x-small"><%= label %></div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <%# ── WORKSPACE ── %>
  <div class="row g-4">
    <%# ── PANEL IZQUIERDO ── %>
    <div class="col-xl-5">
      <div class="card border-0 shadow-sm rounded-4">
        <%# ── Filtros (server-side GET) ── %>
        <div class="card-header bg-white border-bottom p-3 rounded-top-4">
          <%= form_with url: products_path, method: :get,
              data: { turbo_action: "advance" } do |f| %>
            <div class="input-group mb-2 shadow-sm">
              <span class="input-group-text bg-light border-0">
                <i class="bi bi-search text-muted"></i>
              </span>
              <%= f.text_field :search,
                  value: params[:search],
                  class: "form-control bg-light border-0 shadow-none",
                  placeholder: "Buscar por nombre o código...",
                  autocomplete: "off",
                  data: { action: "input->product-filters#debounceSubmit" } %>
            </div>
            <div class="row g-2">
              <div class="col-6">
                <%= f.select :family_id,
                    Family.where(active: true).order(:name).map { |fam| [fam.name, fam.id] },
                    { include_blank: "Todas las familias", selected: params[:family_id] },
                    class: "form-select form-select-sm border-0 bg-light shadow-none",
                    data: { action: "change->product-filters#submit" } %>
              </div>
              <div class="col-6">
                <%= f.select :status,
                    [["Activos","active"],["Inactivos","inactive"],
                     ["Listos para compra","ready"],["Incompletos","incomplete"]],
                    { include_blank: "Todos los estados", selected: params[:status] },
                    class: "form-select form-select-sm border-0 bg-light shadow-none",
                    data: { action: "change->product-filters#submit" } %>
              </div>
            </div>
            <%# Preservar selected_id al filtrar %>
            <%= f.hidden_field :selected_id, value: params[:selected_id] %>
          <% end %>
        </div>
        <%# ── Bulk actions + Lista ── %>
        <div data-controller="bulk-check">
          <% if @products.any? %>
            <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom bg-light flex-wrap">
              <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="select-all-products"
                       data-bulk-check-target="selectAll"
                       data-action="change->bulk-check#toggleAll">
                <label class="form-check-label small fw-semibold" for="select-all-products">Todos</label>
              </div>
              <span class="text-muted small"><span data-bulk-check-target="countBadge"></span> seleccionado(s)</span>

              <%= form_with url: bulk_activate_products_path, method: :patch,
                    data: { bulk_check_target: "form" }, class: "ms-auto d-inline" do %>
                <%= hidden_field_tag :search, params[:search] %>
                <%= hidden_field_tag :family_id, params[:family_id] %>
                <%= hidden_field_tag :status, params[:status] %>
                <%= hidden_field_tag :selected_id, params[:selected_id] %>
                <button type="submit" class="btn btn-sm btn-outline-success" data-bulk-check-target="bulkButton">
                  <i class="bi bi-check-circle me-1"></i>Activar
                </button>
              <% end %>
              <%= form_with url: bulk_deactivate_products_path, method: :patch,
                    data: { bulk_check_target: "form" }, class: "d-inline" do %>
                <%= hidden_field_tag :search, params[:search] %>
                <%= hidden_field_tag :family_id, params[:family_id] %>
                <%= hidden_field_tag :status, params[:status] %>
                <%= hidden_field_tag :selected_id, params[:selected_id] %>
                <button type="submit" class="btn btn-sm btn-outline-secondary" data-bulk-check-target="bulkButton">
                  <i class="bi bi-slash-circle me-1"></i>Desactivar
                </button>
              <% end %>
            </div>
          <% end %>

          <div class="list-group list-group-flush"
               style="max-height: calc(100vh - 380px); overflow-y: auto;">
            <% if @products.empty? %>
              <div class="text-center py-5 text-muted">
                <i class="bi bi-box-seam d-block fs-1 mb-2 opacity-25"></i>
                <p class="fw-bold mb-0">No hay productos para estos filtros.</p>
              </div>
            <% else %>
              <% @products.each do |product| %>
                <%= render "product_row",
                      product: product,
                      selected: @selected_product&.id == product.id,
                      supplier_type_map: @supplier_type_map,
                      procurement_ready_map: @procurement_ready_map %>
              <% end %>
            <% end %>
          </div>
        </div>
        <%# ── Paginación ── %>
        <% if @pagy.pages > 1 %>
          <% prev_page = (@pagy.page > 1) ? (@pagy.page - 1) : nil %>
          <% next_page = (@pagy.page < @pagy.pages) ? (@pagy.page + 1) : nil %>
          <div class="px-3 py-2 border-top bg-white rounded-bottom-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <small class="text-muted">
              <%= @pagy.count %> productos · pág. <%= @pagy.page %> / <%= @pagy.pages %>
            </small>
            <nav>
              <ul class="pagination pagination-sm mb-0 gap-1">
                <% if prev_page %>
                  <li class="page-item">
                    <%= link_to products_path(params.permit(:search, :family_id, :status, :selected_id).merge(page: prev_page)),
                        class: "page-link rounded-pill px-3" do %>
                      <i class="bi bi-chevron-left"></i>
                    <% end %>
                  </li>
                <% end %>
                <% pagy_pages = ([@pagy.page - 1, 1].max..[@pagy.page + 1, @pagy.pages].min) %>
                <% if pagy_pages.first > 1 %>
                  <li class="page-item">
                    <%= link_to "1", products_path(params.permit(:search, :family_id, :status, :selected_id).merge(page: 1)),
                        class: "page-link rounded-pill px-3" %>
                  </li>
                  <li class="page-item disabled"><span class="page-link">…</span></li>
                <% end %>
                <% pagy_pages.each do |p| %>
                  <li class="page-item <%= 'active' if p == @pagy.page %>">
                    <%= link_to p, products_path(params.permit(:search, :family_id, :status, :selected_id).merge(page: p)),
                        class: "page-link rounded-pill px-3" %>
                  </li>
                <% end %>
                <% if pagy_pages.last < @pagy.pages %>
                  <li class="page-item disabled"><span class="page-link">…</span></li>
                  <li class="page-item">
                    <%= link_to @pagy.pages, products_path(params.permit(:search, :family_id, :status, :selected_id).merge(page: @pagy.pages)),
                        class: "page-link rounded-pill px-3" %>
                  </li>
                <% end %>
                <% if next_page %>
                  <li class="page-item">
                    <%= link_to products_path(params.permit(:search, :family_id, :status, :selected_id).merge(page: next_page)),
                        class: "page-link rounded-pill px-3" do %>
                      <i class="bi bi-chevron-right"></i>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </nav>
          </div>
        <% end %>
      </div>
      <%# ── Importador ── %>
      <div class="card border-0 shadow-sm rounded-4 border-start border-4 border-warning mt-3">
        <div class="card-body p-3">
          <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="flex-grow-1">
              <p class="fw-bold small mb-0">
                <i class="bi bi-file-earmark-spreadsheet text-warning me-1"></i>Importación CSV
              </p>
              <code class="x-small text-muted">nombre, codigo_base, descripcion</code>
            </div>
            <%= form_with url: import_products_path, multipart: true, local: true do |f| %>
              <div class="input-group input-group-sm shadow-sm">
                <%= f.file_field :file, class: "form-control rounded-start-pill", accept: ".csv" %>
                <button class="btn btn-warning rounded-end-pill fw-bold text-white" type="submit">
                  <i class="bi bi-cloud-upload"></i>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <%# ── PANEL DERECHO ── %>
    <div class="col-xl-7">
      <%= turbo_frame_tag "product_workspace",
          class: "d-block h-100",
          data: { turbo_action: "advance" } do %>
        <% if @selected_product %>
          <%= render "detail_panel", product: @selected_product %>
        <% else %>
          <%= render "workspace_placeholder" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
<style>
  .x-small { font-size: 0.72rem; }
  .rounded-top-4    { border-radius: 1rem 1rem 0 0 !important; }
  .rounded-bottom-4 { border-radius: 0 0 1rem 1rem !important; }
</style>