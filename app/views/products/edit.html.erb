<div class="container-fluid py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Productos", products_path, class: "text-decoration-none" %></li>
      <li class="breadcrumb-item"><%= link_to @product.name, @product, class: "text-decoration-none" %></li>
      <li class="breadcrumb-item active">Editar</li>
    </ol>
  </nav>
  <h2 class="fw-bold mb-4">Editando: <span class="text-primary"><%= @product.name %></span></h2>
  <%= render "form", product: @product %>
</div>