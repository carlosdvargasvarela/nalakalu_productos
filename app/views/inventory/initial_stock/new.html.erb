<%# Turbo Stream — actualiza selects cuando se crea un producto nuevo %>
<div data-controller="products-live">
  <%= turbo_stream_from "products" %>
  <select id="products_live_source" class="d-none" aria-hidden="true"
          data-products-live-target="source"></select>
</div>

<div data-controller="initial-stock-form"
     data-initial-stock-form-quick-create-url-value="<%= inventory_quick_create_product_path %>">

  <%# ── HEADER ── %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-0 fs-4"><i class="bi bi-box-arrow-in-down me-2 text-primary"></i>Cargar stock inicial</h1>
      <p class="text-muted small mb-0">Registra múltiples productos de una sala en un solo cargue.</p>
    </div>
  </div>

  <%= form_with url: inventory_initial_stock_path, method: :post do %>

    <%# ── PARÁMETROS ── %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-bottom py-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-gear me-2 text-muted"></i>Parámetros del cargue</h6>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label small fw-semibold">Sala <span class="text-danger">*</span></label>
            <%= select_tag :showroom_id,
                  options_for_select(@showrooms.map { |s| [s.name, s.id] }),
                  include_blank: "— Selecciona una sala —",
                  class: "form-select", required: true %>
          </div>
          <div class="col-md-4">
            <label class="form-label small fw-semibold">Fecha de referencia</label>
            <%= date_field_tag :delivery_date, Date.current, class: "form-control" %>
            <div class="form-text">Fecha del conteo o toma de inventario.</div>
          </div>
          <div class="col-md-4">
            <label class="form-label small fw-semibold">Notas <span class="text-muted fw-normal">(opcional)</span></label>
            <%= text_area_tag :notes, nil, rows: 2, class: "form-control",
                  placeholder: "Ej: Toma de inventario apertura junio 2026" %>
          </div>
        </div>
      </div>
    </div>

    <%# ── TABLA DE PRODUCTOS ── %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-list-ul me-2 text-muted"></i>Productos</h6>
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-action="click->initial-stock-form#addRow">
          <i class="bi bi-plus-circle me-1"></i>Agregar fila
        </button>
      </div>
      <div class="card-body p-0">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3" style="width:60%">Producto</th>
              <th style="width:20%">Cantidad</th>
              <th style="width:5%"></th>
            </tr>
          </thead>
          <tbody data-initial-stock-form-target="body">
            <tr data-initial-stock-form-target="row">
              <td class="ps-3">
                <div class="d-flex gap-2 align-items-center">
                  <%= select_tag "items[0][product_id]",
                        options_for_select(@products.map { |p| [p.name, p.id] }),
                        include_blank: "— Seleccionar —",
                        class: "form-select form-select-sm",
                        "data-initial-stock-form-target": "productSelect",
                        "data-product-select": "true" %>
                  <button type="button" class="btn btn-sm btn-outline-secondary text-nowrap"
                          data-action="click->initial-stock-form#openQuickCreate">
                    <i class="bi bi-plus-lg"></i>
                  </button>
                </div>
              </td>
              <td>
                <input type="number" name="items[0][quantity]" min="0.01" step="0.01" value="1"
                       class="form-control form-control-sm" placeholder="1" required>
              </td>
              <td>
                <button type="button" class="btn btn-sm btn-outline-danger" disabled
                        data-action="click->initial-stock-form#removeRow">
                  <i class="bi bi-trash3"></i>
                </button>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-white border-top d-flex justify-content-between align-items-center py-3">
        <button type="button" class="btn btn-outline-primary btn-sm"
                data-action="click->initial-stock-form#addRow">
          <i class="bi bi-plus-circle me-1"></i>Agregar otra fila
        </button>
        <div class="d-flex gap-2">
          <%= link_to "Cancelar", inventory_path, class: "btn btn-outline-secondary" %>
          <button type="submit" class="btn btn-primary fw-semibold">
            <i class="bi bi-cloud-check me-1"></i>Guardar stock inicial
          </button>
        </div>
      </div>
    </div>

  <% end %>

  <%# ── MODAL CREAR PRODUCTO RÁPIDO ── %>
  <div class="modal fade" id="quickCreateProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow-lg">
        <div class="modal-header border-0 bg-primary text-white">
          <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2"></i>Crear nuevo producto</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <div class="alert alert-danger d-none" data-initial-stock-form-target="quickCreateError"></div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Nombre <span class="text-danger">*</span></label>
            <input type="text" class="form-control" placeholder="Ej: Sofá 3 puestos Oslo"
                   data-initial-stock-form-target="newProductName">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Código interno <span class="text-danger">*</span></label>
            <input type="text" class="form-control" placeholder="Ej: SOF-001"
                   data-initial-stock-form-target="newProductCode">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Familia <span class="text-muted fw-normal">(opcional)</span></label>
            <%= select_tag nil, options_for_select(@families.map { |f| [f.name, f.id] }),
                  include_blank: "— Sin familia —", class: "form-select",
                  "data-initial-stock-form-target": "newProductFamily" %>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-primary fw-semibold"
                  data-action="click->initial-stock-form#submitQuickCreate">
            <i class="bi bi-check-lg me-1"></i>Crear producto
          </button>
        </div>
      </div>
    </div>
  </div>

</div>
