<%# ── HEADER ── %>
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <h1 class="fw-bold mb-0 fs-4">Movimientos de inventario</h1>
    <p class="text-muted mb-0 small">
      <% if @movements.size == 300 %>
        Mostrando los últimos 300 movimientos.
        <span class="badge bg-warning text-dark ms-1">Limit 300</span>
      <% else %>
        <%= @movements.size %> movimiento(s) encontrado(s).
      <% end %>
    </p>
  </div>
</div>

<%# ── FILTROS ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-3">
    <%= form_with url: inventory_movements_log_path, method: :get,
          class: "row g-2 align-items-end" do %>
      <div class="col-md-2">
        <label class="form-label small fw-semibold mb-1">Sala</label>
        <%= select_tag :showroom_id,
              options_for_select([["Todas", ""]] + @showrooms.map { |s| [s.name, s.id] }, @filter["showroom_id"]),
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold mb-1">Producto</label>
        <%= select_tag :product_id,
              options_for_select([["Todos", ""]] + @products.map { |p| [p.name, p.id] }, @filter["product_id"]),
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold mb-1">Tipo</label>
        <%= select_tag :movement_type,
              options_for_select(
                [["Todos", ""], ["Entrada", "entry"], ["Salida", "exit"], ["Stock inicial", "initial"]],
                @filter["movement_type"]
              ),
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold mb-1">Desde</label>
        <%= date_field_tag :from, @filter["from"], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold mb-1">Hasta</label>
        <%= date_field_tag :to, @filter["to"], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-1 d-flex gap-1">
        <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
          <i class="bi bi-search"></i>
        </button>
        <% if @filter.values.any?(&:present?) %>
          <%= link_to inventory_movements_log_path, class: "btn btn-outline-secondary btn-sm", title: "Limpiar" do %>
            <i class="bi bi-x-lg"></i>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ── TABLA (con bulk actions) ── %>
<% manual_ids = @movements.select { |m| m.source == "manual" }.map(&:id) %>

<div data-controller="bulk-check">
  <% if manual_ids.any? %>
    <div class="d-flex align-items-center gap-3 mb-3 px-3 py-2 bg-white border rounded-3 shadow-sm flex-wrap">
      <div class="form-check mb-0">
        <input class="form-check-input" type="checkbox" id="select-all-movements"
               data-bulk-check-target="selectAll"
               data-action="change->bulk-check#toggleAll">
        <label class="form-check-label small fw-semibold" for="select-all-movements">Seleccionar todo</label>
      </div>
      <span class="text-muted small"><span data-bulk-check-target="countBadge"></span> seleccionado(s)</span>

      <%= form_with url: bulk_destroy_inventory_movements_path, method: :delete,
            data: { bulk_check_target: "form" } do %>
        <%= hidden_field_tag :showroom_id, @filter["showroom_id"] %>
        <%= hidden_field_tag :product_id, @filter["product_id"] %>
        <%= hidden_field_tag :movement_type, @filter["movement_type"] %>
        <%= hidden_field_tag :from, @filter["from"] %>
        <%= hidden_field_tag :to, @filter["to"] %>
        <button type="submit" class="btn btn-sm btn-outline-danger"
                data-bulk-check-target="bulkButton"
                data-turbo-confirm="¿Eliminar los movimientos manuales seleccionados? Esta acción no se puede deshacer.">
          <i class="bi bi-trash me-1"></i>Eliminar
        </button>
      <% end %>

      <%= form_with url: bulk_export_inventory_movements_path, method: :get,
            data: { bulk_check_target: "form" } do %>
        <button type="submit" class="btn btn-sm btn-outline-secondary" data-bulk-check-target="bulkButton">
          <i class="bi bi-file-earmark-excel me-1"></i>Exportar
        </button>
      <% end %>

      <button type="button" class="btn btn-sm btn-outline-primary" data-bulk-check-target="bulkButton"
              data-bs-toggle="modal" data-bs-target="#bulkReassignShowroomModal">
        <i class="bi bi-arrow-left-right me-1"></i>Reasignar sala
      </button>

      <button type="button" class="btn btn-sm btn-outline-primary" data-bulk-check-target="bulkButton"
              data-bs-toggle="modal" data-bs-target="#bulkEditNoteModal">
        <i class="bi bi-pencil-square me-1"></i>Editar nota/pedido
      </button>

      <span class="text-muted small ms-auto fst-italic">Edición y exportación solo para movimientos <strong>manuales</strong></span>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <% if @movements.empty? %>
        <div class="text-center text-muted py-5">
          <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
          <p class="mb-0 fw-semibold">Sin movimientos para los filtros aplicados.</p>
        </div>
      <% else %>
        <div class="table-responsive">
          <table class="table table-hover table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th style="width:38px;" class="ps-3"></th>
                <th>Fecha</th>
                <th>Tipo</th>
                <th>Sala</th>
                <th>Producto</th>
                <th class="text-center">Cant.</th>
                <th>Origen</th>
                <th>Pedido</th>
                <th>Notas</th>
              </tr>
            </thead>
            <tbody>
              <% @movements.each do |m| %>
                <%
                  is_manual = m.source == "manual"
                  row_bg = case m.movement_type
                    when "entry"   then "table-success"
                    when "exit"    then "table-danger"
                    when "initial" then "table-info"
                  end
                  badge_class = case m.movement_type
                    when "entry"   then "bg-success"
                    when "exit"    then "bg-danger"
                    when "initial" then "bg-info text-dark"
                  end
                %>
                <tr class="<%= row_bg %>">
                  <td class="ps-3">
                    <% if is_manual %>
                      <input class="form-check-input" type="checkbox"
                             value="<%= m.id %>"
                             data-bulk-check-target="checkbox"
                             data-action="change->bulk-check#updateBulkButton">
                    <% end %>
                  </td>
                  <td class="small text-nowrap"><%= m.delivery_date&.strftime("%d/%m/%Y") || "—" %></td>
                  <td><span class="badge <%= badge_class %>"><%= m.type_label %></span></td>
                  <td class="small"><%= m.showroom&.name || "—" %></td>
                  <td class="fw-semibold small"><%= m.product&.name || m.product_name_raw || "—" %></td>
                  <td class="text-center fw-bold"><%= m.quantity.round(2) %></td>
                  <td>
                    <span class="badge <%= is_manual ? 'bg-secondary' : 'bg-light text-dark border' %> small">
                      <%= is_manual ? "Manual" : "Sync" %>
                    </span>
                    <% if m.flag == "stock_missing" %>
                      <i class="bi bi-exclamation-triangle-fill text-warning ms-1" title="Stock insuficiente"></i>
                    <% end %>
                  </td>
                  <td class="small text-muted"><%= m.order_number&.truncate(18) || "—" %></td>
                  <td class="small text-muted" style="max-width:160px;">
                    <span title="<%= m.notes %>"><%= m.notes&.truncate(38) %></span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── MODAL: Reasignar sala ── %>
  <div class="modal fade" id="bulkReassignShowroomModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content border-0 rounded-4 shadow">
        <%= form_with url: bulk_reassign_showroom_inventory_movements_path, method: :patch,
              data: { bulk_check_target: "form" } do %>
          <%= hidden_field_tag :showroom_id, @filter["showroom_id"] %>
          <%= hidden_field_tag :product_id, @filter["product_id"] %>
          <%= hidden_field_tag :movement_type, @filter["movement_type"] %>
          <%= hidden_field_tag :from, @filter["from"] %>
          <%= hidden_field_tag :to, @filter["to"] %>
          <div class="modal-header border-bottom-0 p-4 pb-2">
            <h5 class="modal-title fw-bold">Reasignar sala</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4 pt-0">
            <label class="form-label small fw-semibold">Nueva sala</label>
            <%= select_tag :new_showroom_id,
                  options_for_select([["— Seleccione —", ""]] + @showrooms.map { |s| [s.name, s.id] }),
                  class: "form-select" %>
            <p class="text-muted small mt-2 mb-0">Solo aplica a movimientos manuales seleccionados.</p>
          </div>
          <div class="modal-footer border-top-0 p-4 pt-2">
            <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Reasignar</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── MODAL: Editar nota/pedido ── %>
  <div class="modal fade" id="bulkEditNoteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content border-0 rounded-4 shadow">
        <%= form_with url: bulk_edit_note_inventory_movements_path, method: :patch,
              data: { bulk_check_target: "form" } do %>
          <%= hidden_field_tag :showroom_id, @filter["showroom_id"] %>
          <%= hidden_field_tag :product_id, @filter["product_id"] %>
          <%= hidden_field_tag :movement_type, @filter["movement_type"] %>
          <%= hidden_field_tag :from, @filter["from"] %>
          <%= hidden_field_tag :to, @filter["to"] %>
          <div class="modal-header border-bottom-0 p-4 pb-2">
            <h5 class="modal-title fw-bold">Editar nota / pedido</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4 pt-0">
            <label class="form-label small fw-semibold">Pedido</label>
            <%= text_field_tag :order_number, nil, class: "form-control mb-3", placeholder: "Dejar en blanco para no modificar" %>
            <label class="form-label small fw-semibold">Nota</label>
            <%= text_area_tag :note, nil, rows: 3, class: "form-control", placeholder: "Dejar en blanco para no modificar" %>
            <p class="text-muted small mt-2 mb-0">Solo aplica a movimientos manuales seleccionados. Los campos en blanco no se modifican.</p>
          </div>
          <div class="modal-footer border-top-0 p-4 pt-2">
            <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Guardar</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
