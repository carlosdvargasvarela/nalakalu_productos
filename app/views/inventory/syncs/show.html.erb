<div data-controller="sync-review"
     data-sync-review-quick-create-url-value="<%= inventory_quick_create_product_path %>">

<%# Turbo Stream %>
<div data-controller="products-live">
  <%= turbo_stream_from "products" %>
  <select id="products_live_source" class="d-none" aria-hidden="true"
          data-products-live-target="source"></select>
</div>

<%# ── HEADER ── %>
<% title      = @sync.bulk_upload? ? "Revisión de carga masiva" : "Revisión de sincronización" %>
<% unit_label = @sync.bulk_upload? ? "filas procesadas" : "entregas" %>
<% icon       = @sync.bulk_upload? ? "bi-file-earmark-spreadsheet" : "bi-arrow-repeat" %>
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div>
    <nav aria-label="breadcrumb" class="mb-1">
      <ol class="breadcrumb mb-0 small">
        <li class="breadcrumb-item"><%= link_to "Inventario", inventory_path %></li>
        <li class="breadcrumb-item active"><%= title %></li>
      </ol>
    </nav>
    <h1 class="fw-bold mb-0 fs-4"><i class="bi <%= icon %> me-2 text-primary"></i><%= title %></h1>
    <p class="text-muted small mb-0">
      <%= @sync.from_date.strftime("%d/%m/%Y") %> – <%= @sync.to_date.strftime("%d/%m/%Y") %>
      &nbsp;·&nbsp; <%= @sync.deliveries_processed %> <%= unit_label %>
      &nbsp;·&nbsp; <strong><%= @sync.movements_count %></strong> movimientos
    </p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <% if @sync.confirmable? %>
      <%= button_to confirm_inventory_sync_path(@sync), method: :patch,
            class: "btn btn-success fw-semibold",
            data: { turbo_confirm: "¿Confirmar esta sincronización? Los movimientos afectarán el stock." } do %>
        <i class="bi bi-check-circle me-1"></i>Confirmar y aplicar
      <% end %>
    <% else %>
      <button class="btn btn-success fw-semibold" disabled title="Resuelve todos los ítems pendientes primero">
        <i class="bi bi-check-circle me-1"></i>Confirmar
      </button>
    <% end %>
    <%= button_to inventory_sync_path(@sync), method: :delete,
          class: "btn btn-outline-danger btn-sm",
          data: { turbo_confirm: "¿Eliminar esta sincronización? Se perderán todos los movimientos." } do %>
      <i class="bi bi-trash me-1"></i>Eliminar
    <% end %>
  </div>
</div>

<% if @sync.import_errors.present? %>
  <div class="alert alert-warning border-0 shadow-sm mb-4">
    <i class="bi bi-exclamation-triangle me-2"></i>
    <strong><%= @sync.import_errors.size %> fila(s)</strong> del archivo no se pudieron procesar y fueron omitidas:
    <ul class="mb-0 mt-2 small">
      <% @sync.import_errors.each do |err| %>
        <li><%= err %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%# ── KPI CARDS ── %>
<div class="row g-3 mb-4">
  <% [
    [@stat_confirmed,  "Confirmados",  "bi-check-circle-fill", "success"],
    [@stat_suggested,  "Sugeridos",    "bi-lightbulb-fill",    "info"],
    [@stat_unassigned, "Sin asignar",  "bi-question-circle",   "warning"],
    [@stat_ignored,    "Ignorados",    "bi-eye-slash",         "secondary"],
  ].each do |count, label, icon, color| %>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3 py-3">
          <div class="rounded-3 bg-<%= color %> bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:38px;height:38px;">
            <i class="bi <%= icon %> text-<%= color %>"></i>
          </div>
          <div>
            <div class="fs-4 fw-bold lh-1 mb-1 <%= count > 0 ? "text-#{color}-emphasis" : "text-muted" %>">
              <%= count %>
            </div>
            <div class="text-muted small"><%= label %></div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%# ── ALERTA: CONFIRMAR SUGERIDOS EN LOTE ── %>
<% if @stat_suggested > 0 %>
  <div class="alert alert-info border-0 shadow-sm mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <i class="bi bi-lightbulb-fill me-2"></i>
      <strong><%= @stat_suggested %> movimiento(s)</strong> tienen producto detectado automáticamente.
    </div>
    <%= button_to confirm_matched_inventory_sync_path(@sync), method: :patch,
          class: "btn btn-info btn-sm text-white",
          data: { turbo_confirm: "¿Confirmar todos los movimientos con producto detectado?" } do %>
      <i class="bi bi-check-all me-1"></i>Confirmar todos los sugeridos (<%= @stat_suggested %>)
    <% end %>
  </div>
<% end %>

<% if @sync.confirmable? %>
  <div class="alert alert-success border-0 shadow-sm mb-4">
    <i class="bi bi-check-circle-fill me-2"></i>
    Todos los movimientos están revisados. Puedes confirmar la sincronización.
  </div>
<% end %>

<%# ── FILTROS + BÚSQUEDA ── %>
<% pending_count = @stat_suggested + @stat_unassigned %>
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
  <div class="btn-group btn-group-sm" role="group">
    <button type="button" class="btn btn-outline-secondary active"
            data-action="click->sync-review#setFilter" data-status="all">
      Todos <span class="badge bg-secondary ms-1"><%= @sync.movements_count %></span>
    </button>
    <% if pending_count > 0 %>
      <button type="button" class="btn btn-outline-warning"
              data-action="click->sync-review#setFilter" data-status="pending">
        Pendientes <span class="badge bg-warning text-dark ms-1"><%= pending_count %></span>
      </button>
    <% end %>
    <% if @stat_suggested > 0 %>
      <button type="button" class="btn btn-outline-info"
              data-action="click->sync-review#setFilter" data-status="suggested">
        Sugeridos <span class="badge bg-info text-dark ms-1"><%= @stat_suggested %></span>
      </button>
    <% end %>
    <% if @stat_unassigned > 0 %>
      <button type="button" class="btn btn-outline-warning"
              data-action="click->sync-review#setFilter" data-status="unassigned">
        Sin asignar <span class="badge bg-warning text-dark ms-1"><%= @stat_unassigned %></span>
      </button>
    <% end %>
    <% if @stat_confirmed > 0 %>
      <button type="button" class="btn btn-outline-success"
              data-action="click->sync-review#setFilter" data-status="resolved">
        Confirmados <span class="badge bg-success ms-1"><%= @stat_confirmed %></span>
      </button>
    <% end %>
    <% if @stat_ignored > 0 %>
      <button type="button" class="btn btn-outline-secondary"
              data-action="click->sync-review#setFilter" data-status="ignored">
        Ignorados <span class="badge bg-secondary ms-1"><%= @stat_ignored %></span>
      </button>
    <% end %>
  </div>
  <div class="input-group input-group-sm" style="max-width:280px;">
    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
    <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar pedido o producto…"
           data-action="input->sync-review#search">
    <button class="btn btn-outline-secondary" type="button"
            data-action="click->sync-review#clearSearch"><i class="bi bi-x"></i></button>
  </div>
</div>

<%# ── BULK IGNORE ── %>
<% if pending_count > 0 %>
  <div class="d-flex align-items-center gap-3 mb-3 px-3 py-2 bg-white border rounded-3 shadow-sm">
    <div class="form-check mb-0">
      <input class="form-check-input" type="checkbox" id="select-all-unresolved"
             data-sync-review-target="selectAllUnresolved"
             data-action="change->sync-review#toggleSelectAll">
      <label class="form-check-label small fw-semibold" for="select-all-unresolved">Seleccionar pendientes visibles</label>
    </div>
    <span class="text-muted small"><span data-sync-review-target="bulkCount"></span> seleccionado(s)</span>
    <button type="button" class="btn btn-sm btn-outline-secondary"
            data-sync-review-target="bulkIgnoreBtn"
            data-action="click->sync-review#submitBulkIgnore"
            data-turbo-confirm="¿Ignorar los movimientos seleccionados?" disabled>
      <i class="bi bi-eye-slash me-1"></i>Ignorar seleccionados
    </button>
    <form id="bulk-ignore-form" action="<%= bulk_ignore_inventory_sync_path(@sync) %>" method="post" class="mb-0">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    </form>
  </div>
<% end %>

<%# ── GRUPOS DE MOVIMIENTOS ── %>
<% @movement_groups.each do |order_number, movements| %>
  <% exits           = movements.select { |m| m.movement_type == "exit" } %>
  <% entries         = movements.select { |m| m.movement_type == "entry" } %>
  <% is_transfer     = exits.any? && entries.any? %>
  <% group_date      = movements.first&.delivery_date %>
  <% pending_in_group = movements.count { |m| m.status == "unresolved" } %>
  <% client_name     = movements.first&.client_name %>
  <% delivery_status = movements.first&.delivery_status %>
  <% delivery_badge  = case delivery_status&.downcase
      when /entregad|delivered/  then "bg-success"
      when /cancelad|cancelled/  then "bg-danger"
      when /parcial|partial/     then "bg-warning text-dark"
      when /transit|en_ruta/     then "bg-info text-dark"
      else                            "bg-secondary"
     end %>

  <div class="card border-0 shadow-sm mb-3" data-sync-review-target="orderGroup">
    <div class="card-header py-3 d-flex justify-content-between align-items-center flex-wrap gap-2
                <%= is_transfer ? 'bg-primary-subtle' : (entries.any? ? 'bg-success-subtle' : 'bg-danger-subtle') %>">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <% if is_transfer %>
          <i class="bi bi-arrow-left-right text-primary"></i>
          <strong class="text-primary-emphasis small">Transferencia</strong>
          <span class="badge bg-primary small"><%= exits.first&.showroom&.name || "?" %></span>
          <i class="bi bi-arrow-right text-primary small"></i>
          <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle small">
            <%= entries.first&.showroom&.name || "?" %>
          </span>
        <% elsif entries.any? %>
          <i class="bi bi-arrow-down-circle text-success"></i>
          <strong class="text-success-emphasis small">Entrada</strong>
          <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle small">
            <%= entries.first&.showroom&.name || "?" %>
          </span>
        <% else %>
          <i class="bi bi-arrow-up-circle text-danger"></i>
          <strong class="text-danger-emphasis small">Salida</strong>
          <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle small">
            <%= exits.first&.showroom&.name || "?" %>
          </span>
        <% end %>
        <span class="text-muted small">
          <%= group_date&.strftime("%d/%m/%Y") %>
          &middot; <code class="small"><%= order_number %></code>
          <% if client_name.present? %>
            &middot; <i class="bi bi-person me-1"></i><%= client_name %>
          <% end %>
        </span>
        <% if delivery_status.present? %>
          <span class="badge <%= delivery_badge %> small"><i class="bi bi-truck me-1"></i><%= delivery_status %></span>
        <% end %>
      </div>
      <% if pending_in_group > 0 %>
        <span class="badge bg-warning text-dark small"><i class="bi bi-clock me-1"></i><%= pending_in_group %> pendiente(s)</span>
      <% else %>
        <span class="badge bg-success small"><i class="bi bi-check-lg me-1"></i>Completo</span>
      <% end %>
    </div>

    <table class="table table-sm align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th style="width:36px;" class="ps-3"></th>
          <th>Nombre recibido</th>
          <th>Tipo</th>
          <% if is_transfer %><th>Sala</th><% end %>
          <th class="text-center">Cant.</th>
          <th style="min-width:280px;">Producto a confirmar</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% movements.each do |m| %>
          <%
            m_status = if m.status == "resolved" then "resolved"
                       elsif m.status == "ignored" then "ignored"
                       elsif m.product_id.present? then "suggested"
                       else "unassigned"
                       end
            row_class = case m_status
              when "resolved"   then "table-success"
              when "ignored"    then "table-secondary opacity-75"
              when "suggested"  then "table-info"
              when "unassigned" then "table-warning"
            end
          %>
          <tr class="<%= row_class %>"
              data-sync-review-target="movementRow"
              data-status="<%= m_status %>">
            <td class="ps-3">
              <% if m.status == "unresolved" %>
                <input class="form-check-input ignore-cb" type="checkbox" value="<%= m.id %>"
                       data-action="change->sync-review#checkboxChanged">
              <% end %>
            </td>
            <td><code class="small text-dark"><%= m.product_name_raw %></code></td>
            <td>
              <span class="badge <%= m.movement_type == 'entry' ? 'bg-success' : 'bg-danger' %> small">
                <%= m.type_label %>
              </span>
            </td>
            <% if is_transfer %>
              <td><small class="text-muted"><%= m.showroom&.name %></small></td>
            <% end %>
            <td class="text-center fw-semibold small"><%= m.quantity %></td>
            <td>
              <% if m.status == "resolved" %>
                <span class="text-success-emphasis fw-semibold small">
                  <i class="bi bi-check-circle-fill me-1"></i><%= m.product&.name || "—" %>
                </span>
              <% elsif m.status == "ignored" %>
                <span class="text-muted fst-italic small">
                  <i class="bi bi-eye-slash me-1"></i>Ignorado
                </span>
              <% else %>
                <%= form_with url: inventory_movement_path(m), method: :patch,
                      class: "d-flex gap-1 align-items-center" do %>
                  <%= select_tag "inventory_movement[product_id]",
                        options_for_select(@products_for_select.map { |p| [p.name, p.id] }, m.product_id),
                        include_blank: "— Seleccionar —",
                        class: "form-select form-select-sm",
                        data: { "sync-review-target": "productSelect", "product-select": "true" } %>
                  <button type="button" class="btn btn-sm btn-outline-secondary"
                          title="Nuevo producto" data-action="click->sync-review#openQuickCreate">
                    <i class="bi bi-plus-lg"></i>
                  </button>
                  <button type="submit" class="btn btn-sm <%= m.product_id.present? ? 'btn-primary' : 'btn-success' %> text-nowrap">
                    <i class="bi bi-check-lg"></i> <%= m.product_id.present? ? "Confirmar" : "Asignar" %>
                  </button>
                <% end %>
              <% end %>
            </td>
            <td>
              <% if m.status == "unresolved" %>
                <%= button_to inventory_movement_path(m), method: :patch,
                      params: { ignore: true },
                      class: "btn btn-sm btn-outline-secondary",
                      title: "Ignorar",
                      data: { turbo_confirm: "¿Ignorar este ítem?" } do %>
                  <i class="bi bi-eye-slash"></i>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<% if @movement_groups.empty? %>
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
      <p class="mb-0 fw-semibold text-muted">Esta sincronización no tiene movimientos.</p>
    </div>
  </div>
<% end %>

<%# ── MODAL CREAR PRODUCTO RÁPIDO ── %>
<div class="modal fade" id="quickCreateProductModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header border-bottom">
        <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Nuevo producto</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-danger d-none small py-2" data-sync-review-target="quickCreateError"></div>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Nombre <span class="text-danger">*</span></label>
          <input type="text" class="form-control" placeholder="Ej: Sofá 3 plazas gris"
                 data-sync-review-target="newProductName">
        </div>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Código base <span class="text-danger">*</span></label>
          <input type="text" class="form-control font-monospace" placeholder="Ej: SOF-3P-GR"
                 data-sync-review-target="newProductCode">
        </div>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Familia</label>
          <select class="form-select" data-sync-review-target="newProductFamily">
            <option value="">— Sin familia —</option>
            <% @families.each do |f| %>
              <option value="<%= f.id %>"><%= f.name %></option>
            <% end %>
          </select>
        </div>
      </div>
      <div class="modal-footer border-top">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary fw-semibold"
                data-action="click->sync-review#submitQuickCreate">
          <i class="bi bi-check-lg me-1"></i>Crear y seleccionar
        </button>
      </div>
    </div>
  </div>
</div>

</div>
