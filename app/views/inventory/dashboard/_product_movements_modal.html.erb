<div class="modal-header border-0 pb-0">
  <div>
    <h5 class="modal-title fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i><%= product.name %></h5>
    <p class="text-muted small mb-0">Últimos movimientos confirmados</p>
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body pt-3 px-0">
  <% if movements.empty? %>
    <div class="text-center text-muted py-4">
      <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
      Sin movimientos confirmados para este producto.
    </div>
  <% else %>
    <table class="table table-sm align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Fecha</th>
          <th>Tipo</th>
          <th>Sala</th>
          <th class="text-center">Cant.</th>
          <th>Origen</th>
        </tr>
      </thead>
      <tbody>
        <% movements.each do |m| %>
          <tr>
            <td class="ps-3 small text-muted text-nowrap"><%= m.delivery_date&.strftime("%d/%m/%Y") || "—" %></td>
            <td>
              <span class="badge <%= m.movement_type == 'entry' ? 'bg-success' : m.movement_type == 'exit' ? 'bg-danger' : 'bg-info text-dark' %>">
                <%= m.type_label %>
              </span>
            </td>
            <td class="small"><%= m.showroom&.name || "—" %></td>
            <td class="text-center fw-semibold"><%= m.quantity.round(2) %></td>
            <td>
              <span class="badge bg-light text-dark border small"><%= m.source_label %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
