<div data-controller="sync-config"
     data-sync-config-test-url-value="<%= inventory_sync_config_test_classify_path %>">

<%# ── HEADER ── %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="fw-bold mb-0 fs-4"><i class="bi bi-sliders me-2 text-primary"></i>Configuración de sincronización</h1>
    <p class="text-muted small mb-0">Controla cómo y cuándo se importan movimientos desde la API de logística.</p>
  </div>
</div>

<%# ── 1. PREFIJOS POR SALA ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3">
    <h6 class="mb-0 fw-semibold"><i class="bi bi-tags me-2 text-primary"></i>Reglas de prefijos por sala</h6>
    <p class="text-muted small mb-0 mt-1">
      Si el número de pedido empieza con alguno de estos prefijos, se genera una <strong>Entrada</strong> para esa sala.
    </p>
  </div>
  <div class="card-body p-0">
    <table class="table table-sm align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Sala</th>
          <th>Código API</th>
          <th class="text-center" style="width:80px;">Principal</th>
          <th>Prefijos <span class="text-muted fw-normal small">(separados por coma)</span></th>
          <th style="width:90px;"></th>
        </tr>
      </thead>
      <tbody>
        <% @showrooms.each do |showroom| %>
          <tr>
            <td class="ps-3 fw-semibold small"><%= showroom.name %></td>
            <td><code class="small"><%= showroom.code %></code></td>
            <td class="text-center">
              <%= showroom.is_main? ? '<span class="badge bg-primary small">Sí</span>'.html_safe : '<span class="text-muted">—</span>'.html_safe %>
            </td>
            <td>
              <%= form_with url: inventory_sync_config_prefixes_path(showroom), method: :patch,
                    class: "d-flex gap-2 align-items-center" do %>
                <input type="text" name="prefixes"
                       value="<%= showroom.order_number_prefixes_array.join(', ') %>"
                       class="form-control form-control-sm font-monospace"
                       placeholder="Ej: 2-, 3-">
                <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap">
                  <i class="bi bi-check-lg"></i> Guardar
                </button>
              <% end %>
            </td>
            <td>
              <% if showroom.order_number_prefixes_array.empty? %>
                <span class="badge bg-light text-muted border small">Sin prefijos</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="card-footer bg-white text-muted small">
    <i class="bi bi-info-circle me-1"></i>
    Los pedidos con <code>source_showroom</code> / <code>destination_showroom</code> de la API son detectados automáticamente (Regla 1).
  </div>
</div>

<%# ── 1B. PREFIJOS GLOBALES DE PEDIDOS DE SALIDA ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3">
    <h6 class="mb-0 fw-semibold"><i class="bi bi-box-arrow-right me-2 text-danger"></i>Prefijos de pedidos de salida</h6>
    <p class="text-muted small mb-0 mt-1">
      Si el número de pedido empieza con alguno de estos prefijos (ej. pedidos de venta a cliente),
      se evalúan las <strong>palabras clave de producto</strong> de cada sala (Regla 3) para detectar una <strong>Salida</strong>.
    </p>
  </div>
  <div class="card-body">
    <%= form_with url: inventory_sync_config_exit_prefixes_path, method: :patch,
          class: "d-flex gap-2 align-items-center" do %>
      <input type="text" name="exit_order_prefixes"
             value="<%= @config.exit_order_prefixes_array.join(', ') %>"
             class="form-control font-monospace"
             placeholder="Ej: PED-4, PED-5">
      <button type="submit" class="btn btn-outline-primary text-nowrap">
        <i class="bi bi-check-lg"></i> Guardar
      </button>
    <% end %>
  </div>
  <div class="card-footer bg-white text-muted small">
    <i class="bi bi-info-circle me-1"></i>
    Las palabras clave de cada sala se configuran en su ficha (<%= link_to "ver salas", showrooms_path %>).
    Si un producto matchea palabras clave de más de una sala, el movimiento queda pendiente de
    revisión manual en la pantalla de sincronización.
  </div>
</div>

<%# ── 2. PROBAR CLASIFICACIÓN ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3">
    <h6 class="mb-0 fw-semibold"><i class="bi bi-flask me-2 text-success"></i>Probar clasificación</h6>
    <p class="text-muted small mb-0 mt-1">Simula cómo el sistema clasificaría un pedido sin ejecutar nada real.</p>
  </div>
  <div class="card-body">
    <form data-action="submit->sync-config#runTest">
      <div class="row g-3 mb-3">
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Número de pedido <span class="text-danger">*</span></label>
          <input type="text" name="order_number" class="form-control font-monospace"
                 placeholder="Ej: 2-00123 o PED-4-00123">
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Nombre del producto <span class="text-muted fw-normal">(Regla 3)</span></label>
          <input type="text" name="product_name" class="form-control"
                 placeholder="Ej: Sofá VENDIDO SALA SE">
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Sala de origen <span class="text-muted fw-normal">(Regla 1)</span></label>
          <select name="source_showroom" class="form-select">
            <option value="">— Ninguna —</option>
            <% @showrooms.each do |s| %>
              <option value="<%= s.code %>"><%= s.name %> (<%= s.code %>)</option>
            <% end %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Sala de destino <span class="text-muted fw-normal">(Regla 1)</span></label>
          <select name="destination_showroom" class="form-select">
            <option value="">— Ninguna —</option>
            <% @showrooms.each do |s| %>
              <option value="<%= s.code %>"><%= s.name %> (<%= s.code %>)</option>
            <% end %>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button type="submit" class="btn btn-success w-100">
            <i class="bi bi-play-fill me-1"></i>Simular
          </button>
        </div>
      </div>
    </form>
    <div class="spinner-border spinner-border-sm text-secondary d-none" data-sync-config-target="testSpinner"></div>
    <div data-sync-config-target="testResults"></div>
  </div>
</div>

<%# ── 3. DEFAULTS DE FECHA ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3">
    <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar-range me-2 text-warning"></i>Defaults del rango de fechas</h6>
    <p class="text-muted small mb-0 mt-1">Valores precompletados en el formulario de sync manual.</p>
  </div>
  <div class="card-body">
    <%= form_with url: inventory_sync_config_defaults_path, method: :patch do %>
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Días hacia atrás</label>
          <%= number_field :inventory_sync_config, :default_days_back,
                value: @config.default_days_back, min: 0, max: 365, class: "form-control",
                data: { "sync-config-target": "daysBack", action: "input->sync-config#updateDatePreview" } %>
          <div class="form-text">Días antes de hoy para la fecha "desde".</div>
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Días hacia adelante</label>
          <%= number_field :inventory_sync_config, :default_days_forward,
                value: @config.default_days_forward, min: 0, max: 30, class: "form-control",
                data: { "sync-config-target": "daysForward", action: "input->sync-config#updateDatePreview" } %>
          <div class="form-text">Días después de hoy (0 = hoy).</div>
        </div>
        <div class="col-md-4">
          <p class="text-muted small mb-2" data-sync-config-target="datePreview">
            Con estos valores: <%= @config.default_from_date.strftime("%d/%m/%Y") %> – <%= @config.default_to_date.strftime("%d/%m/%Y") %>
          </p>
          <button type="submit" class="btn btn-warning fw-semibold">
            <i class="bi bi-save me-1"></i>Guardar defaults
          </button>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# ── 4. SYNC AUTOMÁTICO ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
    <div>
      <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-info"></i>Sync automático programado</h6>
      <p class="text-muted small mb-0 mt-1">Requiere Sidekiq con <code>sidekiq-cron</code>.</p>
    </div>
    <span class="badge <%= @config.schedule_enabled? ? 'bg-success' : 'bg-secondary' %>">
      <i class="bi bi-circle-fill me-1 small"></i><%= @config.schedule_enabled? ? "Activo" : "Inactivo" %>
    </span>
  </div>
  <div class="card-body">
    <%= form_with url: inventory_sync_config_schedule_path, method: :patch do %>
      <div class="row g-3">
        <div class="col-12">
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" role="switch"
                   name="inventory_sync_config[schedule_enabled]"
                   id="scheduleEnabled" value="1"
                   <%= @config.schedule_enabled? ? "checked" : "" %>>
            <label class="form-check-label fw-semibold" for="scheduleEnabled">Activar sync automático</label>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label small fw-semibold">Frecuencia</label>
          <% current_preset = InventorySyncConfig::CRON_PRESETS.key(@config.schedule_cron) || "custom" %>
          <select class="form-select" data-sync-config-target="cronPreset"
                  data-action="change->sync-config#updatePreset">
            <option value="daily_6am"      <%= "selected" if current_preset == "daily_6am" %>>Diario a las 6am</option>
            <option value="daily_midnight" <%= "selected" if current_preset == "daily_midnight" %>>Diario a medianoche</option>
            <option value="weekly_monday"  <%= "selected" if current_preset == "weekly_monday" %>>Cada lunes a las 6am</option>
            <option value="hourly"         <%= "selected" if current_preset == "hourly" %>>Cada hora</option>
            <option value="custom"         <%= "selected" if current_preset == "custom" %>>Personalizado</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label small fw-semibold">Expresión cron</label>
          <input type="text" name="inventory_sync_config[schedule_cron]"
                 value="<%= @config.schedule_cron %>"
                 class="form-control font-monospace" placeholder="0 6 * * *"
                 <%= current_preset != "custom" ? "readonly" : "" %>
                 data-sync-config-target="cronInput"
                 data-action="input->sync-config#updateCron">
          <div class="form-text" data-sync-config-target="cronPreview">Activo: <%= @config.schedule_cron %></div>
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Días a sincronizar</label>
          <input type="number" name="inventory_sync_config[schedule_days_back]"
                 value="<%= @config.schedule_days_back %>" min="1" max="90" class="form-control">
          <div class="form-text">Días hacia atrás al ejecutar automáticamente.</div>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-info text-white fw-semibold">
            <i class="bi bi-save me-1"></i>Guardar configuración
          </button>
          <% unless defined?(Sidekiq::Cron::Job) %>
            <span class="text-muted small ms-3">
              <i class="bi bi-exclamation-triangle me-1"></i>
              <code>sidekiq-cron</code> no está instalado.
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

</div>
