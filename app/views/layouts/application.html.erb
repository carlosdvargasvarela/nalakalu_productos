<!DOCTYPE html>
<html>
  <head>
    <title>Nalakalú Productos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <%= link_to "Nalakalú Productos", root_path, class: "navbar-brand" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <% if user_signed_in? && current_user.role == 'admin' %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                  Administración
                </a>
                <ul class="dropdown-menu">
                  <li><%= link_to "Productos Base", products_path, class: "dropdown-item" %></li>
                  <li><%= link_to "Proveedores", providers_path, class: "dropdown-item" %></li>
                  <li><%= link_to "Tipos de Variante", variant_types_path, class: "dropdown-item" %></li>
                  <li><%= link_to "Variantes", variants_path, class: "dropdown-item" %></li>
                </ul>
              </li>
            <% end %>
          </ul>
          <div class="d-flex align-items-center">
            <% if user_signed_in? %>
              <span class="navbar-text text-white me-3">
                <i class="bi bi-person-circle"></i> <%= current_user.email %>
                <span class="badge bg-primary ms-1"><%= current_user.role %></span>
              </span>
              <%= button_to "Cerrar Sesión", destroy_user_session_path, method: :delete, class: "btn btn-outline-light btn-sm" %>
            <% else %>
              <%= link_to "Iniciar Sesión", new_user_session_path, class: "btn btn-outline-light btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    <div class="container mt-4">
      <% if notice %>
        <div class="alert alert-info alert-dismissible fade show" role="alert">
          <i class="bi bi-info-circle"></i> <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-triangle"></i> <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
      <%= yield %>
    </div>
    <footer class="mt-5 py-3 bg-light">
      <div class="container text-center text-muted">
        <small>Nalakalú Productos © <%= Time.current.year %> - Sistema Interno</small>
      </div>
    </footer>
  </body>
</html>