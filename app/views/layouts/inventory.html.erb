<!DOCTYPE html>
<html lang="es">
  <head>
    <title>Inventario — Nalakalú Productos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css">
    <style>
      .inv-sidebar {
        width: 220px;
        min-width: 220px;
        background: #fff;
        border-right: 1px solid #dee2e6;
        flex-shrink: 0;
      }
      .inv-sidebar .sidebar-section {
        font-size: 0.67rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #adb5bd;
        padding: 1rem 1.1rem 0.25rem;
      }
      .inv-sidebar .sidebar-link {
        display: flex;
        align-items: center;
        padding: 0.42rem 0.75rem;
        margin: 0.05rem 0.5rem;
        border-radius: 0.375rem;
        color: #495057;
        text-decoration: none;
        font-size: 0.875rem;
        line-height: 1.4;
        transition: background-color 0.1s;
        gap: 0.55rem;
      }
      .inv-sidebar .sidebar-link:hover {
        background: #f1f3f5;
        color: #212529;
      }
      .inv-sidebar .sidebar-link.active {
        background: #e7f1ff;
        color: #0d6efd;
        font-weight: 600;
      }
      .inv-sidebar .sidebar-link.active i {
        color: #0d6efd;
      }
      .inv-sidebar .sidebar-link i {
        font-size: 0.95rem;
        width: 1rem;
        text-align: center;
        color: #6c757d;
        flex-shrink: 0;
      }
      .inv-sidebar .sidebar-divider {
        height: 1px;
        background: #f1f3f5;
        margin: 0.5rem 1rem;
      }
      /* Mobile bottom nav */
      .inv-mobile-nav {
        height: 60px;
        z-index: 1030;
        background: #fff;
        border-top: 1px solid #dee2e6;
      }
      .inv-mobile-nav a {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        color: #6c757d;
        text-decoration: none;
        font-size: 0.65rem;
        line-height: 1;
        padding: 0.4rem 0.25rem;
        flex: 1;
        border-radius: 0;
        min-width: 0;
      }
      .inv-mobile-nav a i { font-size: 1.25rem; }
      .inv-mobile-nav a.active { color: #0d6efd; }
      .inv-mobile-nav a:active { background: #f1f3f5; }
      @media (max-width: 991.98px) {
        main.inv-main { padding-bottom: 68px !important; }
      }

      /* ── Help Panel ───────────────────────────────────────────── */
      .help-offcanvas { width: 480px; max-width: 92vw; }
      .help-offcanvas .offcanvas-header {
        background: #0d6efd;
        color: #fff;
        padding: 0.875rem 1.25rem;
        flex-shrink: 0;
      }
      .help-offcanvas .offcanvas-header .btn-close { filter: invert(1); opacity: .8; }
      .help-offcanvas .offcanvas-body { padding: 1.25rem 1.5rem; overflow-y: auto; flex: 1 1 auto; }
      .help-offcanvas .offcanvas-footer { flex-shrink: 0; }

      /* Spinner inicial */
      .help-loading { display: flex; align-items: center; justify-content: center;
        height: 160px; color: #6c757d; gap: .5rem; }

      /* Tipografía del contenido */
      .help-doc h1 { font-size: 1.35rem; font-weight: 700; margin-bottom: 1rem;
        padding-bottom: .5rem; border-bottom: 2px solid #e9ecef; }
      .help-doc h2 { font-size: 1.1rem; font-weight: 700; margin-top: 1.75rem;
        margin-bottom: .6rem; color: #343a40; }
      .help-doc h3 { font-size: .95rem; font-weight: 600; margin-top: 1.25rem;
        margin-bottom: .4rem; color: #495057; }
      .help-doc p  { font-size: .9rem; line-height: 1.65; margin-bottom: .75rem; }
      .help-doc ul, .help-doc ol { font-size: .9rem; line-height: 1.65;
        padding-left: 1.4rem; margin-bottom: .75rem; }
      .help-doc li { margin-bottom: .25rem; }
      .help-doc a  { color: #0d6efd; }

      /* Tablas */
      .help-doc table { width: 100%; font-size: .85rem; border-collapse: collapse;
        margin-bottom: 1rem; }
      .help-doc thead th { background: #f8f9fa; font-weight: 600;
        border-bottom: 2px solid #dee2e6; padding: .5rem .75rem; }
      .help-doc td { padding: .45rem .75rem; border-bottom: 1px solid #f1f3f5;
        vertical-align: top; }
      .help-doc tr:last-child td { border-bottom: none; }

      /* Código */
      .help-doc code { font-size: .82rem; background: #f1f3f5; padding: .1em .35em;
        border-radius: .25rem; color: #d63384; }
      .help-doc pre  { background: #1e1e2e; border-radius: .5rem; padding: 1rem;
        overflow-x: auto; margin-bottom: 1rem; }
      .help-doc pre code { background: none; color: #cdd6f4; padding: 0; font-size: .82rem; }

      /* kbd */
      .help-doc kbd { font-size: .8rem; padding: .15em .45em;
        background: #343a40; color: #fff; border-radius: .3rem; }

      /* Callout hints */
      .help-hint { border-radius: .5rem; padding: .85rem 1rem;
        margin-bottom: 1rem; font-size: .88rem; }
      .help-hint i { font-size: 1rem; margin-top: .1rem; }
      .help-hint__body > *:last-child { margin-bottom: 0; }
      .help-hint__body p { margin-bottom: .35rem; }

      /* Mermaid */
      .help-mermaid { background: #f8f9fa; border-radius: .5rem;
        padding: .75rem; margin-bottom: 1rem; overflow-x: auto; }
      .help-mermaid svg { max-width: 100%; height: auto; }

      /* details/summary */
      .help-doc details { border: 1px solid #dee2e6; border-radius: .5rem;
        padding: .75rem 1rem; margin-bottom: .75rem; }
      .help-doc summary { font-weight: 600; font-size: .9rem; cursor: pointer;
        color: #0d6efd; list-style: none; }
      .help-doc summary::before { content: "▶  "; font-size: .7rem; }
      .help-doc details[open] summary::before { content: "▼  "; }
      .help-doc details[open] { background: #f8f9fa; }
      .help-doc details > *:not(summary) { margin-top: .75rem; }

      /* Botón ayuda en sidebar */
      .help-trigger {
        display: flex; align-items: center; gap: .55rem;
        padding: .42rem .75rem; margin: .25rem .5rem 0;
        border-radius: .375rem; font-size: .875rem; color: #0d6efd;
        text-decoration: none; background: #e7f1ff; font-weight: 600;
        border: none; width: calc(100% - 1rem); cursor: pointer;
        transition: background-color .1s;
      }
      .help-trigger:hover { background: #cfe2ff; color: #0a58ca; }
      .help-trigger i { font-size: .95rem; width: 1rem; text-align: center; flex-shrink: 0; }
    </style>
  </head>
  <body class="bg-light d-flex flex-column min-vh-100">
    <%= render "layouts/navbar" %>
    <div class="d-flex flex-grow-1">
      <%= render "inventory/shared/sidebar" %>
      <main class="inv-main flex-grow-1 px-3 px-md-4 py-4" style="min-width: 0;">
        <div id="flash_container">
          <%= render "layouts/flash_messages" %>
        </div>
        <%= yield %>
      </main>
    </div>
    <%# Mobile bottom nav (hidden on lg+) %>
    <% ctrl = params[:controller] %>
    <nav class="inv-mobile-nav d-flex d-lg-none fixed-bottom">
      <%= link_to inventory_path,
            class: "#{ctrl == 'inventory/dashboard' ? 'active' : ''}" do %>
        <i class="bi bi-speedometer2"></i><span>Inicio</span>
      <% end %>
      <%= link_to inventory_movements_log_path,
            class: "#{ctrl == 'inventory/movements' ? 'active' : ''}" do %>
        <i class="bi bi-journal-text"></i><span>Movimientos</span>
      <% end %>
      <%= link_to new_inventory_exit_path,
            class: "#{ctrl == 'inventory/exits' ? 'active' : ''}" do %>
        <i class="bi bi-box-arrow-up"></i><span>Salida</span>
      <% end %>
      <%= link_to new_inventory_adjustment_path,
            class: "#{ctrl == 'inventory/adjustments' ? 'active' : ''}" do %>
        <i class="bi bi-pencil-square"></i><span>Ajuste</span>
      <% end %>
      <%= link_to inventory_sync_config_path,
            class: "#{ctrl == 'inventory/config' ? 'active' : ''}" do %>
        <i class="bi bi-sliders"></i><span>Config</span>
      <% end %>
    </nav>
    <%= turbo_frame_tag "remote_modal" %>
    <%= render "layouts/footer" %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>
    <script type="module">
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"
      mermaid.initialize({ startOnLoad: false, theme: "neutral", securityLevel: "loose" })
      document.addEventListener("turbo:frame-load", (e) => {
        if (e.target.id === "help_panel_content") mermaid.run({ querySelector: ".help-mermaid" })
      })
    </script>
    <script>
      // Bootstrap's data-bs-toggle on <a> calls preventDefault, blocking Turbo frame navigation.
      // Handle the help trigger manually: set frame src + show offcanvas via JS API.
      document.addEventListener("click", (e) => {
        const trigger = e.target.closest(".help-trigger")
        if (!trigger) return
        e.preventDefault()
        const frame = document.getElementById("help_panel_content")
        const url = trigger.getAttribute("href")
        if (frame.getAttribute("src") !== url) frame.src = url
        bootstrap.Offcanvas.getOrCreateInstance(document.getElementById("helpOffcanvas")).show()
      })
    </script>

    <%# ── Help Offcanvas ── %>
    <div class="offcanvas offcanvas-end help-offcanvas" tabindex="-1"
         id="helpOffcanvas" aria-labelledby="helpOffcanvasLabel"
         data-bs-scroll="true" data-bs-backdrop="false">
      <div class="offcanvas-header">
        <div class="d-flex align-items-center gap-2">
          <i class="bi bi-question-circle-fill fs-5"></i>
          <h5 class="offcanvas-title mb-0 fw-bold" id="helpOffcanvasLabel">Ayuda — Inventarios</h5>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
      </div>
      <div class="offcanvas-body">
        <turbo-frame id="help_panel_content">
          <div class="help-loading">
            <span class="spinner-border spinner-border-sm"></span>
            <span>Cargando ayuda…</span>
          </div>
        </turbo-frame>
      </div>
      <div class="offcanvas-footer border-top px-4 py-3 bg-white d-flex justify-content-between align-items-center">
        <small class="text-muted">Manual de inventarios</small>
        <a href="<%= inventory_help_path('README') %>" data-turbo-frame="help_panel_content"
           class="btn btn-outline-primary btn-sm">
          <i class="bi bi-list-ul me-1"></i>Ver índice
        </a>
      </div>
    </div>
  </body>
</html>
