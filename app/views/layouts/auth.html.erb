<!DOCTYPE html>
<html lang="es">
  <head>
    <title>Acceso | Nalakalú Productos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      body {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        height: 100vh;
      }
      .auth-card {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
      }
      .auth-logo {
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
      }
    </style>
  </head>
  <body class="d-flex align-items-center justify-content-center">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-md-5 col-lg-4">
          <div class="text-center mb-4">
            <i class="bi bi-grid-3x3-gap-fill text-primary auth-logo"></i>
            <h2 class="fw-bold text-dark">Nalakalú</h2>
            <p class="text-muted small">Gestión de Productos e Inventario</p>
          </div>
          <%= render "layouts/flash_messages" %>
          <%= yield %>
          <div class="text-center mt-4">
            <p class="text-muted small">© <%= Time.current.year %> Nalakalú — Sistema Interno</p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>