<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container-fluid px-4">
    <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 fw-bold" do %>
      <i class="bi bi-grid-3x3-gap-fill text-primary"></i>
      Nalakalú Productos
    <% end %>

    <button class="navbar-toggler border-0" type="button" 
            data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto gap-1">
        <% if user_signed_in? %>
          <%= render "layouts/navbar_seller_links" %>
          <% if current_user.role == "admin" %>
            <%= render "layouts/navbar_admin_links" %>
          <% end %>
        <% end %>
      </ul>

      <div class="d-flex align-items-center gap-2">
        <% if user_signed_in? %>
          <span class="navbar-text text-white-50 small">
            <i class="bi bi-person-circle me-1"></i><%= current_user.email %>
          </span>
          <span class="badge bg-primary rounded-pill"><%= current_user.role %></span>
          <%= button_to destroy_user_session_path, method: :delete,
              class: "btn btn-outline-light btn-sm rounded-pill px-3" do %>
            <i class="bi bi-box-arrow-right me-1"></i>Salir
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, class: "btn btn-outline-light btn-sm rounded-pill px-3" do %>
            <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar Sesión
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</nav>