<div class="row justify-content-center">
  <div class="col-md-10 col-lg-8">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
      
      <!-- HEADER -->
      <div class="p-4 text-white" style="background: linear-gradient(145deg, #0d6efd, #0a4fb4);">
        <div class="d-flex align-items-center gap-3">
          <div class="bg-white text-primary rounded-3 shadow-sm d-flex justify-content-center align-items-center" style="width:50px;height:50px;">
            <i class="bi bi-upc-scan fs-3"></i>
          </div>
          <div>
            <h2 class="fw-bold mb-1">Generador de Código</h2>
            <p class="mb-0 small opacity-75">Configure las variantes para obtener el código del CRM.</p>
          </div>
        </div>
      </div>

      <!-- BODY -->
      <div class="card-body p-4" data-controller="code-generator" data-code-generator-url-value="<%= variants_for_product_sales_path %>">
        
        <!-- STEP 1 -->
        <section class="mb-5">
          <h5 class="fw-bold mb-3 text-secondary">1. Producto</h5>
          <div class="form-floating shadow-sm">
            <select class="form-select" id="productoSelect" 
                    data-action="change->code-generator#loadProduct" 
                    data-code-generator-target="productSelect">
              <option value="">Seleccione un producto...</option>
              <% @products.each do |product| %>
                <option value="<%= product.id %>"><%= product.name %></option>
              <% end %>
            </select>
            <label for="productoSelect"><i class="bi bi-box-seam me-1"></i> Producto Base</label>
          </div>
        </section>

        <!-- STEP 2 -->
        <section class="mb-5">
          <h5 class="fw-bold mb-3 text-secondary">2. Variantes</h5>
          <div data-code-generator-target="variantsContainer">
            <div class="text-muted small italic p-3 border rounded bg-light">
              Seleccione un producto primero para ver las variantes disponibles.
            </div>
          </div>
        </section>

        <!-- STEP 3 -->
        <section>
          <h5 class="fw-bold mb-3 text-secondary">3. Código generado</h5>
          <div class="card bg-light border-0 shadow-sm rounded-4 p-4">
            <textarea class="form-control font-monospace shadow-sm fs-5 text-center fw-semibold mb-3" 
                      rows="5" readonly placeholder="Esperando configuración..." 
                      style="resize:none; letter-spacing:0.04em; background-color: #fff !important;" 
                      data-code-generator-target="result"></textarea>

            <div class="alert alert-warning d-none py-2 small" data-code-generator-target="lineWarning"></div>

            <div class="text-center mt-3">
              <button class="btn btn-primary btn-lg px-5 shadow-sm fw-bold" 
                      data-action="code-generator#copy" disabled 
                      data-code-generator-target="copyButton">
                <i class="bi bi-clipboard-check me-2"></i> Copiar código
              </button>
            </div>
          </div>
        </section>

      </div>
    </div>
  </div>
</div>