<%# app/views/inventory_exits/new.html.erb %>
<div class="row justify-content-center">
  <div class="col-lg-10 col-xl-9">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
      <div class="p-4 text-white" style="background: linear-gradient(145deg, #dc3545, #a02530);">
        <div class="d-flex align-items-center gap-3">
          <div class="bg-white text-danger rounded-3 shadow-sm d-flex justify-content-center align-items-center"
               style="width:50px;height:50px;">
            <i class="bi bi-box-arrow-up fs-3"></i>
          </div>
          <div>
            <h2 class="fw-bold mb-1">Registrar salidas de inventario</h2>
            <p class="mb-0 small opacity-75">Selecciona la sala y agrega todos los productos de una vez.</p>
          </div>
        </div>
      </div>

      <div class="card-body p-4"
           data-controller="inventory-exit-form"
           data-inventory-exit-form-new-url-value="<%= new_inventory_exit_path %>">

        <%= form_with url: inventory_exits_path, method: :post do |f| %>

          <%# Errores de validación %>
          <% if @errors&.any? %>
            <div class="alert alert-danger mb-4">
              <% @errors.each do |err| %>
                <div><strong>Fila <%= err[:index] + 1 %>:</strong> <%= err[:messages].join(", ") %></div>
              <% end %>
            </div>
          <% end %>

          <%# Sala + Número de pedido %>
          <div class="row g-3 mb-4">
            <div class="col-md-5">
              <label class="form-label fw-semibold">
                Sala de origen <span class="text-danger">*</span>
              </label>
              <%= select_tag "showroom_id",
                    options_for_select(@showrooms.map { |s| [s.name, s.id] }, @showroom_id),
                    include_blank: "— Selecciona una sala —",
                    class: "form-select shadow-sm",
                    required: true,
                    data: { "inventory-exit-form-target": "showroomSelect" } %>
            </div>

            <div class="col-md-7">
              <label class="form-label fw-semibold">
                Número de pedido
                <span class="text-muted fw-normal small">(opcional, para corroborar)</span>
              </label>
              <div class="input-group">
                <%= text_field_tag "order_number", @order_number,
                      class: "form-control shadow-sm",
                      placeholder: "Ej: 2-00123",
                      data: { "inventory-exit-form-target": "orderInput" } %>
                <button type="button" class="btn btn-outline-primary"
                        data-action="click->inventory-exit-form#consultOrder">
                  <i class="bi bi-search me-1"></i>Consultar
                </button>
              </div>

              <% if @order_number.present? && (@delivery_preview || @delivery_preview_error) %>
                <% if @delivery_preview %>
                  <div class="alert alert-info mt-2 mb-0 small">
                    <strong>Pedido encontrado</strong> —
                    Cliente: <%= @delivery_preview.dig("client", "name") || "—" %>
                    · Fecha: <%= @delivery_preview["delivery_date"] %>
                    <ul class="mb-0 mt-2">
                      <% Array(@delivery_preview["items"]).each do |item| %>
                        <li><%= item["product_name"] %> — entregado: <%= item["quantity_delivered"] %></li>
                      <% end %>
                    </ul>
                  </div>
                <% else %>
                  <div class="alert alert-warning mt-2 mb-0 small"><%= @delivery_preview_error %></div>
                <% end %>
              <% end %>
            </div>
          </div>

          <%# Tabla de productos %>
          <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <label class="form-label fw-semibold mb-0">Productos a retirar</label>
              <button type="button"
                      class="btn btn-sm btn-outline-secondary"
                      data-action="click->inventory-exit-form#addRow">
                <i class="bi bi-plus-circle me-1"></i>Agregar producto
              </button>
            </div>

            <div class="table-responsive border rounded-3 overflow-hidden">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th style="min-width:260px;">Producto <span class="text-danger">*</span></th>
                    <th style="width:130px;">Cantidad <span class="text-danger">*</span></th>
                    <th>Notas</th>
                    <th style="width:50px;"></th>
                  </tr>
                </thead>
                <tbody data-inventory-exit-form-target="body">
                  <% @items.each_with_index do |item, i| %>
                    <tr data-inventory-exit-form-target="row">
                      <td>
                        <%= select_tag "items[#{i}][product_id]",
                              options_for_select(
                                @products.map { |p| [p.name, p.id] },
                                item[:product_id]
                              ),
                              include_blank: "— Selecciona —",
                              class: "form-select form-select-sm" %>
                      </td>
                      <td>
                        <%= number_field_tag "items[#{i}][quantity]", item[:quantity],
                              min: 0.01, step: 0.01,
                              class: "form-control form-control-sm",
                              placeholder: "1" %>
                      </td>
                      <td>
                        <%= text_field_tag "items[#{i}][notes]", item[:notes],
                              class: "form-control form-control-sm",
                              placeholder: "Observación opcional" %>
                      </td>
                      <td class="text-center">
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-action="click->inventory-exit-form#removeRow">
                          <i class="bi bi-trash"></i>
                        </button>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>

          <%= hidden_field_tag "delivery_date", Date.current %>

          <div class="d-flex gap-2 justify-content-end">
            <%= link_to "Cancelar", inventory_path, class: "btn btn-outline-secondary" %>
            <button type="submit" class="btn btn-danger px-4 fw-bold">
              <i class="bi bi-check2-circle me-1"></i>Registrar salidas
            </button>
          </div>

        <% end %>
      </div>
    </div>
  </div>
</div>
