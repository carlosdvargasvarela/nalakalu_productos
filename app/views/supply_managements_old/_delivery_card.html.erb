<div class="card mb-4 border-0 shadow-sm overflow-hidden">
  <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-2">
    <div class="form-check mb-0">
      <input type="checkbox"
             class="form-check-input"
             checked
             data-order="<%= delivery["order_number"] %>"
      data-action="change->procurement#toggleOrder">
      <label class="form-check-label fw-bold ms-2">
        Pedido: <%= delivery["order_number"] %>
      </label>
    </div>
    <div class="small">
      <%= delivery.dig("client", "name") %>
    </div>
  </div>
  <div class="card-body p-0">
    <% delivery["items"].each do |item| %>
      <% item_reqs = all_provider_reqs.select { |r|
           r.origin_order_number == delivery["order_number"] &&
           r.origin_product_name.include?(item["product_name"])
         } %>
      <% if item_reqs.any? %>
        <%= render "product_block",
              item: item,
              item_reqs: item_reqs,
              delivery: delivery %>
      <% end %>
    <% end %>
  </div>
</div>