<div class="container-fluid mt-4 pb-5">
  <!-- Header con Contexto -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">
        <i class="bi bi-connector-cascade text-primary me-2"></i>
        Sincronización con Logística
      </h1>
      <p class="text-muted small mb-0">
        Consulta de entregas y desglose técnico de variantes desde Nalakalú Rutas.
      </p>
    </div>
    <div class="text-end">
      <span class="badge bg-light text-dark border">
        <i class="bi bi-circle-fill text-success me-1 small"></i>
        Conectado a: <%= ENV['LOGISTICS_API_URL'] || 'Localhost:3000' %>
      </span>
    </div>
  </div>
  <!-- Filtros Avanzados -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <%= form_with url: logistics_queries_path, method: :get, class: "row g-3 align-items-end" do |f| %>
        <div class="col-md-2">
          <label class="form-label fw-bold small text-uppercase text-muted">Rango Desde</label>
          <%= f.date_field :from, value: @from, class: "form-control border-2" %>
        </div>
        <div class="col-md-2">
          <label class="form-label fw-bold small text-uppercase text-muted">Rango Hasta</label>
          <%= f.date_field :to, value: @to, class: "form-control border-2" %>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-bold small text-uppercase text-muted">Número de Pedido</label>
          <div class="input-group">
            <span class="input-group-text bg-white border-2 border-end-0">
              <i class="bi bi-hash"></i>
            </span>
            <%= f.text_field :order_number, value: @order_number, class: "form-control border-2 border-start-0", placeholder: "Ej: PED-123" %>
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-bold small text-uppercase text-muted">Vendedor</label>
          <div class="input-group">
            <span class="input-group-text bg-white border-2 border-end-0">
              <i class="bi bi-person"></i>
            </span>
            <%= f.text_field :seller_code, value: @seller_code, class: "form-control border-2 border-start-0", placeholder: "Código de vendedor" %>
          </div>
        </div>
        <div class="col-md-2">
          <%= f.submit "Consultar", class: "btn btn-primary w-100 fw-bold py-2 shadow-sm" %>
        </div>
      <% end %>
    </div>
  </div>
  <!-- Tabla de Resultados -->
  <div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-dark text-white">
          <tr>
            <th class="ps-4 py-3 fw-medium">Entrega / Pedido</th>
            <th class="py-3 fw-medium">Cliente / Vendedor</th>
            <th class="py-3 fw-medium" style="width: 45%;">Desglose de Productos y Variantes</th>
            <th class="py-3 fw-medium text-center">Estado Logística</th>
          </tr>
        </thead>
        <tbody class="border-top-0">
          <% if @deliveries.any? %>
            <% @deliveries.each do |delivery| %>
              <tr class="border-bottom">
                <td class="ps-4">
                  <div class="fw-bold text-dark"><%= Date.parse(delivery["delivery_date"]).strftime("%d/%m/%Y") %></div>
                  <div class="mt-1">
                    <%= link_to logistics_query_path(delivery["id"]), class: "text-decoration-none" do %>
                      <span class="badge bg-secondary-subtle text-secondary border border-secondary-alpha-20">
                        <i class="bi bi-receipt me-1"></i><%= delivery["order_number"] %>
                      </span>
                    <% end %>
                  </div>
                </td>
                <td>
                  <div class="fw-semibold text-dark">
                    <%= delivery.dig("client", "name") %>
                  </div>
                  <div class="small text-muted">
                    <i class="bi bi-person-badge me-1"></i>
                    Vendedor: <%= delivery["seller_code"] %>
                  </div>
                </td>
                <td class="py-3">
                  <% delivery["items"].each do |item| %>
                    <% decoding = ProductDecoder.decode(item["product_name"]) %>
                    <div class="mb-3 p-3 rounded-3 <%= decoding[:has_variants] ? 'bg-primary-subtle border-start border-4 border-primary' : 'bg-light border-start border-4 border-secondary' %>">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="h6 mb-0 fw-bold">
                          <span class="badge bg-white text-primary border border-primary me-2">
                            <%= item["quantity_delivered"] %>
                          </span>
                          <code class="text-dark"><%= item["product_name"] %></code>
                        </span>
                      </div>
                      <div class="ms-2">
                        <% if decoding[:base_product] %>
                          <div class="mb-2">
                            <span class="badge bg-dark-subtle text-dark px-2 py-1">
                              <i class="bi bi-box-seam me-1"></i>
                              <%= decoding[:base_product].name %>
                            </span>
                          </div>
                        <% elsif decoding[:has_variants] %>
                          <div class="mb-2">
                            <span class="badge bg-warning-subtle text-warning-emphasis px-2 py-1 border border-warning">
                              <i class="bi bi-question-circle me-1"></i>
                              Producto base no identificado
                            </span>
                            <small class="text-muted ms-2">
                              Se detectaron variantes en el código.
                            </small>
                          </div>
                        <% end %>
                        <% if decoding[:has_variants] %>
                          <div class="row g-2">
                            <% decoding[:variants].each do |variant| %>
                              <div class="col-12">
                                <div class="d-flex align-items-center bg-white p-2 rounded border border-primary-subtle shadow-sm">
                                  <i class="bi bi-check2-circle text-primary me-2"></i>
                                  <div class="flex-grow-1">
                                    <span class="fw-bold small text-uppercase text-muted d-block" style="font-size: 0.65rem;">
                                      <%= variant.variant_type.name %>
                                    </span>
                                    <span class="text-dark"><%= variant.name %></span>
                                  </div>
                                  <div class="text-end border-start ps-3 ms-2">
                                    <span class="fw-bold text-primary d-block small">
                                      <% if variant.provider.present? %>
                                        <%= variant.provider.name %>
                                      <% else %>
                                        <span class="text-muted italic">Interno / Sin asignar</span>
                                      <% end %>
                                    </span>
                                    <span class="text-muted" style="font-size: 0.7rem;">Proveedor</span>
                                  </div>
                                </div>
                              </div>
                            <% end %>
                          </div>
                        <% end %>
                        <% if decoding[:unrecognized_codes].present? %>
                          <div class="mt-2 p-2 bg-warning-subtle rounded border border-warning">
                            <small class="text-warning-emphasis fw-bold">
                              <i class="bi bi-exclamation-triangle-fill me-1"></i>
                              Segmentos no reconocidos: <%= decoding[:unrecognized_codes].join(", ") %>
                            </small>
                          </div>
                        <% end %>
                        <% if !decoding[:base_product] && !decoding[:has_variants] %>
                          <div class="alert alert-danger py-1 px-2 mb-0 small d-inline-block">
                            <i class="bi bi-x-octagon-fill me-1"></i>
                            Código sin coincidencias en el sistema.
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </td>
                <td class="text-center pe-4">
                  <%
                    status_class = case delivery["status"]
                                   when "delivered"         then "bg-success"
                                   when "ready_to_deliver"  then "bg-primary"
                                   when "cancelled", "failed" then "bg-danger"
                                   else "bg-info text-dark"
                                   end
                  %>
                  <span class="badge rounded-pill <%= status_class %> px-3 py-2 shadow-sm">
                    <%= delivery["status_label"] %>
                  </span>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="text-center py-5">
                <div class="py-4">
                  <i class="bi bi-search display-1 text-light mb-3 d-block"></i>
                  <h4 class="text-muted">No se encontraron resultados</h4>
                  <p class="text-muted small">
                    Intenta ajustar el rango de fechas o los filtros de búsqueda.
                  </p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>